// https://rosettacode.org/wiki/100_doors
import ballerina/io;

public function main() {
    boolean[100] doors = [];
    foreach int i in int:range(0,100,1) {
        foreach int j in int:range(i, 100, i+1) {
            doors[j] = ! doors[j];
        }
    }
    foreach int i in int:range(0,doors.length(),1) {
        if doors[i] {
            io:println("Door #",i+1," is ","open");
        }
    }
}
