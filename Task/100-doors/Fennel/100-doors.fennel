(do ;;; find the first few squares via the unoptimised door flipping method

    (local door-max 100)

    ; repeatedly flip the doors and show the ones that are left open
    (var door {})
    (for [i 1 door-max]
         (for [j i door-max i]
              (tset door j (not (. door j)))
         )
         (when (. door i)
               (io.write (.. " " i))
         )
    )
)
