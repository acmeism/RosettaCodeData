 <span style="color: #008080;">enum</span> <span style="color: #000000;">RESET</span><span style="color: #0000FF;">,</span> <span style="color: #000000;">THINKING</span><span style="color: #0000FF;">,</span> <span style="color: #000000;">SOLVED</span> <span style="color: #000080;font-style:italic;">-- (solve_state values)</span>
