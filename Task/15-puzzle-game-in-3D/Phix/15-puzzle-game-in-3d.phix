 <span style="color: #008080;">procedure</span> <span style="color: #000000;">iterative_solve</span><span style="color: #0000FF;">()</span>
     <span style="color: #008080;">if</span> <span style="color: #000000;">solve_state</span><span style="color: #0000FF;">=</span><span style="color: #000000;">RESET</span> <span style="color: #008080;">then</span>
         <span style="color: #000000;">solve_state</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">THINKING</span>
