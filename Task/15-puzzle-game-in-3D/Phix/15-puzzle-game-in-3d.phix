 <span style="color: #000080;font-style:italic;">-- &lt;copied from demo\pGUI\r3d.exw&gt;:</span>
 <span style="color: #008080;">constant</span> <span style="color: #000000;">num</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">90</span><span style="color: #0000FF;">,</span>  <span style="color: #000080;font-style:italic;">-- number of lines</span>
          <span style="color: #000000;">dist</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">11000</span><span style="color: #0000FF;">,</span>
