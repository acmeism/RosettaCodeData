!ys-0

defn main():
  digits =:: [3, 7, 8, 2]
  player =: '(8 - 2) * (7 - 3)'  # player input is parsed and run as YS
  say: "Digits given: $(digits:joins)"
  say: "Player's expression: $player"
  used =: re-seq(/\d/ player).map(parse-long):sort
  if used != digits:sort:vec:
    die: 'Invalid: must use each digit exactly once.'
    else:
      result =: player:eval
      say: "Result: $result"
      if result == 24:
        say: 'You win!'
        say: 'Not 24.'
