loop :with i := 99
  :while (i > 0) :do
    # Turns out Common Lisp (and thus, Moonli) has a format directive for plurals!
    format(t, "~D bottle~P of beer on the wall~%", i, i)
    format(t, "~D bottle~P of beer~%", i, i)
    format(t, "Take one down, pass it around~%")
    decf(i)
    format(t, "~D bottle~P of beer on the wall~%~%", i, i)
end
