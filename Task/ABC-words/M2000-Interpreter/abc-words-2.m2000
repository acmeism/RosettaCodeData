Module Check {
	cls #FFFFFF, 0
	pen 0
	print $(9) ' proportional text
	document a$
	load.doc a$, "unixdict.txt"
	flush
	m=Paragraph(a$, 0)
	if Forward(a$,m) then
		while m
			p$=Paragraph$(a$,(m))
			if p$ ~"*a*b*c*" then
				if instr(p$, "a")<instr(p$, "b") then
					if instr(p$, "b")<instr(p$, "c") then
						print quote$(p$),
					end if
				end if
			end if
		end while
	end if
	print
}
Check
