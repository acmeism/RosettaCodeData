local word_list = "unixdict.txt"  -- local copy
local file = io.open(word_list, "r")
local count = 0
print($"Based on first occurrences only, the ABC words in {word_list} are:")
for word in file:lines() do
    local a = word:find("a") ?? 0
    local b = word:find("b") ?? 0
    local c = word:find("c") ?? 0
    if 0 < a < b < c do
        ++count
        print(string.format("%2d: %s", count, word))
    end
end
file:close()
