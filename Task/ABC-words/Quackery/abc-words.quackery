  [ true swap
    behead swap
    witheach
      [ tuck < not if
          [ dip not
            conclude ] ]
    drop ]               is ascending ( [ --> b )

  [ [] swap
    $ "abc" witheach
      [ over find
        swap dip join ]
     size join
     ascending ]         is abcword   ( $ --> b )

  []
  $ "rosetta/unixdict.txt" sharefile drop nest$
  witheach
    [ dup abcword iff
        [ nested join ]
      else drop ]
  dup size echo say " words found." cr
  70 wrap$
