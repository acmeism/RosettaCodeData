isAbcWord := [ :word | | i j k |
	i := word indexOf: $a. j := word indexOf: $b. k := word indexOf: $c.
	(i > 0) and: [(i < j) and: [ j < k ]] ].
rd := (FileLocator home / 'unixdict.txt') asFileReference readStream.
[ rd atEnd ] whileFalse: [ | word |
	word := rd nextLine.
	(isAbcWord value: word) ifTrue: [
		Transcript crShow: word
		 ]
	 ].
rd close.
