!ys-0

defn main():
  say: "Polynomial expansions of (x-1)^p:"
  each p (0 .. 7):
    say: "  (x-1)^$p = $poly-str(coeffs(p))"
  say:
  say: "Primes under 50:"
  primes =: (2 .. 50).filter(aks-prime?)
  say: primes:joins

defn poly-str(row):
  n =: row.#
  terms =:
    map-indexed _ row:
      fn(k c): term-str(n k c)
  joined =: join(terms.filter(identity) ' + ')
  joined: .replace(/\+ -/ '- ')

defn term-str(n k c):
  e =: n.-- - k
  when c != 0:
    cond:
      e:zero?: c:S
      c == 1: (e == 1).if('x' "x^$e")
      c == -1: (e == 1).if('-x' "-x^$e")
      else: (e == 1).if("${c}x" "${c}x^$e")

defn coeffs(p):
  init =: +[1]
  loop i 0, row init:
    if i >= p:
      then: row
      else:
        recur: i.++ row:next-row

defn next-row(row):
  padded =: row.conj(0)
  n =: padded.#
  init =: +[]
  loop k 0, new-row init:
    if k >= n:
      then: new-row
      else:
        prev =: k:zero?.if(0 padded.nth(k.--))
        val =: prev - padded.$k
        recur: k.++ new-row.conj(val)

defn aks-prime?(p):
  if p < 2: false
  row =: p:coeffs
  # Inner coefficients (skip first and last)
  inner =: row.drop(1).drop-last(1)
  inner: .every?(\(zero?(_ % p)))
