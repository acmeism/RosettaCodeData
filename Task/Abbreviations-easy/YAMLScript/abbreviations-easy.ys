!ys-0

commands =: qw(add alter backup bottom cappend change schange check
               compress copy count cprepend create delete down)

tests =: qw(a al alter b bot c cha check comp cp d do down)

defn main():
  each word tests:
    say: "$word: $(valid-abbreviation?(word))"

defn valid-abbreviation?(word):
  matches =:
    filter _ commands:
      fn(cmd):
        cmd.starts?(word)
  matches.# ==: 1
