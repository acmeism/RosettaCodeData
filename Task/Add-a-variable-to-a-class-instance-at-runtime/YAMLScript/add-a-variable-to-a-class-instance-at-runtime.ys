!ys-0

# YS instances are maps; a mutable one is an atom holding a map.
# Adding a variable at runtime is just swapping in a new key.

defn main(var='foo' value=42):
  obj =: atom({:name 'empty'})
  say: "Before: $(obj.@)"
  add-variable obj: var value
  say: "After:  $(obj.@)"

defn add-variable(obj var value):
  swap obj: assoc K(var) value
