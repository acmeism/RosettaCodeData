!ys-0

defn main(limit=500):
  nums =: 2 .. limit.--
  result =: filter(additive-prime? nums)
  say: result:joins
  say: "Count: $(result.#)"

defn additive-prime?(n):
  prime?(n) && prime?(digit-sum(n))

defn digit-sum(n):
  sum: n:digits.map(I)

defn prime?(n):
  cond:
    n < 2: false
    n < 4: true
    else: (2 .. I(sqrt(n))).some(\((n % _):zero?)).!
