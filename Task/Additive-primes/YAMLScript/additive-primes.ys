!ys-0

defn main(limit=500):
  nums =: 2 .. limit.--
  result =: filter(additive-prime? nums)
  say: result:joins
  say: "Count: $(result.#)"

defn additive-prime?(n):
  prime?(n) && prime?(digit-sum(n))

defn digit-sum(n):
  sum: n:digits.map(I)

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
