!ys-0

defn main(kmax=5 count=10):
  each k (1 .. kmax):
    primes =: k-almost-primes(k count)
    say: "k = $k: $(primes:joins)"

defn k-almost-primes(k count):
  (2 .. 1000000)
    .filter(\(k-factors(_) == k))
    .take(count)

defn k-factors(n):
  loop m n, p 2, k 0:
    if m != 1:
      if rem(m p):zero?:
        recur: (m // p), p, k.++
        recur: m, p.++, k
      else: k
