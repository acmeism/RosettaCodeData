!ys-0

defn main(path='/usr/share/dict/words'):
  words =: path:read:lines.filter(word?):distinct:V
  ws =: words:set
  each w words.filter(\(_.# >= 6)):
    a b =: split-alternate(w)
    when ws(a) && ws(b):
      say: "$w -> $a $b"

defn word?(w): w =~ /^[a-z]+$/

defn split-alternate(w):
  chars =: w:seq:V
  a =: (0 .. chars.#.--).filter(even?).map(\(chars.nth(_):S)):join
  b =: (0 .. chars.#.--).filter(odd?).map(\(chars.nth(_):S)):join
  =>: +[a b]
