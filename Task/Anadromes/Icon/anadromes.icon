procedure main()
   words := list()
   word_tab := table()
   f := open("words.txt") | stop("Cannot open words.txt")
   every put(words, (*(w := !f) > 6, w)) do word_tab[reverse(w)] := w

   every (w2 := \word_tab[w1 := !words],w1 ~== w2) do {
          write(right(w1,20)," -> ",w2)
          every delete(word_tab,w1|w2)
          }
end
