do  -- find some anadromes - words that when reversed are another word
    -- the anadromes must be at least 7 characters long

    local words = {}
    for word in io.lines( "words.txt" ) do
        if # word > 6 then
            words[ word ] = true
        end
    end

    for w, _ in pairs( words ) do
        local r = w:reverse()
        if r > w then
            if words[ r ] then
                io.write( string.format( "%12s %s\n", w, r ) )
            end
        end
    end

end
