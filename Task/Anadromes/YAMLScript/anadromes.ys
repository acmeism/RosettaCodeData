!ys-0

DICT =: '/usr/share/dict/words'

defn main(dict=DICT, limit=20):
  words =:
    split('able elba abut tuba agar raga avid diva bard drab', ' ')
  word-set =: set(words)
  loop words words, left limit:
    when left > 0:
      when-not words:empty?:
        word =: words.0
        rev =: word:reverse
        when compare(word rev) < 0:
          when in?(rev word-set):
            say: "$word $rev"
            left =: left.--
        recur: words:rest, left
