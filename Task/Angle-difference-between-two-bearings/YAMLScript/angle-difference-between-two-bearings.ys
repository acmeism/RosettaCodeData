!ys-0

defn main(*):
  pairs =::
  - [20, 45]
  - [-45, 45]
  - [-85, 90]
  - [-95, 90]
  - [-45, 125]
  - [-45, 145]
  - [29.4803, -88.6381]
  - [-78.3251, -159.036]
  each [b1 b2] pairs:
    d =: bearing-diff(b1 b2)
    say: "bearing-diff($b1, $b2) = $d"

defn bearing-diff(b1 b2):
  r =: (b2 - b1) % 360
  cond:
    r > 180: r - 360
    r <= -180: r + 360
    else: r
