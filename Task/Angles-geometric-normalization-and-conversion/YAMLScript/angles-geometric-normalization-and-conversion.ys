!ys-0

defn main(deg=-45):
  normal =: normalize(deg)
  say: "$deg degrees -> $normal degrees"
  say: "$normal degrees -> $radians(normal) radians"
  say: "$radians(normal) radians -> $degrees(radians(normal)) degrees"

defn normalize(deg):
  ((deg % 360) + 360) % 360

defn radians(deg):
  x =: deg * Math/PI
  x /: 180

defn degrees(rad):
  x =: rad * 180
  x /: Math/PI
