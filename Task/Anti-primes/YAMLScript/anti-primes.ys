!ys-0

defn main(want=20):
  loop n 1, best 0, found []:
    if found.# == want:
      then: say(found:joins)
      else:
        d =: divisor-count(n)
        if d > best:
          recur: n.++ d conj(found n)
          recur: n.++ best found

defn divisor-count(n):
  loop i 1, c 0:
    cond:
      i:sqr > n:
        c
      i:sqr == n:
        recur: i.++ c.++
      rem(n i):zero?:
        recur: i.++ (c + 2)
      else:
        recur: i.++ c
