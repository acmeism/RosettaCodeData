100 CLS
110 DIM LIST1(9)
120 DATA 1,2,3,4,5,6,7,8,9
130 FOR I = 1 TO 9
140   READ LIST1(I)
150 NEXT I
160 DIM LIST2(9)
170 DATA 10,11,12,13,14,15,16,17,18
180 FOR I = 1 TO 9
190   READ LIST2(I)
200 NEXT I
210 DIM LIST3(9)
220 DATA 19,20,21,22,23,24,25,26,27
230 FOR I = 1 TO 9
240   READ LIST3(I)
250 NEXT I
260 DIM CATLIST(9)
270 FOR I = 1 TO 9
280   TEMP$ = STR$(LIST1(I))+STR$(LIST2(I))+STR$(LIST3(I))
290   CATLIST(I) = VAL(TEMP$)
300   PRINT CATLIST(I);" ";
310 NEXT I
320 END
