110 DIM l1(9)
120 DATA 1,2,3,4,5,6,7,8,9
130 FOR i = 1 TO 9
140   READ l1(i)
150 NEXT i
160 DIM l2(9)
170 DATA 10,11,12,13,14,15,16,17,18
180 FOR i = 1 TO 9
190   READ l2(i)
200 NEXT i
210 DIM l3(9)
220 DATA 19,20,21,22,23,24,25,26,27
230 FOR i = 1 TO 9
240   READ l3(i)
250 NEXT i
260 DIM c(9)
270 FOR i = 1 TO 9
280   t$ = STR$(l1(i))+STR$(l2(i))+STR$(l3(i))
290   c(i) = VAL(t$)
300   PRINT c(i);" ";
310 NEXT i
320 END
