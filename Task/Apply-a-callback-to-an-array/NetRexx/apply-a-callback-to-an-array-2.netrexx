/* NetRexx Pipes */
import org.netrexx.njpipes.pipes.

class RCApplyCh extends stage

  method run()

    loop forever
      line = Rexx peekto()
      select
        when line == 'O' then line = 'O,'
        when line == 'mese' then line = 'muse'
        otherwise nop
      end
      output(line)
      readto()
    catch StageError
      rc = rc()
    end -- loop forever

    exit(rc * (rc <> 12))
