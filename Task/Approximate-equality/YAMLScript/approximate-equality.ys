!ys-0

tests =::
- [100000000000000.01, 100000000000000.011, 0.000000000001]
- [100.01, 100.011, 0.00001]
- [100.01, 100.011, 0.000001]

defn main():
  each [a b eps] tests:
    say: "$a $b eps=$eps -> $(approx?(a b eps))"

defn approx?(a b eps):
  diff =: abs(a - b)
  scale =: max(a:abs b:abs 1)
  diff <=: eps * scale
