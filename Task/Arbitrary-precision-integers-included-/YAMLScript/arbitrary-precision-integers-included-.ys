!ys-0

# The `N` suffix makes a literal a BigInt; multiplication of BigInts
# stays exact, so reducing `*` over `repeat(e 5N)` is arbitrary-precision.

defn main():
  e =: 4N ** (3 ** 2)
  n =: reduce(* repeat(e 5N))
  s =: n:str
  say: "First 20 digits: $(s.subs(0 20))"
  say: "Last 20 digits:  $(s.subs(s.# - 20))"
  say: "Number of digits: $(s.#)"
