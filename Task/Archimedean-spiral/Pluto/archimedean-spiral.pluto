require "bitmap"

local w = 400
local h = 400
local bmp = bitmap.of(w, h, color.black, "Archimedean_spiral")

local col = pico.red
local theta = 0
while theta < 52 * math.pi do
    local x = math.trunc(math.cos(theta / math.pi) * theta + w / 2)
    local y = math.trunc(math.sin(theta / math.pi) * theta + h / 2)
    bmp:set(x, y, col)
    theta += 0.025
end
bmp:view()
