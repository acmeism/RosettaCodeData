import "complex"

x = complex.of(1, 3)
y = complex.of(5, 2)
print "x     =  " + x.str
print "y     =  " + y.str
print "x + y =  " + x.add(y).str
print "x - y =  " + x.sub(y).str
print "x * y =  " + x.mul(y).str
print "x / y =  " + x.div(y).str
print "-x    =  " + x.neg.str
print "1 / x =  " + x.inv.str
print "x*    =  " + x.conj.str
