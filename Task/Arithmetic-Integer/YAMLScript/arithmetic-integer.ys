!ys-0

defn main(a=23, b=4):
  say: "a + b    = $(a + b)"
  say: "a - b    = $(a - b)"
  say: "a * b    = $(a * b)"
  say: "a quot b = $(a.quot(b))"  # `quot` truncates toward zero
  say: "a rem b  = $(a % b)"      # `%` (rem) has sign matching the dividend
  say: "a mod b  = $(a %% b)"     # `%%` (mod) has sign matching the divisor
  say: "a ** b   = $(a ** b)"
