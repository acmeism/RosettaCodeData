import "int"
import "rat"

print "The following numbers (less than 2^14) are perfect:"
one = rat.of(1)
for i in range(2, 2^14 - 1)
    sum = rat.of(1, i)
    divs = int.divisors(i, true)[1:]
    skip = false
    for j in divs
        sum = sum.add(rat.of(1, j))
        if sum.gt(one) then
            skip = true
            break
        end if
    end for
    if not skip and sum.eq(one) then print "  " + i
end for
