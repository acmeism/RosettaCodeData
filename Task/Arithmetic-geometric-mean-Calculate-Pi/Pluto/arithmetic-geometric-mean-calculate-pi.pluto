require "bignum"

local digits = 500
local an = bigrat.int(1)
local half = bigrat.recip(2)
local bn = half:sqrt(digits)
local tn = half * half
local pn = an
while pn <= digits do
    local prev_an = an
    an = (bn + an) * half
    bn = (bn * prev_an):sqrt(digits)
    prev_an -= an
    tn -= prev_an * prev_an * pn
    pn += pn
end
local cn = an + bn
local pi = cn * cn / (tn * 4)
print(pi:todecimal(digits, false))
