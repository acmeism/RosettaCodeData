!ys-0

defn main(iterations=6):
  a g t p =:
    agm(iterations 1 (1 / sqrt(2)) 0.25 1)
  sum =: a + g
  pi =: sum:sqr / (4 * t)
  say: format('%.15f' pi)

defn agm(n a g t p):
  if n.!:
    then: +[a g t p]
    else:
      next-a =: (a + g) / 2
      next-g =: sqrt(a * g)
      next-t =: t - (p * sqr(a - next-a))
      agm: n.-- next-a next-g next-t (p * 2)
