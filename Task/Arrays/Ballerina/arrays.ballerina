import ballerina/io;

public function main() {
    // fixed length array
    int[4] a = [1, 3, 9, 16];
    // assign a value
    a[1] = 4;
    // retrieve and print element at index 1 (zero indexing)
    io:println(a[1]);

    // dynamic array
    int[] b = [];
    // push an element into it
    b.push(42);
    // etrieve and print last element added
    io:println(b[b.length() - 1]);
}
