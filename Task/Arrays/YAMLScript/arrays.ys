!ys-0

defn main():
  # Create a vector (all YS arrays are immutable persistent vectors).
  a =: +[1 2 3 4 5]
  say: "a            = $a"
  say: "a.2          = $(a.2)"
  say: "count(a)     = $(a:count)"

  # Append (returns a new vector).
  b =: a.conj(6).conj(7)
  say: "a.conj(6 7)  = $b"

  # Update by index (returns a new vector).
  c =: a.assoc(0 99)
  say: "a.assoc(0 99) = $c"
