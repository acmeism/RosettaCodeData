link factors

procedure main(A)
   limit := integer(\A[1]) | 123456789
   every writes(" ",aprimes(limit))
   write()
end

procedure aprimes(limit)
   a := mklist()
   t := [: 1 to 9 :]
   while (n := get(t)) <= limit do {
      suspend isprime(n)
      every put(t,10*n+!a[n%10])
      }
end

procedure mklist()
   t := [: 1 to 9 :]
   every i := 1 to 9 do {
      every put(t[i] := [],(i+1) to 9)
      }
   return t
end
