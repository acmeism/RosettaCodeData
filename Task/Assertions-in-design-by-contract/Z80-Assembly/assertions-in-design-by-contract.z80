SmallMultiply:
;returns A = C * A
or a       ;compares A to zero
ret z      ;returns with the product A = C * 0 = 0.
dec a      ;sets zero flag if A equaled 1 prior to decrement, effectively comparing A to 1.
jr z, C_Times_One
ld b,a
ld a,c
loop_smallMultiply:
add c
djnz loop_smallMultiply
ret   ;returns A = C * A


C_Times_One:
ld a,c
ret  ;returns A = C
