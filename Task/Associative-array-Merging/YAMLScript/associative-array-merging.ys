!ys-0

# Merge two maps: the result has every key from either, with the
# update map's value winning on conflicts. `merge` does exactly this,
# taking values from later maps when keys collide.

defn main():
  base =:: {name: Rocket Skates, price: 12.75, color: yellow}
  update =:: {price: 15.25, color: red, year: 1974}
  merged =: merge(base update)
  each k merged:keys:
    say: "$k: $(merged.$k)"
