IsPrime(n) = if(n < 4, n > 1, range(2, n - 1).filter{n mod divisor == 0}.count == 0)

CountPrimeFactors(n) = {
    Step(candidate, factor, factors) = {
        Divides = candidate mod factor == 0

        if(Divides, candidate / factor, candidate),
        factor + if(Divides, 0, 1),
        factors + if(Divides, 1, 0),
        candidate > 1
    }
    Step.while(n, 2, 0):2
}

range(1, 120).filter{IsPrime(CountPrimeFactors(n))}
