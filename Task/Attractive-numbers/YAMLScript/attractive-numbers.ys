!ys-0

defn main(limit=120):
  say:
    (1 .. limit).filter(attractive?):joins

defn prime?(n):
  when n > 1:
    loop d 2:
      cond:
        (d * d) > n: true
        (n % d) == 0: false
        else: recur(d.++)

defn prime-factor-count(n):
  loop n n, d 2, cnt 0:
    if n >= 2:
      if (n % d) == 0:
        recur: quot(n d) d cnt.++
        recur: n d.++ cnt
      else: cnt

defn attractive?(n):
  n.prime-factor-count():prime?
