!ys-0

defn main(limit=120):
  say:
    (1 .. limit).filter(attractive?):joins

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
defn prime-factor-count(n):
  loop n n, d 2, cnt 0:
    if n >= 2:
      if (n % d) == 0:
        recur: (n // d), d, cnt.++
        recur: n, d.++, cnt
      else: cnt

defn attractive?(n):
  n:prime-factor-count:prime?
