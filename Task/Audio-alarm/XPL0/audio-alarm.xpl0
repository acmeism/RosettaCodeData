int Time, I, J, Ch;
char FN(80), Ext;
[Text(0, "Number of seconds to wait? ");
Time:= IntIn(0);
Text(0, "Name of mp3 file to play?  ");
I:= 0;
loop    [Ch:= ChIn(0);
        if Ch = \CR\$0D then quit;
        FN(I):= Ch;
        I:= I+1;
        ];
Ext:= ".mp3";
for J:= 0 to 3 do
        FN(I+J):= Ext(J);
ChOut(0, $0C);  \blank screen with form feed
DelayUs(Time * 1_000_000);
PlaySoundFile(FN);
]
