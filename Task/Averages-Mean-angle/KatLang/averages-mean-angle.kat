open Math

DisplayDecimals = 2

MeanAngle(Angles...) = {
    DegSin = Sin(a*Pi/180)
    DegCos = Cos(a*Pi/180)
    SinSum = map(Angles..., DegSin).sum
    CosSum = map(Angles..., DegCos).sum
    Atan2(SinSum / Angles.count, CosSum / Angles.count)*180/Pi
}

MeanAngle(350, 10)
MeanAngle(90, 180, 270, 360)
MeanAngle(10, 20, 30)
