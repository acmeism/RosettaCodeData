!ys-0

# Mean angle by averaging sin/cos components.

defn main():
  cases =::
  - [350, 10]
  - [90, 180, 270, 360]
  - [10, 20, 30]
  each angles cases:
    say: "Mean of $angles -> $(mean-angle(angles)) deg"

defn- mean-angle(angles):
  rads =: angles.map(\((Math/PI * _) / 180))
  sx =: rads.map(\(Math/sin(_))):sum
  cx =: rads.map(\(Math/cos(_))):sum
  rad =: Math/atan2(sx cx)
  deg =: (rad * 180) / Math/PI
  format '%.3f': deg
