CountItem(values..., item) = values.filter{value == item}.count

Mode(values...) = (
    Freqs = values.distinct.map{CountItem(values, candidate)}
    MaxFreq = Freqs.max

    values.distinct.filter{CountItem(values, candidate) == MaxFreq}
)

Mode(1, 3, 6, 6, 6, 6, 7, 7, 12, 12, 17)
Mode(1, 1, 2, 4, 4)
