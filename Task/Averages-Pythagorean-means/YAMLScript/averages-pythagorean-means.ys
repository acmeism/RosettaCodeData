!ys-0

defn main():
  xs =: 1 .. 10
  a =: arithmetic(xs)
  g =: geometric(xs)
  h =: harmonic(xs)
  say: "Arithmetic: $a"
  say: "Geometric:  $g"
  say: "Harmonic:   $h"
  ok =: a >= g >= h
  say: "A >= G >= H: $ok"

defn arithmetic(xs):
  sum =: apply(+ xs)
  sum /: xs.#

defn geometric(xs):
  prod =: apply(* xs)
  pow: prod (1.0 / xs.#)

defn harmonic(xs):
  recips =: xs.map(\(1.0 / _))
  xs.# /: apply(+ recips)
