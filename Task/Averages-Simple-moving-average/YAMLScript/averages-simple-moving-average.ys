!ys-0

defn main():
  sma3 =: make-sma(3)
  sma5 =: make-sma(5)
  inputs =:: [1, 2, 3, 4, 5, 5, 4, 3, 2, 1]
  each n inputs:
    say: "sma3=$sma3(n) sma5=$sma5(n)"

defn- make-sma(p):
  buf =: atom([])
  fn(n):
    b =: deref(buf).conj(n)
    b2 =:
      if b.# > p:
        vec: b:rest
        else: b
    swap! buf: constantly(b2)
    F(b2:sum) /: b2.#
