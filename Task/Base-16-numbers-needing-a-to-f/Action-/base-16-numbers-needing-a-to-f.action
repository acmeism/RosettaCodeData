BYTE FUNC IsHexWithLetter(INT x)
  DO
    IF x MOD 16>9 THEN
      RETURN (1)
    FI
    x==/16
  UNTIL x=0
  OD
RETURN (0)

PROC Main()
  INT i,count,min=[0],max=[500]

  count=0
  FOR i=min TO max
  DO
    IF IsHexWithLetter(i) THEN
      PrintI(i) Put(32)
      count==+1
    FI
  OD
  PrintF("%E%EFound %I numbers between %I and %I",count,min,max)
RETURN
