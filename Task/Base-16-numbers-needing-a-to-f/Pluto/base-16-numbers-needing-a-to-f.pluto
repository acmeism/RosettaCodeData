local fmt = require "fmt"

local function contains_any(s1, s2)
    for c in s2:gmatch(".") do
        if c in s1 then return true end
    end
    return false
end

local nondecimal = "abcdef"
local c = 0
for i = 0, 500 do
    local hex = fmt.itoa(i, 16)
    if contains_any(hex, nondecimal) then
        fmt.write("%3d ", i)
        ++c
        if c % 15 == 0 then print() end
    end
end
print($"\n\n{c} such numbers found.")
