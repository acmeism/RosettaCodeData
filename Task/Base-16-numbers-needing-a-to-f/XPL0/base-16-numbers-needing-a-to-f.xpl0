func HasHex(N);
int  N;
[while N do
     [if (N&$F) > 9 then return true;  N:= N>>4];
return false;
];

int N, Cnt;
[Cnt:= 0;
for N:= 1 to 500 do
    [if HasHex(N) then
        [if N<100 then ChOut(0, ^ );
        IntOut(0, N);
        Cnt:= Cnt+1;
        if rem(Cnt/20) = 0 then CrLf(0) else ChOut(0, ^ );
        ];
    ];
CrLf(0);
IntOut(0, Cnt);  Text(0, " such numbers found.");  CrLf(0);
]
