!ys-0

defn main(limit=500):
  nums =: (1 .. limit).filter(needs-a-f?)
  each row partition-all(20 nums):
    say: row.map(\(format('%3d' _))):joins
  say: "$(nums.#) numbers found."

defn needs-a-f?(n):
  when n != 0:
    loop x n:
      when x != 0:
        if (x % 16) >= 10:
          true
          recur(x // 16)
