  [ table ]              is base58char ( n --> n )

  $ "123456789ABCDEFGHJKLMNPQRSTUV"
  $ "WXYZabcdefghijkmnopqrstuvwxyz"
  join witheach
    [ ' base58char put ]

  [ [] swap
    [ 58 /mod base58char
      rot join swap
      dup 0 = until ]
    drop ]               is base58$    ( n --> $ )


' [ 25420294593250030202636073700053352635053786165627414518
    hex 61
