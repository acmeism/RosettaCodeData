    hex 636363
    hex 73696d706c792061206c6f6e6720737472696e67
    hex 516b6fcd0f
    hex bf4f89001e670274dd
    hex 572e4794
    hex ecac89cad93923c02321
    hex 10c8511e ]

witheach [ base58$ echo$ cr ]
