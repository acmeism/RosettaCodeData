bernoulli (n):
    a =: new row
    for m =: from 0 upto n
	a[m] =: 1 / (m + 1)
	for j =: from m downto 1
	    a[j-1] =: j * (a[j-1] - a[j])
    return a[0]

main (p):+
    max =: string p.1 as integer else 60     \ max number as parameter
    for i =: from 2 upto max step 2
	b =: bernoulli i
	\ to align the slash, print numerator and denominator separately
	print format "B(%2;) = %50; / %;" i, b.num, b.den
