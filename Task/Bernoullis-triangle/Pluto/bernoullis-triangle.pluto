local fmt = require "fmt"

local prev_row = {}
local max <const> = 15

for n = 0, max - 1 do
    local row = {}
    for k = 0, n do
        if k == 0 then
            row:insert(1)
        elseif k < n then
            row:insert(prev_row[k + 1] + prev_row[k])
        else
            row:insert(1 << n)
        end
    end
    fmt.tprint("%-5d", row, #row)
    prev_row = row
end
