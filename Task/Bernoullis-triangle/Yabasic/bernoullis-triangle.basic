lim = 15
dim prevRow(lim)
dim row(lim)

for n = 0 to lim - 1
    dim row(n + 1)
    for k = 0 to n
        if k = 0 then
            row(k) = 1
        elsif k < n then
            row(k) = prevRow(k) + prevRow(k - 1)
        else
            row(k) = 2 ^ n
        fi
    next k

    for k = 0 to n
        print row(k), " ";
    next k
    print

    dim prevRow(n + 1)
    for k = 0 to n
        prevRow(k) = row(k)
    next k
next n
