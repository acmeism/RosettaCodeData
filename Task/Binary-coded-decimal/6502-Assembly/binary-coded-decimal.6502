sed ;set decimal flag; now all math is BCD
lda #$19
clc
adc #1
cld           ;chances are, PrintHex won't work properly when in decimal mode.
JSR PrintHex  ;unimplemented print routine
JSR NewLine

sed
lda #$30
sec
sbc #1
cld
jsr PrintHex
JSR NewLine

sed
lda #$99
clc
adc #1
pha
lda #0
adc #0  ;adds the carry
cld
jsr PrintHex
pla
jsr PrintHex
jsr NewLine
rts   ;return to basic
