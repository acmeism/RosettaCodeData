import ballerina/io;

function bin(int number) returns string {
    int n = number;
    string out = "";
    while n > 0 {
        out = (n % 2).toString() + out;
        n /= 2;
    }
    return out;
}

public function main() {
    foreach int i in [5, 50, 9000] {
        io:println(bin(i));
    }
}
