dnaSeq = StringJoin @@ RandomChoice[{"A", "C", "G", "T"}, 200];
sampleSeq = StringJoin @@ RandomChoice[{"A", "C", "G", "T"}, 4];
positions = First /@ StringPosition[dnaSeq, sampleSeq];

Print["DNA sequence:\n" <> StringRiffle[StringPartition[dnaSeq, 50], "\n"]];
Print["Subsequence to find: " <> sampleSeq];
Print["Matches found at positions: " <> StringRiffle[ToString /@ positions, ", "]];
