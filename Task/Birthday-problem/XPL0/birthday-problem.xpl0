func Sim(N);
\Simulate birthdays and return number of people to have N same days
int  N, I, People, R;
char Days(365);
[for I:= 0 to 365-1 do Days(I):= 0;
People:= 0;
loop    [R:= Ran(365);
        Days(R):= Days(R)+1;
        People:= People+1;
        if Days(R) = N then return People;
        ];
];

int N, Sum, Trial;
[for N:= 2 to 5 do
    [Sum:= 0;
    for Trial:= 1 to 10000 do
        Sum:= Sum + Sim(N);
    IntOut(0, N);  Text(0, ": ");  IntOut(0, Sum/10000);  CrLf(0);
    ];
]
