!ys-0

defn main(file='bitmap-write-a-ppm-file.ppm'):
  write file: ppm(8 8)
  say: "wrote $file"

defn ppm(w h):
  rows =:
    for y (0 .. h.--):
      for x (0 .. w.--):
        if (x + y):even?:
          then: '255 255 255'
          else: '0 0 0'
  body =: map(joins rows):joins
  =>: "P3\n$w $h\n255\n$body\n"
