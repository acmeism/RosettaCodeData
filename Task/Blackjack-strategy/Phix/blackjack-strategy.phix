     <span style="color: #008080;">case</span> <span style="color: #000000;">20</span><span style="color: #0000FF;">:</span>
         <span style="color: #000000;">eg</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">1</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">2</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">3</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">7</span><span style="color: #0000FF;">]</span> <span style="color: #000080;font-style:italic;">// dealer has 17 to 19 or is bust</span>
         <span style="color: #000000;">eg</span> <span style="color: #0000FF;">-=</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">5</span><span style="color: #0000FF;">]</span>                         <span style="color: #000080;font-style:italic;">// dealer has (non-blackjack) 21</span>
     <span style="color: #008080;">case</span> <span style="color: #000000;">21</span><span style="color: #0000FF;">:</span>
         <span style="color: #000000;">eg</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">1</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">2</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">3</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">4</span><span style="color: #0000FF;">]</span> <span style="color: #0000FF;">+</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">7</span><span style="color: #0000FF;">]</span> <span style="color: #000080;font-style:italic;">// dealer has 17 to 20 or is bust</span>
