     <span style="color: #008080;">if</span> <span style="color: #000000;">card</span> <span style="color: #0000FF;">==</span> <span style="color: #000000;">1</span> <span style="color: #008080;">then</span> <span style="color: #000080;font-style:italic;">// an ace</span>
         <span style="color: #000000;">score</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">11</span>
         <span style="color: #000000;">eleven</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">1</span>
     <span style="color: #008080;">end</span> <span style="color: #008080;">if</span>
