 // is not completed) are exactly the same.</span>
     <span style="color: #004080;">sequence</span> <span style="color: #000000;">deck</span> <span style="color: #0000FF;">:=</span> <span style="color: #000000;">NewDeck</span><span style="color: #0000FF;">()</span>
