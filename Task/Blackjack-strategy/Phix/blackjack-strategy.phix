         <span style="color: #008080;">end</span> <span style="color: #008080;">for</span>
         <span style="color: #008080;">if</span> <span style="color: #000000;">dailyGain</span> <span style="color: #0000FF;">></span> <span style="color: #000000;">0</span> <span style="color: #008080;">then</span>
             <span style="color: #000000;">winDays</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">1</span>
         <span style="color: #008080;">elsif</span> <span style="color: #000000;">dailyGain</span> <span style="color: #0000FF;"><</span> <span style="color: #000000;">0</span> <span style="color: #008080;">then</span>
             <span style="color: #000000;">loseDays</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">1</span>
         <span style="color: #008080;">else</span>
             <span style="color: #000000;">evenDays</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">1</span>
         <span style="color: #008080;">end</span> <span style="color: #008080;">if</span>
         <span style="color: #008080;">if</span> <span style="color: #000000;">dailyGain</span> <span style="color: #0000FF;">></span> <span style="color: #000000;">bigWin</span> <span style="color: #008080;">then</span>
             <span style="color: #000000;">bigWin</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">dailyGain</span>
         <span style="color: #008080;">elsif</span> <span style="color: #0000FF;">-</span><span style="color: #000000;">dailyGain</span> <span style="color: #0000FF;">></span> <span style="color: #000000;">bigLoss</span> <span style="color: #008080;">then</span>
