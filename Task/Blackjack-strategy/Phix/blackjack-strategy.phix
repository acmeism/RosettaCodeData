 <span style="color: #000080;font-style:italic;">// Calculates gain per unit staked for a given scenario (helper function).</span>
 <span style="color: #008080;">function</span> <span style="color: #000000;">calcGain</span><span style="color: #0000FF;">(</span><span style="color: #004080;">integer</span> <span style="color: #000000;">pscore</span><span style="color: #0000FF;">,</span> <span style="color: #004080;">sequence</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">)</span>
     <span style="color: #004080;">atom</span> <span style="color: #000000;">eg</span> <span style="color: #0000FF;">:=</span> <span style="color: #000000;">0.0</span>
     <span style="color: #008080;">switch</span> <span style="color: #000000;">pscore</span> <span style="color: #008080;">do</span>
     <span style="color: #008080;">case</span> <span style="color: #000000;">17</span><span style="color: #0000FF;">:</span>
         <span style="color: #000000;">eg</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">dp</span><span style="color: #0000FF;">[</span><span style="color: #000000;">7</span><span style="color: #0000FF;">]</span>                         <span style="color: #000080;font-style:italic;">// dealer is bust</span>
