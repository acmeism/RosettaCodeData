 <span style="color: #004080;">sequence</span> <span style="color: #000000;">sTable2</span> <span style="color: #0000FF;">=</span> <span style="color: #7060A8;">repeat</span><span style="color: #0000FF;">(</span><span style="color: #7060A8;">repeat</span><span style="color: #0000FF;">(</span><span style="color: #008000;">""</span><span style="color: #0000FF;">,</span><span style="color: #000000;">10</span><span style="color: #0000FF;">),</span><span style="color: #000000;">10</span><span style="color: #0000FF;">)</span> <span style="color: #000080;font-style:italic;">// soft strategy table (round &gt;= 2, no doubling)</span>

 <span style="color: #008080;">function</span> <span style="color: #000000;">splitt</span><span style="color: #0000FF;">(</span><span style="color: #004080;">integer</span> <span style="color: #000000;">card</span><span style="color: #0000FF;">)</span>
 <span style="color: #000080;font-style:italic;">// Returns player's expected gains per unit originally staked, for each dealer up-card, after
 // splitting a pair and doubling the stake, getting a second card for each hand  and then continuing
