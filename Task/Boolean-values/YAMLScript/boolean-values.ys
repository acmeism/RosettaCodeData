!ys-0

defn main():
  say: "true literal:  $true"
  say: "false literal: $false"
  say: "1 == 1: $(1 == 1)"
  say: "1 == 2: $(1 == 2)"
  show-truthy: true
  show-truthy: false
  show-truthy: nil
  show-truthy: 0
  show-truthy: ''
  show-truthy: +[]
  show-truthy: 'hello'
  show-truthy: 42

defn show-truthy(v):
  truey =: v.??
  falsey =: v.!
  say: "value=$v  truey?=$truey  falsey?=$falsey"
