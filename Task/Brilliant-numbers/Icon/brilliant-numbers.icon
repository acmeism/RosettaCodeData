link factors

procedure main(A)
   limit := \A[1] | 100
   every writes(" ",brilliant()\limit)
   write("\n")
   every write(brillianth(10^(1 to 6)))
end

procedure brilliant()
   suspend (*(f := factors(i := seq())) = 2, *f[1] = *f[2], i)
end

procedure brillianth(e)
   static ln, j
   initial ln := j := 0

   every (*(f := factors(i := seq(j+1))) = 2,*f[1] = *f[2],j := i,ln +:= 1) do {
      if i >= e then return i||" is >= "||e||" and is brilliant number: "||ln
      }
end
