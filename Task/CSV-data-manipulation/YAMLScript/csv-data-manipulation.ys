!ys-0

csv-in =: |-
  C1,C2,C3,C4,C5
  1,5,9,13,17
  2,6,10,14,18
  3,7,11,15,19
  4,8,12,16,20

defn main(*):
  rows =: csv-in:lines.mapv(\(_.split(",")))
  header =: rows.0.conj("SUM")
  new-rows =: rows:rest.mapv(add-sum)
  all-rows =: new-rows.cons(header)
  output =: all-rows.mapv(\(_.join(","))):text
  print: output

defn add-sum(row):
  nums =: row.mapv(N)
  s =: sum(nums)
  row: .conj(s)
