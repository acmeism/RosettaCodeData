MODULE CalculateE;
IMPORT Out;

VAR
    fact,n : INTEGER;
    e,e0 : REAL;

BEGIN
    fact := 1;
    e    := 2.0;
    e0   := 0.0;
    n    := 2;

    WHILE e > e0 DO
        e0 := e;
        fact := fact * n;
        INC(n);
        e := e + 1.0 / FLT(fact)
    END;

    Out.String("e = ");Out.Real(e, 0);
    Out.String(", ");Out.Int(n,0);
    Out.String(" iterations");Out.Ln

END CalculateE.
