!ys-0

defn main(count=15):
  each n (1 .. count):
    f =: cw(n)
    say: "$(f.0)/$(f.1)"

defn cw(n):
  bits =: Long/toString(n 2):rest
  loop bits bits, a 1, b 1:
    if bits:empty?:
      then: +[a b]
      else:
        bit =: bits.0
        if bit == C('0'):
          recur: bits:rest, a, (a + b)
          recur: bits:rest, (a + b), b
