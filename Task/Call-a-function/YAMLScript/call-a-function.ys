!ys-0

defn main():
  say: greet()

  say: add(3 4)

  say: shout('hello')
  say: shout('hello' '!!!')

  say: sum-all(1 2 3 4 5)

  doubled =: map(double [1 2 3 4])
  say: doubled:joins

  result =: add(10 20)
  say: "captured: $result"

  say: inc(41)
  say: double(21)

  add5 =: partial(add 5)
  say: add5(10)

defn greet():
  'hello, world'

defn add(a b):
  a + b

defn shout(s suffix='!'):
  uc(s) + suffix

defn sum-all(*nums):
  +: nums*

defn double(n):
  n * 2
