  [ true swap
    factors dup size 3 < iff
      [ drop not ] done
    1 split nip
    -1 split drop
    dup size 3 mod 0 != iff
      [ drop not ] done
    [ 3 split
      0 rot witheach +
      factors size 2 != iff
        [ dip not ] done
      dup [] = until ]
    drop ]                   is calmo ( n --> b )

  [] 1000 times [ i^ calmo if [ i^ join ] ]
  echo
