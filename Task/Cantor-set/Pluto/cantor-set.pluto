local n = 5
local w = 3 ^ (n - 1)
local len = w
local line = table.create(w)
for i = 1, w do line[i] = "#" end

while true do
    print(line:concat(""))
    if len == 1 then break end
    len //= 3
    local pos = 1
    while pos < w - len do
        pos += len
        for i = pos, pos + len - 1 do line[i] = " " end
        pos += len
    end
end
