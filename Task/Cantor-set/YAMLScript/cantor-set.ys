!ys-0

# Render one line per depth; a line at depth d is two copies of the
# depth d-1 line around a blank middle third.

defn main(levels=5):
  width =: 3 ** levels.--
  each depth (0 .. levels.--):
    say: line(depth width)

defn line(depth width):
  if depth:zero?:
    then: width * '#'
    else:
      third =: width // 3
      part =: line(depth.-- third)
      gap =: third * ' '
      =>: "$part$gap$part"
