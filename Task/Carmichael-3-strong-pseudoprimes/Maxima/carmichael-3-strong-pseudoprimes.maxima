for p1 in primes(2, 61) do(
    for h3 from 2 thru p1 do(
        for d from 1 thru h3+p1 do(
            if mod((h3+p1)*(p1-1), d)=0 and mod(-p1^2, h3)=mod(d, h3) then block(
                p2: 1+floor((p1-1)*(h3+p1)/d),
                if primep(p2) and p2#p1 then block(
                    p3: 1+floor(p1*p2/h3),
                    if primep(p3) and mod(p2*p3, p1-1)=1 then print([p1, p2, p3]))))));
