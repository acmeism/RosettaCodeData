!ys-0

# First 15 Catalan numbers via Pascal's triangle:
# C(n) = binom(2n n) - binom(2n n+1)

defn main():
  cs =: (0 .. 14).map(catalan)
  say: 'First 15 Catalan numbers:'
  say: cs:joins

defn- catalan(n):
  row =: pascal-row(2 * n)
  row.$n -: row.get(n.++ 0)

defn- pascal-row(n):
  loop r [1] i 0:
    if i == n:
      r
      recur(next-row(r) i.++)

defn- next-row(r):
  pairs =: map(+ r.cons(0) r.conj(0))
  vec: pairs
