100 REM Catalan numbers
110 LET MaxN = 14
120 LET N = 0
130 LET C = 1
140 PRINT USING "C(##) = ########": N, C
150 DO WHILE N < MaxN
160    LET N = N + 1
170    LET I = 0
180    DO WHILE C > 0
190       LET C = C - (N + 1)
200       LET I = I + 1
210    LOOP
220    LET C = INT(2 * (2 * N - 1) * C / (N + 1))
230    LET C = C + 2 * I * (2 * N - 1)
240    PRINT USING "C(##) = ########": N, C
250 LOOP
260 END
