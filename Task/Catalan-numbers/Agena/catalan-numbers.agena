scope # print some catalan numbers
    local proc printCatalan( n :: number, cn :: number )
        printf( "%3d: %d\n", n, cn )
    end
    local Cprev := 1; # C0
    printCatalan( 0, Cprev )
    for n to 15 do
        Cprev := round( ( ( ( 4 * n ) - 2 ) / ( n + 1 ) ) * Cprev );
        printCatalan( n, Cprev )
    od
epocs
