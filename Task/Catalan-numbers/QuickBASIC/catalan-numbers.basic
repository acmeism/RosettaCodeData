' Catalan numbers
CONST MAXN% = 13 ' with 32-bit signed  integer; 10 for 16-bit signed integer
N% = 0
C& = 1
PRINT USING "C(##) = ########"; N%, C&
DO WHILE N% < MAXN%
  N% = N% + 1
  I% = 0
  DO WHILE C& > 0
    C& = C& - (N% + 1)
    I% = I% + 1
  LOOP
  C& = 2 * (2& * N% - 1) * C& \ (N% + 1)
  C& = C& + 2& * I% * (2 * N% - 1)
  PRINT USING "C(##) = ########"; N%, C&
LOOP
END
