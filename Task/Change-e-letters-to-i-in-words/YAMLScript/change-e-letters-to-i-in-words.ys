!ys-0

DICT =: '/usr/share/dict/words'

defn main(dict=DICT, limit=20):
  words =: read(dict):lines
  loop words words, left limit:
    when left > 0:
      when-not words:empty?:
        word =: words.0
        match? =: word =~~ /^[a-z]*e[a-z]*$/
        when match?:
          say: word.replace('e' 'i')
        next-left =:
          if match?:
            left.--
            left
        recur: words:rest, next-left
