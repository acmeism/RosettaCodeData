100 cls
110 rem pi = 4 * atn(1)
120 a = 0
130 b = 1
140 n = 10
150 dim cheby(n)
160 dim coef(n)
170 for i = 0 to n-1
180     coef(i) = cos(cos(pi/n*(i+1/2))*(b-a)/2+(b+a)/2)
190 next i
200 for i = 0 to n-1
210     w = 0
220     for j = 0 to n-1
230         w = w+coef(j)*cos(pi/n*i*(j+1/2))
240     next j
250     cheby(i) = w*2/n
260     print i;" : ";cheby(i)
270 next i
280 end
