100 CLS
110 PI# = 4 * ATN(1)
120 A# = 0
130 B# = 1
140 N# = 10
150 DIM CHEBY(N#)
160 DIM COEF(N#)
170 FOR I = 0 TO N#-1
180     COEF(I) = COS(COS(PI#/N#*(I+1/2))*(B#-A#)/2+(B#+A#)/2)
190 NEXT I
200 FOR I = 0 TO N#-1
210     W# = 0
220     FOR J = 0 TO N#-1
230         W# = W# + COEF(J) * COS(PI#/N#*I*(J+1/2))
240     NEXT J
250     CHEBY(I) = W# * 2 / N#
260     PRINT I; " : "; CHEBY(I)
270 NEXT I
280 END
