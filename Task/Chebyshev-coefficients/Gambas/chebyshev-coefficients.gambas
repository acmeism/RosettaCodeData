Public coef[10] As Float

Public Sub Main()
  Dim i As Integer, j As Integer
  Dim w As Float, a As Float = 0, b As Float = 1, n As Float = 10

  For i = 0 To n - 1
    coef[i] = Cos(Cos(Pi / n * (i + 1 / 2)) * (b - a) / 2 + (b + a) / 2)
  Next

  For i = 0 To n - 1
    w = 0
    For j = 0 To n - 1
      w += coef[j] * Cos(Pi / n * i * (j + 1 / 2))
    Next
    cheby[i] = w * 2 / n
    Print i; " : "; cheby[i]
  Next

End
