110 LET P = 4 * ATN(1)
120 LET A = 0
130 LET B = 1
140 LET N = 10
170 FOR I = 0 TO N-1
180   LET K(I) = COS(COS(P/N*(I+1/2))*(B-A)/2+(B+A)/2)
190 NEXT I
200 FOR I = 0 TO N-1
210   LET W = 0
220   FOR J = 0 TO N-1
230     LET W = W + K(J) * COS(P/N*I*(J+1/2))
240   NEXT J
250   LET C(I) = W * 2 / N
260   PRINT I; " : "; C(I)
270 NEXT I
280 END
