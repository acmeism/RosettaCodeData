uses console

'const pi as double = 4 * atn(1)
dim as integer i, j
dim as double w, a = 0, b = 1, n = 10
dim as double cheby(10), coef(10)

for i = 0 to n-1
    coef(i) = cos(cos(pi/n*(i+1/2))*(b-a)/2+(b+a)/2)
next i

for i = 0 to n-1
    w = 0
    for j = 0 to n-1
        w += coef(j) * cos(pi/n*i*(j+1/2))
    next j
    cheby(i) = w*2/n
    printl i " : " cheby(i)
next i

printl cr "Enter ..."
waitkey
