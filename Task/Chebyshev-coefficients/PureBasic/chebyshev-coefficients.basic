Define PI.f = 4 * ATan(1)
Define i.i, j.i
Define w.d, a.d = 0, b.d = 1, n.i = 10

Dim cheby.d(n)
Dim coef.d(n)

OpenConsole()
For i = 0 To n-1
  coef(i) = Cos(Cos(#PI/n*(i+1/2))*(b-a)/2+(b+a)/2)
Next

For i = 0 To n-1
  w = 0
  For j = 0 To n-1
    w + coef(j) * Cos(#PI/n*i*(j+1/2))
  Next
  cheby(i) = w*2/n
  PrintN(Str(i) + " : " + StrF(cheby(i), 15))
Next

PrintN(#CRLF$ + "Press ENTER to exit"): Input()
