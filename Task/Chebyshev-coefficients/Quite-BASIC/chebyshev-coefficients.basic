100 cls
110 rem pi = 4 * atn(1)
120 let a = 0
130 let b = 1
140 let n = 10
150 array c
160 array k
170 for i = 0 to n-1
180   let k[i] = cos(cos(pi/n*(i+1/2))*(b-a)/2+(b+a)/2)
190 next i
200 for i = 0 to n-1
210   let w = 0
220   for j = 0 to n-1
230     let w = w + k[j] * cos(pi/n*i*(j+1/2))
240   next j
250   let c[i] = w * 2 / n
260   print i; " : "; c[i]
270 next i
280 end
