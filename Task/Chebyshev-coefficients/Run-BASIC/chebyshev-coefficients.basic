pi = 4 * atn(1)
a = 0
b = 1
n = 10
dim cheby(n)
dim coef(n)
for i = 0 to n-1
    coef(i) = cos(cos(pi/n*(i+1/2))*(b-a)/2+(b+a)/2)
next i
for i = 0 to n-1
    w = 0
    for j = 0 to n-1
        w = w + coef(j)*cos(pi/n*i*(j+1/2))
    next j
    cheby(i) = w * 2 / n
    print i; " : "; cheby(i)
next i
end
