LET a = 0
LET b = 1
LET n = 10
DIM cheby(0)
MAT redim cheby(0 TO n)
DIM coef(0)
MAT redim coef(0 TO n)
LET PiDivN = PI / n
LET BPlADiv2 = (b + a) / 2
LET BMiADiv2 = (b - a) / 2

FOR i = 0 to n-1
    LET coef(i) = COS(COS(PiDivN * (I + .5)) * BMiADiv2 + BPlADiv2)
NEXT i

FOR i = 0 to n-1
    LET w = 0
    FOR j = 0 to n-1
        LET w = w + Coef(J) * COS(PiDivN * i * (j + .5))
    NEXT j
    LET cheby(i) = w * 2 / n
    PRINT using " # : ##.#####################": i, cheby(i)
NEXT i

END
