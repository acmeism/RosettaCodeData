rect[x_, y_, width_, height_] := Rectangle[{x, y}, {x + width, y + height}];
overlapsQ[poly_, rect_] := Head[RegionIntersection[poly, rect]] =!= EmptyRegion;

poly = Polygon[{{0, 0}, {0, 2}, {1, 4}, {2, 2}, {2, 0}}];
rect1 = rect[4, 0, 2, 2];
rect2 = rect[1, 0, 8, 2];

overlapsQ[poly, rect1]
overlapsQ[poly, rect2]
