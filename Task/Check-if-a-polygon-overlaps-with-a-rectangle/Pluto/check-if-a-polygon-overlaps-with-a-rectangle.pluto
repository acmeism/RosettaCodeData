require "bitmap"
local fmt = require "fmt"

local poly  = { {0, 0}, {0, 2}, {1, 4}, {2, 2}, {2, 0} }
local rect1 = { {4, 0}, {4, 2}, {6, 2}, {6, 0} }
local rect2 = { {1, 0}, {1, 2}, {9, 2}, {9, 0} }

print($"poly  = {fmt.swrite(poly)}")
print($"rect1 = {fmt.swrite(rect1)}")
print($"rect2 = {fmt.swrite(rect2)}")
print()

print($"poly and rect1 overlap? {bitmap.polygonsOverlap(poly, rect1)}")
print($"poly and rect2 overlap? {bitmap.polygonsOverlap(poly, rect2)}")
