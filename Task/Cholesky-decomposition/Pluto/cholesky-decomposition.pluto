require "matrix"

local arrays = {
    { {25, 15, -5},
      {15, 18,  0},
      {-5,  0, 11} },

    { {18, 22,  54,  42},
      {22, 70,  86,  62},
      {54, 86, 174, 134},
      {42, 62, 134, 106} }
}

for arrays as array do
    local m = matrix.from(array)
    print("Original:")
    print(m)
    print("\nLower Cholesky factor:")
    print(m:cholesky():format("%8.5f"))
    print()
end
