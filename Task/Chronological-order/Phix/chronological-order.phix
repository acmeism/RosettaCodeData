with javascript_semantics
procedure test(string s)
    sequence lines = split(s,'\n')
    for i,line in lines do
        string {y,bc} = split(line)[-2..-1]
        lines[i] = {to_integer(y)*iff(trim(bc)="BCE"?-1:1),line}
    end for
    lines = vslice(sort(lines),2)
    printf(1,"%s\n\n",join(lines,'\n'))
end procedure

-- or get these via get_text()...
constant txt = `
Pi                250  BCE
Magic Squares     2200 BCE
Kwarizmi          830  CE
Dice              3000 BCE
Liber Abaci       1202 CE
Euclid's Elements 300  BCE
Euler's Number    1727 CE
The Abacus        1200 CE`,
        stretch = `
Pi             250  BCE
Magic Squares  2200 BCE
Kwarizmi       830  CE
Dice           3000 BCE
Liber Abaci    1202 CE
Euler's Number 1727 CE
The Abacus     1200 CE`,
        stretch2 = `
Pi                250  BCE
FTSE 100          1984 CE
Magic Squares     2200 BCE
Kwarizmi          830  CE
Dice              3000 BCE
Liber Abaci       1202 CE
Euclid's Elements 300  BCE
Euler's Number    1727 CE
The Abacus        1200 CE`
test(txt)
test(stretch)
test(stretch2)
