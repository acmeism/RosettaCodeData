!ys-0

defn main(limit=200):
  each n (2 .. limit):
    when circular-prime?(n):
      say: n

defn circular-prime?(n):
  every? _ rotations(n:S):
    fn(s): prime?(s:parse-long)

defn rotations(s):
  for i (0 .. s:count.--):
    str(subs(s i) subs(s 0 i))

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
