!ys-0

defn main(limit=200):
  each n (2 .. limit):
    when circular-prime?(n):
      say: n

defn circular-prime?(n):
  every? _ rotations(n:S):
    fn(s): prime?(s)

defn rotations(s):
  for i (0 .. s:count.--):
    str(subs(s i) subs(s 0 i))

defn prime?(n):
  n =: parse-long(n:S)
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
