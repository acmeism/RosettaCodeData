#!/usr/bin/env ys-0

defn main():
  alice =: make-person('Alice' 30)
  bob =: make-person('Bob' 25)

  say: greet(alice)
  say: greet(bob)

  say: "Alice's age is $(alice.age)"

  older =: birthday(alice)
  say: greet(older)

defn make-person(name age):
  +{:name name, :age age}

defn greet(p):
  "Hi, I'm $(p.name) and I'm $(p.age) years old."

defn birthday(p):
  p.assoc(:age p.age.++)
