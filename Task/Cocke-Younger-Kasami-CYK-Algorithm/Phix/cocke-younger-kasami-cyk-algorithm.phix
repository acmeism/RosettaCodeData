with javascript_semantics
function cyk_parse(sequence words, grammar, string start_symbol)
    integer n = length(words)
    sequence t = repeat(repeat({},n),n)
    for j=1 to n do
        for rule in grammar do
            sequence {lhs,rhs} = rule
            if find(words[j],rhs) then
                t[j,j] &= {lhs}
            end if
        end for
        for i=j to 1 by -1 do
            for k=i to j-1 do
                for rule in grammar do
                    sequence {lhs,rhs} = rule
                    for r in rhs do
                        if not string(r)
                        and find(r[1],t[i,k])
                        and find(r[2],t[k+1,j]) then
                            t[i,j] &= {lhs}
                        end if
                    end for
                end for
            end for
        end for
    end for
    return find(start_symbol,t[1,n])
end function

constant grammar = {{"NP",  {{"Det","Nom"}}},
                    {"Nom", {{"AP", "Nom"}, "book", "orange", "man"}},
                    {"AP",  {{"Adv", "A"}, "heavy", "orange", "tall"}},
                    {"Det", {"a"}},
                    {"Adv", {"very", "extremely"}},
                    {"A",   {"heavy", "orange", "tall", "muscular"}}},
        texts = {`a very heavy orange book`,
                 `a very heavy orange`,
                 `a heavy orange`,
                 `a heavy`,
                 `orange`,
                 `very heavy orange`}
for text in texts do
    printf(1,"%s => %t\n",{text,cyk_parse(split(text),grammar,"NP")})
end for
