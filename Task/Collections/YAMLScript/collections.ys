!ys-0

defn main(*):
  # Vector (ordered, indexed)
  v =: +[1 2 3]
  v =: v.conj(4)
  say: "vector: $v"

  # List
  lst =: list(1 2 3)
  lst =: lst.conj(0)
  say: "list: $lst"

  # Set (unordered, unique)
  s =: \{1 2 3}
  s =: s.conj(4)
  say: "set: $s"

  # Map (key-value pairs)
  m =: +{:a 1, :b 2}
  m =: m.assoc(:c 3)
  say: "map: $m"
