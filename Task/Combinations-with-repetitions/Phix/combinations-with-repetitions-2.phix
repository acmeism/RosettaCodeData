with javascript_semantics
function count_choices(integer set_size, n, at=1, taken=0)
    integer count = 0
    if taken=n then return 1 end if
    taken += 1
    for i=at to set_size do
        count += count_choices(set_size,n,i,taken)
    end for
    return count
end function

?count_choices(10,3)
