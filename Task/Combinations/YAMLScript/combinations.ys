!ys-0

defn main(m=3, n=5):
  each c combinations(m (0 .. n.--)):
    say: c:joins

defn combinations(k items):
  cond:
    k == 0: +[[]]
    items.# < k: +[]
    else:
      head =: items:first
      tail =: items:rest
      with-first =:
        combinations(k.-- tail).map(\(cons(head _)))
      without-first =: combinations(k tail)
      with-first +: without-first
