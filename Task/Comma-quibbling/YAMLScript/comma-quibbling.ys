#!/usr/bin/env ys-0

tests =::
- []
- [ABC]
- [ABC, DEF]
- [ABC, DEF, G, H]

defn main():
  each xs tests: !say
    quibble: xs

defn quibble(xs):
  cnt =: xs.#
  body =:
    cond:
      cnt:zero?: ''
      cnt == 1: first(xs)
      else:
        butlast =: xs.drop-last(1).join(', ')
        =>: "$butlast and $(xs.$)"
  =>: "{$body}"
