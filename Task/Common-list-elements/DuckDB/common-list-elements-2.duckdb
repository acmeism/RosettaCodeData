create or replace function intersection(l1,l2,l3) as table (
  WITH combined AS (
    SELECT unnest(l1) as value
    UNION ALL
    SELECT unnest(l2)
    UNION ALL
    SELECT unnest(l3)
   )
   FROM (FROM combined
         GROUP BY value
         HAVING COUNT(*) = 3 )
   ORDER BY VALUE
);

from intersection([2,5,1,3,8,9,4,6], [3,5,6,2,9,8,4], [1,3,7,6,9]) as intersection;
