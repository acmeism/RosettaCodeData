INTERSECT
=LAMBDA(xs,
    LAMBDA(ys,
        FILTERP(
            LAMBDA(x,
                ELEM(x)(ys)
            )
        )(xs)
    )
)


INTERSECTCOLS
=LAMBDA(xs,
    IF(1 < COLUMNS(xs),
        INTERSECT(
            FIRSTCOL(xs)
        )(
            INTERSECTCOLS(
                TAILCOLS(xs)
            )
        ),
        xs
    )
)
