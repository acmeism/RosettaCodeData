require "map"
local fmt = require "fmt"

local lls = {
    {{2, 5, 1, 3, 8, 9, 4, 6}, {3, 5, 6, 2, 9, 8, 4}, {1, 3, 7, 6, 9}},
    {{2, 2, 1, 3, 8, 9, 4, 6}, {3, 5, 6, 2, 2, 2, 4}, {2, 3, 7, 6, 2}}
}

for i = 1, 2 do
    local bs = {}
    for lls[i] as ll do
        bs:insert(bag.of(ll:unpack()))
    end
    local common = bs[1]:intersect(bs[2]):intersect(bs[3]):flatten()
    fmt.print("\nIntersection of %s is %s", fmt.swrite(lls[i]), fmt.swrite(common))
end
