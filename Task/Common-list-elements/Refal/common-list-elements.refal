$ENTRY Go {
    , (2 5 1 3 8 9 4 6): t.L1
    , (3 5 6 2 9 8 4): t.L2
    , (1 3 7 6 9): t.L3
    = <Prout <Reduce (Union) t.L1 t.L2 t.L3>>;
};

Reduce {
    (e.F) t.I = t.I;
    (e.F) t.I t.J e.X = <Reduce (e.F) (<Mu e.F t.I t.J>) e.X>;
};

Union {
    () (e.L2) = ;
    (t.X e.L1) (e.L2), e.L2: {
        e.1 t.X e.2 = t.X <Union (e.L1) (e.L2)>;
        e.L2 = <Union (e.L1) (e.L2)>;
    };
};
