\ Intersection: keep in (m) only those also in (x)
map (m) keep (x):
	?# i =: map m give keys
		? x{i} = ()				\ if not in x
			m{i} =: ()			\ remove from m

main (parms):+
	m =: new map keys 2, 5, 1, 3, 8, 9, 4, 6
	x =: new map keys 3, 5, 6, 2, 9, 8, 4
	y =: new map keys 1, 3, 7, 9, 6
	map m keep x
	map m keep y
	print join m

\ create a map from keys, value is key (used by join ())
new map keys (t):
	m =: new map
	?# i =: give values t
		m{i} =: i
	:> m
