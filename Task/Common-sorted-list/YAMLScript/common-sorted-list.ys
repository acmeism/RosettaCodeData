!ys-0

defn main():
  a =: +[1 2 3 4 5 6 7]
  b =: +[2 4 6 8]
  say: common(a b):joins

defn common(a b):
  loop a a, b b, out (vector):
    cond:
      a:empty? || b:empty?: out
      a.0 == b.0:
        recur: a:rest, b:rest, conj(out a.0)
      a.0 < b.0:
        recur: a:rest, b, out
      else:
        recur: a, b:rest, out
