!ys-0

defn main(*args):
  strings =: args || qw(AA BB CC DD)
  say: "Strings:    $(strings:joins)"
  say: "All equal:  $(all-equal?(strings))"
  say: "Ascending:  $(ascending?(strings))"

defn all-equal?(strings):
  strings.every?(\(_ == strings:first))

defn ascending?(strings):
  strings
    .partition(2 1)
    .every?(\(compare(_.0 _.1) < 0))
