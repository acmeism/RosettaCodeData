sortstr: sort\by { "abcd" "123456789" } fn { a b } { a .length? > b .length? }
    ; returns [Block: ^[String: 123456789] [String: abcd] ]

for sortstr { ::i print "The length of string " ++ i ++ " is " ++ length? i }

sort\by list { "abcd" "123456789" "abcdef" "1234567" } fn { a b } { a .length? > b .length? } |print
