/* definition */
type Point = struct {
    int x;
    int y;
};

/* usage */
proc main() void:
    /* initialization */
    Point p = (2, 3);

    /* fields are accessed using '.' syntax */
    writeln(p.x, ", ", p.y);  /* prints 2, 3 */

    /* fields can be assigned */
    p.x := 5;
    writeln(p.x, ", ", p.y);  /* now prints 5, 3 */
corp
