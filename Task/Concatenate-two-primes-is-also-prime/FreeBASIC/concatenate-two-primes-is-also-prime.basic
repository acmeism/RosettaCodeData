#include "isprime.bas"
dim as integer p1, p2, cat, c = 0

for p1 = 2 to 99
    if not isprime(p1) then continue for
    for p2 = 2 to 99
        if not isprime(p2) then continue for
        cat = val( str(p1) + str(p2) )    ' =^..^=
        if isprime(cat) then
            c+=1
            print using "##|##  ";p1;p2;
            if c mod 10 = 0 then print
        end if
    next p2
next p1
