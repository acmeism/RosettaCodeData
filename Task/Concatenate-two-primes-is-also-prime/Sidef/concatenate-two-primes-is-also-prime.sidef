var upto = 100
var arr  = upto.primes
var base = 10

arr = arr.map {|p|
    var d = p.digits(base);
    arr.map {|q| [q.digits(base)..., d...].digits2num(base) }.grep { .is_prime }
}.flat.uniq.sort

say "Concatenated primes from primes p,q <= #{upto}:"

arr.each_slice(10, {|*a|
    say a.map { '%6s' % _ }.join(' ')
})

say "\nFound #{arr.len} such concatenated primes."
