!ys-0

# The ys runtime has no future/pmap/agent, so concurrency comes from
# Java Thread interop; a random sleep in each thread shuffles the
# output order.

defn main():
  threads =: qw(Enjoy Rosetta Code).mapv(speaker)
  each t threads: (. t start)
  each t threads: (. t join)

defn speaker(word):
  new Thread:
    fn():
      sleep: rand(0.05)
      say: word
