!ys-0

defn main(n=100):
  points =: set(repeatedly(n random-point))
  each y (15 .. -15):
    say: plot-row(points y)

# Rejection sampling: retry until the point lands in the ring
defn random-point():
  x =: rand-int(31) - 15
  y =: rand-int(31) - 15
  if 100 <= (x:sqr + y:sqr) <= 225:
    +[x y] random-point()

defn plot-row(points y):
  join: (-15 .. 15).map(\([_ y].in?(points).if('*' ' ')))
