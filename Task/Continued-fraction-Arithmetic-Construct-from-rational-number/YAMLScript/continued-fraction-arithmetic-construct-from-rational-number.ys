!ys-0

pairs-text =: |
  1 2
  3 1
  23 8
  13 11
  22 7
  -151 77
  14142 10000
  141421 100000
  1414214 1000000
  31 10
  314 100
  3142 1000
  31428 10000

defn main():
  pairs =:
    pairs-text:lines
      .map(\(words(_).mapv(I)))
  each pair pairs:
    say: "$pair -> $(r2cf(pair.0 pair.1))"

defn r2cf(num den):
  loop n num, d den, out []:
    if d == 0:
      then: out
      else:
        q =: n // d
        r =: n % d
        recur: d, r, out.conj(q)
