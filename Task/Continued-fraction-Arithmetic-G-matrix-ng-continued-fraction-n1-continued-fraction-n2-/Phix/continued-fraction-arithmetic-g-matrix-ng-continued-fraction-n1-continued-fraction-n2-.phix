             <span style="color: #000000;">l2</span> <span style="color: #0000FF;">=</span> <span style="color: #7060A8;">length</span><span style="color: #0000FF;">(</span><span style="color: #000000;">cf2</span><span style="color: #0000FF;">),</span> <span style="color: #000000;">dx2</span><span style="color: #0000FF;">=</span><span style="color: #000000;">1</span>
     <span style="color: #008080;">while</span> <span style="color: #004600;">true</span> <span style="color: #008080;">do</span>
         <span style="color: #008080;">if</span> <span style="color: #000000;">fm</span><span style="color: #0000FF;">.</span><span style="color: #000000;">need_term</span><span style="color: #0000FF;">()</span> <span style="color: #008080;">then</span>
             <span style="color: #004080;">bool</span> <span style="color: #000000;">is_cf1</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">fm</span><span style="color: #0000FF;">.</span><span style="color: #000000;">which_term</span><span style="color: #0000FF;">()</span>
             <span style="color: #004080;">object</span> <span style="color: #000000;">t</span> <span style="color: #0000FF;">=</span> <span style="color: #0000FF;">{}</span>
             <span style="color: #008080;">if</span> <span style="color: #000000;">is_cf1</span> <span style="color: #008080;">then</span>
                 <span style="color: #008080;">if</span> <span style="color: #000000;">dx1</span><span style="color: #0000FF;"><=</span><span style="color: #000000;">l1</span> <span style="color: #008080;">then</span>
                     <span style="color: #000000;">t</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">cf1</span><span style="color: #0000FF;">[</span><span style="color: #000000;">dx1</span><span style="color: #0000FF;">]</span>
                     <span style="color: #000000;">dx1</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">1</span>
                 <span style="color: #008080;">end</span> <span style="color: #008080;">if</span>
             <span style="color: #008080;">else</span>
                 <span style="color: #008080;">if</span> <span style="color: #000000;">dx2</span><span style="color: #0000FF;"><=</span><span style="color: #000000;">l2</span> <span style="color: #008080;">then</span>
                     <span style="color: #000000;">t</span> <span style="color: #0000FF;">=</span> <span style="color: #000000;">cf2</span><span style="color: #0000FF;">[</span><span style="color: #000000;">dx2</span><span style="color: #0000FF;">]</span>
                     <span style="color: #000000;">dx2</span> <span style="color: #0000FF;">+=</span> <span style="color: #000000;">1</span>
                 <span style="color: #008080;">end</span> <span style="color: #008080;">if</span>
             <span style="color: #008080;">end</span> <span style="color: #008080;">if</span>
             <span style="color: #000000;">fm</span><span style="color: #0000FF;">.</span><span style="color: #000000;">in_term</span><span style="color: #0000FF;">(</span><span style="color: #000000;">is_cf1</span><span style="color: #0000FF;">,</span><span style="color: #000000;">t</span><span style="color: #0000FF;">)</span>
