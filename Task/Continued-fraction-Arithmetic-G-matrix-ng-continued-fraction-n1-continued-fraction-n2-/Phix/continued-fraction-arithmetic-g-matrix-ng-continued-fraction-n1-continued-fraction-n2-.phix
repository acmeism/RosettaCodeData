 <span style="color: #008080;">function</span> <span style="color: #000000;">apply_full_matrix</span><span style="color: #0000FF;">(</span><span style="color: #004080;">sequence</span> <span style="color: #000000;">ctrl</span><span style="color: #0000FF;">,</span> <span style="color: #000000;">cf1</span><span style="color: #0000FF;">,</span> <span style="color: #000000;">cf2</span><span style="color: #0000FF;">)</span>
   <span style="color: #000080;font-style:italic;">--
   -- If ctrl is {a12, a1, a2, a,
   --             b12, b1, b2, b}
   --
   -- Then the result of apply_full_matrix(ctrl,cf1,cf2) would be
   --
   --        (a12*cf1*cf2 + a1*cf1 + a2*cf2 + a)
   --        -----------------------------------
   --        (b12*cf1*cf2 + b1*cf1 + b2*cf2 + b)
   --
   -- For instance:
   --        { 0, 1, 1, 0,       calculates cf1 + cf2
   --          0, 0, 0, 1}         (divided by 1)
   --
   --        { 0, 1,-1, 0,       calculates cf1 - cf2
   --          0, 0, 0, 1}         (divided by 1)
   --
   --        { 1, 0, 0, 0,       calculates cf1 * cf2
   --          0, 0, 0, 1}         (divided by 1)
   --
   --        { 0, 1, 0, 0,       calculates cf1
   --          0, 0, 1, 0}          divided by cf2
   --</span>
