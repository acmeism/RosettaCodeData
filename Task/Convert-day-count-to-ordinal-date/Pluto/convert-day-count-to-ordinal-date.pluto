local function day_count_to_ord(dc)
    return os.time({year = 2000, month = 1, day = 1 + dc})
end

for {0, 109573, 146096} as i do
    print($"Daycount: {i}")
    for j = 0, 5 do
        local d = os.date("*t", day_count_to_ord(j * 146097 + i))
        print(string.format("%02d/%02d/%04d", d.day, d.month, d.year - 2000))
    end
    print()
end
