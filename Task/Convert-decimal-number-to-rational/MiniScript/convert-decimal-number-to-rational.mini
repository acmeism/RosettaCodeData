import "fmt"
import "rat"

// numbers with no more than 6 d.p.
tests = [0.905405, 0.518518, 0.75]
for test in tests
    r = rat.ofVal(test)
    test = fmt.str(str(test), -9)
    fmt.print "{} -> {}", test, r.str
end for

// workaround for number with 7 d.p.
f = 0.9054054
r = rat.of(f * 10^7, 10^7)
fmt.print "{} -> {}", fmt.num(f, -9, 7), r.str
