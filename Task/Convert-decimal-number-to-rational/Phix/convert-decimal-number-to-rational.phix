with javascript_semantics
function decrat(string s)
    integer nom = 0,
            denom = 1
    assert(s[1..2]="0.")
    for i=3 to length(s) do
        integer ch = s[i]
        assert(ch>='0' and ch<='9')
        nom = nom*10 + ch-'0'
        denom *= 10
    end for
    return sq_div({nom,denom},gcd(nom,denom))
end function

?decrat("0.9054054")
?decrat("0.518518")
?decrat("0.75")
