\( convert float to rational (built-in)
   rationals are automatically reduced and converted to integer if possible
\)
main(parms):+
  inp =: 0.009054054, 0.518518, 0.75, -3.141592, 12.0319272, 230.0
  for f =: tuple inp give values
    print f, '=', float f as rational

\ not (yet) in the standard library:
float (@) as rational:
  m, e =: float @ split decimal     \ library function does the work
  return m * 10^e
