!ys-0

defn main(x='3.14159'):
  r =: decimal-rational(x)
  say: "$(r.0)/$(r.1)"

defn decimal-rational(s):
  parts =: split(s /\./)
  int =: parts.0
  frac =: parts.1 || ''
  scale =: 10 ** frac.#
  num =: (int + frac):I
  g =: gcd(abs(num) scale)
  numerator =: num // g
  denominator =: scale // g
  =>: +[numerator denominator]

defn gcd(a b):
  loop a a, b b:
    if b:zero?:
      then: a
      else:
        recur: b, rem(a b)
