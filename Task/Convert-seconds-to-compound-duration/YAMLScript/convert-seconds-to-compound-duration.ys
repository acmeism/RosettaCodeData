!ys-0

units =:: [[wk, 604800], [d, 86400], [hr, 3600], [min, 60], [sec, 1]]

defn main(n=7259):
  say: duration(n)
  say: duration(86400)
  say: duration(6000000)

defn- duration(secs):
  sep =: ', '
  loop i 0, left secs, parts []:
    if i >= units:count:
      join parts: sep
      else:
        u =: units.$i
        unit =: u.0
        size =: u.1
        q =: left // size
        r =: left % size
        np =: q:zero?.if(parts parts.conj("$q $unit"))
        recur: i.++ r np
