ClearAll[NextTerm]
NextTerm[a_List] := Module[{pred1, pred2, cands},
  {pred1, pred2} = Take[a, -2];
  cands =
   Select[Range[50], CoprimeQ[#, pred1] && CoprimeQ[#, pred2] &];
  cands = Complement[cands, a];
  If[Length[cands] > 0,
   Append[a, First[cands]]
   ,
   a
   ]
  ]
Nest[NextTerm, {1, 2}, 120]
