create or replace table strings(string VARCHAR);

insert into strings values
  ('Forever HOPL'),
  ('Now is the time for all good men to come to the aid of their country.');

create or replace function json_synopsis(string) as (
   with s as (from synopsis(string)),
   t as (select s from s)
   select s::JSON from t
   );

.mode list
select json_synopsis(string) from strings;
