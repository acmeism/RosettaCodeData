!ys-0

defn main(s='The quick brown fox jumps over the lazy dog.'):
  counts =: vowel-consonant-counts(s)
  say: "vowels: $(counts.vowels)"
  say: "consonants: $(counts.consonants)"

defn vowel-consonant-counts(s):
  letters =: s:lc:seq.filter(\(_ =~ /^[a-z]$/))
  vowels =: letters.filter(\(_ =~ /^[aeiou]$/)).#
  M+:
    :vowels vowels
    :consonants (letters.# - vowels)
