!ys-0

defn main(n=10):
  each i (1 .. n):
    say: "$i = $factor-string(i)"

defn- factor-string(n):
  if n == 1: +
    '1'
    factors(n).join(' x ')

defn- factors(n):
  loop i 2, m n, fs []:
    cond:
      m == 1: fs
      zero?(m % i):
        recur: i, (m / i), fs.conj(i)
      else: recur(i.++ m fs)
