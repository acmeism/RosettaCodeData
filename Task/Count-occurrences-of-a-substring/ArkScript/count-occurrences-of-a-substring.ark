(import std.String)

(let count (fun (str word) {
  (mut total 0)
  (mut next (string:find str word))
  (while (!= -1 next) {
    (set total (+ 1 total))
    (set next (string:findAfter str word (+ next (len word)))) })
  total }))

(print (count "the three truths" "th"))
(print (count "ababababab" "abab"))
