func count str$ pat$ .
   ind = 1
   lp = len pat$
   while ind - 1 + lp <= len str$
      if substr str$ ind lp = pat$
         cnt += 1
         ind += lp
      else
         ind += 1
      .
   .
   return cnt
.
print count "the three truths" "th"
print count "ababababab" "abab"
print count "11111111" "11"
print count "11111111" "12"
print count "12" "12"
