!ys-0

defn main(*):
  say: "Ways to make $1.00: $count-coins(100 [1 5 10 25])"
  say: "Ways to make $10.00: $count-coins(1000 [1 5 10 25 50 100])"

defn count-coins(amount coins):
  table =: vec(repeat(amount.++ 0))
  table2 =: table.assoc(0 1)
  last:
    reduce _ table2 coins:
      fn(tbl coin):
        reduce _ tbl (coin .. amount):
          fn(t i):
            prev =: nth(t (i - coin))
            cur =: nth(t i)
            assoc t: i (cur + prev)
