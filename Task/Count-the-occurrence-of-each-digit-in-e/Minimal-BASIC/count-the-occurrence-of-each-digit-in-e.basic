110 LET N = 2000
120 DIM V(2000)
130 FOR I = 1 TO N
140   LET V(I) = 1
150 NEXT I
160 DIM D(10)
170 FOR I = 1 TO 10
180   LET D(I) = 0
190 NEXT I
200 LET D(3) = 1
210 FOR K = 1 TO 2*N
220   LET A = N+1
230   LET C = 0
240   FOR I = 1 TO N
250     LET C = C+V(I)*10
260     LET V(I) = C-INT(C/A)*A
270     LET C = INT(C/A)
280     LET A = A-1
290   NEXT I
300   LET D(C+1) = D(C+1)+1
310 NEXT K
320 FOR I = 1 TO 10
330   PRINT D(I);
340 NEXT I
350 PRINT
360 END
