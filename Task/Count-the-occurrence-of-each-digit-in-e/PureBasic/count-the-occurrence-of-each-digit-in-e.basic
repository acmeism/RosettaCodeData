OpenConsole()
#N = 2000

Dim v(#N-1)
Dim dcount(9)

For i = 0 To 9
  dcount(i) = 0
Next i
dcount(2) = 1

For i = 0 To #N-1
  v(i) = 1
Next i

; Main calculation loop
For col = 0 To 2 * #N
  a = #N + 1
  c = 0

  For i = 0 To #N-1
    c + v(i) * 10
    v(i) = c % a
    c = c / a
    a - 1
  Next i

  dcount(c) + 1

Next col

For i = 0 To 9
  Print(" " + Str(dcount(i)))
Next i

PrintN(#CRLF$ + "Press ENTER to exit"): Input()
CloseConsole()
