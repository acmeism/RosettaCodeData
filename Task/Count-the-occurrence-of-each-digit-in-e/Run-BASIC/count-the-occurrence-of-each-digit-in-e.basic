MaxIDx = 2000

dim v(MaxIDx-1)
for i = 0 To MaxIDx -1
    v(i) = 1
next

dim dcount(9)
for i = 0 To 9
    dcount(i) = 0
next
dcount(2) = 1

for col = 0 to 2 * MaxIDx
    a = MaxIDx +1
    c = 0

    for i = 0 to MaxIDx -1
        c = c + v(i) * 10
        v(i) = c mod a
        c = int(c / a)
        a = a -1
    next

    dcount(c) = dcount(c) +1
next

for i = 0 to 9
    print " "; dcount(i);
next
