INCLUDE "H6:SIEVE.ACT"

PROC Main()
  DEFINE MAX="999"
  BYTE ARRAY primes(MAX+1)
  INT i,count=[0]

  Put(125) PutE() ;clear the screen
  Sieve(primes,MAX+1)
  FOR i=2 TO MAX-4
  DO
    IF primes(i)=1 AND primes(i+4)=1 THEN
      PrintF("(%I,%I) ",i,i+4)
      count==+1
    FI
  OD
  PrintF("%E%EThere are %I pairs",count)
RETURN
