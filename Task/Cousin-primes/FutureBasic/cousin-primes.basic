clear local fn cousins as bool
  uint16 odds(1000), count = 0

  for int p = 3 to 1000 step 2
    if odds(p) then continue

    for int q = p * p to 1000 step p*2
      odds(q) = 1
    next

    if p < 6 || odds(p - 4) then continue
    print fn StringWithFormat( @"[%3d,%4d]  ", p-4,p);
    count ++ : if count mod 6 == 0 then print
  next

  print @"\ncount = ";count
end fn

window 1, @"Cousin Primes under 1000"
fn cousins

handleevents
