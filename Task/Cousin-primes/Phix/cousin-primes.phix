with javascript_semantics
function has_cousin(integer p) return is_prime(p+4) end function
for n=2 to 8 do
    integer tn = power(10,n), maxlen = 4-floor((n-1)/3)
    sequence res = filter(get_primes_le(tn-9),has_cousin)
    res = columnize({res,sq_add(res,4)})
    printf(1,"%,d cousin prime pairs less than %,d found: %v\n",{length(res),tn,shorten(res,"",maxlen)})
end for
