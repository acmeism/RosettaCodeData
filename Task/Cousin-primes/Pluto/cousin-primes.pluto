local int = require "int"
local fmt = require "fmt"

local c = int.arecomps(999)
local count = 0
print("Cousin prime pairs whose elements are less than 1,000:")
local i = 3
while i <= 995 do
    if !c[i] and !c[i + 4] then
        fmt.write("%3d:%3d  ", i, i + 4)
        count += 1
        if count % 7 == 0 then print() end
        i = (i != 3) ? i + 4 : i + 2
    end
    i += 2
end
print($"\n\n{count} pairs found")
