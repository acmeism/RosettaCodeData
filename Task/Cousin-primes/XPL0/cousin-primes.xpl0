include xpllib; \For IsPrime and Print
int  N, C;
[C:= 0;
for N:= 2 to 1000-1-4 do
    [if IsPrime(N) then
      if IsPrime(N+4) then
        [Print("(%3.0f, %3.0f)  ", float(N), float(N+4));
        C:= C+1;
        if rem(C/6) = 0 then CrLf(0);
        ];
    ];
Print("\nThere are %d cousin primes less than 1000.\n", C);
]
