!ys-0

defn main(file='output.txt' dir='docs'):
  mk-file: file
  mk-dir: dir
  mk-file: "/$file"
  mk-dir: "/$dir"

defn mk-file(path):
  try:
    fs/touch: path
    say: "Created file $path"
    catch Exception e: !warn
      "Failed to create file $path: $(ex-message(e))"

defn mk-dir(path):
  try:
    fs/mkdir-p: path
    say: "Created dir $path"
    catch Exception e: !warn
      "Failed to create dir $path: $(ex-message(e))"
