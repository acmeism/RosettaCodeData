!ys-0

defn main(rows=3, cols=4):
  grid =: make-grid(rows cols)
  say: "Initial grid:"
  print-grid: grid

  grid =: assoc-in(grid [1 2] 42)
  say: "\nAfter setting [1,2] = 42:"
  print-grid: grid

  say: "\nValue at [1,2] = $(grid.get-in([1 2]))"

defn make-grid(rows cols):
  vec: repeat(rows repeat(cols 0):V)

defn print-grid(grid):
  each row grid: !say
    joins: row
