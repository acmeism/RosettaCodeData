!ys-0

letters =: rng(C('A') C('Z')):V

defn main(rows=3 cols=3):
  say: '<table>'
  say: '<tr><th></th>'
  each c (0 .. cols.--):
    say: cell('th' letters.$c:S)
  say: '</tr>'
  each r (1 .. rows):
    say: '<tr>'
    say: cell('td' r)
    each i (1 .. cols):
      say: cell('td' rand-int(9999).++)
    say: '</tr>'
  say: '</table>'

defn cell(tag content):
  "<$tag>$content</$tag>"
