EXPORT Cuban_primes()
BEGIN
PRINT;
LOCAL C:=0,I:=0,CP,L1:={};
PRINT("First 200 cuban primes:");
WHILE C<75000 DO
  I:=I+1;
  CP:=3*I*(I+1)+1;
  IF isprime(CP) THEN
    C:=C+1;
    IF C<=200 THEN
      L1(C):=CP;
    END;
    R:=CP;
  END;
END;
PRINT(L1);
PRINT("");
PRINT("The "+C+"th Cuban Prime is "+R);
END;
