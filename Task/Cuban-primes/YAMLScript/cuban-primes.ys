!ys-0

defn main(limit=20):
  say: (1 .. 10000).filter(cuban-prime?).take(limit):joins

defn cuban-prime?(n):
  some _ (1 .. I(sqrt(n))):
    fn(k):
      candidate =: ((3 * k:sqr) + (3 * k)).++
      when (candidate == n) && n:prime?: n

defn prime?(n):
  when n >= 2:
    if n < 4:
      then: true
      else:
        not-any? _ (2 .. sqrt(n)):
          fn(d): zero?(n % d)
