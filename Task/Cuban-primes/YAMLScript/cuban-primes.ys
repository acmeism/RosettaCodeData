!ys-0

defn main(limit=20):
  say: (1 .. 10000).filter(cuban-prime?).take(limit):joins

defn cuban-prime?(n):
  some _ (1 .. I(sqrt(n))):
    fn(k):
      candidate =: ((3 * k:sqr) + (3 * k)).++
      when (candidate == n) && n:prime?: n

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
