INCLUDE "H6:SIEVE.ACT"

PROC Main()
  DEFINE MAX="14999"
  BYTE ARRAY primes(MAX+1)
  INT i=[2],next,count=[1],n=[1]

  Put(125) PutE() ;clear the screen
  Sieve(primes,MAX+1)
  PrintI(i)
  DO
    next=i+n*n*n
    IF next>=MAX THEN
      EXIT
    FI
    IF primes(next) THEN
      n=1 i=next count==+1
      Put(32) PrintI(i)
    ELSE
      n==+1
    FI
  OD
  PrintF("%E%EThere are %I cubic special primes",count)
RETURN
