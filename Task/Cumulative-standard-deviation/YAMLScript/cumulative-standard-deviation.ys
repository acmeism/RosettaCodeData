!ys-0

defn main(*):
  nums =:: [2, 4, 4, 4, 5, 5, 7, 9]
  state =: atom({:n 0, :sum 0.0, :sum2 0.0})
  each x nums:
    swap state update-state x:
    s =: state.@
    say: "n=$(s.n) mean=$format('%.4f' mean(s)) sd=$format('%.4f' std-dev(s))"

defn update-state(s x):
  s .assoc(:n s.n.++)
    .assoc(:sum (s.sum + x))
    .assoc(:sum2 (s.sum2 + (x * x)))

defn mean(s):
  s.sum / s.n

defn std-dev(s):
  sqrt((s.sum2 / s.n) - (mean(s) * mean(s)))
