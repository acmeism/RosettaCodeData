!ys-0

# Currying via partial: add-n returns a closure that adds n; partial
# does the same with the built-in +.

defn main():
  add2 =: add-n(2)
  add3 =: add-n(3)
  say: "add2(7)        = $(add2(7))"
  say: "add3(7)        = $(add3(7))"
  add10 =: add + 10  # partial add (same as +)
  say: "partial(+ 10)(7) = $(add10(7))"

defn- add-n(n):
  fn(x): n + x
