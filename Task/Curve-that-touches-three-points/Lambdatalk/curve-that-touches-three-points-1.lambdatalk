p(t) = 1*p0(1-t)2 + 2*p1(1-t)t + 1*p2t2

{def interpol
 {lambda {:p0 :p1 :p2 :t :u}       // u =1-t
   {+ {* 1 {A.get 0 :p0} :u :u}
      {* 2 {A.get 0 :p1} :u :t}
      {* 1 {A.get 0 :p2} :t :t}}
   {+ {* 1 {A.get 1 :p0} :u :u}
      {* 2 {A.get 1 :p1} :u :t}
      {* 1 {A.get 1 :p2} :t :t}} }}
-> interpol
