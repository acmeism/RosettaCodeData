procedure main(A)
    limit := \A[1] | 50
    every b := 2 to 10 by 2 do {
       writes("Base integer ",b,":")
       every (cnt := 0, n := curzon(b)\1000, cnt +:= 1) do
          if cnt <= 50 then writes(" ",n)
       write("\n\t1000th Curzon number is ",n)
       write("\n")
       }
end

procedure curzon(b)
   every n := seq() do {
     x := b^n+1
     y := b*n+1
     suspend ((x/y)*y = x, n)
     }
end
