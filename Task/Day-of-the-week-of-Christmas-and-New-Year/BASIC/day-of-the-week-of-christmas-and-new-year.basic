10 DEFINT A-Z
20 DIM D$(6)
30 FOR I=0 TO 6: READ D$(I): NEXT
40 FOR I=1 TO 2
50 READ Y,M,D
60 PRINT USING "##/##/#### is a ";M;D;Y;
70 IF M<=2 THEN M=M+12: Y=Y-1
80 J=Y\100
90 K=Y MOD 100
100 D=(D+((M+1)*26)\10+K+K\4+J\4+5*J) MOD 7
110 PRINT D$(D)
120 NEXT
130 DATA Saturday,Sunday,Monday,Tuesday,Wednesday,Thursday,Friday
140 DATA 2021,12,25
150 DATA 2022,1,1
