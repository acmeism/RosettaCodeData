CFArrayRef  wd : wd = @[ @"Sun", @"Mon", @"Tues", @"Wednes", @"Thurs", @"Fri", @"Satur" ]
CFArrayRef  yr : yr = @[ @1100, @1578, @1582, @1590, @1642, @2020, @2021, @2022, @2100 ]

CFStringRef  local fn jan1( y as Int )
  y--
  Int  d = 5 * y / 4 + 6
  if y > 1581 then d -= 3 * ( y / 100 + 1) / 4 + 5
end fn = wd[ d % 7 ]

for CFNumberRef i in yr
  printf @"01–01–%@: %@day", i, fn jan1( intval( i ) )
  printf @"25–12–%@: %@day\n", i, fn jan1( intval( i ) + 1)
next

handleevents
