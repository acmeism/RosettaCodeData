  [ [ table
      $ "Sun"   $ "Mon"
      $ "Tues"  $ "Wednes"
      $ "Thurs" $ "Fri"
      $ "Satur"  ]
    do $ "day" join ]        is day       ( n --> $ )

  [ 25 12 rot dayofweek ]    is christmas ( n --> $ )

  [ 1 1 rot dayofweek  ]     is newyear's ( n --> $ )

  2021 christmas day echo$ cr
  2022 newyear's day echo$ cr
