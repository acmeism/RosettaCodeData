!ys-0

defn main(from=2020 to=2030):
  each y (from .. to):
    say: "$y Christmas: $dow(y 12 25), New Year: $dow(y 1 1)"

defn dow(y m d):
  names =: qw(Sunday Monday Tuesday Wednesday Thursday Friday Saturday)
  names: .nth(zeller(y m d))

defn zeller(y m d):
  yy =: (m < 3).if(y.-- y)
  mm =: (m < 3).if((m + 12) m)
  k =: yy % 100
  j =: yy // 100
  term =: ((13 * (mm + 1)) // 5) + k + (k // 4) + (j // 4) + (5 * j)
  h =: (d + term) % 7
  mod: (h + 6) 7
