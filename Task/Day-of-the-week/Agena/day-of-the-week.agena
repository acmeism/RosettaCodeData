# Day of the week
proc dayofweek(y, m, d) is
  # Sunday = 0, Saturday = 6
  if m < 3 then
    y -:= 1;
    m +:= 12
  fi;
  z := y + (y \ 4) - (y \ 100) + (y \ 400);
  return (z + d + (153 * m + 8) \ 5) symmod 7
end;

scope
  for y from 2007 to 2122 do
    if dayofweek(y, 12, 25) = 0 then
      printf("%d ", y)
    fi
  od
  print()
epocs
