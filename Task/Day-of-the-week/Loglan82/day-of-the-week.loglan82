(* Day of the week *)

block
var
  y: integer;

  unit day_of_week: function (y, m, d: integer): integer;
  begin
    (* Sunday = 0, Saturday = 6 *)
    if m < 3
    then
      y := y - 1;
      m := m + 12
    fi;
    result := (y + y div 4 - y div 100 + y div 400 + d + (153 * m + 8) div 5) mod 7;
  end day_of_week;

begin
  for y := 2007 to 2122
  do
    if day_of_week(y, 12, 25) = 0 then write(y: 5) fi
  od;
  writeln;
end;
