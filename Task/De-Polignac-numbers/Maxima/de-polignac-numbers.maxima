biggest_pow2(n) := floor(log(n)/log(2))$

is_depolignac(n) := block(
poss_primes: makelist(n-2^i, i, 0, biggest_pow2(n)),
primes: sublist(poss_primes, primep),
length(primes)=0)$

block(count: 0, n:1, while count<50 do(
    if(is_depolignac(n)) then block(
        sprint(n),
        count: count+1,
        if mod(count, 10)=0 then newline()
    ),
    n: n+2));
