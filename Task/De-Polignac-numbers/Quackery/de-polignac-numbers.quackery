  [ true swap
    1 from
      [ index over > iff
          end done
        dup index -
        isprime if
          [ dip not end ]
        index incr ]
    drop ]                is depolignac ( n --> b )

  [] 1 from
    [ index depolignac if
        [ index join ]
      dup size 50 = if
        end
      2 incr ]
  echo
