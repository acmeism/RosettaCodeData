link fastprime

procedure main(A)
   limit := \A[1] | 10
   every writes(" ",deceptive()\limit)
   write()
end

procedure deceptive()
   every n := seq(2) do {
      if not is_prime(n) then {
         r := repunit(10,n-1)
         if (r/n*n) = r then suspend n
         }
      }
end

procedure repunit(b,n)
   every (r := 0) +:= b^(0 to n-1)
   return r
end
