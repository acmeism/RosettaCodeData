F decToBin(d)
   V whole = Int(floor(d))
   V binary = bin(whole)‘.’
   V dd = d - whole
   L dd > 0.0
      V r = dd * 2.0
      I r >= 1.0
         binary ‘’= ‘1’
         dd = r - 1
      E
         binary ‘’= ‘0’
         dd = r
   R binary

F binToDec(s)
   V num = Int(s.replace(‘.’, ‘’), radix' 2)
   V den = Int(‘1’s.split(‘.’)[1].replace(‘1’, ‘0’), radix' 2)
   R Float(num) / den

V d = 23.34375
print(d"\t => "decToBin(d))
V s = ‘1011.11101’
print(s"\t => "binToDec(s))
