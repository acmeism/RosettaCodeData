local fmt = require "fmt"

local function schwartzian(a, f)
    fmt.lprint(a:mapped(|e| -> {e, f(e)})     -- decorate
                :sort(|p, q| -> p[2] < q[2])  -- sort
                :map(|p| -> $'"{p[1]}"')      -- undecorate
              )
end

local words = {"Rosetta", "Code", "is", "a", "programming", "chrestomathy", "site"}
local length = |s| -> #s
schwartzian(words, length)
