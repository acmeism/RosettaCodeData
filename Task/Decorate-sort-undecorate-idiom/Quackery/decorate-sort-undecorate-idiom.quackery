  [ ]'[ temp put
    [] swap witheach
      [ dup temp share do
        dip nested join
        nested join ]
    temp release ]            is decoratewith ( [ --> [ )

  [ [] swap witheach
     [ 0 peek nested join ] ] is undecorate   ( [ --> [ )

  $ "Rosetta Code is a programming chrestomathy site" nest$

  decoratewith size
  sortwith [ dip [ 1 peek ] 1 peek > ]
  undecorate
  witheach [ echo$ sp ]
