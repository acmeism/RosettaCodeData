data = ReadList["data.txt", Number];
percents = Map[100 * (First[#] - Last[#]) / First[#] &, Split[data, GreaterEqual]];
frequ = BinCounts[Select[percents, Positive], {{0, 4, 8, 12, 16, 25, Infinity}}];
Transpose[{{"(0%, 4%)", "[4%, 8%)", "[8%, 12%)", "[12%, 16%)", "[16%, 25%)", "[25%, inf)"}, frequ}] // Grid
