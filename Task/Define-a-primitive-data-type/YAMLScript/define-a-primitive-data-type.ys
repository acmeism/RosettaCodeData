!ys-0

defn main():
  x =: bounded-int(3)
  y =: bounded-int(4)
  z =: add(x y)
  say: "$x + $y = $z"
  each n [0 1 10 11]:
    say: "$n -> $(valid?(n).if('valid' 'invalid'))"

defn bounded-int(n):
  if n:valid?:
    then: n
    else: die("$n is outside 1..10")

defn valid?(n):
  1 <= n <= 10

defn add(a b):
  bounded-int(a + b)
