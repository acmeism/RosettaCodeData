!ys-0

defn main(file='/tmp/input.txt' dir='/tmp/docs'):
  # Set up the file and directory so the demo always has something
  # to delete. The Rosetta task asks for "input.txt" / "docs" both
  # in the cwd and at the filesystem root; root paths require
  # privileges, so use /tmp here.
  write file: 'sample contents'
  fs/mkdir-p: dir

  fs/rm: file
  fs/rm-r: dir

  say: "$file exists? $(fs/e(file))"
  say: "$dir exists? $(fs/e(dir))"
