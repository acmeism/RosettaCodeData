100 REM Department numbars
110 PRINT "POLICE SANITATION FIRE"
120 FOR P = 2 TO 7 STEP 2
130    FOR S = 1 TO 7
140       IF S <> P THEN
150          LET F = 12 - P - S
160          IF F <> S AND F <> P AND F >= 1 AND F <= 7 THEN
170             PRINT USING "   #       #       #": P, S, F
180          END IF
190       END IF
200    NEXT S
210 NEXT P
220 END
