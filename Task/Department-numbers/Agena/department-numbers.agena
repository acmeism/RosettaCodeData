# Department numbers
scope
  print('POLICE SANITATION FIRE');
  for p from 2 to 7 by 2 do
    for s to 7 do
      if s <> p then
        f := 12 - p - s
        if f <> s and f <> p and f >= 1 and f <= 7 then
          printf("   %1d       %1d       %1d\n", p, s, f)
        fi
      fi
    od
  od
epocs
