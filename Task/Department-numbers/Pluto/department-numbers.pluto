print("Police  Sanitation  Fire")
print("------  ----------  ----")
local count = 0
for h = 1, 3 do
    local i = h * 2
    for j = 1, 7 do
        if j != i then
            for k = 1, 7 do
                if k != i and k != j and i + j + k == 12 then
                    print($"  {i}         {j}         {k}")
                    ++count
                end
            end
        end
    end
end
print($"\n{count} valid combinations")
