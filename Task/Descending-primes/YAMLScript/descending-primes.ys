!ys-0

defn main():
  each n (2 .. 100000):
    when descending?(n) && prime?(n):
      say: n

defn descending?(n):
  s =: n:S
  every? _ partition(2 1 s):
    fn(pair): compare(pair.0 pair.1) > 0

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
