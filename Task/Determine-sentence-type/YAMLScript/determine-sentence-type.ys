!ys-0

TEXT =: |-
  hi there, how are you today? I'd like to present to you the washing
  machine 9001. You have been nominated to win one of these! Just make
  sure you don't break it

defn main(text=TEXT):
  each s sentences(text):
    say: sentence-type(s)

defn sentences(text):
  text.re-seq(/[^.!?]+[.!?]?/)
    .map(\(_:trim))
    .filter(\(_.# > 0))

defn sentence-type(s):
  last =: s.re-seq(/[.!?]/).$
  condp eq last:
    '!' : 'E'
    '?' : 'Q'
    '.' : 'S'
    else: 'N'
