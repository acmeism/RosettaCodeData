0010 FUNC sum5(n) CLOSED
0020   sum:=0
0030   WHILE n>0 DO sum:+(n MOD 10)^5;n:=n DIV 10
0040   RETURN sum
0050 ENDFUNC sum5
0060 //
0070 max:=9^5*6
0080 total:=0
0090 FOR i:=2 TO max DO
0100   IF i=sum5(i) THEN
0110     PRINT USING "######":i
0120     total:+i
0130   ENDIF
0140 ENDFOR i
0150 PRINT "------ +"
0160 PRINT USING "######":total
0170 END
