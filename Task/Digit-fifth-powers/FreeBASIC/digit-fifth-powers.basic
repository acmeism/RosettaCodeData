function dig5( n as uinteger ) as uinteger
    dim as string ns = str(n)
    dim as uinteger ret = 0
    for i as ubyte = 1 to len(ns)
        ret += val(mid(ns,i,1))^5
    next i
    return ret
end function

dim as uinteger i, sum = 0

for i = 2 to 999999
    if i = dig5(i) then
        print i
        sum += i
    end if
next i

print "Their sum is ", sum
