$ include "seed7_05.s7i";

const proc: main is func
  local
    var integer: i is 0;
    var integer: n is 0;
    var integer: sum is 0;
    var integer: digitsum is 0;
  begin
    for i range 2 to 9 ** 5 * 6 do
      n := i;
      while n > 0 do
        digitsum +:= (n mod 10) ** 5;
        n := n div 10;
      end while;
      if digitsum = i then
        sum +:= i;
      end if;
      digitsum := 0;
    end for;
    writeln(sum);
  end func;
