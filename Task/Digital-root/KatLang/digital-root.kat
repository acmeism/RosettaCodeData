AdditivePersistenceAndDigitalRoot(n, base) = {
    DigitSum = {
        Step = current div base, total + current mod base, current > 0
        Step.while(number div base, number mod base):1
    }
    Step = DigitSum(value), steps + 1, value >= base
    Step.while(n, 0)
}
(627615, 39390, 588225, 393900588225).map{
    Result = AdditivePersistenceAndDigitalRoot(x, 10)
    ('number' x 'persistence' Result:1 'root' Result:0)
}
