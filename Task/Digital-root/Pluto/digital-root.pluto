local int = require "int"
local fmt = require "fmt"

local a = {1, 14, 267, 8128, 627615, 39390, 588225, 393900588225}
for a as n do
    local res = int.digroot(n)
    local dr = res[1]
    local ap = res[2]
    fmt.print("%15s has additive persistence %d and digital root of %d", fmt.int(n), ap, dr)
end
