#!/usr/bin/env ys-0

defn main():
  tests =: +[627615 39390 588225 393900588225]
  each n tests:
    pr =: digital-root(n)
    say: "$n: additive persistence = $(pr.0), digital root = $(pr.1)"

defn digital-root(n):
  loop p 0, x n:
    if x < 10:
      vector: p x
      recur: p.++ digit-sum(x)

defn digit-sum(n):
  loop sum 0, x n:
    if x.?:
      recur: (sum + (x % 10)) quot(x 10)
      else: sum
