ClearAll[DFT, IDFT]
DFT[x_List] := Module[{length},
  length = Length[x];
  N@Table[Sum[x[[n + 1]] Exp[-I 2 Pi k n/length], {n, 0, length - 1}], {k, 0, length - 1}]
 ]
IDFT[X_List] := Module[{length},
  length = Length[X];
  N@Table[Sum[X[[k + 1]] Exp[-I 2 Pi k n/length], {k, 0, length - 1}]/length, {n, 0, length - 1}]
 ]
DFT[{2, 3, 5, 7, 11}]
IDFT[%] // Chop
