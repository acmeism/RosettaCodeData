!ys-0

defn main():
  each terms [[1 2 3] [0 1 -1] [-1 -2 0 3]]:
    say: display(terms)

defn display(terms):
  parts =:
    for [i c] terms.map-indexed(vector _):
      when c != 0:
        term(c i)
  if parts.!:
    then: '0'
    else: parts:joins

defn term(c i):
  variable =: "e($i)"
  cond:
    c == 1: "+ $variable"
    c == -1: "- $variable"
    c > 0: "+ $c*$variable"
    else: "- $abs(c)*$variable"
