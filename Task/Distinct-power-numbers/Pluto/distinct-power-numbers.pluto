local pows = {}
for a = 2, 5 do
    local pow = a
    for b = 2, 5 do
        pow *= a
        if !pows:contains(pow) do
            pows:insert(pow)
        end
    end
end
pows:sort()
print("Ordered distinct values of a ^ b for a in [2, 5] and b in [2, 5]:")
for i = 1, #pows do
    io.write(string.format("%5s ", string.formatint(pows[i])))
    if i % 5 == 0 do print() end
end
print($"\nFound {#pows} such numbers.")
