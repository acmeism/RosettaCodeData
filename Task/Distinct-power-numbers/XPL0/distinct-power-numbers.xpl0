int A, B, N, Last, Next;
[Last:= 0;
loop    [Next:= -1>>1;          \infinity
        for A:= 2 to 5 do       \find smallest Next
            for B:= 2 to 5 do   \ that's > Last
                [N:= fix(Pow(float(A), float(B)));
                if N>Last & N<Next then Next:= N;
                ];
        if Next = -1>>1 then quit;
        IntOut(0, Next);  ChOut(0, ^ );
        Last:= Next;
        ];
]
