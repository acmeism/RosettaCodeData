!ys-0

DAYS =: qw(Sunday Monday Tuesday Wednesday Thursday Friday Saturday)

defn main(year=2024):
  day =: nth(DAYS doomsday(year))
  say: "$year doomsday: $day"
  dates =: +['4/4' '6/6' '8/8' '10/10' '12/12']
  each date dates:
    say: "$date/$year"

defn doomsday(year):
  century =: year // 100
  y =: year % 100
  c =: century % 4
  anchor =: ((5 * c) + 2) % 7
  total =: anchor + y + (y // 4)
  mod: total 7
