Def Dot (
  Let A be first vector;
  Let B be second vector;

  Unless == Length A and Length B (
    Error "Vectors must have the same length."
  );

  Let I be Box of 0;
  For each number in A (
    + * Index Unbox I in B;
    Set I to + 1 of Unbox I
  ) with seed 0;
);

Print Dot product of List (1 3 -5) and List (4 -2 -1)
