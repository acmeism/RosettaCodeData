(* Dot product *)

block
  unit vector: class (x, y, z: real);
  end vector;

  unit dot_product: function (u, v: vector) : real;
  begin
    result := u.x * v.x + u.y * v.y + u.z * v.z
  end dot_product;

var
  dp: real;
begin
  dp := dot_product(new vector(1.0, 3.0, -5.0), new vector(4.0, -2.0, -1.0));
  writeln(dp)
end
