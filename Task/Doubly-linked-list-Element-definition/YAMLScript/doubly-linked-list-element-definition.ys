!ys-0

defn main():
  a =: element('a')
  b =: element('b')
  link: a b
  say: "$(a.@.0) next $(a.@.2.@.0)"
  say: "$(b.@.0) prev $(b.@.1.@.0)"

defn element(value):
  data =: +[value nil nil]
  atom: data

defn link(left right):
  reset left: left.@.assoc(2 right)
  reset right: right.@.assoc(1 left)
