with javascript_semantics
requires("1.0.6")
include theGUI.e

constant tl = {220,150}, tr = {380,150},
        ml = {140,230},    mr = {460,230},
                 pt = {300,450},
       poly = {ml,tl,tr,mr,pt,
               ml,mr,tr,pt,tl}

procedure redraw(gdx canvas)
    gDrawPolygon(canvas,poly,false,colour:=TG_BLUE)
end procedure

gdx canvas = gCanvas(redraw,"SIZE=600x600"),
    dialog = gDialog(canvas,`Diamond`)
gMainLoop(dialog)
