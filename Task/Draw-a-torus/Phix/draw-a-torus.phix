-- demo\rosetta\torus.exw
with javascript_semantics
requires("1.0.6")
include theGUI.e

procedure redraw(gdx canvas)
    integer R = 150,  -- outer radius
            r = 60   -- inner radius (tube radius)

    -- Rotation angles (in radians).
    atom A = 0.5,  -- tilt around X axis
         B = 0.5,  -- tilt around Z axis
      sinA = sin(A), cosA = cos(A),
      sinB = sin(B), cosB = cos(B)

    for jj=0 to 628 do         -- ring circumference (theta)
        atom j = jj / 100
        for ii=0 to 628 by 4 do  -- tube circumference (phi)
            atom i = ii / 100, sini = sin(i), cosi = cos(i),
                               sinj = sin(j), cosj = cos(j),
                 -- 3D coordinate calculation.
                 h = R + r*cosj,
                 x = h*(cosB*cosi + sinA*sinB*sini) - r*cosA*sinB*sinj,
                 y = h*(sinB*cosi - sinA*cosB*sini) + r*cosA*cosB*sinj,
                 z = h*cosA*sini + r*sinA*sinj,
                 -- Luminance calculation (dot product with light source).
                 -- Light source is coming from top-front.
                 tmp = cosj*cosi*sinB - sinA*cosj*sini*cosB - cosA*sinj*cosB,
                 lum = 8*(tmp - cosi*sinj*sinA)

            if lum > 0 then
                -- Set color based on brightness (0-255).
                atom bright = min(floor(lum*30),255),
                     col = rgba(bright/2,bright,255),
                     -- Perspective projection to 2D.
                     ooz = 1/(z+500),   -- depth feeling
                     xp = round(400 + x*ooz*600),
                     yp = round(300 - y*ooz*600)

                gCanvasPixel(canvas,xp,yp,col)
            end if
        end for
    end for
end procedure

gdx canvas = gCanvas(redraw,"SIZE=750x540,BGCLR=BLACK"),
    dialog = gDialog(canvas,`TITLE="Torus"`)
gMainLoop(dialog)
