void local fn BuildWindow
  CGRect r = fn CGRectMake( 0, 0, 640, 480 )
  window 1, @"Draw Pixel 2", r, NSWindowStyleMaskTitled + NSWindowStyleMaskClosable
  WindowSetBackgroundColor( 1, fn ColorBlack )

  CGFloat x = rnd(640), y = rnd(480)
  pen 1, fn ColorYellow, NSLineCapStyleSquare
  line x,y to x,y
end fn

void local fn DoDialog( ev as long, tag as long, wnd as long )
  select ( ev )
    case _windowWillClose : end
  end select
end fn

on dialog fn DoDialog

fn BuildWindow

HandleEvents
