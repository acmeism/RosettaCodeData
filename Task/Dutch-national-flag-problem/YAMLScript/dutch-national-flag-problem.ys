!ys-0

# Sort balls into Dutch flag order: red, white, blue.

flag =:: [red, white, blue]
rank =:: {red: 0, white: 1, blue: 2}

defn main():
  balls =: random-balls(9)
  say: "before:  $(balls:joins)"
  sorted =: balls.sort-by(rank)
  say: "after:   $(sorted:joins)"
  say: "in order? $(in-order?(sorted))"

defn- random-balls(n):
  loop bs []:
    if (bs.# < n) || in-order?(bs):
      recur: bs.conj(rand-nth(flag))
      else: bs

defn- in-order?(bs):
  apply le: bs.map(rank)
