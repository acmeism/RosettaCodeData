!ys-0

# The variable name is read at runtime, so the binding can't be a real
# lexical var. A runtime map is the dynamic environment: the user's name
# becomes a key whose value we set and read back. read-line() supplies
# the name; the CLI default is only the EOF fallback.
defn main(name='foo'):
  print: "Enter a variable name: "
  name =: read-line() || name
  env =: +{name 42}
  say: "$name = $(env.$name)"
