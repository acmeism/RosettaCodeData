eban?: function [n][
    [b r]: n /% 1000000000
    [m r]: r /% 1000000
    [t r]: r /% 1000
    [m t r]: map @[m t r] 'x -> ? x <=> 30 66 -> x % 10 -> x
    subset? @[b m t r] [0 2 4 6]
]

show: $[rn][
    print ["eban numbers from" rn]
    print select rn => eban?
]

count: $[rn][
    print ["eban count from" rn "=>" enumerate rn => eban?]
]

show 1..1000
show 1000..4000
count 1..10000
count 1..100000
count 1..1000000
count 1..10000000
