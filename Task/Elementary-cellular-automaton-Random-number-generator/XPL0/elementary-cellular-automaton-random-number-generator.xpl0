define     N = 8 * 8;

proc Evolve(State, Rule);
int  State, Rule;
int  I, P, Q, B, St;
[for P:= 0 to 10-1 do
    [B:= 0;  Q:= 8;
    while Q do
        [Q:= Q-1;       \C: for (b=0, q=8; q--;), so Q is 7..0
        St:= State;
        B:= B or (St&1) << Q;
        State:= 0;
        for I:= 0 to N-1 do
            if Rule & 1 << (7 & (St>>(I-1) or St<<(N+1-I))) then
                State:= State or 1<<I;
        ];
    ChOut(0, ^ );  IntOut(0, B);
    ];
CrLf(0);
];

Evolve(1, 30);
