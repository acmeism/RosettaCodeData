!ys-0

defn main():
  color =: :red
  say: "color = $color"
  say: "is red? $(color == :red)"

  day =: +{:mon 0, :tue 1, :wed 2, :thu 3, :fri 4, :sat 5, :sun 6}
  say: "wed = $(day.wed)"

  fruits =: +[:apple :banana :cherry]
  ids =: 0 .. (fruits.# - 1)
  rank =: zipmap(fruits ids)
  say: "rank = $rank"
  say: "banana rank = $(rank.banana)"
