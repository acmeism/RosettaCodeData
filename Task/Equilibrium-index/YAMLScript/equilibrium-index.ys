!ys-0

defn main():
  seq =:: [-7, 1, 5, 2, -4, 3, 0]
  indices =: equilibrium-indices(seq)
  say: "Equilibrium indices: $joins(indices)"

defn equilibrium-indices(seq):
  total =: sum(seq)
  init =: +[]
  loop i 0, left 0, result init:
    if i >= seq.#:
      then: result
      else:
        val =: seq.$i
        right =: total - left - val
        new-result =: (left == right).if(result.conj(i) result)
        recur: i.++ (left + val) new-result
