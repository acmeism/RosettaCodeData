ClearAll[ErdosPrimeQ]
ErdosPrimeQ[p_Integer] := Module[{k},
  If[PrimeQ[p],
   k = 1;
   While[k! < p,
    If[PrimeQ[p - k!], Return[False]];
    k++;
    ];
   True
   ,
   False
   ]
  ]
sel = Select[Range[2500], ErdosPrimeQ]
Length[sel]
sel = Select[Range[999999], ErdosPrimeQ];
{Length[sel], Last[sel]}
