Def Halve as (Floor of / by 2);
Def Double as (+ Twin);
Def Odd? as (== 1 Modulo 2);

Def EthiopianMultiply as (
  Let X be Box with multiplicand;
  Let Y be Box with multiplier;
  Let Result be Box with 0;
  While (Not Zero? Unbox X) (
    When Odd? Unbox X then (
      Set Result to + Unbox Y and Unbox Result;
    );
    Set X to Halve Unbox X;
    Set Y to Double Unbox Y;
  );
  return Unbox Result
);

Print EthiopianMultiply 17 by 34
