  [ dup temp put
    [] swap 1+ times
      [ i^ 1 - join ]
    [] unrot
    witheach
      [ over *
        temp share mod
        rot join swap ]
    drop
    temp release
    [] swap
    behead swap
    witheach
      [ tuck <
        rot join swap ]
    drop ]              is rhythm ( n n --> [ )

