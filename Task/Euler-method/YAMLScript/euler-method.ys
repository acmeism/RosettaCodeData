!ys-0

defn main(*):
  exact =: analytical(100.0)
  steps =:: [2.0, 5.0, 10.0]
  each h steps:
    approx =: euler(cooling 0.0 100.0 100.0 h)
    say: "h=$(h:I): $(format '%.4f' approx) (exact: $(format '%.4f' exact))"

defn analytical(t):
  20.0 + (80.0 * Math/exp(-0.07 * t))

defn euler(f t0 y0 t-end h):
  loop t t0, y y0:
    if t >= t-end:
      then: y
      else:
        t2 =: t + h
        y2 =: y + (h * f(t y))
        recur: t2 y2

defn cooling(t T):
  -0.07 * (T - 20.0)
