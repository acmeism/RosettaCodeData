// accurate to 13 decimal places

Epsilon = 10^-6
N = 13
Nsq = N^2
Step = {
    NextK = k + 1
    NextB = Nsq * bValue~ / k^2
    NextA = (Nsq * aValue / k + NextB) / k
    NextU = uValue + NextA
    NextV = vValue + NextB

    NextK, NextA, NextB, NextU, NextV, Math.Abs(NextA) > Epsilon
}

Result = Step.while(1, -Math.Ln(N), 1, -Math.Ln(N), 1)

Result:3/Result:4
