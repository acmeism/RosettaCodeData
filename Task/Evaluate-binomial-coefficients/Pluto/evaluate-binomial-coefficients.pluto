local int = require "int"
local fmt = require "fmt"

local limit <const> = 14
io.write("n/k |")
for k = 0, limit do fmt.write("%5d", k) end
print()
print("----+" .. string.rep("-----", limit + 1))
for n = 0, limit do
    fmt.write("%3d |", n)
    for k = 0, n do fmt.write("%5d", int.binomial(n, k)) end
    print()
end
