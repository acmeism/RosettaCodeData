define at(n,x) {
    return n/(10^x)%10
}

define three_adj(num) {
    auto i,n
    while(i < length(num) \
        && (at(num,i)==3 || n==0 || n==3) \
        && n<=3) {
        if(at(num,i)==3) n+=1
        i += 1
    }
    return n == 3
}

l[0]=933321785
l[1]=529337841
l[2]=143673832
l[3]=123456789
l[4]=468723331

for(i=0;i<5;i++) {
    three_adj(l[i])
}
