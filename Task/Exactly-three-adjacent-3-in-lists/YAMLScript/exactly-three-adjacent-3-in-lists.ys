!ys-0

defn main():
  each xs lists():
    say: exactly-three-adjacent-3?(xs)

defn exactly-three-adjacent-3?(xs):
  s =: xs.map(S):join
  s.re-seq(/3/).# == 3 &&:
    s.index('333'):nil?.!

defn lists(): +
  [[9 3 3 3 2 1 7 8 5]
   [5 2 9 3 3 7 8 4 1]
   [1 4 3 6 7 3 8 3 2]
   [1 2 3 4 5 6 7 8 9]
   [4 6 8 7 2 3 3 3 1]]
