local U0 = "U0"
local U1 = "U1"

local baz_called = 0

local function baz()
    baz_called += 1
    error((baz_called == 1) ? U0 : U1, 0)
end

local function bar()
    baz()
end

local function foo()
    for i = 1, 2 do
        local ok, err = pcall(bar)
        if !ok then
            if err == U0 then
                print("Caught error U0")
            else
                error($"Uncaught error {err} rethrown", 0)
            end
        end
    end
end

foo()
