throw "not a math exception"

# example using a catch switch
catch _err'cat, _err'msg {
    case "math", _:
        # exception category "math"
        ...
    case _, -> re/^not/:
        # exception message starts with "not"
        ...
    case[and] "general", "hey":
        # category "general" and message "hey"
        ...
        # no default; therefore exception will propagate if no conditions matched
    }
} else {
    # no exception
    ...
}
