#!/usr/bin/env ys-0

defn main():
  try:
    do:
      n =: 1 / 0
      say: "no exception - $n"
    catch Exception e:
      say: "caught - $(ex-message(e))"

  try:
    risky: -1
    catch Exception e:
      say: "caught custom - $(ex-message(e))"

  say: 'done'

defn risky(n):
  if n < 0:
    throw: Exception.new("negative input - $n")
    say: "ok - $n"
