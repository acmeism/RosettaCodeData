!ys-0

defn main(s='I bought a B of As from T S.'):
  rules =::
  - [A, apple, false]
  - [B, bag, false]
  - [S, shop, false]
  - [T, the, false]
  - ['the shop', 'my brother', true]
  say: markov(s rules)

defn markov(s rules):
  loop s s:
    hit =: first(rules.filter(\(s =~ qr(_.0))))
    if hit.!:
      then: s
      else:
        next =: s.replace1(hit.0 hit.1)
        if-not hit.2:
          recur: next
          else: next
