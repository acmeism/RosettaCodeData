with javascript_semantics

enum DATE, X, V, M // date, X=position (m), V=velocity (m/s), M=mass (kg)

// ================================
// 1. NASA 2024 Reference Data
// ================================
constant reference_2024 = {"31/12/2024", 4.64e10, 5.81e4, 3.30e23}

atom p_ref = reference_2024[M] * reference_2024[V],
     nktg1_constant = reference_2024[X] * p_ref

printf(1,"NKTg1 reference constant: %0.3fe38\n", nktg1_constant / 1e38)
printf(1,"======================================\n")

// ================================
// 2. NASA 2025 Real Data
// ================================
constant nasa_2025 = {{"01/01/2025", 5.16e10, 5.34e4, 3.30e23},
                      {"01/04/2025", 6.97e10, 3.89e4, 3.30e23},
                      {"01/07/2025", 5.49e10, 5.04e4, 3.30e23},
                      {"01/10/2025", 6.83e10, 3.98e4, 3.30e23},
                      {"31/12/2025", 4.61e10, 5.89e4, 3.30e23}}

// Mass variation rate (MESSENGER data)
atom dm_dt = -0.5 // kg/s

printf(1,"Date             v_NKTg       v_NASA    Rel.Error(%%)      NKTg2\n")
printf(1,"-----------------------------------------------------------------------\n")

for data in nasa_2025 do

    // Interpolated velocity from constant NKTg1
    atom v_nktg = nktg1_constant / (data[X] * data[M])

    // Relative error
    atom rel_error = ((v_nktg - data[V]) / data[V]) * 100.0

    // Momentum
    atom p = data[M] * v_nktg

    // NKTg2 calculation
    atom nktg2 = dm_dt * p

    printf(1,"%-12s %9.3fe04 %9.3fe04 %10.4f %12.3fe27\n",
               {data[DATE],
                v_nktg / 1e4,
                data[V] / 1e4,
                rel_error,
                nktg2 / 1e27})
end for

printf(1,"\n========================================\n")
printf(1,"Interpretation:\n")
printf(1,"NKTg1 maintained as constant.\n")
printf(1,"NKTg2 negative ==> mass variation resists motion.\n")
