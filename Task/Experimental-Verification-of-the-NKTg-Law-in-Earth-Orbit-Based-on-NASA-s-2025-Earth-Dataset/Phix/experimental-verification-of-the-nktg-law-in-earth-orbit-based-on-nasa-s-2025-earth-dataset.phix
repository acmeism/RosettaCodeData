with javascript_semantics

constant DM_DT = -1.8  -- kg/s

function momentum(atom m, v) return m * v end function
function nktg1(atom x, p) return x * p end function
function nktg2(atom p) return DM_DT * p end function
function relative_error(atom sim, nasa) return (sim-nasa)/nasa*100 end function

-- Simulated NKTg 2025 dataset.
enum DATE,X,V,M
constant sim_2025 = {{"01/01/2025", 1.471012e11, 3.0276e4, 5.97219e24},
                     {"04/01/2025", 1.494953e11, 2.9791e4, 5.97218999999998e24},
                     {"07/01/2025", 1.520965e11, 2.9282e4, 5.97218999999997e24},
                     {"10/01/2025", 1.496328e11, 2.9764e4, 5.97218999999995e24},
                     {"12/31/2025", 1.471025e11, 3.0276e4, 5.97218999999994e24}}

-- NASA observed velocities.
enum OBSERVED = 2
constant nasa_2025 = {{"01/01/2025", 3.0287e4},
                      {"04/01/2025", 2.9791e4},
                      {"07/01/2025", 2.9291e4},
                      {"10/01/2025", 2.9778e4},
                      {"12/31/2025", 3.0286e4}}

printf(1,"Experimental Verification of NKTg Law (Earth 2025)\n\n")

constant f = "%-12s %14s %14s %14s %12s %12s %10s\n",
       fmt = "%-12s %14.3e %14.3e %14.3e %12.3e %12.3e %10.4f%%\n"
printf(1,f,{"Date", "Momentum(p)", "NKTg1", "NKTg2", "v_sim", "v_NASA", "Error"})
printf(1,"%s\n",repeat('-',95))

for i, data in sim_2025 do
    atom p = momentum(data[M], data[V]),
        n1 = nktg1(data[X], p),
        n2 = nktg2(p),
     v_sim = data[V],
    v_nasa = nasa_2025[i][OBSERVED],
       err = relative_error(v_sim, v_nasa)
    printf(1,fmt,{data[DATE], p, n1, n2, v_sim, v_nasa, err})
end for
