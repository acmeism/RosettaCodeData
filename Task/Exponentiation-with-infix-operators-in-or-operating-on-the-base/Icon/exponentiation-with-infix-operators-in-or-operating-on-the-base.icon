procedure main()
   every (b := -5|5, e := 2|3) do {
      writes(left(" -"||b||"^"||e,8)," -> ",right(-b^e,4),"     ")
      writes(left(" -("||b||")^"||e,8)," -> ",right(-(b)^e,4),"     ")
      writes(left(" (-"||b||")^"||e,8)," -> ",right((-b)^e,4),"     ")
      write(left(" -("||b||"^"||e,8),") -> ",right(-(b^e),4))
      }
end
