syntax: ["-x^p", "-(x)^p", "(-x)^p", "-(x^p)"]$

exp_test(x, p) := block(
    sprint("| x =", x, ",", "p =", p, ":"),
    newline(),
    for i from 1 thru 4 do(
        sprint("|", syntax[i], "=", eval_string(syntax[i]))
    ),
    newline()
)$

x: [5, -5, 5, -5]$
p: [2, 2, 3, 3]$
for i from 1 thru 4 do(exp_test(x[i], p[i]))$
