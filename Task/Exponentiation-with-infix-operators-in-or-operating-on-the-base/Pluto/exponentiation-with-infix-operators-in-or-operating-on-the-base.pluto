local fmt = require "fmt"

local expr = {"-x**p", "-(x)**p", "(-x)**p", "-(x**p)"}
for {-5, 5} as x  do
    for {2, 3} as p do
        fmt.write("x = %2d p = %d | ", x, p)
        fmt.write("%s = %4d | ", expr[1], -x ** p)
        fmt.write("%s = %4d | ", expr[2], -(x) ** p)
        fmt.write("%s = %4d | ", expr[3], (-x) ** p)
        fmt.print("%s = %4d", expr[4], -(x ** p))
    end
end
