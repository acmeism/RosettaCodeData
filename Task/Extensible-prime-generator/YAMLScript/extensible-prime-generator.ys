!ys-0

defn main(limit=50):
  say: primes-up-to(limit):joins
  say: "next after $limit: $next-prime(limit.++)"

defn primes-up-to(limit):
  filter prime?: 2 .. limit

defn next-prime(n):
  if n:prime?:
    n
    recur(n.++)

defn prime?(n):
  if n < 2:
    then: false
    else:
      if n < 4:
        then: true
        else:
          not-any? _ (2 .. I(sqrt(n))):
            fn(d): (n % d):zero?
