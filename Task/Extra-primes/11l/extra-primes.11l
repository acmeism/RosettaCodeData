V limit = 10'000

V is_prime = [0B] * 2 [+] [1B] * (limit - 1)
L(n) 0 .< Int(limit ^ 0.5 + 1.5)
   I is_prime[n]
      L(i) (n * n .< limit + 1).step(n)
         is_prime[i] = 0B

F is_extra_prime(n)
   I !:is_prime[n]
      R 0B
   V s = 0
   L(digit_char) String(n)
      V digit = Int(digit_char)
      I !:is_prime[digit]
         R 0B
      s += digit
   R Bool(:is_prime[s])

V i = 0
L(n) 0 .< limit
   I is_extra_prime(n)
      i++
      print(‘#4’.format(n), end' I i % 9 == 0 {"\n"} E ‘ ’)
