  [ [] swap
    [ 10 /mod
      rot join swap
      dup 0 = until ]
    drop ]              is digits ( n --> [ )

  [ 0 swap witheach + ] is sum    ( [ --> n )

  10000 eratosthenes
  []
  10000 times
    [ i^ isprime not if done
      true i^ digits
      tuck witheach
        [ isprime and
          dup not if conclude ]
      not iff drop done
      sum isprime
      if [ i^ join ] ]
  echo
