!ys-0

defn main(limit=200):
  each n (2 .. limit):
    ones =: n % 10
    when ones != 0:
      r =: n:S:reverse:I
      when n != r:
        when prime?(n):
          when prime?(r):
            say: n

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
