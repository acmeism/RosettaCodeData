F extract_ext(path)
   V m = re:‘\.[A-Za-z0-9]+$’.search(path)
   R I m {m.group(0)} E ‘’

V paths = [‘http://example.com/download.tar.gz’,
           ‘CharacterModel.3DS’,
           ‘.desktop’,
           ‘document’,
           ‘document.txt_backup’,
           ‘/etc/pam.d/login’]

L(path) paths
   print(path.rjust(max(paths.map(p -> p.len)))‘ -> ’extract_ext(path))
