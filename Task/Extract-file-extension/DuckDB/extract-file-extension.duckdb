create or replace function file_extension(s) as (
  coalesce(regexp_extract(s, '[.][a-zA-Z0-9]*$' ), '')
);

select s, file_extension(s) from unnest([
  'http://example.com/download.tar.gz',
  'CharacterModel.3DS',
  '.desktop',
  'document',
  'document.txt_backup',
  '/etc/pam.d/login'
  ]) _(s);

