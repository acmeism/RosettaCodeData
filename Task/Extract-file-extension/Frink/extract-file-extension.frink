fileExtension[str] :=
{
   if [ext] = str =~ %r/(\.[A-Za-z0-9]+)$/
      return ext
   else
      return ""
}

files = ["http://example.com/download.tar.gz",
         "CharacterModel.3DS",
         ".desktop",
         "document",
         "document.txt_backup",
         "/etc/pam.d/login"]

r = new array
for f = files
   r.push[[f, "->", fileExtension[f]]]

println[formatTable[r, "right"]]
