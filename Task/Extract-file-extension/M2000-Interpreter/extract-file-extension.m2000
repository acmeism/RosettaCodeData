module Extract_file_extension {
	a=("http://example.com/download.tar.gz",  "CharacterModel.3DS",  ".desktop", "document", "document.txt_backup", "/etc/pam.d/login")
	m=each(a)
	while m
		t$=file.type$(array$(m))
		if len(filter$(lcase$(t$), "abcdefghijklmnopqrstuvwxyz1234567890"))=0 Else t$=""
		if len(t$)>0 then t$="."+t$
		print array$(m), @(40), t$
	end while
}
Extract_file_extension
