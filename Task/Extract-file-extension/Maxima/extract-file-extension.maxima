get_file_ext(path) := block(
    ext: regex_match("\\.[A-Za-z0-9]+$", path),
    if(is(ext=false)) then "" else ext)$

test_paths: ["http://example.com/download.tar.gz",
                "CharacterModel.3DS",
                ".desktop",
                "document",
                "document.txt_backup",
                "/etc/pam.d/login"]$

map(get_file_ext, test_paths);
