!ys-0

defn main():
  inf =: \\Inf
  neg-inf =: \\-Inf
  nan =: \\NaN
  neg-zero =: -0.0
  say: "positive infinity: $inf"
  say: "negative infinity: $neg-inf"
  say: "not a number: $nan"
  say: "negative zero: $neg-zero"
  say: "1 + infinity: $(1.0 + inf)"
  say: "infinity + negative infinity: $(inf + neg-inf)"
