extreme_sum(p) := apply("+", primes(2, next_prime(p)))$

is_extreme(p) := primep(extreme_sum(p))$

block(count: 0, p: 0, while count<30 do(
        if is_extreme(p) then block(
            sprint(extreme_sum(p)),
            count: count+1,
            if mod(count, 10)=0 then newline()
        ),
        p: next_prime(p)
    )
)$
