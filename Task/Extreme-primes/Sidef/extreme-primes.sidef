var(c,p,n) = (0,0,0)

while (c < 50_000) {
    p.next_prime!
    n += p
    if (n.is_prime) {
        ++c
        if (c <= 30) {
            say "Sum of prime series up to #{p}: prime #{n}"
        }
        elsif (c ~~ [1000, 2000, 3000, 4000, 5000, 30_000, 40_000, 50_000]) {
            say ("Sum of #{c.commify} in prime series up to #{p}: prime #{n}")
        }
    }
}
