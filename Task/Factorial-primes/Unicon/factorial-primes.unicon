link fastprime

procedure main(A)
   limit := \A[1] | 10
   every f := gfactorial(n := seq()) do {
      if (x := (is_prime(y := f-1),n||"!-1")) then
         (write(" (",x,",",y,")"), if 0 = (limit -:= 1) then break)
      if (x := (is_prime(y := f+1),n||"!+1")) then
         (write(" (",x,",",y,")"), if 0 = (limit -:= 1) then break)
      }
end
