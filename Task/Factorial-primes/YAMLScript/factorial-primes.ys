!ys-0

defn main(limit=10):
  each n (1 .. limit):
    f =: factorial(n)
    candidates =: +[f.-- f.++]
    each x candidates:
      when prime?(x):
        sign =:
          if x < f:
            then: '-'
            else: '+'
        say: "$n! $sign 1 = $x"

defn factorial(n):
  reduce _ 1 (1 .. n):
    fn(acc x): acc * x

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
