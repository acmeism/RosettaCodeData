import ballerina/io;

function fac(int a) returns int {
    int prod = 1;
    foreach int i in 1...a {
        prod *= i;
    }
    return prod;
}

public function main() {
    foreach int i in 1...10 {
        io:print(i);
        io:print("! = ");
        io:print(fac(i));
        io:println();
    }
}
