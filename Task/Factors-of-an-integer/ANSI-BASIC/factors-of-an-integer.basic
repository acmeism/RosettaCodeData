100 REM Factors of an integer
110 DECLARE EXTERNAL SUB PrintFactors
120 CALL PrintFactors(11)
130 CALL PrintFactors(21)
140 CALL PrintFactors(32)
150 CALL PrintFactors(45)
160 CALL PrintFactors(67)
170 CALL PrintFactors(96)
180 END
190 !
200 EXTERNAL SUB PrintFactors(N)
210 PRINT N; "=>";
220 LET N = ABS(N)
230 FOR I = 1 TO INT(N / 2)
240    IF MOD(N, I) = 0 THEN PRINT I;
250 NEXT I
260 PRINT N
270 END SUB
