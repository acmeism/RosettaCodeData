open Math

Factors(1) = 1
Factors(2) = (1, 2)
Factors(3) = (1, 3)
Factors(4) = (1, 2, 4)
Factors(n) = {
    Left((A, B)) = A
    Right((A, B)) = B
    Div = if(n mod d == 0, ((Left(init)...d), (n/d, Right(init)...)), init)
    Isqrt = Floor(Sqrt(n))
    Temp = reduce(range(2, Isqrt-1), Div, ((1),(n)))
    (Left(Temp)... if(n mod Isqrt == 0, Isqrt, ())... Right(Temp)...)
}
