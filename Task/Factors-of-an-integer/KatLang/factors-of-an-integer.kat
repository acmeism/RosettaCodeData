Factors(1) = 1
Factors(2) = (1, 2)
Factors(3) = (1, 3)
Factors(n) = {
    Left((A,B)) = A.content
    Right((A,B)) = B.content
    Div = if(n mod d == 0, ((Left(init)...d),(n/d...Right(init)...)), init)
    Temp = reduce(range(2,Math.Floor(Math.Sqrt(n)))..., Div, ((1),(n)))
    Temp:0...if((Temp:0).last == (Temp:1).first,(Temp:1).skip(1),Temp:1)
}

Factors(100)
Factors(108)
Factors(999)
Factors(255)
Factors(256)
Factors(257)
