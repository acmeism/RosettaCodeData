(* Factors of an integer *)

block

  unit write_factors: procedure (n: integer);
  var
    i: integer;
  begin
    write(n, " => ");
    n := abs(n);
    for i := 1 to n div 2
    do
      if n mod i = 0 then write(i: 1, " ") fi
    od;
    writeln(n: 1);
  end;

begin
  call write_factors(11);
  call write_factors(21);
  call write_factors(32);
  call write_factors(45);
  call write_factors(67);
  call write_factors(96);
end;
