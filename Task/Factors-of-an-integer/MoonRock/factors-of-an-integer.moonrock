' Factors of an integer
BEGIN DEF
SUB PrintFactors(N%)

BEGIN CODE
CALL PrintFactors(11)
CALL PrintFactors(21)
CALL PrintFactors(32)
CALL PrintFactors(45)
CALL PrintFactors(67)
CALL PrintFactors(96)
END

SUB PrintFactors(N%)
PRINT N% + " => "
NA% = ABS(N%)
NDiv2% = NA% \ 2
FOR I% = 1 TO NDiv2%
  NModI% = NA% MOD I%
  IF NModI% = 0 THEN
    PRINT I% + " "
  ENDIF
NEXT
PRINT NA% + "\n"
END SUB
