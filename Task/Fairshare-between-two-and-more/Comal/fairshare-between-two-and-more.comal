0010 FUNC fair'share#(n#,base#) CLOSED
0020   sum#:=0
0030   WHILE n#>0 DO sum#:+n# MOD base#;n#:=n# DIV base#
0040   RETURN sum# MOD base#
0050 ENDFUNC fair'share#
0060 //
0070 REPEAT
0080   READ base#
0090   ZONE 4
0100   PRINT STR$(base#)+":",
0110   ZONE 3
0120   FOR n#:=0 TO 24 DO PRINT fair'share#(n#,base#),
0130   PRINT
0140 UNTIL EOD
0150 END
0160 DATA 2,3,5,11
