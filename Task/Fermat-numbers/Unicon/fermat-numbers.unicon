link fastprime

procedure main(A)
   limit := \A[1] | 10
   limit2 := \A[2] | 6
   write("First ",limit," Fermat numbers:")
   cnt := 0
   every f := fermat()\limit do {
       if cnt > limit2 then write(right(cnt,3)," ",f)
       else {
          if (g := f/(x := getfactor(f))) = 1 then s := " is prime"
          else s := " factors: ["||x||" x "||(f/x)||"]"
          write(right(cnt,3)," ",f,s)
          }
       cnt +:= 1
       }
end

procedure fermat()
   suspend 2^2^seq(0)+1
end
