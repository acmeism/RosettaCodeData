is_pseudoprime(x, a) := integerp((a^(x-1)-1)/x) and not primep(x)$

for i from 1 thru 20 do(
    pseudoprimes: sublist(makelist(j, j, 1, 12000), lambda([x], is_pseudoprime(x, i))),
    sprint("Number of Fermat pseudoprimes up to 12000 for base", i, ":", length(pseudoprimes)),
    newline(),
    sprint("First 20 Fermat pseudoprimes for base", i, ":", firstn(pseudoprimes, 20)),
    newline()
)$
