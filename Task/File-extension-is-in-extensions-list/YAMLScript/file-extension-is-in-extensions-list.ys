!ys-0

defn main():
  exts =:: [zip, rar, 7z, gz, archive, A##, tar.bz2]
  files =::
    - MyData.a##
    - MyData.tar.Gz
    - MyData.gzip
    - MyData.7z.backup
    - MyData...
    - MyData
    - MyData_v1.0.tar.bz2
    - MyData_v1.0.bz2
  each file files:
    say: "$file: $(has-extension?(file exts))"

defn has-extension?(file exts):
  lower =: file:lc
  found =:
    some _ exts:
      fn(ext):
        lower.ends?('.' + ext:lc)
  B: found
