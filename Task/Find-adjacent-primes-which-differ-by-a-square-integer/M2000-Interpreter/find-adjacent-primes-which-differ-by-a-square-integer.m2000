module Find_adjacent_primes (N) {
	prev=5
	for i=6 to N
		If i Mod 2 = 0 Or i mod 3 =0 Then continue for
		d= 5&
	50	If i Mod d = 0 Then continue for
		d += 2:	If i Mod d = 0 Then continue for
		d += 4:	if d^2>i else 50	
		if i-prev<37 then prev=i:continue for
		d=i-prev
		if int(sqrt(d))^2=d then Print i+" "+prev+" diff = "+d
		prev=i
	next i
	print
}
Find_adjacent_primes 1000000
