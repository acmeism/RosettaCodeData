with javascript_semantics
constant limit = 1_000_000
sequence primes = get_primes_le(limit),
         square = repeat(false,floor(sqrt(limit)))
integer sq = 7
while sq*sq<=length(square) do
    square[sq*sq] = true
    sq += 1
end while
for i=2 to length(primes) do
    integer p = primes[i],
            q = primes[i-1],
            d = p-q
    if square[d] then
        printf(1,"%,7d - %,7d = %d\n",{p,q,d})
    end if
end for
