local int = require "int"
local fmt = require "fmt"

local limit = 1e6 - 1
local primes = int.primes(limit)
print("Adjacent primes under 1,000,000 whose difference is a square > 36:")
for i = 2, #primes do
    local diff = primes[i] - primes[i - 1]
    if diff > 36 then
        local s = math.floor(math.sqrt(diff))
        if diff == s * s then
            fmt.print ("%,7s - %,7s = %3d = %2d x %2d", primes[i], primes[i - 1], diff, s, s)
        end
    end
end
