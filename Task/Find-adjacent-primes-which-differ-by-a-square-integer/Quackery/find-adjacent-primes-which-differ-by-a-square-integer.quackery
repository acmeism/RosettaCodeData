  1000000 eratosthenes

  0 0
  1000000 times
    [ i^ isprime if
        [ nip i^ 2dup swap -
          dup 36 > iff
            [ dup sqrt dup * = if
                [ 2dup swap
                  2dup - unrot
                  echo say " - "
                  echo say " = "
                  echo cr ] ]
          else drop ] ]
  2drop
