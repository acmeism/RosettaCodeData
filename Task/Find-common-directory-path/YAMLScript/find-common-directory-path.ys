!ys-0

dflt =::
- /home/user1/tmp/coverage/test
- /home/user1/tmp/covert/operator
- /home/user1/tmp/coven/members

defn main(*paths):
  paths =: paths:empty?.if(dflt paths)
  sep =: '/'
  say: common-dir(paths sep)

defn- common-dir(paths sep):
  parts =: paths.map(\(_.split(sep)))
  common =: parts.reduce(\(common-prefix(%1 %2)))
  join common: sep

defn- common-prefix(a b):
  a.take-while(\(has?(b _)))
