Function MSB(i As Integer) As Integer
    Return Len(Bin(i))-1
End Function

Function LSB(i As Integer) As Integer
    Return MSB(i And -i)
End Function

Dim As Integer p = 1
For j As Integer = 0 To 11
    Print Using "################## & MSB: ## LSB: ##"; p; Bin(p,64); MSB(p); LSB(p)
    p *= 42
Next j
Sleep
