 [ dup 0 = iff
     [ 1 - ] done
   0 swap
   [ dup 1 & not while
     dip 1+
     1 >>
     again ]
   drop ]              is lsb ( n --> n )

 [ -1 swap
   [ dup 1 < not while
     dip 1+
     1 >>
     again ]
   drop ]              is msb ( n --> n )

  6 times
    [ 42 i^ ** dup echo
      say "  msb:"
      dup msb echo
      say "  lsb:"
      lsb echo cr ]
  cr
  6 times
    [ 1302 i^ ** dup echo
      say "  msb:"
      dup msb echo
      say "  lsb:"
      lsb echo cr ]
