        org     100h
        jmp     tests

        ; Find first missing positive in array in DE, result in L
fmp:    xra     a
        lxi     h,buf
finit:  mov     m,a             ; Set flags to zero
        inr     l
        jnz     finit
        ldax    d
        inx     d
        mov     b,a
fset:   ldax    d               ; Set flag for each positive item in array
        inx     d
        ana     a
        jm      fskip
        mov     l,a
        inr     m
fskip:  dcr     b
        jnz     fset
        mvi     l,1
fscan:  mov     a,m             ; Find first unset flag
        ana     a
        rz
        inr     l
        jp      fscan
        ret

        ; Run tests
tests:  lxi     h,arrs
test:   mov     e,m             ; Load test array pointer
        inx     h
        mov     d,m
        inx     h
        mov     a,d
        ora     e
        rz                      ; Stop if zero
        push    h
        call    fmp             ; Find first missing positive
        mvi     a,'0'
        add     l
        mov     e,a
        mvi     c,2
        call    5               ; Output result as single digit
        pop     h
        jmp     test

        ; Input arrays
arrs:   dw      arr1, arr2, arr3, 0
arr1:   db      3,   1, 2, 0
arr2:   db      4,   3, 4, -1, 1
arr3:   db      5,   7, 8, 9, 11, 12

buf     equ     ($/256+1)*256
