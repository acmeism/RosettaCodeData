amount = 988
sumCoins = 0
dim coins = {1, 2, 5, 10, 20, 50, 100, 200}

print "Make a value of "; amount; " using the coins 1, 2, 5, 10, 20, 50, 100 and 200:"

for n = coins[?]-1 to 0 step -1
	tmp = floor(amount/coins[n])
	if tmp >= 0 then
		print tmp; " * "; coins[n]
		sumCoins = sumCoins + tmp
		amount = amount % coins[n]
	end if
next n
end
