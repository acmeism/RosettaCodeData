local fmt = require "fmt"

local denoms = {200, 100, 50, 20, 10, 5, 2, 1}
local coins = 0
local amount = 988
local remaining = 988
print($"The minimum number of coins needed to make a value of {amount} is as follows:")
for denoms as denom do
    local n = remaining // denom
    if n > 0 then
        coins += n
        fmt.print("  %3d x %d", denom, n)
        remaining %= denom
        if remaining == 0 then break end
    end
end
print($"\nA total of {coins} coins in all.")
