  [ ' [ 200 100 50 20 10 5 2 1 ] ] is coins (   --> [ )

  [ [] swap
    coins witheach
      [ /mod dip join ]
    drop
    witheach
      [ dup 0 > iff
          [ echo say " * "
            coins i^ peek echo
            cr ]
        else drop ] ]              is task  ( n -->   )

  ' [ 988 345 1024 ]
  witheach
    [ say "To make "
      dup echo say ":" cr
      task cr ]
