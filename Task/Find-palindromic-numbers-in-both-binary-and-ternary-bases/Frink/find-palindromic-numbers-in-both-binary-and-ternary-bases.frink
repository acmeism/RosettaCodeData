count = 0
n = 0
do
{
   half = base2[n]
   nns = half + reverse[left[half, -1]]
   nn = parseInt[nns, 2]

   if isPalindrome[nn, 3]
   {
      println[nn]
      count = count + 1
   }
   n = n +1
} until count == 6

// Returns true if the given number is a palindrome in the specified base.
isPalindrome[num, base] :=
{
   str = base[num, base]
   return reverse[str] == str
}
