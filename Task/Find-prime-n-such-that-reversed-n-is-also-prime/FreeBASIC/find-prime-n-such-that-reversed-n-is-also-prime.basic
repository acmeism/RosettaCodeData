#include "isprime.bas"

function isbackprime( byval n as integer ) as boolean
    if not isprime(n) then return false
    dim as integer m = 0
    while n
        m *= 10
        m += n mod 10
        n \= 10
    wend
    return isprime(m)
end function

for n as uinteger = 2 to 499
    if isbackprime(n) then print n;" ";
next n
print
