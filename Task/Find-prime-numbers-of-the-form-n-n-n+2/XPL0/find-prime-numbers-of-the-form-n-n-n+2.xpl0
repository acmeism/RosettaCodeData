func IsPrime(N);        \Return 'true' if N is a prime number
int  N, I;
[if N <= 1 then return false;
for I:= 2 to sqrt(N) do
    if rem(N/I) = 0 then return false;
return true;
];

int N;
[for N:= 1 to 199 do
    [if IsPrime(N*N*N+2) then
        [IntOut(0, N);
        ChOut(0, 9\tab\);
        IntOut(0, N*N*N+2);
        CrLf(0);
        ]
    ];
]
