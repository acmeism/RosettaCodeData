function isprime(n as integer) as boolean
    if n<0 then return isprime(-n)
    if n<2 then return false
    if n<4 then return true
    dim as uinteger i=3
    while i*i<n
        if n mod i = 0 then return false
        i+=2
    wend
    return true
end function


print 1;"  ";
dim as integer n=2, n2=4
while n2<1000
    if isprime(1+n2) then print n2;"  ";
    n+=2
    n2=n^2
wend
