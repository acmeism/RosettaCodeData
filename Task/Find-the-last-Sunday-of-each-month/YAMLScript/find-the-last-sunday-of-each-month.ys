!ys-0

defn main(year=2013):
  each m (1 .. 12):
    say: last-sunday(year m):S

defn last-sunday(year month):
  first =: java-time/local-date(year month 1)
  last =:
    java-time/minus:
      java-time/plus(first (java-time/months 1))
      java-time/days(1)
  loop d last:
    if java-time/sunday?(java-time/day-of-week(d)):
      then: d
      else: recur(java-time/minus(d (java-time/days 1)))
