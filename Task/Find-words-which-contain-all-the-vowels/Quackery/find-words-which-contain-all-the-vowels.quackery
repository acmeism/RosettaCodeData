  [ [] swap ]'[ swap
    witheach
      [ dup nested
        unrot over do
        iff [ dip join ]
        else nip ]
    drop ]               is filter (   [ --> [ )

  [ 2dup peek
    1+ unrot poke ]      is pink   ( [ n --> [ )

  [ ' [ 0 0 0 0 0 0 ]
    swap witheach
      [ lower
        $ "aeiou" find
        pink ]
    -1 split drop
    ' [ 1 1 1 1 1 ] = ]  is valid  (   [ --> b )

  $ "rosetta/unixdict.txt" sharefile drop nest$
  filter [ size 10 > ]
  filter valid
  70 wrap$
