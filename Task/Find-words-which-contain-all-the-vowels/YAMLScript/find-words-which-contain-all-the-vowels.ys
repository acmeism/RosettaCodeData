!ys-0

vowels =: qw(a e i o u)

defn main():
  each word filter(all-vowels-once? words()):
    say: word

defn all-vowels-once?(word):
  w =: word:lc
  long =: w.# > 10
  counts =:
    map _ vowels:
      fn(v):
        count(filter(eq(v) w:seq.map(S)))
  if long:
    then: every?(eq(1) counts)
    else: false

defn words():
  file =: '/usr/share/dict/words'
  if fs/e(file):
    then: file:read:lines
    else: qw(educationals adventitious facetiously)
