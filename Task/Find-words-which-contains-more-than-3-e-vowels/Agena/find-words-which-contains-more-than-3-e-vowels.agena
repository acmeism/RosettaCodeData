scope # find words that contain more than 3 es

    for word in io.lines( "unixdict.txt" ) do
        local es, others := 0, false;
        for c in word while not others do
            if c = "e" then
                es +:= 1
            elif c in "aiou" then
                others := true
            fi
        od;
        if es > 3 and not others then
            print( word )
        fi
    od

end
