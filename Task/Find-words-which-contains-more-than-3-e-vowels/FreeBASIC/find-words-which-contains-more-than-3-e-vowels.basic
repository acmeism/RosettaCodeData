open "unixdict.txt" for input as #1

dim as string s, c
dim as integer e, i

while not eof(1)
    line input #1, s
    e = 0
    for i = 1 to len(s)
        c = mid(s,i,1)
        if c="e" then e+=1
        if c="a" or c="i" or c="o" or c="u" then continue while
    next i
    if e>3 then print s
wend
