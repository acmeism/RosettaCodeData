do  -- find words that contain more than 3 es

    for word in io.lines( "unixdict.txt" ) do
        local es, others = 0, false
        for c = 1, # word do
            local ch <const> = word[ c ]
            if ch == "e" then
                es += 1
            elseif "aiou":contains( ch ) then
                others = true
                break
            end
        end
        if es > 3 and not others then
            print( word )
        end
    end

end
