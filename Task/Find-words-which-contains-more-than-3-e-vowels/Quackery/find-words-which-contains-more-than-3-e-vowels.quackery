  [ bit
    [ 0 $ "aiou"
      witheach
        [ bit | ] ] constant
    & 0 != ]                 is aiou ( c --> b )

  []
  $ "rosetta/unixdict.txt" sharefile drop nest$
  witheach
    [ 0 over
      witheach
        [ dup char e = if
            [ dip 1+ ]
          aiou if
            [ drop 0
              conclude ] ]
      3 > iff
        [ nested join ]
      else drop ]

    50 wrap$
