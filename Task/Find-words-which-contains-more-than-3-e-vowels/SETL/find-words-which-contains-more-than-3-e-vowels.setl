program e_words;
    dict := open("unixdict.txt", "r");
    loop doing geta(dict, word); while word /= om do
        if exists letter in word | letter in "aiou" then
            continue;
        end if;
        if #[letter in word | letter = "e"] <= 3 then
            continue;
        end if;
        print(word);
    end loop;
    close(dict);
end program;
