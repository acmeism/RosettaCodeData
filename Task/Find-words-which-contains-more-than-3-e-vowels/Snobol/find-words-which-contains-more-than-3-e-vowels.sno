        input(.words, 1,, 'unixdict.txt')   :s(line)
        output = 'Error!'                   :(end)
line    word = words                        :f(end)
        word 'a' | 'i' | 'o' | 'u'          :s(line)
        word 'e' arb 'e' arb 'e' arb 'e'    :f(line)
        output = word                       :(line)
end
