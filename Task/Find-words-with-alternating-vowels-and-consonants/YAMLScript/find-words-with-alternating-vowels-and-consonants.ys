!ys-0

defn main(path='/usr/share/dict/words'):
  each word path:read:lines.filter(word?):
    when alternating?(word):
      say: word

defn word?(word):
  word =~ /^[a-z]+$/

defn alternating?(word):
  letters =: word:lc:seq.filter(\(_ =~ /^[a-z]$/))
  when letters.# >= 2:
    last =: letters.# - 2
    every? _ (0 .. last):
      fn(i):
        vowel?(letters.$i) != vowel?(letters.nth(i.++))

defn vowel?(c):
  c:S =~: /^[aeiou]$/
