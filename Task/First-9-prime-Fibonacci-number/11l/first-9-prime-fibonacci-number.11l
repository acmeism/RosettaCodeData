F prime(x)
   I x < 2
      R 0B
   I x == 2 | x == 3
      R 1B
   I x % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(x))).step(2)
      I x % i == 0
         R 0B
   R 1B

V n = 11
V fibn = 3
V (a, b) = (Int64(1), Int64(1))
L n > 0
   (a, b) = (b, a + b)
   I prime(b)
      print(‘fib(#.): #.’.format(fibn, b))
      n--
   fibn++
