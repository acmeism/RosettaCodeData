include "isprime.kbs"

function fib(nr)
	if nr = 0 then return 0
	if nr = 1 then return 1
	if nr > 1 then return fib(nr-1) + fib(nr-2)
end function

i = 0
cont = 0
print "The first 9 Prime Fibonacci numbers: "
do
	i += 1
	num = fib(i)
	if isPrime(num) then
		cont += 1
		print num; " ";
	end if
until cont >= 9
end
