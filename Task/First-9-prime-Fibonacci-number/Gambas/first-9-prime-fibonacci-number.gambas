Use "isprime.bas"

Public Sub Main()

  Dim i As Integer = 0, num As Integer, cont As Integer = 0

  Print "The first 9 Prime Fibonacci numbers: "
  Do
    i += 1
    num = fib(i)
    If isprime(num) Then
      cont += 1
      Print num; " ";
    End If
  Loop Until cont >= 9

End

Function fib(nr As Integer) As Integer

  If nr = 0 Then Return 0
  If nr = 1 Then Return 1
  If nr > 1 Then Return fib(nr - 1) + fib(nr - 2)

End Function
