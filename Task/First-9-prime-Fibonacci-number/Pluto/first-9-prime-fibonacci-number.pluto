local int = require "int"

local limit <const> = 12
print($"The first {limit} prime Fibonacci numbers are:")
local count = 0
local f1 = 1
local f2 = 1
while count < limit do
    local f3 = f1 + f2
    if int.isprime(f3) then
        io.write($"{f3} ")
        count += 1
    end
    f1 = f2
    f2 = f3
end
print()
