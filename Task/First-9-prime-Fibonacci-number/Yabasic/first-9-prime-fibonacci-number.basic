import isprime

sub fib(nr)
    if nr = 0  return 0
    if nr = 1  return 1
    if nr > 1  return fib(nr-1) + fib(nr-2)
end sub

i = 0
cont = 0
print "The first 9 Prime Fibonacci numbers: "
repeat
    i = i + 1
    num = fib(i)
    if isPrime(num) then
        cont = cont + 1
        print num, " ";
    fi
until cont >= 9
print
end
