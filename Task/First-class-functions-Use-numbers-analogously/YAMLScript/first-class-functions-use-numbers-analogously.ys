!ys-0

defn main():
  x =: 2.0
  xi =: 0.5
  y =: 4.0
  yi =: 0.25
  z =: x + y
  zi =: 1.0 / (x + y)
  nums =: +[x y z]
  invs =: +[xi yi zi]
  each [n inv] map(vector nums invs):
    f =: multiplier(n inv)
    say: "$format('%.1f' n) *
          $format('%.6f' inv) ->
          $f(1.0)"

defn multiplier(a b):
  fn(c): a * b * c
