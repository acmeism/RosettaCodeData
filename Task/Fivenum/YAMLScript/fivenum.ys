!ys-0

defn main():
  data =: qw(15 6 42 41 7 36 49 40 39 47 43)
    .map(N):sort
  say: five-number(data):joins

defn five-number(xs):
  +[xs.0 quartile(xs 0.25) median(xs) quartile(xs 0.75) xs.$]

defn quartile(xs q):
  pos =: q * xs.#.--
  lo =: floor(pos)
  hi =:
    if pos == lo: lo lo.++
  frac =: pos - lo
  xs.$lo +: frac * (xs.$hi - xs.$lo)

defn median(xs):
  quartile(xs 0.5)
