!ys-0

inf =: 999999

defn main():
  dist =: floyd(graph())
  each row dist:
    say: row.map(show):joins

defn graph():
  +[[0 3 8 inf -4]
    [inf 0 inf 1 7]
    [inf 4 0 inf inf]
    [2 inf -5 0 inf]
    [inf inf inf 6 0]]

defn floyd(d):
  n =: d.#
  loop k 0, d d:
    if k == n:
      then: d
      else:
        d =:
          for i (0 .. n.--):
            for j (0 .. n.--):
              min(d.$i.$j (d.$i.$k + d.$k.$j))
        recur: k.++, d

defn show(x):
  (x >= inf).if('∞' x:S)
