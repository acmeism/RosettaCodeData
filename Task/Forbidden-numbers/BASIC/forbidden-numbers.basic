10 DEFINT A-Z
20 N=0: C=0: L=500
30 N=N+1
40 M=N
50 IF M>1 AND (M AND 3)=0 THEN M=M\4: GOTO 50
60 IF (M AND 7)<>7 THEN 30
70 C=C+1
80 IF C<=50 THEN PRINT USING "#####";N;: IF C MOD 10=0 THEN PRINT
90 IF N<L THEN 30
100 PRINT USING "Forbidden numbers up to #####: #####";L;C
110 IF L<5000 THEN L=L*10: GOTO 30
120 END
