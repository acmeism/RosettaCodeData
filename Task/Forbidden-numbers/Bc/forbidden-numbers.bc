define forbidden(n) {
    while((n>1) && (n%4==0)) {
        n /= 4
    }
    return n % 8 == 7
}

n = 0
count = 0
lim = 500
while(n < lim) {
    n += 1
    while(forbidden(n) != 1) n += 1
    count += 1
    if (count <= 50) {
        print n, " "
        if (count % 10 == 0) print "\n"
    }
    if (n >= lim) {
        print "Forbidden numbers <= ",lim,":"
        print count-1,"\n"
        if (lim < 50000) lim *= 10
    }
}
