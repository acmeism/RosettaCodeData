forbiddenQ[n_] := Mod[NestWhile[#/4 &, n, Divisible[#, 4] &], 8] == 7;

forbidden = Select[Range[500000], forbiddenQ];

Partition[Take[forbidden, 50], 10] // TableForm

format[m_, n_] := StringForm["There are `` forbidden numbers <= ``.", m, n];
Table[format[LengthWhile[forbidden, # <= n &], n],
  {n, {500, 5000, 50000, 500000}}] // TableForm
