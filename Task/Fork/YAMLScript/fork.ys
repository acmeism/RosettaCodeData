!ys-0

# YS has no fork(); process() spawns a child that runs concurrently
# with the parent. The parent continues at once and waits at deref.
defn main():
  script =: |
    sleep 0.3
    echo "child: hello from PID $$"
  child =:
    process {:out :inherit}: +
      'bash' '-c' script
  say: 'parent: child spawned; parent keeps running'
  say: "parent: child exited with status $(child.@.exit)"
