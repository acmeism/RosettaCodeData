void local fn BorderedSquare( size as int )
  int v, x, y, q = 20, edge = q * size
  int color(1) : color(0) = _zCyan : color(1) = _zYellow
  window 1, @"Mosaic Matrix Graphic", (0, 0, edge + 40, edge + 40)
  text @"Arial bold", 16
  for x = q to edge step q
    for y = q to edge step q
      v = ( x == q | y == q | x == edge | y == edge )
      rect fill (x, y, q, q), color(v)
      print %(x + 6, y + 2 ) v
    next
  next
end fn

fn BorderedSquare(20)
HandleEvents
