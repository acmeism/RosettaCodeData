void local fn OutlinedGrid( gridSize as int )
  int i, j

  for i = 0 to gridSize
    for j = 0 to gridSize
      if( (i = 0) || (i = gridSize) || (j = 0) || (j = gridSize) )
        printf @"%@\b", @"1 "
      else
        printf @"%@\b", @"0 "
      end if
    next
    print
  next
end fn

fn OutlinedGrid(20)

HandleEvents
