F isPrime(v)
   I v <= 1
      R 0B
   I v < 4
      R 1B
   I v % 2 == 0
      R 0B
   I v < 9
      R 1B
   I v % 3 == 0
      R 0B
   E
      V r = round(pow(v, 0.5))
      V f = 5
      L f <= r
         I v % f == 0 | v % (f + 2) == 0
            R 0B
         f += 6
      R 1B

V pn = 2
V n = 0
L(i) (3..).step(2)
   I isPrime(i)
      n++
      V f = (pn * i) - pn - i
      I f > 10000
         L.break
      print(n‘  =>  ’f)
      pn = i
