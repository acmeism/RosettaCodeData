  200 eratosthenes

  [ [ [] 200 times
      [ i^ isprime if
          [ i^ join ] ] ]
    constant
    swap peek ]            is prime     ( n --> n )

  [ dup prime
    swap 1+ prime
    2dup * rot - swap - ]  is frobenius ( n --> n )

  [] 0
  [ tuck frobenius dup
    10000 < while
    join swap
    1+ again ]
  drop nip echo
