sub isPrime(v)
    if v < 2 then return False : fi
    if mod(v, 2) = 0 then return v = 2 : fi
    if mod(v, 3) = 0 then return v = 3 : fi
    d = 5
    while d * d <= v
        if mod(v, d) = 0 then return False else d = d + 2 : fi
    wend
    return True
end sub

pn = 2
n = 0
for i = 3 to 9999 step 2
    if isPrime(i) then
        n = n + 1
        f = pn * i - pn - i
        if f > 10000 then break : fi
        print n, " =>  ", f
        pn = i
    end if
next i
end
