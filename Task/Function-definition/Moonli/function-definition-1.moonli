defun this-is-a-function():
  "It returns a string."
end

defun another-function():
  "If first expression is a string, it becomes the docstring and documents the function."
  "It also returns a string."
end

another-function()
#=> "It also returns a string"
documentation($another-function, $function)
#=> "If first expression is a string, it becomes the docstring and documents the function."
