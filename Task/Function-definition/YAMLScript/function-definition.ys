!ys-0

tests =:: 3 4 5

# Main function definition with variable arguments:
defn main(args=tests):
  args =: args:words.map(N)
  say: "multiply($(args.join(', ')))
        -> $multiply(args*)"

# A multi-arity function definition:
defn multiply:
  (): 1
  (x): x
  (x y): x * y
  (x y *more):
    reduce multiply:
      multiply(x y) more
