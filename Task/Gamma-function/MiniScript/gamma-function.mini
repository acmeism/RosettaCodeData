import "num"
import "fmt"

stirling = function(x)
    return sqrt(2 * pi / x) * ((x / num.exp) ^ x)
end function

TAB = char(9)
print " x" + TAB + "Stirling" + TAB + TAB + "Lanczos"
print
for i in range(1, 20)
    d = i / 10
    s = stirling(d)
    g = num.gamma(d)
    d = fmt.num(d, 4, 2)
    s = fmt.num(s, 16, 14)
    g = fmt.num(g, 16, 14)
    fmt.print "{}{}{}{}{}", d, TAB, s, TAB, g
end for
