procedure main(A)
   writes("First 30 >= 100:")
   every writes(" ",gapful(seq(100))\30 | "\n")

   writes("First 15 >= 1000000:")
   every writes(" ",gapful(seq(10^6))\15 | "\n")

   writes("First 10:")
   every writes(" ",gapful(seq(10^9))\10 | "\n")
end

procedure gapful(n)
   s := string(n)
   m := s[1]*10+s[-1]
   return (n%m = 0, n)
end
