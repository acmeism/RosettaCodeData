!ys-0

# Gapful: n >= 100 and (first-digit*10 + last-digit) divides n.

defn main():
  show 'First 30 gapful numbers:': 30 100
  show 'First 15 gapful >= 1e6:':  15 1000000
  show 'First 10 gapful >= 1e9:':  10 1000000000

defn- show(title cnt start):
  ns =:
    iterate(inc start)
      .filter(gapful?)
      .take(cnt)
  say: title
  say: ns:joins

defn- gapful?(n):
  zero?: n % n:key

defn- key(n):
  s =: n:S
  hi =: s.0:I - 48
  lo =: s.$:I - 48
  (hi * 10) +: lo
