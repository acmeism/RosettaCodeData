require "matrix"

local arrays = {
    { { 1,  2,  3 },
      { 4,  1,  6 },
      { 7,  8,  9 } },

    { { 2, -1,  0 },
      {-1,  2, -1 },
      { 0, -1,  2 } },

    { { -1, -2, 3, 2 },
      { -4, -1, 6, 2 },
      {  7, -8, 9, 1 },
      {  1, -2, 1, 3 } }
}

for arrays as array do
    print("Original:\n")
    local m = matrix.from(array)
    print(m)
    print("\nInverse:\n")
    print(m:inverse():format("%9.6f"))
    print()
end
