# Generalized FizzBuzz: factor->word map. For each n in 1..max,
# join the words for factors dividing n, else print n.

defn main():
  rules =: +
    [[3 'Fizz']
     [5 'Buzz']
     [7 'Baxx']]
  each n (1 .. 20):
    say: n.fizz(rules)

defn- fizz(n rules):
  matched =:
    filter \((n % _.0):zero?): rules
  if matched:empty?:
    str: n
    join: matched.map(last)
