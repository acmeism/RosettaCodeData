arraybase 1
for num = 1 to 5
	call pRand()
next num
end

subroutine pRand()
	dim randCheck(21)
	nr = 1
	do
		aleat = int(rand * 20) + 1
		if randCheck[aleat] = 1 then
			continue do
		else
			randCheck[aleat] = 1
			print aleat; " ";
		end if
		for n = 1 to randCheck[?]
			if randCheck[nr] then nr += 1
		next n
	until nr = 21
	print
end subroutine
