Sub pRand
    Dim As Integer randCheck(20), nr = 1
    Do
        Dim As Integer aleat = Int(Rnd * 20) + 1
        If randCheck(aleat) = 1 Then
            Continue Do
        Else
            randCheck(aleat) = 1
            Print aleat;
        End If
        For n As Integer = 1 To Ubound(randCheck)
            If randCheck(nr) = 1 Then nr += 1
        Next n
    Loop Until nr = 21
    Print
End Sub

Randomize Timer
For num As Integer = 1 To 5
    pRand()
Next num
Sleep
