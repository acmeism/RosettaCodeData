DECLARE SUB pRand ()

RANDOMIZE TIMER
FOR num = 1 TO 5
    pRand
NEXT num
END

SUB pRand
    DIM randCheck(1 TO 21)
    nr = 1
    DO
        aleat = INT(RND * 20) + 1
        IF randCheck(aleat) <> 1 THEN
            randCheck(aleat) = 1
            PRINT aleat;
        END IF

        FOR n = 1 TO UBOUND(randCheck)
            IF randCheck(nr) = 1 THEN nr = nr + 1
        NEXT n
    LOOP UNTIL nr = 21
    PRINT
END SUB
