arraybase 1
dim n[5]
n[1] = 7
n[2] = 12.00
n[3] = 12.345
n[4] = 12.345677
n[5] = 0.142857142857142

for i = n[?,] to n[?]
	print n[i] + " has " + dec(n[i]) + " decimals"
next i
end

function dec(n)
	c = string(n)
	if instr(c, ".") then return length(mid(c, instr(c, ".") + 1, length(c))) else return 0
end function
