ClearAll[DecimalDigits]
DecimalDigits[r_String] := Module[{pos},
  If[StringContainsQ[r, "."],
   pos = StringPosition[r, "."][[-1, 1]];
   StringLength[StringDrop[r, pos]]
   ,
   0
   ]
  ]
DecimalDigits["12.345"]
DecimalDigits["12.3450"]
DecimalDigits["8"]
DecimalDigits["3128"]
DecimalDigits["13."]
DecimalDigits["13.1312312"]
