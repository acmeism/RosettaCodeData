FUNCTION dec(n_t)
    LET c$ = STR$(n_t)
    IF POS(c$,".")<>0 THEN LET dec = LEN((c$)[POS(c$,".")+1:maxnum]) ELSE LET dec = 0
END FUNCTION

DIM n(5)
DATA 7, 12.00, 12.345, 12.345677, 0.142857142857142

FOR i = LBOUND(n) TO UBOUND(n)
    READ n(i)
    PRINT n(i); "has"; dec(n(i)); "decimals"
NEXT i
END
