import "int"

limit = 4
giuga = []
n = 6  // can't be 2 or 4
while giuga.len < limit
    pf = int.factors(n)
    for f in pf
        if (n / f - 1) % f != 0 then
            pf = []
            break
        end if
    end for
    if pf.len > 0 then giuga.push n
    n += 2
end while

print "The first " + limit + " Guiga numbers are: "
print giuga
