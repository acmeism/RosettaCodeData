!ys-0

defn main(limit=10000):
  each n (2 .. limit):
    when giuga?(n):
      say: n

defn giuga?(n):
  ps =: prime-divisors(n)
  composite? =: not(prime?(n))
  divisor-test? =:
    every? _ ps:
      fn(p): mod(((n // p) - 1) p) == 0
  composite? &&: divisor-test?

defn prime-divisors(n):
  filter _ (2 .. n):
    fn(p): prime?(p) && (n % p).!

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
