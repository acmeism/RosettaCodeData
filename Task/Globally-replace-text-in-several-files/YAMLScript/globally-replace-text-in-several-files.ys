!ys-0

# Replace every "Goodbye London!" with "Hello New York!" in each file.
# With no args, create three demo files first so the program is
# self-contained and runnable.

defn main(*files):
  files =:
    if files: files demo-files()
  each file files:
    write file: file:read
      .replace('Goodbye London!' 'Hello New York!')
    say: "patched $file"

defn demo-files():
  names =:: [doc1.txt, doc2.txt, doc3.txt]
  each name names:
    write name: "Goodbye London!\n"
  =>: names
