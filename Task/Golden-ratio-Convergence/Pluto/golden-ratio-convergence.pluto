local fmt = require "fmt"

local old_phi = 1
local phi
local iters = 0
local limit = 1e-5
while true do
    phi = 1 + 1 / old_phi
    iters += 1
    if math.abs(phi - old_phi) <= limit then break end
    old_phi = phi
end
fmt.print("Final value of phi : %16.14f", phi)
local actual_phi = (1 + math.sqrt(5.0)) / 2
fmt.print("Number of iterations : %d", iters)
fmt.print("Error (approx) : %16.14f", phi - actual_phi)
