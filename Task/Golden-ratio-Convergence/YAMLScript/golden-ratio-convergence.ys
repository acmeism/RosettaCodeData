!ys-0

defn main(epsilon=0.00001):
  result =: converge(epsilon)
  phi =: (1 + sqrt(5)) / 2
  say: "value:      $(format('%.12f' result.value))"
  say: "iterations: $(result.iterations)"
  say: "error:      $(format('%.12f' abs(result.value - phi)))"

defn converge(epsilon):
  loop n 0, prev 1.0:
    next =: 1 + (1 / prev)
    if abs(next - prev) <= epsilon:
      M+: :value next :iterations n.++
      recur: n.++, next
