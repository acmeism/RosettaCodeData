GospersHack[x_] := Module[{c, r},
  c = BitAnd[x, -x];
  r = x + c;
  BitOr[BitShiftRight[Quotient[BitXor[r, x], c], 2], r]
]

Table[
  With[{start = s},
    Row[{start, ": ",
      StringRiffle[
        ToString /@ NestList[GospersHack, start, 10][[2 ;; 11]],
        " "
      ]
    }]
  ],
  {s, {1, 3, 7, 15}}
] //Column
