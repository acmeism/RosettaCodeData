function gospers_hack(integer x)
    integer c = x && -x,
            r = x + c
    return floor(floor(xor_bits(r,x)/4)/c) || r
end function

for bits=1 to 4 do
    integer start = power(2,bits)-1, x = start
    sequence results = {}
    for i=1 to 10 do
        x = gospers_hack(x)
        results &= x
    end for
    printf(1,"%d: %s\n",{start,join(results,fmt:="%d")})
end for
