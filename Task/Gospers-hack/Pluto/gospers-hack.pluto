local function gospers_hack(x)
    local c = x & -x
    local r = x + c
    return (((r ~ x) >> 2) // c) | r
end

for {1, 3, 7, 15} as start do
    local x = start
    local results = {}
    for _ = 0, 9 do
        x = gospers_hack(x)
        results:insert(x)
    end
    print($"{start}: {results:concat(" ")}")
end
