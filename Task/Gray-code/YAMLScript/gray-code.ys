!ys-0

defn main(n=5):
  lim =: I(2 ** n).--
  each i (0 .. lim):
    g =: encode(i)
    d =: decode(g)
    say: "$format('%2d' i)  \
          $format('%5s' Integer/toBinaryString(i))  \
          $format('%5s' Integer/toBinaryString(g))  $d"

defn- encode(b):
  bit-xor: b bit-shift-right(b 1)

defn- decode(g):
  loop b 0, mask g:
    if-not mask.!:
      recur:
        bit-xor(b mask)
        bit-shift-right(mask 1)
      else: b
