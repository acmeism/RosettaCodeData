import ballerina/io;

function gcd(int u, int v) returns int {
    int _u = u;
    int _v = v;
    while _v != 0 {
        [_u, _v] = [_v, _u % _v];
    }
    return _u.abs();
}

public function main() {
    io:println(gcd(0, 0));
    io:println(gcd(0, 10));
    io:println(gcd(0, -10));
    io:println(gcd(9, 6));
    io:println(gcd(6, 9));
    io:println(gcd(-6, 9));
    io:println(gcd(8, 45));
    io:println(gcd(40902, 24140));
}
