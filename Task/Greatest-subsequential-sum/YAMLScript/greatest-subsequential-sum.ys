!ys-0

defn main():
  nums =:: [-1, -2, 3, 5, 6, -2, -1, 4, -4, 2, -1]
  say: nums:max-subseq

defn- max-subseq(xs):
  loop i 0, bsum 0, bs 0, be 0, csum 0, cs 0:
    if i >= xs.#:
      xs: .subvec(bs be)
      else:
        x =: xs.$i
        ns =: csum + x
        if ns > bsum:
          recur: i.++, ns, cs, i.++, ns, cs
          if ns < 0:
            recur: i.++, bsum, bs, be, 0, i.++
            recur: i.++, bsum, bs, be, ns, cs
