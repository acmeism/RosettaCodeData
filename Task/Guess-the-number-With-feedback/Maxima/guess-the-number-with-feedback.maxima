guesser2(nmin, nmax) := block(
    n: nmin+random(nmax-nmin+1),
    guess: readonly(sconcat("I'm thinking of a number between ", nmin, " and ", nmax, ".")),
    while guess#n do(
        if not integerp(guess) or guess < nmin or guess > nmax then guess: readonly("Invalid input. Try again!"),
        if guess > n then guess: readonly("Too high! Guess again."),
        if guess < n then guess: readonly("Too low! Guess again.")
    ),
    "That's right!"
)$

guesser2(1, 100);
