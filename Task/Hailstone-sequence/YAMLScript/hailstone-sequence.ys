!ys-0

defn main():
  h27 =: hailstone(27)
  say: "hailstone(27) length: $(h27.#)"
  say: "first 4: $(h27.take(4):V)"
  say: "last 4:  $(h27.take-last(4):V)"

  best =:
    apply max-key last:
      map \([_ hailstone(_).#]):
        =>: 1 .. 99999
  say: "longest under 100000: n=$(best.0) length=$(best.1)"

defn hailstone(n):
  loop v n, acc [n]:
    cond:
      v == 1: acc
      else:
        nv =: even?(v).if((v / 2) (3 * v).++)
        recur nv: acc.conj(nv)
