// Graph represents an undirected graph using an adjacency matrix.
integer n
sequence adj,
         adjClone

// Degree returns the degree of vertex u.
function Degree(sequence adj, integer u)
    return sum(adj[u])
end function

// Closure computes the Chvátal closure in-place.
procedure Closure()
    do
        bool added := false
        for u=1 to n do
            for v=u+1 to n do
                if not adjClone[u][v] then
                    if Degree(adjClone,u)+Degree(adjClone,v) >= n then
                        adjClone[u][v] = true
                        adjClone[v][u] = true
                        added = true
                        exit
                    end if
                end if
            end for
            if added then exit end if
        end for
    until not added
end procedure

// IsComplete reports whether the graph is complete.
function IsComplete()
    for u=1 to n do
        for v=u+1 to n do
            if not adjClone[u][v] then
                return false
            end if
        end for
    end for
    return true
end function

sequence visited, path

function dfs(integer u)
    if length(path) == n then
        // check if we can close the cycle
        if adj[u][path[1]] then
            path &= path[1]
            return true -- (result in path)
        end if
        return false
    end if
    for v=1 to n do
        if not visited[v] and adj[u][v] then
            visited[v] = true
            path = append(path, v)
            if dfs(v) then return true end if
            // backtrack
            path = path[1..$-1]
            visited[v] = false
        end if
    end for
    return false
end function

// HamiltonianCycle finds a Hamiltonian cycle in the original graph
// by simple backtracking. If found, returns a slice of vertices
// including the return to the start; otherwise returns nil.
function HamiltonianCycle()
    visited = repeat(false, n)
    visited[1] = true
    path = {1}
    return dfs(1)
end function

// Example: 5 vertices, almost complete graph missing edge 0--1.
// This satisfies Ore's condition: deg(0)=3, deg(1)=3, 3+3>=5.
n = 5
adj = repeat(repeat(false,n),n)
// Add all edges except (1,2)
for u=1 to n do
    for v=u+1 to n do
        if u!=1 or v!=2 then
            adj[u][v] = true
            adj[v][u] = true
        end if
    end for
end for

printf(1,"Original graph degrees:\n")
for u=1 to n do
    printf(1," deg(%d) = %d\n", {u, Degree(adj,u)})
end for

// Compute closure
adjClone = deep_copy(adj)
Closure()

printf(1,"\nAfter Chvátal closure:\n")
for u=1 to n do
    printf(1,"  %d:", u)
    for v=1 to n do
        if adjClone[u][v] then
            printf(1," %d", v)
        end if
    end for
    printf(1,"\n")
end for

if IsComplete() then
    printf(1,"\nClosure is complete => graph is Hamiltonian (by Bondy-Chvátal).\n")
    if HamiltonianCycle() then
        printf(1,"Found Hamiltonian cycle in original graph:\n")
        printf(1,"%s\n",{join(path," -> ",fmt:="%d")})
    else
        printf(1,"Unexpected: could not find a Hamiltonian cycle.\n")
    end if
else
    printf(1,"\nClosure is not complete => no guarantee of Hamiltonian cycle.\n")
end if
