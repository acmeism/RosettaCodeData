!ys-0

# Print the first N happy numbers.

defn main(n=8):
  happys =: (1 .. 10000)
              .filter(happy?)
              .take(n)
  say: happys:joins

defn happy?(n):
  loop k n, seen \{}:
    cond:
      k == 1: true
      seen.contains?(k): false
      else:
        recur: k:digit-sq-sum seen.conj(k)

defn digit-sq-sum(n):
  loop k n, total 0:
    if k.?:
      then:
        total +=: (k % 10):sqr
        recur: (k // 10) total
      else: total
