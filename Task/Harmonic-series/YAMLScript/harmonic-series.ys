!ys-0

defn main():
  each n (1 .. 20):
    say: "H($n) = $format('%.6f' harmonic(n))"
  each limit (1 .. 5):
    say: "first H(n) > $limit: $first-greater-than(limit)"

defn harmonic(n):
  sum:
    for i (1 .. n):
      1.0 / i

defn first-greater-than(limit):
  loop n 1, total 0.0:
    total =: total + (1.0 / n)
    if total > limit:
      n
      recur(n.++ total)
