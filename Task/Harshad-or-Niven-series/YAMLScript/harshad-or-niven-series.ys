!ys-0

defn main():
  harshads =: (1 .. 100000).filter(harshad?)
  first20 =: harshads.take(20)
  say: "First 20 Harshad numbers:"
  say: first20:joins
  say:
  over =: harshads.drop-while(\(_ <= 1000)):first
  say: "First Harshad number > 1000: $over"

defn harshad?(n):
  (n % digit-sum(n)):zero?

defn digit-sum(n):
  reduce add: 0 digits(n)

defn digits(n):
  n:S:
    .split('')
    .map(N)
