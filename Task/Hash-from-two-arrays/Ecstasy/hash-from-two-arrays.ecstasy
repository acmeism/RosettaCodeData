module HashTromTwoArrays {
    void run() {
        @Inject Console console;
        console.print(zip(["hello", "world"], [7, 101]));
    }

    /**
     * Using two Arrays of equal length, create a Hash object
     * where the elements from one array (the keys) are linked
     * to the elements of the other (the values)
     */
    static <Key, Value> ListMap<Key, Value> zip(Key[] keys, Value[] values) {
        return new ListMap(keys, values);
    }
}
