!ys-0

defn main(lat1=36.12, lon1=-86.67, lat2=33.94, lon2=-118.40):
  say: "Distance: $(haversine(lat1 lon1 lat2 lon2)) km"

defn haversine(lat1 lon1 lat2 lon2):
  r =: 6372.8
  dlat =: rad(lat2 - lat1)
  dlon =: rad(lon2 - lon1)
  sdlat =: Math/sin(dlat / 2):sqr
  sdlon =: Math/sin(dlon / 2):sqr
  clat =: Math/cos(rad(lat1)) * Math/cos(rad(lat2))
  a =: sdlat + (clat * sdlon)
  c =: 2 * Math/asin(sqrt(a))
  r *: c

defn rad(d):
  (d * Math/PI) / 180
