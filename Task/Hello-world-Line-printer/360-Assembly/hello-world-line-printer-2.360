HELLO    CSECT
         SAVE (14,12)
         BASR 12,0
         USING *,12
         ST 13,SAVEA+4
         LA 13,SAVEA
         OPEN (SYSPRINT,OUTPUT)
         PUT SYSPRINT,HELLOREC
         CLOSE SYSPRINT
         L 13,SAVEA+4
         RETURN (14,12),RC=0
HELLOREC DC    CL80'HELLO, WORLD!'
SYSPRINT DCB   DDNAME=SYSPRINT,                                        X
               DSORG=PS,                                               X
               MACRF=PM,                                               X
               RECFM=FB,                                               X
               LRECL=80
SAVEA    DS 18F
         END
