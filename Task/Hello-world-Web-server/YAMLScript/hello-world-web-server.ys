!ys-0

defn main(port=8080):
  say: "Serving http://localhost:$port/"
  bash-out: |
    while true; do
      {
        printf 'HTTP/1.1 200 OK\r\n'
        printf 'Content-Type: text/plain\r\n'
        printf 'Content-Length: 15\r\n'
        printf 'Connection: close\r\n'
        printf '\r\n'
        printf 'Goodbye, World!'
      } | nc -l -p $port -q 1 >/dev/null
    done
