!ys-0

defn main(limit=200):
  tris =: take(10 heronians(limit))
  each t tris:
    a b c area =: t
    say: "$a $b $c area=$area"

defn heronians(limit):
  all =:
    for a (1 .. limit), b (a .. limit), c (b .. limit):
      when triangle?(a b c):
        area =: heron-area(a b c)
        when (area - I(area)):zero?:
          +[a b c I(area)]
  filter: a all

defn triangle?(a b c):
  (a + b) > c

defn heron-area(a b c):
  s =: (a + b + c) / 2.0
  sqrt: s * (s - a) * (s - b) * (s - c)
