print @"Demo assumes file at path: ~/Desktop/hex_dump_test.txt with string:"
print @"\"Rosetta Code is a programming chrestomathy site 😀.\"\n"
print @"Canonical hex dump of entire file:"
print unix @"hexdump -C ~/Desktop/hex_dump_test.txt"
print @"Start offset 13 bytes with next 35 bytes interpreted:"
print unix @"hexdump -C -s 13 -n 35 ~/Desktop/hex_dump_test.txt"
print @"Output displayed in binary mode:"
print unix @"xxd -b ~/Desktop/hex_dump_test.txt"
HandleEvents
