!ys-0

defn main(n=20):
  rs ss =: figure-figure(n)
  say: "R: $(rs:joins)"
  say: "S: $(ss:joins)"

defn figure-figure(n):
  used =: atom(\{})
  seed =: +[]
  r =: atom(seed)
  s =: atom(seed)
  next =: atom(1)
  while r.@.# < n:
    prev =: r.@.$ || 0
    value =: prev + next.@
    swap r conj: value
    swap used conj: value
    while next.@.in?(used.@):
      swap next: inc
    swap s conj: next.@
    swap next: inc
  =>: +[r.@ s.@]
