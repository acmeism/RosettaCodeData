10 DEFINT A-Z
20 DIM P(7000)
30 FOR P=2 TO SQR(7000)
40 FOR C=P*P TO 7000 STEP P
50 P(C)=-1
60 NEXT C,P
65 N=1: I=0
70 FOR H=1 TO 50
80 N=N+1: IF P(N) THEN 80 ELSE Z=N: GOSUB 200: S=Y
90 I=I+1: Z=I: GOSUB 200: IF S<>Y THEN 80
100 PRINT N;"@";I,
110 NEXT H
120 END
200 Y=0
210 IF Z=0 THEN RETURN
220 Y=Y+Z MOD 10
230 Z=Z\10
240 GOTO 210
