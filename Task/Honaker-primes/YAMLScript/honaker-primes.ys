!ys-0

defn main(count=10):
  loop n 2, rank 0, found 0:
    when found < count:
      is-prime =: prime?(n)
      rank :if is-prime +=: 1
      if is-prime && (digit-sum(n) == digit-sum(rank)):
        then:
          say: n
          recur: n.++, rank, found.++
        else: recur(n.++, rank, found)

defn digit-sum(n):
  sum: n:S.map(\(_:S:I))

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
