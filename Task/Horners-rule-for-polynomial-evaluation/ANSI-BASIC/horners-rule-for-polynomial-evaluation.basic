100 REM Horner's rule for polynomial evaluation
110 DECLARE EXTERNAL FUNCTION Poly
120 DIM Coeffs(0 TO 10)
130 REM coefficients of all x^0..x^n
140 LET Coeffs(0) = -19
150 LET Coeffs(1) = 7
160 LET Coeffs(2) = -4
170 LET Coeffs(3) = 6
180 LET X = 3.0
190 PRINT "Value of (";
200 PRINT Coeffs(3); ")*x^3 + ("; Coeffs(2); ")*x^2 + (";
210 PRINT Coeffs(1); ")*x + ("; Coeffs(0); ")"
220 PRINT "at x ="; X; ":"; Poly(Coeffs, 3, 3.0)
230 END
240 !
250 EXTERNAL FUNCTION Poly(C(), N, X)
260 LET H = 0
270 FOR I = N TO 0 STEP -1
280    LET H = (H * X) + C(I)
290 NEXT I
300 LET Poly = H
310 END FUNCTION
