program Horner;
(* Horner's rule for polynomial evaluation *)

var
  x: real,
  coeffs: arrayof real; (* coefficients of all x^0..x^n *)

  unit poly: function (c: arrayof real; n: integer; x: real): real;
  var
    i: integer,
    h: real;
  begin
    h := 0;
    for i := n downto 0
    do
      h := (h * x) + c(i)
    od;
    result := h
  end;

begin
  array coeffs dim (0 : 3);
  coeffs(0) := -19;
  coeffs(1) := 7;
  coeffs(2) := -4;
  coeffs(3) := 6;
  x := 3.0;
  write("Value of (");
  write(coeffs(3): 1: 2, ")*x^3 + (", coeffs(2): 1: 2, ")*x^2 + (");
  writeln(coeffs(1): 1: 2, ")*x + (", coeffs(0): 1: 2, ")");
  writeln("at x = ", x: 1: 2, ": ", poly(coeffs, 3, 3.0): 1: 2);
end
