!ys-0

# Read the ELF identification header of the running executable
# (Linux-specific): byte 4 is the file class (1 = 32-bit, 2 = 64-bit)
# and byte 5 is the data encoding (1 = little, 2 = big).

defn main():
  elf =: read('/proc/self/exe')
  bits =: 32 * I(elf.4)
  order =: (I(elf.5) == 1).if('little' 'big')
  say: "word size: $bits bits"
  say: "endianness: ${order}-endian"
