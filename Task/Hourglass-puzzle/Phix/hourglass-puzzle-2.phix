procedure findinterval(integer want, t1, t2)
    for i=0 to want*t1*t2 do -- (aside: slight overrun, but it makes no real odds)
        if (rmdr(i+want,t1)=0 or rmdr(i+want,t2)=0) and (rmdr(i,t1)=0 or rmdr(i,t2)=0) then
            printf(1,"To get %d minute%s, Start at time %d and End at time %d\n",{want,iff(want=1?"":"s"),i,i+want})
            return
        end if
    end for
    printf(1,"%d is not possible\n",want)
end procedure
papply(true,findinterval,{tagset(20),4,7})
