factors_only: true$
is_humble(n) := length(sublist(ifactors(n), lambda([x], x>7)))=0$

block(count: 0, n: 1, while(count<50) do(
    if is_humble(n) then block(
            sprint(n),
            count: count+1,
            if mod(count, 10)=0 then newline()
        ),
        n: n+1))$

humble_digits(n) := length(sublist(makelist(i, i, 10^(n-1), (10^n)-1), is_humble))$
map(humble_digits, makelist(i, i, 1, 6));
