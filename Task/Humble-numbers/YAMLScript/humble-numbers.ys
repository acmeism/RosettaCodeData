!ys-0

defn main(limit=50):
  say: take(limit filter(humble? (1 .. 100000))):joins

defn humble?(n):
  ps =: +[2 3 5 7]
  loop n n, ps ps:
    if n == 1:
      then: true
      else:
        p =: first-divisor(n ps)
        when p:
          q =: n // p
          recur: q ps

defn first-divisor(n ps):
  some _ ps:
    fn(p):
      when (n % p):zero?: p
