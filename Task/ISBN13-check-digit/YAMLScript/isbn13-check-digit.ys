!ys-0

defn main():
  isbns =::
  - 978-0596528126
  - 978-0596528120
  - 978-1788399081
  - 978-1788399083
  each isbn isbns:
    valid =: isbn13-valid?(isbn).if('good' 'bad')
    say: "$isbn: $valid"

defn isbn13-valid?(isbn):
  digits =: isbn.replace(/-/)
  sum =:
    reduce _ 0 (0 .. 11):
      fn(acc i):
        d =: I(digits.$i:S)
        w =: i:odd?.if(3 1)
        acc +: d * w
  check =: (10 - (sum % 10)) % 10
  check ==: I(digits.12:S)
