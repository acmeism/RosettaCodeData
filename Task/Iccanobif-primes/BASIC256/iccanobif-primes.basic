#include "isprime.kbs"

cnt = 0 : prev = 0 : curr = 1

print "First 10 iccanobiF primes:"
while cnt < 10
	sgte = prev + curr
	prev = curr
	curr = sgte
	rev = reverseNumber(curr)
	if isPrime(rev) then
		# have a prime iccanobif number
		cnt += 1
		print rev; " ";
	end if
end while
end

function reverseNumber(num)
	if num < 10 then return num
	reverse = 0
	while num > 0
		reverse = 10 * reverse + num mod 10
		num = int(num / 10)
	end while
	return reverse
end function
