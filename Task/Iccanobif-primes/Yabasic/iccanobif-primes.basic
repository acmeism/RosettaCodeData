//import isprime

cnt = 0 : prev = 0 : curr = 1
print "First 10 iccanobiF primes:"
while cnt < 10
	sgte = prev + curr
	prev = curr
	curr = sgte
	rev = reverseNumber(curr)
	if isPrime(rev) then
		// have a prime iccanobif number
		cnt = cnt + 1
		print rev, " ";
	fi
wend
print
end

sub reverseNumber(num)
    local revers
	
	if num < 10  return num
	revers = 0
	while num > 0
		revers = 10 * revers + mod(num, 10)
		num = int(num / 10)
	wend
	return revers
end sub
