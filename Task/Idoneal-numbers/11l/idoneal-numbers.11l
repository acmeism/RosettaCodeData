F is_idoneal(num)
   ‘ Return true if num is an idoneal number ’
   L(a) 1 .< num
      L(b) a + 1 .< num
         I a * b + a + b > num
            L.break
         L(c) b + 1 .< num
            V sum3 = a * b + b * c + a * c
            I sum3 == num
               R 0B
            I sum3 > num
               L.break
   R 1B

V row = 0
L(n) 1..1999
   I is_idoneal(n)
      row++
      print(f:‘{n:5}’, end' I row % 13 == 0 {"\n"} E ‘’)
