isIdoneal = function(n)
	for a in range(1, n)
		for b in range(a + 1, n)
			if a * b + a + b > n then break
			for c in range(b + 1, n)
				sum3 = a * b + b * c + a * c
				if sum3 == n then return false
				if sum3 > n then break
			end for
		end for
	end for
	return true
end function

idoneals = []
for n in range(1, 2000)
	if isIdoneal(n) then idoneals.push(n)
end for

print idoneals.join(", ")
