with javascript_semantics
function idoneal(integer n)
    for a=1 to n do
        for b=a+1 to n do
            if a*b+a+b>n then exit end if
            integer ab = (2*a + b)*b
            for c=b+1 to n do
                ab += a+b
                if ab == n then return false end if
                if ab >= n then exit end if
            end for
         end for
    end for
    return true
end function
sequence res = filter(tagset(1850),idoneal)
printf(1,"The %d known Idoneal numbers:\n%s\n",
         {length(res),join_by(res,1,13," ",fmt:="%4d")})
