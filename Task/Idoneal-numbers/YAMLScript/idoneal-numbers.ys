!ys-0

defn main(limit=100):
  each n (1 .. limit):
    when idoneal?(n):
      say: n

defn idoneal?(n):
  bad =:
    some identity:
      for a (1 .. n), b (a .. n):
        total =: a * b
        total +=: a
        total +=: b
        when total == n:
          gcd(a b) != 1
  not: bad

defn gcd(a b):
  loop a a, b b:
    if b.?:
      recur: b, (a % b)
      else: a
