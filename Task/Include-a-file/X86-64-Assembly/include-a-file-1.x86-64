;*********************************
; MACROS
;*********************************
displayLib MACRO messa
local mess1,LGMESS1C
.data
 mess1  db messa,10,0
 LGMESS1C equ $ - mess1
.code
   push rax
   push rcx
   push rdx
   push r8
   push r9
   push r10
   push r11
   mov rcx, offset  mess1
   mov rdx,LGMESS1C
   call afficherConsole
   pop r11
   pop r10
   pop r9
   pop r8
   pop rdx
   pop rcx
   pop rax

ENDM
