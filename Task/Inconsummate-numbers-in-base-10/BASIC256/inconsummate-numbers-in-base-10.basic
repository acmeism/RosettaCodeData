m = 999
dim c(m) fill false
z = m * 9 * (length(string(m))-1)

for i = 10 to z
	j = i
	s = 0
	while j <> 0
		s += (j % 10)
		j /= 10
	end while
	if i % s = 0 then j = i \ s : if j <= m then c[j] = true
next i

cont = 0
print "The first 50 inconsummate numbers:"
for i = 10 to m
	if cont = 50 then end
	if not c[i] then cont += 1 : print rjust(string(i), 4);
next i
