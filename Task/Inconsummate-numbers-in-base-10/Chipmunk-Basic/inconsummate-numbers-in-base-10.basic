110 m = 999
120 dim c(m)
130 z = m*9*(len(str$(m))-1)
140 for i = 10 to z
150  j = i : s = 0
160  s = s+j mod 10 : j = int(j/10) : if j then goto 160
170  if i mod s = 0 then j = int(i/s) : if j <= m then c(j) = -1
180 next i
190 j = 0
200 for i = 10 to m
210  if j = 50 then end
220  if c(i) <> -1 then j = j+1 : print i,
230 next i
