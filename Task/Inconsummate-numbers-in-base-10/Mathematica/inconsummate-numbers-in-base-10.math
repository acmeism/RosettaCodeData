generateInconsummates[size_] := Complement[Range[10^size],
   Cases[Map[#/Total[IntegerDigits[#]] &, Range[9*size*10^size]], _Integer]];

size = 1;
inconsummates = {};
While[Length[inconsummates] < 1000,
    inconsummates = generateInconsummates[size];
    size++
];

"The first 50 inconsummate numbers in base 10:"
Partition[Take[inconsummates, 50], 10] // TableForm

"The 1000th inconsummate number:"
inconsummates[[1000]]
