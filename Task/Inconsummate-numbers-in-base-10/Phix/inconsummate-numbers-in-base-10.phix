--demo\rosetta\incomsummate_numbers.exw
-- find some incomsummate numbers: integers that cannot be expressed as
--                          an integer divided by the sum of its digits
constant maxConsummate = 9_999_999,
         count_limit = (maxConsummate+1)/10,
         logmc = ceil(log10(maxConsummate))
-- table of numbers that can be formed by n / digit_sum(n):
sequence consummate = repeat(false,maxConsummate)
consummate[1] = true
-- calculate the maximum number we must consider to find consummate numbers
-- up to maxConsummate - which is 9 * the number of digits in maxConsummate
integer maxNumber = maxConsummate * 9*logmc
-- construct the digit sums of the numbers up to maxNumber and find the consumate numbers
sequence digits = 1 & repeat(0,logmc)
integer sumd = 1
for n=10 to maxNumber by 10 do
    for d=n to n+9 do
        if rmdr(d,sumd)==0 then  -- d is comsummate
            atom dRatio = d/sumd
            if dRatio<=maxConsummate then
                consummate[dRatio] = true
            end if
        end if
        sumd += 1
    end for
    sumd -= 10
    for i,d in digits do
        if d<9 then
            digits[i] = d+1
            sumd += 1
            exit
        end if
        digits[i] = 0
        sumd -= 9
    end for
end for
integer count = 0, nth = 1000
puts(1,"The first 50 inconsummate numbers:\n")
for i=1 to maxConsummate do
    if not consummate[i] then
        count += 1
        if count<51 then
            printf(1,"%6d%n", {i,rmdr(count,10)==0})
        elsif count==nth then
            printf(1,"inconsummate number %6d: %8d\n",{count,i})
            if count=count_limit then exit end if
            nth *= 10
        end if
    end if
end for
