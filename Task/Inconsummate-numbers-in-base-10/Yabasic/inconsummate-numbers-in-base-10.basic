m = 999
dim c(m)
z = m * 9 * (len(str$(m))-1)

for i = 10 to z
	j = i
	s = 0
	while j <> 0
		s = s + mod(j, 10)
		j = int(j / 10)
	wend
	if mod(i, s) = 0 then j = int(i / s) : if j <= m then c(j) = true : fi : fi
next i

cont = 0
print "The first 50 inconsummate numbers:"
for i = 10 to m
	if cont = 50  end
	if not c(i) then cont = cont + 1 : print i using("####"); : fi
next i
print
