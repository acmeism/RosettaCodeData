Camera = {}

Camera.snap = function
    print "taking a photo"
end function

Phone = {}

Phone.call = function
    print "calling home"
end function

CameraPhone = new Camera  // inherits Camera's 'snap' method
CameraPhone.phone = null  // use composition for the Phone part

CameraPhone.call = function
    p = self.phone
    if p then p.call      // wraps' Phone's 'call' method
end function

p = new Phone
cp = new CameraPhone
cp.phone = p
cp.snap
cp.call
