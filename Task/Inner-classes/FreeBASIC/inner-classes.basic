Type Inner
    campo As Integer
End Type

Type Outer
    campo As Integer
    interno As Inner
End Type

Sub outerMethod(o As Outer)
    Print "Outer's field has a value of "; o.field
End Sub

Sub innerMethod(o As Outer)
    Print "Inner's field has a value of "; o.interno.field
End Sub

Dim As Outer o
o.field = 43
o.interno.field = 42
innerMethod(o)
outerMethod(o)

Dim As Outer p
p.field = 45
p.interno.field = 44
innerMethod(p)
outerMethod(p)

Sleep
