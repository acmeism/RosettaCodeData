string 0;

proc PrintLn(Str);      \"method" to print a line of text
char Str;
[Text(0, Str);
CrLf(0);
];

char Line(1000);
int  N, I, C;
for N:= 1 to IntIn(1) do
    [I:= 0;
    loop [repeat C:= ChIn(1) until C # $0D \CR\;
         if C = $0A \LF\ then quit;
         Line(I):= C;
         I:= I+1;
         ];
    Line(I):= 0;
    PrintLn(Line);
    ]
