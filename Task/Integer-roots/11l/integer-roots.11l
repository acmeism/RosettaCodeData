F iRoot(BigInt b, Int n)
   I b < 2 {R b}
   V n1 = n - 1
   V n2 = BigInt(n)
   V n3 = BigInt(n1)
   V c = BigInt(1)
   V d = (n3 + b) I/ n2
   V e = (n3 * d + b I/ d ^ n1) I/ n2
   L c != d & c != e
      c = d
      d = e
      e = (n3 * e + b I/ e ^ n1) I/ n2
   I d < e {R d}
   R e

print(‘3rd root of 8 = ’iRoot(8, 3))
print(‘3rd root of 9 = ’iRoot(9, 3))
print(‘First 2001 digits of the square root of 2: ’iRoot(BigInt(100) ^ 2000 * 2, 2))
