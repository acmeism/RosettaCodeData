local int = require "int"
require "bignum"

local a = { {8, 3}, {9, 3}, {2e+18, 2} }
for a as e do
    local [x, n] = e
    print($"{x} ^ (1/{n}) = {int.root(x, n)}")
end

print("\nFirst 2001 digits of the square root of 2:")
local root2 = bigint.sqrt(bigint.two * bigint.new(100) ^ 2000)
print(root2)
