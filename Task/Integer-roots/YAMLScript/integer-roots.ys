!ys-0

defn main():
  cases =: +[[27 3] [16 2] [81 4] [82 4]]
  each [n k] cases:
    say: "$n root $k = $(iroot(n k))"

defn iroot(n k):
  loop lo 0, hi n:
    if lo > hi:
      then: hi
      else:
        mid =: (lo + hi) // 2
        p =: mid ** k
        cond:
          p == n: mid
          p < n:
            recur: mid.++, hi
          else:
            recur: lo, mid.--
