!ys-0

# YS has no dedicated REPL prompt; you evaluate expressions ad hoc with
# `ys -pe '...'`, which reads, evals, and prints one expression:
#   $ ys -pe '((fn [a b sep] (str a sep sep b)) "Rosetta" "Code" ":")'
#   "Rosetta::Code"
# (YS also embeds in a Clojure REPL via the libys shared library.)
# This file reproduces that interaction non-interactively.

defn main():
  say: f('Rosetta' 'Code' ':')

defn f(a b sep):
  a + (sep * 2) + b
