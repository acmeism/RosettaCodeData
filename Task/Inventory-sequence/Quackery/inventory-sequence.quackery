  [ 0 unrot witheach
      [ over =
        rot + swap ]
    drop ]                  is occurs  ( n [ --> n   )

  [ 2dup occurs
    tuck join
    dip [ 0 != tuck * + ] ] is additem ( n [ --> n [ )

  0 [] 100 times additem
  witheach
    [ dup 10 < if sp
      echo sp
      i^ 10 mod 9 = if cr ]
  drop
  cr
  0 []
  [ additem
    dup -1 peek 999 >
    until ]
  say "Element #"
  dup size 1 - echo
  say " is "
  -1 peek echo
  say "." cr
  drop
