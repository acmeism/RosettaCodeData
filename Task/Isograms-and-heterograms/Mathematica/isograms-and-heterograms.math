isogramQ[w_] := SameQ @@ Tally[Characters[w]][[All, 2]];
isogramLevel[w_] := Count[Characters[w], StringTake[w, 1]];

words = ReadList["unixdict.txt", Word];
isograms = Select[words, isogramQ];

"n-isograms with n > 1:"
Select[isograms, isogramLevel[#] > 1 &] //
    SortBy[{-isogramLevel[#], -StringLength[#], #} &] // TableForm

"Heterograms with more than 10 letters:"
Select[isograms, isogramLevel[#] == 1 && StringLength[#] > 10 &] //
    SortBy[{-StringLength[#], #} &] // TableForm
