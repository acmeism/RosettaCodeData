!ys-0

defn main(a=1001, n=9907):
  say: "($a / $n) = $(jacobi(a n))"

defn jacobi(a n):
  loop a (mod a n), n n, t 1:
    cond:
      a.!:
        if n == 1: t 0
      a:even?:
        a =: a // 2
        r =: n % 8
        flip? =: r.in?([3 5])
        t =: flip?.if((0 - t) t)
        recur: a, n, t
      else:
        amod =: a % 4
        nmod =: n % 4
        flip? =: (amod == 3).when(nmod == 3)
        t =: flip?.if((0 - t) t)
        recur: (n % a), a, t
