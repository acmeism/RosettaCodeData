F kahansum(input)
   V summ = 0.0s
   V c = 0.0s
   L(num) input
      V y = num - c
      V t = summ + y
      c = (t - summ) - y
      summ = t
   R summ

V eps = 1.0s
L 1.0s + eps != 1.0s
   eps = eps / 2.0s

print(‘Epsilon     = ’eps)
print(‘(a + b) + c = #.7’.format((1.0s + eps) - eps))
print(‘Kahan sum   = #.7’.format(kahansum([1.0s, eps, -eps])))
