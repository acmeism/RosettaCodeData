!ys-0

defn main():
  xs =: concat([1.0] repeat(100000 0.00001) [-1.0])
  say: "plain: $sum(xs)"
  say: "kahan: $kahan(xs)"

defn kahan(xs):
  loop xs xs, sum 0.0, c 0.0:
    if xs:empty?:
      then: sum
      else:
        y =: xs.0 - c
        t =: sum + y
        c =: (t - sum) - y
        recur: xs:rest, t, c
