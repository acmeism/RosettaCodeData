!ys-0

# Print quake records whose magnitude exceeds 6.
# The data is embedded as a block scalar so the program runs with no
# args; the third whitespace field is the magnitude.

data =: |
  8/27/1883    Krakatoa            8.8
  5/18/1980    MountStHelens       7.6
  3/13/2009    CostaRica           5.1

defn main(text=data):
  each line text:lines.remove(empty?):
    mag =: line:words.$.N()
    when mag > 6:
      say: line
