!ys-0

# (. IN ready) is a non-blocking "input waiting?" test on stdin, so
# the program never stops to wait. A terminal delivers keys only
# after Enter unless put in raw mode first (e.g. `stty -icanon`).

defn main():
  key =: keypress()
  if key:
    say: "Key pressed: $key"
    say: 'No key pressed'

defn keypress():
  when (. IN ready):
    C: (. IN read)
