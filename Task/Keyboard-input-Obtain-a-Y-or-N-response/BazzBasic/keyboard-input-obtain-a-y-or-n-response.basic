' ============================================
' https://rosettacode.org/wiki/Keyboard_input/Obtain_a_Y_or_N_response
' BazzBasic: https://github.com/EkBass/BazzBasic
' ============================================
PRINT "Press Y or N to continue."

' Works with "N", "n", "Y" & "y"
LET key$ = WAITKEY(KEY_Y#, KEY_N#)
PRINT "You pressed: "; CHR(key$)
