!ys-0

# ys has no portable raw-tty mode, so we read a whole line (Enter needed)
# and loop until its first character is Y or N (case-insensitive).
defn main():
  loop:
    print: 'Press Y or N: '
    line =: read-line()
    when line:nil?: die('No input')
    key =: line:trim:lc.0
    if key.in?('yn'):
      say: "You pressed $(key:uc)"
      recur:
