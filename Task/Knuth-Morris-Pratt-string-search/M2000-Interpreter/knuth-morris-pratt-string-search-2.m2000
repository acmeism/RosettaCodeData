FUNCTION GLOBAL search_kmp(d$, t$) {
	VAR d=@load_string(d$), t=@load_string(t$)
	LONG j, k
	VAR tm = @table_kmp(t)
	VAR lim=LEN(d) DIV 2, limT=LEN(t) DIV 2
	VAR result=STACK
	WHILE j < lim
		IF t[k] = d[j] THEN
			j++:k++
			IF k = limT THEN
				STACK result {DATA j - k}
				k = tm[k]
			END IF
		ELSE
			k = tm[k]
			IF k < 0 THEN j++:k++
		END IF
	END WHILE
	=ARRAY(result)
	FUNCTION load_string(a$)
		LOCAL m
		BUFFER m AS INTEGER*LEN(a$)
		RETURN m, 0:=a$
		=m
	END FUNCTION
	FUNCTION table_kmp(t AS BUFFER)
		LOCAL LONG p = 1, count = 0, lim=LEN(t) DIV 2
		LOCAL LONG result[lim]
		result[0] = -1
		WHILE p < lim
			IF t[p] = t[count] THEN
				result[p] = result[count]
			ELSE
				result[p] = count
				WHILE count >= 0
					IF t[p] <> t[count] ELSE EXIT
					count = result[count]
				END WHILE
			END IF
			p++
			count++
		END WHILE
		result[p] = count
		=result
	END FUNCTION
}
MODULE SEARCH_STRING (W) {
	FLUSH
	SearchList=List:="TCTA":=0, "TAATAAA":=1, "word":=2, "needle":=3, "put":=4, "and":=4, "alfalfa":=5
	DATA "GCTAGCTCTACGAGTCTA",
	DATA "GGCTATAATGCGTA",
	DATA "there would have been a time for such a word",
	DATA "needle need noodle needle",
	DATA "InhisbookseriesTheArtofComputerProgrammingpublishedbyAddisonWesleyDKnuthusesanimaginarycomputertheMIXanditsassociatedmachinecodeandassemblylanguagestoillustratetheconceptsandalgorithmsastheyarepresented"
	DATA "Nearby farms grew a half acre of alfalfa on the dairy's behalf, with bales of all that alfalfa exchanged for milk."
	Dim s()
	s()=Array([])
	one=each(s())
	WHILE one
		PRINT #W, "Text"+(one^+1)+": "+array$(one)
	END WHILE
	
	one=each(SearchList)
	WHILE one
		q=EVAL(one)
		m=search_kmp(s(q) , EVAL$(one!))
		PRINT #W, "From Text"+(q+1)+" searching "+QUOTE$(EVAL$(one!))+": ["+m#STR$(", ")+"]"
	END WHILE
}
SEARCH_STRING -2
OPEN "OUTPUT.TXT" FOR WIDE OUTPUT AS #N
SEARCH_STRING N
CLOSE #N
WIN DIR$+"OUTPUT.TXT"

