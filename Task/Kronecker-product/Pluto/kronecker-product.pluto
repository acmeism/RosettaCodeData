require "matrix"

local a1 = {
    {1, 2},
    {3, 4}
}

local a2 =  {
    {0, 5},
    {6, 7}
}

local a3 = {
    {0, 1, 0},
    {1, 1, 1},
    {0, 1, 0}
}

local a4 = {
    {1, 1, 1, 1},
    {1, 0, 0, 1},
    {1, 1, 1, 1}
}

local m1 = matrix.from(a1)
local m2 = matrix.from(a2)
print(m1:kronecker(m2))
print()
local m3 = matrix.from(a3)
local m4 = matrix.from(a4)
print(m3:kronecker(m4))
