!ys-0

defn main():
  a1 =:: [[1, 2], [3, 4]]
  b1 =:: [[0, 5], [6, 7]]
  a2 =:: [[0, 1, 0], [1, 1, 1], [0, 1, 0]]
  b2 =:: [[1, 1, 1, 1], [1, 0, 0, 1], [1, 1, 1, 1]]
  show: kron(a1 b1)
  say:
  show: kron(a2 b2)

defn kron(a b):
  rows =:
    for row-a a:
      for row-b b:
        row =:
          mapcat _ row-a:
            fn(x):
              map \(_ * x): row-b
        vec: row
  concat: rows*

defn show(matrix):
  each row matrix:
    say: row:joins
