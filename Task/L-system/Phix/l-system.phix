function lindenmayer(string s, sequence rules, integer count)
    sequence {chars, reps} = columnize(rules)
    for i=1 to count do
        string nxt = ""
        for c in s do
            integer k = find(c,chars)
            nxt &= iff(k?reps[k]:c)
        end for
        s = nxt
    end for
    return s
end function
