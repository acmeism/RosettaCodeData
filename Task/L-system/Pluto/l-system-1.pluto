require "lsystem"
local fmt = require "fmt"

local lsys = lsystem.of(
    {"I", "M"},           -- variables
    {},                   -- constants
    "I",                  -- axiom
    {                     -- rules
        rule.of("I", "M"),
        rule.of("M", "MI")
    }
)

print("Step  String")
print("---- --------")
local steps = lsys:listSteps(5)
for i = 0, 5 do
    fmt.print("%-4d %s", i, fmt.center(steps[i + 1], 8))
end
