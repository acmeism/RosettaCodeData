require "matrix"

local arrays = {
    { {1, 3, 5},
      {2, 4, 7},
      {1, 1, 0} },

    { {11,  9, 24, 2},
      { 1,  5,  2, 6},
      { 3, 17, 18, 1},
      { 2,  5,  7, 1} }
}

for arrays as array do
    local m = matrix.from(array)
    print("A\n")
    print(m)
    print("\nL\n")
    local [l, u, p] = m:lup()
    print(l:format("%8.5f"))
    print("\nU\n")
    print(u:format("%8.5f"))
    print("\nP\n")
    print(p)
    print()
end
