dim number(1000)
highest = 0
lowest = 100000
for i = 0 to 999
	number[i] = int(rand*10)
	if i >= 4 then
		tmp = number[i] + 10*number[i-1] + 100*number[i-2] + 1000*number[i-3] + 10000*number[i-4]
		if tmp < lowest then lowest = tmp
		if tmp > highest then highest = tmp
	end if
next i
print highest, lowest
