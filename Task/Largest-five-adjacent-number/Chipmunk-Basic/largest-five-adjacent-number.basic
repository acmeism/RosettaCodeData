100 randomize timer
110 dim number(999)
120 highest = 0
130 lowest = 100000
140 for i = 0 to 999
150   number(i) = int(rnd(10))
160   if i >= 4 then
170     tmp = number(i)+10*number(i-1)+100*number(i-2)+1000*number(i-3)+10000*number(i-4)
180     if tmp < lowest then lowest = tmp
190     if tmp > highest then highest = tmp
200   endif
210 next i
220 print highest,lowest
230 end
