OpenConsole()
Dim number.i(999)
highest.i = 0
lowest.i = 100000
For i.i = 0 To 999
  number(i) = Random(10)
  If i >= 4:
    tmp = number(i) + 10*number(i-1) + 100*number(i-2) + 1000*number(i-3) + 10000*number(i-4)
    If tmp < lowest: lowest = tmp: EndIf
    If tmp > highest: highest = tmp: EndIf
  EndIf
Next i
PrintN(Str(highest) + #TAB$ + Str(lowest))
