RANDOMIZE
DIM number(0 TO 999)
LET highest = 0
LET lowest = 100000
FOR i = 0 TO 999
    LET number(i) = INT(RND*10)
    IF i >= 4 THEN
       LET tmp = number(i)+10*number(i-1)+100*number(i-2)+1000*number(i-3)+10000*number(i-4)
       IF tmp < lowest THEN LET lowest = tmp
       IF tmp > highest THEN LET highest = tmp
    END IF
NEXT i
PRINT highest, lowest
END
