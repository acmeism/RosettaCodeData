char    Number(1000);
int     Num, Max, I, J;
[for I:= 0 to 1000-1 do         \generate 1000-digit number
        Number(I):= Ran(10);
Max:= 0;                        \find its largest 5-digit number
for I:= 0 to 1000-5 do
        [Num:= 0;
        for J:= 0 to 5-1 do
                Num:= Num*10 + Number(I+J);
        if Num > Max then
                Max:= Num;
        ];
IntOut(0, Max);
]
