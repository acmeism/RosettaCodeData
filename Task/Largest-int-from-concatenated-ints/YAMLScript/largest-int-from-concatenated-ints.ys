!ys-0

# Pair-wise compare (a++b) vs (b++a) as strings; sort descending
# with that comparator and concatenate the results.

defn main():
  each xs [[1 34 3 98 9 76 45 4] [54 546 548 60]]:
    say: "$xs -> $(largest(xs))"

defn- largest(xs):
  better.sort(xs.map(S)):sort:join

defn- better(a b):
  compare (b + a): a + b
