link lists

procedure main(A)
   n := \A[1] | 9
   every (max := 0) <:= lynchbell(makenum(n to 1 by -1))
   write(max)
end

procedure lynchbell(n)
   m := n
   while m > 0 do (n%(m%10) == 0, m /:= 10) | fail
   return n
end

procedure makenum(n)
   suspend tonum(lpermute(lcomb([: 9 to 1 by -1 :],n)))
end

procedure tonum(a)
   every (n := 0, d := !a) do n := 10*n + d
   return n
end
