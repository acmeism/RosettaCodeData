func Rev(A);    \Reverse digits
int A, B;
[B:= 0;
repeat  A:= A/10;
        B:= B*10 + rem(0);
until   A = 0;
return B;
];

int Max, M, N, Prod;
[Max:= 0;
for M:= 100 to 999 do
    for N:= M to 999 do
        [Prod:= M*N;
        if Prod/1000 = Rev(rem(0)) then
            if Prod > Max then Max:= Prod;
        ];
IntOut(0, Max);
]
