include "NSLog.incl"

local fn LargestPrimeFactor( numToFactor as UInt64 )
  UInt64 latestDivisor = 2

  while ( numToFactor != 1 )
    latestDivisor = 2
    while ( numToFactor % latestDivisor != 0 )
      latestDivisor += 1
    wend
    numToFactor /= latestDivisor
  wend
  NSLog( @"%lld", latestDivisor )
end fn

fn LargestPrimeFactor( 600851475143 )

HandleEvents
