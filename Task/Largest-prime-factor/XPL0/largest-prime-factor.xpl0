real Num, Max, Div, Quot;
[Num:= 600851475143.;
Max:= 0.;
Div:= 2.;
repeat  loop    [Quot:= Num / Div;
                if Mod(Quot, 1.) < 1E-10 then \evenly divisible
                        [Num:= Quot;
                        Max:= Div;
                        ]
                else    quit;
                if Div > Num then quit;
                ];
        Div:= Div + 1.;
until   Div > Num;
Format(1, 0);
RlOut(0, Max);
]
