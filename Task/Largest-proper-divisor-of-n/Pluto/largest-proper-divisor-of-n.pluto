local int = require "int"
local fmt = require "fmt"

print("The largest proper divisors for numbers in the interval [1, 100] are:")
io.write(" 1  ")
for n = 2, 100 do
    if n % 2 == 0 then
        fmt.write("%2d  ", n // 2)
    else
        fmt.write("%2d  ", int.divisors(n, true):back())
    end
    if n % 10 == 0 then print() end
end
