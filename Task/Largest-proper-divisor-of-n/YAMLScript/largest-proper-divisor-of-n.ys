!ys-0

# Largest proper divisor: scan down from n-1; first that divides
# wins. a(1) = 1.

defn main():
  rows =: partition(10 (1 .. 100).map(lpd))
  each row rows:
    say: row.map(\(format("%3d" _))):join
  say: ''

defn- lpd(n):
  if n != 1:
    loop i n.--:
      if pos?(n % i):
        recur: i.--
        else: i
    else: 1
