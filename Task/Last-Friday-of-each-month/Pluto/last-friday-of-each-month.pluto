local fmt = require "fmt"

assert(#arg == 1, "Please pass just the year to be processed.")
local year = arg[1]
print($"The dates of the last Sundays in the month for {year} are:")
for m = 1, 12 do
    local d = fmt.month(m, year)
    local t = os.time({year = year, month = m, day = d})
    local wd = tonumber(os.date("%u", t))
    if wd > 5 then
        t -= 86400 * (wd - 5)
    elseif wd < 5 then
        t -= 86400 * (wd + 2)
    end
    print(os.date("%F", t))
end
