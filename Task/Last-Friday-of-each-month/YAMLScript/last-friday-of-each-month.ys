!ys-0

defn main(year=2012):
  each month (1 .. 12):
    say: last-friday(year month):S

defn last-friday(year month):
  last-d =: last-of-month(year month)
  loop d last-d:
    if java-time/friday?(java-time/day-of-week(d)):
      then: d
      else:
        recur: java-time/minus(d java-time/days(1))

defn last-of-month(year month):
  first =: java-time/local-date(year month 1)
  next-m =: java-time/plus(first java-time/period(0 1 0))
  java-time/minus next-m: java-time/days(1)
