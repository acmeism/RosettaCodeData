100 REM Leap year
110 DECLARE EXTERNAL FUNCTION IsLeap
120 FOR Y = 1750 TO 2022
130    IF IsLeap(Y) <> 0 THEN PRINT Y;
140 NEXT Y
150 PRINT
160 END
170 REM
180 EXTERNAL FUNCTION IsLeap(Y)
190 LET Result = 0
200 IF MOD(Y, 4) = 0 AND MOD(Y, 100) <> 0 THEN LET Result = -1
210 IF MOD(Y, 400) = 0 THEN LET Result = -1
220 LET IsLeap = Result
230 END FUNCTION
