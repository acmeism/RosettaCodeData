' Leap year
BEGIN DEF
pointer word LPtr~
SUB CheckIfLeap (Y%, LPtr~)

BEGIN CODE
FOR Y% = 1750 TO 2022
  CALL CheckIfLeap(Y%, VARPTR(L%))
  IF L% = TRUE THEN
    PRINT Y% + " "
  ENDIF
NEXT
PRINT "\n"
END

SUB CheckIfLeap (Y%, LPtr~)
[LPtr~] = FALSE
YMod% = Y% MOD 4
IF YMod% = 0 THEN
  YMod% = Y% MOD 100
  IF YMod% <> 0 THEN
    [LPtr~] = TRUE
  ENDIF
  YMod% = Y% MOD 400
  IF YMod% = 0 THEN
    [LPtr~] = TRUE
  ENDIF
ENDIF
END SUB
