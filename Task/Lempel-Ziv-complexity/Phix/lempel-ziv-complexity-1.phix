function lempel_ziv_complexity(string s)
    integer complexity = 0,
            n = length(s),
            c_start = n=0 -- (loop not for empty string, else 0)
    string ehist = "" -- (exhaustive history, entirely optional)
    while c_start<n do
        complexity += 1
        integer component_len = 1
        string component
        do
            component = s[c_start+1..c_start+component_len]
            if not rmatch(component,s,c_start) then
                component &= "."
                exit
            end if
            component_len += 1
        until c_start+component_len>n
        ehist &= component
        c_start += component_len
    end while
    return {ehist,complexity}
end function

constant tests = {{                 "AZSEDRFTGYGUJIJOKB",16},
                  {                 "ABCABCABCABCABCABC", 4},
                  {           "111011111001111011111001", 6},
                  {                 "101001010010111110", 5},
                  {                   "1001111011000010", 6},
                  {                         "1010101010", 3},
                  {                   "1010101010101010", 3},
                  {             "1001111011000010000010", 7},
                  {           "100111101100001000001010", 8},
                  {                   "0001101001000101", 6},
                  {                            "1111111", 2},
                  {                               "0001", 2},
                  {                                "010", 3},
                  {                                  "1", 1},
                  {                                   "", 0},
                  {               "01011010001101110010", 7},
                  {         "ABCDEFGHIJKLMNOPQRSTUVWXYZ",26},
  {"HELLO WORLD! HELLO WORLD! HELLO WORLD! HELLO WORLD!",11}}

for te in tests do
    {string test, integer expected} = te
    {string hist, integer complexity} = lempel_ziv_complexity(test)
    string error = iff(complexity==expected?"":"  ***ERROR***")
    printf(1,"%64s: %2d%s\n",{hist,complexity,error})
end for
