# Leonardo numbers

proc printleonnums(k0, k1, sum, lmt, what) is
  printf("%s (%d, %d, %d):\n", what, k0, k1, sum);
  if lmt >= 1 then printf("%d ", k0) fi;
  if lmt >= 2 then printf("%d ", k1) fi;
  for i from 3 to lmt do
    printf("%d ", k0 + k1 + sum);
    tmp := k0
    k0 := k1;
    k1 := tmp + k1 + sum
  od;
  print()
end;

scope
  printleonnums(1, 1, 1, 25, "Leonardo numbers");
  printleonnums(0, 1, 0, 25, "Fibonacci numbers")
epocs
