!ys-0

# BSD and MS LCG: state_{n+1} = (a*state + c) mod 2^31.
# MS shifts state right 16 to keep the high bits.

defn main():
  say: 'BSD RAND:'
  each n lcg(0 1103515245 12345).take(5):
    say: n
  say: 'MS RAND:'
  ms =: map(\(_.quot(65536)) lcg(0 214013 2531011))
  each n ms.take(5):
    say: n

m =: 2 ** 31
defn- lcg(seed a c): !rest
  iterate \(((a * _) + c) % m): seed
