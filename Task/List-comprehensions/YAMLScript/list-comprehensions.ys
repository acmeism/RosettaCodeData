!ys-0

# Pythagorean triples (a,b,c) with 1<=a<=b<=c<=n, a^2+b^2=c^2.
# YS has `for` as a list comprehension with :when filters.

defn main(n=20):
  triples =:
    ? for a (1 .. n)
          b (a .. n)
          c (b .. n)
          :when ((a:sqr + b:sqr) == c:sqr)
    : vector: a b c
  say: "Triples up to $n:"
  each t triples: say(t)
