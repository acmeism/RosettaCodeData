constant az = tagset('z','a'),
         bz = tagset('z','b'),
      tests = {{{94, 94, 13, 77, 35, 10, 51, 27, 60}, 6},
               {{19, 46, 43, 17, 94}, 1},
               {{93, 88, 40, 88, 30, 68, 84, 25}, 3},
               {{88, 94, 10, 27, 54, 14}, 3},
               {{31, 19, 63, 57, 57, 74, 50, 14, 38}, 4},
               {{72, 57, 89, 55, 36, 84, 10, 95, 99, 35}, 7},
               {{23, 49, 57}, 10},
               {{1}, 2},
               {{}, 2},
               {bz, 2}, {az, 2},
               {bz, 5}, {az, 5},
               {bz, 9}, {az, 9}}

for t in tests do
    integer n
    {t, n} = t
    string s = sprintf("%v into %d part%s",{t,n,iff(n=1?"":"s")})
    sequence res = {}
    for i=1 to n do
        integer k = ceil((length(t))/(n-(i-1)))
        res &= {t[1..k]}
        t = t[k+1..$]
    end for
    printf(1,"%s: %v\n",{s,res})
end for
