!ys-0

# YS inherits Clojure's reader, so the same notations work here.

defn main():
  show '42':         42
  show '-42':        -42
  show '0xFF':       0xFF
  show '0o17':       0o17
  show '2r1010':     2r1010
  show '3r210':      3r210
  show '16rDEAD':    16rDEAD
  show '36rZZZ':     36rZZZ
  show '123456789N': 123456789N

defn show(label n):
  say: "$label => $n"
