function is_long_prime(integer n)
    integer count = 0
    for f in factors(n-1,1) do
        integer e=1, base=10
        while f!=0 do
            if odd(f) then
                e = rmdr(e*base,n)
            end if
            base = rmdr(base*base,n)
            f = floor(f/2)
        end while
        if e=1 then
            count += 1
            if count>1 then exit end if
        end if
    end for
    return count=1
end function

procedure main()
    atom t0 = time()
    integer count = 0, n = 500, i = 2
    sequence long_primes = {}
    while true do
        integer prime = get_prime(i)
        if is_long_prime(prime) then
            if prime<500 then
                long_primes &= prime
            end if
            if prime>n then
                if n=500 then
                    string lp = join_by(long_primes,1,7," ","\n ","%3d")
                    printf(1,"The long primes up to 500 are:\n %s\n",{lp})
                    printf(1,"The number of long primes up to:\n")
                end if
                string et = elapsed(time()-t0,0.5," (%s)")
                printf(1,"  %,10d is %,d%s\n", {n, count, et})
                if time()-t0>20 then exit end if
                n *= 2
            end if
            count += 1
        end if
        i += 1
    end while
end procedure
main()
