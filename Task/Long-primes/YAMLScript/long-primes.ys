!ys-0

defn main(limit=100):
  each p (7 .. limit):
    when prime?(p):
      when period(p) == p.--:
        say: p

defn period(p):
  loop r 10, k 1:
    if mod(r p) != 1:
      recur: mod((r * 10) p), k.++
      else: k

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
