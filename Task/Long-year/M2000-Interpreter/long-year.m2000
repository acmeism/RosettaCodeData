MODULE LONG_YEARS {
	FLUSH
	PRINT "LONG YEARS BETWEEN 2000 - 2099"
	FOR I=2000 TO 2099
		DATE A=STR$(I,"")+"-1-1"
		SELECT CASE STR$(A,"w")
		CASE "5"
			DATA I
		CASE "4"
			IF CDATE(A,1,0,0)-A=366 THEN DATA I
		END SELECT
	NEXT
	B=ARRAY([])  ' dump stack to an array (tuple type).
	CLIPBOARD B#STR$(", ")
	' 	same as CLIPBOARD ARRAY([])#STR$(", ")
	PRINT CLIPBOARD$
}
LONG_YEARS
