!ys-0

defn main(*):
  say: "Long years 2000-2030:"
  each y (2000 .. 2030):
    when long-year?(y):
      say: y

defn long-year?(y):
  yn =: y.--
  a =: yn + I(yn / 4)
  b =: a - I(yn / 100)
  c =: b + I(yn / 400)
  p =: c.++ % 7
  is-thu =: p == 4
  is-wed =: p == 3
  is-wed-leap =: is-wed && leap-year?(y)
  is-thu ||: is-wed-leap

defn leap-year?(y):
  (y % 400):zero? ||
    ((y % 4):zero? && (y % 100):zero?.!)
