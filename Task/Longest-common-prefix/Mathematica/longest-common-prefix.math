ClearAll[LCP]
LCP[x_List] := Module[{l, s},
  If[Length[x] > 0,
   l = Min[StringLength /@ x];
   s = Characters[StringTake[x, l]];
   s //= Transpose;
   l = LengthWhile[s, Apply[SameQ]];
   StringTake[First[x], l]
   ,
   ""
   ]
  ]
LCP[{"interspecies", "interstellar", "interstate"}]
LCP[{"throne", "throne"}]
LCP[{"throne", "dungeon"}]
LCP[{"throne", "", "throne"}]
LCP[{"cheese"}]
LCP[{""}]
LCP[{}]
LCP[{"prefix", "suffix"}]
LCP[{"foo", "foobar"}]
