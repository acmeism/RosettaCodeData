!ys-0

cases =::
- [interspecies, interstellar, interstate]
- [throne, throne]
- [throne, dungeon]
- [throne, '']

defn main():
  each case cases:
    prefix =: case:lcp
    say: "\"$prefix\""

defn lcp(strings):
  first =: strings.0
  loop i 0:
    if i == first.#:
      then: first
      else:
        prefix =: subs(first 0 i.++)
        if every? \(_.starts?(prefix)) strings:
          then: recur(i.++)
          else: first.subs(0 i)
