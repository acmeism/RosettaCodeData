function LCS( a, b )
    if #a == 0 or #b == 0 then
        return ""
    elseif a[ #a ] == b[ #b ] then
        return LCS( string.sub( a, 1, -2 ), string.sub( b, 1, -2 ) ) .. a[ #a ]
    else
        local a_sub = LCS( a, string.sub( b, 1, -2 ) )
        local b_sub = LCS( string.sub( a, 1, -2 ), b )
        return if #a_sub > #b_sub then a_sub else b_sub end
    end
end

print( LCS( "thisisatest", "testing123testing" ) )
