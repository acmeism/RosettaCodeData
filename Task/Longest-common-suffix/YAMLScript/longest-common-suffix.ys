!ys-0

defn main(text='walking talking stalking'):
  say: suffix(text:words)

defn suffix(words):
  rev =: words.map(reverse)
  min-len =:
    apply min: rev.map(count)
  common =:
    take-while _ (0 .. min-len.--):
      fn(i):
        chars =: rev.map(\(_.$i)):set
        chars.# ==: 1
  common: .map(\(rev.0.nth(_))):reverse:join
