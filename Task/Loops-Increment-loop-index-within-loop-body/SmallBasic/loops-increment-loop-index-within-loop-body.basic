func isPrime(number)
    local i, lim
    if (number % 2 == 0) or (number % 3 == 0) then return false
    lim = sqr(number)
    for i = 5 to lim step 2
        if(number % i == 0) then return false
    next
    return true
end

i = 42
counter = 0
while counter < 42
    if isPrime(i)
        counter += 1
        print "n = "; counter, format("##,###,###,###,###",i)
        i *= 2
    endif
    i += 1
wend
