!ys-0

defn main(rows=4 cols=5):
  matrix =:
    for r (1 .. rows):
      for c (1 .. cols):
        rand-int(20).++

  # Loop rows/cols; break out of both when 20 is seen.
  loop i 0, found false:
    when (i < rows) && not(found):
      hit =: print-row(matrix.$i cols)
      say:
      recur: i.++ hit

defn print-row(row cols):
  loop j 0:
    when j < cols:
      v =: row.$j
      print: "$v "
      if v == 20:
        true
        recur(j.++)
