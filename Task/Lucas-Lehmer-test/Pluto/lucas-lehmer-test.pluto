local int = require "int"
require "bignum"

mpz.init()
local max = 28
local count = 0
local table = {521, 607, 1279, 2203, 2281, 3217, 4253, 4423, 9689, 9941, 11213, 19937, 21701, 23209, 44497, 86243, 110503}
local p = 3  -- first odd prime
local ix = 1
local m, s
local one = bigint.one
while true do
    m = mpz.shl(one, p, 1)
    mpz.sub(m, 1)
    s = mpz.set(2, 4)
    for i = 1, p - 2 do
        mpz.mulVar(s, s)
        mpz.sub(s, 2)
        mpz.remVar(s, m)
    end
    if mpz.sgn(s) == 0 then
        count += 1
        io.write($"M{p} ")
        if count == max then
            print()
            break
        end
        io.output():flush()
    end
    -- Obtain next odd prime or look up in table after 127.
    if p < 127 then
        while true do
            p += 2
            if int.isprime(p) then break end
        end
    else
        p = table[ix]
        ix += 1
    end
end
mpz.clearAll()
