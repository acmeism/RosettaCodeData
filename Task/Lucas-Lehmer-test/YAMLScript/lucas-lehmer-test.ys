!ys-0

# Lucas-Lehmer test for Mersenne primes.
# For odd prime p, M_p = 2^p - 1 is prime iff S(p-1) mod M_p = 0
# where S(1) = 4, S(n+1) = S(n)^2 - 2.

defn main(limit=2000):
  say: 'Mersenne primes M_p for prime p up to limit:'
  each p limit:odd-primes:
    when p:ll?:
      say: "  p = $p"

defn- ll?(p):
  m =: reduce(* 1N p.repeat(2N)) - 1
  loop s bigint(4) i 1:
    if i == p.--:
      then: (s % m):zero?
      else:
        s2 =: (s * s) - 2
        recur: (s2 % m) i.++

defn- odd-primes(n):
  filter prime?: 3 .. n

defn- prime?(n):
  cond:
    n < 2: false
    n < 4: true
    (n % 2):zero?: false
    else: trial(n 3)

defn- trial(n d):
  cond:
    d:sqr > n: true
    (n % d):zero?: false
    else: recur(n (d + 2))
