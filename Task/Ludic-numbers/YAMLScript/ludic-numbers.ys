!ys-0

# Ludic sieve: repeatedly take the first survivor L, then drop every
# L-th item by index (index 0 included), until we have enough.

defn main(want=25):
  say: ludics(want):joins

defn ludics(want):
  limit =: (want * want) + 100
  loop nums (2 .. limit), acc [1]:
    if acc.# == want:
      then: acc
      else:
        l =: nums:first
        recur: remove-every(l nums) acc.conj(l)

defn remove-every(l nums):
  keep-indexed _ nums:
    fn(i x):
      when-not (i % l):zero?: x
