function lunar_add(atom a, b)
   atom e = 1, r = 0
   while a or b do
      r += max(rmdr(a,10),rmdr(b,10))*e
      a = floor(a/10)
      b = floor(b/10)
      e *= 10
   end while
   return r
end function

function lunar_mul(atom a, b)
    nested function inner_mul(atom a, b, e)
       atom r = 0
       while a do
          r += min(rmdr(a,10),b)*e
          a = floor(a/10)
          e *= 10
       end while
       return r
    end nested function

    atom e = 1, r = 0
    while b do
        r = lunar_add(r,inner_mul(a,rmdr(b,10),e))
        b = floor(b/10)
        e *= 10
    end while
    return r
end function

for t in {{976,348},{23,321},{232,35},{123,32192,415,8}} do
   integer s = 0,
           p = 9
   for h in t do
      s = lunar_add(s,h)
      p = lunar_mul(p,h)
   end for
   printf(1,"%18v: lunar_add -> %-6d,",{t,s})
   printf(1,    "  lunar_mul -> %d\n",{p})
end for
sequence evens = {}
integer n = 1
while length(evens)<20 do
    integer r = lunar_mul(n,2)
    if not find(r,evens) then evens &= r end if
    n += 1
end while
printf(1,"First 20 distinct even lunar numbers: %v\n",{evens})
sequence squares = apply(true,lunar_mul,{tagset(19,0),tagset(19,0)})
printf(1,"First 20 square lunar numbers: %v\n",{squares})
atom fac = 1
sequence factorials = {fac}
for i=1 to 19 do
    fac = lunar_mul(fac,i)
    factorials &= fac
end for
factorials = join(factorials," ",fmt:="%d")
printf(1,"First 20 factorial lunar numbers:\n%s\n",{factorials})
integer i = 1, sq = 0, psq = 0
while sq>=psq do
    i += 1
    psq = sq
    sq = lunar_mul(i,i)
end while
printf(1,"First lunar square smaller than previous: %d squared = %d, previous = %d\n",
         {i,sq,psq})
