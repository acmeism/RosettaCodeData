glinewidth 0.1
rad = 35
halfw = 10
k = 0.6
func[] get u v .
   x1 = (rad + v * cos (u / 2)) * cos u
   y1 = (rad + v * cos (u / 2)) * sin u
   z1 = v * sin (u / 2)
   px1 = 50 + x1 + z1 * k
   py1 = 50 + y1 - z1 * k
   return [ px1 py1 ]
.
for u = 0 step 4 to 360 - 4
   p1[] = get u -halfw
   p2[] = get u halfw
   gline p1[1] p1[2] p2[1] p2[2]
.
for h = -halfw step 2 to halfw
   gpenup
   for u = 0 step 4 to 360
      p[] = get u h
      glineto p[1] p[2]
   .
.

