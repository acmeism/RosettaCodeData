with javascript_semantics
requires("1.0.6")
include theGUI.e

constant radius = 150,
         half_width = 60,
         k = 0.3

function get_pt(atom u, v)
   atom r = v*cos(u/2)+radius,
        z = v*sin(u/2)*k,
        x = 300 + r*cos(u) + z,
        y = 300 + r*sin(u) - z
   return {x,y}
end function

procedure redraw(gdx canvas)
    for u=0 to 360 by 2 do
        atom rad_u = u*PI/180
        sequence p1 = get_pt(rad_u,-half_width),
                 p2 = get_pt(rad_u,half_width)
        gDrawLine(canvas,p1,p2,colour:=TG_RED)
    end for
    for h=-half_width to half_width by 10 do
        sequence xy, pxy
        for u = 0 to 360 by 4 do
            xy = get_pt(u*PI/180,h)
            if u!=0 then
                gDrawLine(canvas,pxy,xy,colour:=TG_RED)
            end if
            pxy = xy
        end for
    end for
end procedure

gdx canvas = gCanvas(redraw,"SIZE=600x600,BGCLR=BLACK"),
    dialog = gDialog(canvas,`Mobius`)
gMainLoop(dialog)
