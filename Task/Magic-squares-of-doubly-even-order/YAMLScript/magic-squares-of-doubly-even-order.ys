!ys-0

defn main(n=4):
  each row magic(n):
    say: row.map(\(format('%2d' _))):joins

defn magic(n):
  for i (0 .. n.--):
    for j (0 .. n.--):
      row-base =: i * n
      x =: row-base + j.++
      same? =: mod(i 4) == mod(j 4)
      diag-sum =: mod(i 4) + mod(j 4)
      opposite? =: diag-sum == 3
      keep? =: same? || opposite?
      if keep?:
        then: x
        else:
          max =: (n * n).++
          max -: x
