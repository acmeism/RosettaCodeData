!ys-0

# Magic square for odd N: cell(r,c) = N*((r+c-1+N/2) % N) +
#                                     ((r+2c-2) % N) + 1.

defn main(n=5):
  magic: n
  say: ''
  say: "Magic constant: $(quot(((n * n).++ * n) 2))"

defn- magic(n):
  w =: str(n * n).#
  fmt =: "%${w}d"
  each r (1 .. n):
    cells =:
      for c (1 .. n):
        a =: ((r + c.--) + (n // 2)).mod(n)
        b =: ((r + (2 * c)) - 2).mod(n)
        inc: (n * a) + b
    say: cells.map(\(format(fmt _))):joins
