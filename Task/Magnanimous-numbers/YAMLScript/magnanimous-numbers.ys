!ys-0

defn main(limit=30):
  say: (1 .. 10000).filter(magnanimous?)
       .take(limit):joins

defn magnanimous?(n):
  s =: n:S
  (s.# < 2) ||:
    every? _ (1 .. s.#.--):
      fn(i):
        a =: subs(s 0 i):I
        b =: subs(s i):I
        prime?: a + b

defn prime?(n):
  if n < 2:
    then: false
    else:
      (n < 4) ||:
        not-any? _ (2 .. I(sqrt(n))):
          fn(d):
            (n % d):zero?
