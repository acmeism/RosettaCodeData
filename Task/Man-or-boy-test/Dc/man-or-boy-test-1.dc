[lPx lS;M1+d;M-sL lL;M1-lL:M lL;M lS;M lL1+;M lL2+;M lL3+;M lL4+;M lAx lQx]sB

# P('(x):1', '(x):-1', '(x):-1', '(x):1', '(x):0')
