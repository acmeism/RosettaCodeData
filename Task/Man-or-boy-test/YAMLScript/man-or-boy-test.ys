!ys-0

# Knuth's "man or boy" test. It stresses recursion together with
# non-local references: each call to A keeps its own mutable k, and
# the inner B (passed by name into the recursive A) must keep seeing
# and decrementing *that* k even after A would have returned. Here k
# is an atom and the by-name arguments x1..x5 are thunks, re-called
# each time their value is needed. A(10, 1, -1, -1, 1, 0) = -67.

defn main(n=10):
  result =: a(n \(1) \(-1) \(-1) \(1) \(0))
  say: "A($n) = $result"

defn- a(k x1 x2 x3 x4 x5):
  kk =: atom(k)
  b =: atom(nil)
  reset b:
    fn():
      swap kk: dec
      a: kk.@ b.@ x1 x2 x3 x4
  if kk.@ <= 0:
    then:
      v4 =: x4()
      v5 =: x5()
      v4 +: v5
    else:
      bf =: b.@
      bf:
