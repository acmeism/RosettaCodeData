10 MODE 0:INK 14,1:INK 15,16
20 DEFINT c,i,p
30 itmax=64
40 xs=1/213*4:ys=1/200*2
50 y0=-1:FOR py=0 TO 199 STEP 2
60 x0=-2:FOR px=0 TO 639 STEP 4
65 xm=x0+1:IF xm*xm+y0*y0<0.0625 THEN 100
70 it=0:x=0:y=0:x2=0:y2=0
80 IF x2+y2<=4 AND it<itmax THEN y=2*x*y+y0:x=x2-y2+x0:x2=x*x:y2=y*y:it=it+1:GOTO 80
90 IF it<itmax THEN c=it AND 15:PLOT px,py,c:PLOT px,398-py
100 x0=x0+xs:NEXT
110 y0=y0+ys:NEXT
