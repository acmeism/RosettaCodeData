100 REM
110 REM DIAGONAL-DIAGONAL MATRIX
120 REM
130 LET N = 7
140 DIM A(N,N)
150 FOR I=1 TO N
150 FOR J=1 TO N
160 LET A(I,J) = 0
170 NEXT J
180 LET J1 = I
190 LET J2 = N - I + 1
200 LET A(I,J1) = 1
210 LET A(I,J2) = 1
220 NEXT I
230 REM
240 FOR I=1 TO N
250 FOR J=1 TO N
260 PRINT " ";A(I,J);
270 NEXT J
280 PRINT
290 NEXT I
300 END
