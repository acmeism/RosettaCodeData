program matrix_with_two_diagonals;
    print(fmt matrix 10);
    print(fmt matrix 11);

    op fmt(mat);
        return "" +/[(fl := str l)(2..#fl-1) + "\n" : l in mat];
    end op;

    op matrix(size);
        return [[if x=y or size-x+1=y then 1 else 0 end : x in [1..size]] : y in [1..size]];
    end op;
end program;
