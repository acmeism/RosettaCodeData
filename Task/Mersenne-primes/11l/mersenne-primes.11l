F is_prime(BigInt bi)
   I bi < 2 {R 0B}
   I bi % 2 == 0 {R bi == 2}
   I bi % 3 == 0 {R bi == 3}

   V test = BigInt(5)
   L test * test < bi
      I bi % test == 0
         R 0B
      test += 2
      I bi % test == 0
         R 0B
      test += 4

   R 1B

V base = BigInt(2)
L(p) 1..31
   I is_prime(base - 1)
      print(‘2 ^ ’p‘ - 1’)
   base *= 2
