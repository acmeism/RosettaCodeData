require "bignum"
local int = require "int"

local MAX <const> = 23
print($"The first {MAX} Mersenne primes are:")
local count = 0
local p = 2
local one = bigint.one
mpz.init()
local m
while true do
    m = mpz.shl(one, p, 1)
    m = mpz.sub(m, 1, true)
    if mpz.isprobableprime(m, 10) then
        print($"2 ^ {p} - 1")
        count += 1
        if count == MAX then break end
    end
    repeat
        p = p > 2 ? p + 2 : 3
    until int.isprime(p)
end
