#lang transd

MainModule: {
    _start: (λ locals: curexp 1 maxexp 1000 base BigLong(2)
        (while (< curexp maxexp)
            (+= curexp 1)
            (if (not (is-prime BigLong(curexp))) continue)
            (with cand (- (pow base curexp) 1)
                (if (is-probable-prime cand 10)
                    (lout curexp " : " cand ))
    )   )   )
}
