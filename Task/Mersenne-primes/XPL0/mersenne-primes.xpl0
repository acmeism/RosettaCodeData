func IsPrime(N);        \Return 'true' if N is prime
int  N, I;
[if N <= 2 then return N = 2;
if (N&1) = 0 then \even >2\ return false;
for I:= 3 to sqrt(N) do
    [if rem(N/I) = 0 then return false;
    I:= I+1;
    ];
return true;
];

int N;
[for N:= 1 to 31 do
    if IsPrime(1<<N-1) then
        [Text(0, "2^^");  IntOut(0, N);  Text(0, " - 1");
        CrLf(0);
        ];
]
