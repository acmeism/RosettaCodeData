with javascript_semantics
procedure mid3(integer i)
    string s = sprintf("%d",abs(i))
    integer k = length(s)-1
    s = iff(k<1?"too short":
        iff(odd(k)?"not odd":
                s[k/2..k/2+2]))
    printf(1,"%10d: %s\n",{i,s})
end procedure

papply({123,12345,1234567,987654321,10001,-10001,-123,
        -100,100,-12345,1,2,-1,-10,2002,-2002,0},mid3)
