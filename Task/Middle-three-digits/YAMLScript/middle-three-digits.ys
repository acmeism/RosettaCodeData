#!/usr/bin/env ys-0

defn main():
  tests =: +[123 12345 1234567 987654321 10001 -10001 -123 -100
             100 -12345 1 2 -1 -10 2002 -2002 0]
  each n tests: !say
    "$n => $(middle3(n))"

defn middle3(n):
  s =: abs(n):str
  len =: s.#
  bad? =: (len < 3) || ((len % 2) == 0)
  start =: (len - 3) / 2
  if bad?:
    then: 'error: needs odd length >= 3'
    else: s.subs(start (start + 3))
