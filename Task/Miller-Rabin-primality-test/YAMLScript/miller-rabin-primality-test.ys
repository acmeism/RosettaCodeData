!ys-0

defn main():
  each n [2 3 4 5 17 19 20 561 1105 1729 7919 104729]:
    say: "$n $(probably-prime?(n))"

defn probably-prime?(n):
  cond:
    n < 2: false
    n == 2: true
    n:even?: false
    else:
      s d =: factor-twos(n.--)
      bases =: +[2 3 5 7 11 13 17].filter(lt(n))
      every? _ bases:
        fn(a):
          witness?(a n s d)

defn factor-twos(n):
  loop s 0, d n:
    if d:even?:
      recur: s.++ (d // 2)
      else: +[s d]

defn witness?(a n s d):
  x =: mod-pow(a d n)
  (x == 1) ||:
    (x == n.--) ||:
      loop r 1, x x:
        if r == s:
          then: false
          else:
            x =: x:sqr % n
            if x == n.--:
              then: true
              else: recur(r.++ x)

defn mod-pow(a e m):
  loop a a, e e, result 1:
    if e:zero?:
      then: result
      else:
        result :if odd?(e) =: (result * a) % m
        a =: a:sqr % m
        e =: e // 2
        recur: a, e, result
