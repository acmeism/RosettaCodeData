procedure main(A)
   limit := \A[1] | 40
   every m := minmult(n := seq())\limit do
      writes(right(m,9),if n%10=0 then "\n" else "")
end

procedure minmult(n)
   every m := seq() do if n = sums(m*n) then return m
end

procedure sums(k)
   j := 0
   while k > 0 do (j +:= k%10, k /:= 10)
   return j
end
