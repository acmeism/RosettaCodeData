with javascript_semantics
for n=1 to 70 do
    integer m = 1
    while true do
        integer nm = n*m, t = 0
        while nm do
            t += rmdr(nm,10)
            nm = floor(nm/10)
        end while
        if t=n then exit end if
        m += 1
    end while
    printf(1,"%-8d%n",{m,rmdr(n,10)=0})
end for
