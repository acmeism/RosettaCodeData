=LAMBDA(n,
    LET(
        lastIndex, n - 1,
        LAMBDA(i,
            LET(
                x, MOD(i, n),
                y, QUOTIENT(i, n),

                evaluate(
                    "MIN({" &
                        TEXT(x, "0") & "," &
                        TEXT(y, "0") & "," &
                        TEXT(lastIndex - x, "0") & "," &
                        TEXT(lastIndex - y, "0") &
                    "})"
                )
            )
        )(SEQUENCE(n, n, 0, 1))
    )
)
