func Min(A, B);
int  A, B;
return if A<B then A else B;

def N=10, M=N-1, C=M/2;
int X, Y, VX, VY;
[for Y:= 0 to M do
    [for X:= 0 to M do
        [VX:= if X <= C then X else M-X;
         VY:= if Y <= C then Y else M-Y;
         IntOut(0, Min(VX, VY));  ChOut(0, ^ );
        ];
    CrLf(0);
    ];
]
