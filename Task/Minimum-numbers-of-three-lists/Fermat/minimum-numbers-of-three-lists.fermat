[numbers1] := [(5,45,23,21,67)];
[numbers2] := [(43,22,78,46,38)];
[numbers3] := [(9,98,12,98,53)];

Func Minby( a, b, c, n ) =
    if a[n]<b[n] and a[n]<b[n] then Return(a[n]) fi;
    if b[n]<c[n] then Return(b[n]) fi;
    Return(c[n]).;

for i = 1 to 5 do !!Minby( [numbers1], [numbers2], [numbers3], i ) od;
