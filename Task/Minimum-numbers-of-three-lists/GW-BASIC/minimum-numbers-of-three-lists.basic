100 DIM N1
110 N1(1) = 5
120 N1(2) = 45
130 N1(3) = 23
140 N1(4) = 21
150 N1(5) = 67
160 DIM N2
170 N2(1) = 43
180 N2(2) = 22
190 N2(3) = 78
200 N2(4) = 46
210 N2(5) = 38
220 DIM N3
230 N3(1) = 9
240 N3(2) = 98
250 N3(3) = 12
260 N3(4) = 98
270 N3(5) = 53
280 FOR I = 1 TO 5
290   A = N2(I)
300   B = N3(I)
310   GOSUB 380
320   A = N1(I)
330   B = M
340   GOSUB 380
350   PRINT M
360 NEXT I
370 END
380 REM FUNCTION min(a, b)
390   IF A < B THEN M = A ELSE M = B
400 RETURN
