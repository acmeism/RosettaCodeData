OpenConsole()

Procedure.i min(a, b)
  If a < b
    Result = a
  Else
    Result = b
  EndIf
  ProcedureReturn result
EndProcedure

Dim n1.i(5)
n1(1) =  5 : n1(2) = 45 : n1(3) = 23 : n1(4) = 21 : n1(5) = 67
Dim n2.i(5)
n2(1) = 43 : n2(2) = 22 : n2(3) = 78 : n2(4) = 46 : n2(5) = 38
