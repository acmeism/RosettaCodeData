FUNCTION min(a, b)
    IF a < b then LET min = a else LET min = b
END FUNCTION

DIM n1(5)
LET n1(1) =  5
LET n1(2) = 45
LET n1(3) = 23
LET n1(4) = 21
LET n1(5) = 67
DIM n2(5)
LET n2(1) = 43
LET n2(2) = 22
LET n2(3) = 78
LET n2(4) = 46
LET n2(5) = 38
DIM n3(5)
LET n3(1) =  9
LET n3(2) = 98
LET n3(3) = 12
LET n3(4) = 98
LET n3(5) = 53

FOR i = 1 to 5
    PRINT min(n1(i), min(n2(i), n3(i)))
NEXT i
END
