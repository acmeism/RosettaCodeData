local int = require "int"

local numbers1 = { 5, 45, 23, 21, 67}
local numbers2 = {43, 22, 78, 46, 38}
local numbers3 = { 9, 98, 12, 54, 53}

local primes  = {}
for i = 1, 5 do
    local max = {numbers1[i], numbers2[i], numbers3[i]}:max()
    primes[i] = int.nextprime(max - 1)
end
print(primes:concat(" "))
