!ys-0

defn main(a=10, b=3, m=7):
  say: "($a + $b) mod $m = $mod((a + b) m)"
  say: "($a - $b) mod $m = $mod((a - b) m)"
  say: "($a * $b) mod $m = $mod((a * b) m)"
  say: "$a ^ $b mod $m = $mod-pow(a b m)"

defn mod-pow(a e m):
  loop a (mod a m), e e, r 1:
    if e.!:
      then: r
      else:
        r :if e:odd? =: (r * a) % m
        recur: ((a * a) % m), (e // 2), r
