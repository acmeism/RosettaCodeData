import "int"

tests = [
    [42, 2017],
    [40, 1],
    [52, -217],
    [-486, 217],
    [40, 218],
]

TAB = char(9)
print "The modular inverses of the following are:"
for t in tests
    mi = int.modInv(t[0], t[1])
    if mi == null then mi = "no inverse"
    print "  " + t[0] + " and " + t[1] + TAB + " = " + mi
end for
