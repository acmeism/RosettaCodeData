!ys-0

# Extended Euclidean algorithm

defn main(a=42 m=2017):
  say: mod-inverse(a m)

defn mod-inverse(a m):
  result =:
    loop t 0, nt 1, r m, nr (a % m):
      if nr:zero?:
        then: t
        else:
          q =: I(r / nr)
          nt2 =: t - (q * nt)
          nr2 =: r - (q * nr)
          recur: nt, nt2, nr, nr2
  if result < 0: (result + m) result
