!ys-0

defn main(*):
  each n qw(100 1000 10000 100000):
    pi =: n:I:monte-carlo
    say: "n=$(n:I): pi ~ $pi"

defn monte-carlo(n):
  pts =:
    for i (1 .. n):
      +[rand() rand()]
  cnt =:
    count:
      filter _ pts:
        fn([x y]):
          ((x * x) + (y * y)) < 1.0
  (4.0 * cnt) /: n
