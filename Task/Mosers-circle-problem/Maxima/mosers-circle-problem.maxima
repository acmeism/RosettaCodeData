moser_1(n) := (n^4-6*n^3+23*n^2-18*n+24)/24$

moser_2(n) := binomial(n, 4)+binomial(n, 2)+1$

binom_term(list, k) := sum(binomial(k, i)*list[i+1], i, 0, k)$
moser_3(n) := binom_term(append(makelist(1, 5), makelist(0, n)), n-1)$

moser_4(n) := block(
  lim: if n<5 then n-1 else 4,
  sum(binomial(n-1, i), i, 0, lim))$

funs: [moser_1, moser_2, moser_3, moser_4]$
map(lambda([f], makelist(f(i), i, 1, 20)), funs);
