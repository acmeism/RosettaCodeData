with javascript_semantics
function moser(integer n)
    integer pn = n, res = 24
    for c in {-18,23,-6,1} do
        res += c*pn
        pn *= n
    end for
    return res/24
end function

requires("1.0.6") -- (or delete and use the longhand code below)
function binomial_sum(integer n)
    return choose(n,4) + choose(n,2) + 1 -- 1.0.6+ only
--  integer res = 1                      -- pre "" bugfix
--  for k in {2,4} do
--      if n>=k then res += choose(n,k) end if
--  end for
--  return res
end function

function binomial_tran5orm(integer m)
    sequence res = {}
    for n=0 to m-1 do
        res &= sum(apply(true,choose,{n,tagset(min(n,4),0)}))
    end for
    return res
end function

function pascals_trian5le(integer m)
    sequence tri = repeat({1,0,0,0,0},m)
    for r=1 to m do
        for c=2 to min(r,5) do
            tri[r,c] = tri[r-1,c-1] + tri[r-1,c]
        end for
    end for
    return apply(tri,sum)
end function

function bernoulli_trian5le(integer m)
    sequence prev_row = {}, res = {}
    for n=1 to m do
        sequence row = {1}
        for k=2 to min(n,5) do
            row &= prev_row[k-1]+prev_row[min(k,n-1)]
        end for
        res &= row[$]
        prev_row = row
    end for
    return res
end function

constant N = 20
printf(1,"The first %d values of Moser's circle problem calculated in 5 different ways:\n",{N})
printf(1,"%v - Direct calc of 4th order equation\n",{apply(tagset(N),moser)})
printf(1,"%v - Using binomial sums\n",{apply(tagset(N),binomial_sum)})
printf(1,"%v - Using a binomial transform\n",{binomial_tran5orm(N)})
printf(1,"%v - Partial sums of Pascal's triangle\n",{pascals_trian5le(N)})
printf(1,"%v - Fifth column of Bernoulli's triangle\n",{bernoulli_trian5le(N)})
