MostFreqKHashing[inputString_, K_] := Module[{occuDict, occuList, outputDict},
  occuDict = Counts[Characters[inputString]];
  occuList = ReverseSortBy[Normal[occuDict], Last];
  outputDict = Take[occuList, K];
  Association[outputDict]
]

MostFreqKSimilarity[inputDict1_, inputDict2_] := Module[{similarity = 0},
  Do[
    If[KeyExistsQ[inputDict2, c],
      similarity += inputDict1[c] + inputDict2[c]
    ],
    {c, Keys[inputDict1]}
  ];
  similarity
]

MostFreqKSDF[inputStr1_, inputStr2_, K_, maxDistance_] :=
  maxDistance - MostFreqKSimilarity[
    MostFreqKHashing[inputStr1, K],
    MostFreqKHashing[inputStr2, K]
  ]

(* Example usage *)
str1 = "LCLYTHIGRNIYYGSYLYSETWNTGIMLLLITMATAFMGYVLPWGQMSFWGATVITNLFSAIPYIGTNLV";
str2 = "EWIWGGFSVDKATLNRFFAFHFILPFTMVALAGVHLTFLHETGSNNPLGLTSDSDKIPFHPYYTIKDFLG";
K = 2;
maxDistance = 100;

dict1 = MostFreqKHashing[str1, K];
Print[dict1];
Print[StringJoin[# <> ToString[dict1[#]] & /@ Keys[dict1]]];

dict2 = MostFreqKHashing[str2, K];
Print[dict2];
Print[StringJoin[# <> ToString[dict2[#]] & /@ Keys[dict2]]];

Print[MostFreqKSDF[str1, str2, K, maxDistance]]

