include xpllib;         \for IsPrime and Print
int  M0, M1, I, M;
[Print(" n          M(n)             Prime?\n");
 Print("-----------------------------------\n");
M0:= 1;  M1:= 1;
for I:= 0 to 42-1 do
    [M:= if I>1 then (M1*(2*I+1) + M0*(3*I-3)) / (I+2) else 1;
    Print("%2d%25,d  %s\n", I, M, if IsPrime(M) then "true" else "false");
    M0:= M1;
    M1:= M;
    ];
]
