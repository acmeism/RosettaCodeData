!ys-0

# Build n distinct mutable objects (atoms) and prove that mutating
# one does not affect the others. Then show the common mistake of
# making n references to a single shared object.

defn main(n=3):
  say: "$n distinct atoms:"
  distinct =: n.repeatedly(\(atom(0)))
  swap: distinct.0 inc
  say: distinct.map(deref):joins

  say: "$n references to one atom:"
  shared =: n.repeat(atom(0))
  swap: shared.0 inc
  say: shared.map(deref):joins
