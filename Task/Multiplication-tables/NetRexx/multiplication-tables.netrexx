#!/usr/bin/env nr
/* NetRexx */
-- . ... 1 ... ... 2 ... ... 3 ... ... 4 ... ... 5
method main(args = String[]) public static

  bxh = '\U2500' -- UTF-8: 0xE2 0x94 0x80 -- horizontal
  bxv = '\U2502' -- UTF-8: 0xE2 0x94 0x82 -- vertical
  bxt = '\U252C' -- UTF-8: 0xE2 0x94 0xAC -- down tee
  bxx = '\U253C' -- UTF-8: 0xE2 0x94 0xBC -- cross
  bxu = '\U2534' -- UTF-8: 0xE2 0x94 0xB4 -- up tee

  -- program argument sets max. bound of table. Defaults to 12
  arg = Rexx(args)
  parse arg base .
  if base.length = 0 then
    base = 12

  say 'tables 1 to' base

  a_base = ArrayList(base)
  loop _i = 1 to base
    a_base.add(_i - 1, Rexx _i)
  end _i

  say bxh.copies(5) || bxt || bxh.copies(base * 4 + 2)
  say '+'.right(4) bxv fmtString(a_base)
  say bxh.copies(5) || bxx || bxh.copies(base * 4 + 2)

  loop _x = 0 to base - 1
    ax = ArrayList a_base.clone
    loop _v = ax.size - 1 to 0 by -1
      if (_v + 1) <= (_x + 1) then do
        ax.set(_v, (Rexx ax.get(_v)) * (_x + 1))
      end
      else do
        ax.set(_v, Rexx -1)
      end
    end _v
    say (_x + 1).right(4) bxv fmtString(ax)
  end _X

  say bxh.copies(5) || bxu || bxh.copies(base * 4 + 2)
  say

  return

-- . ... 1 ... ... 2 ... ... 3 ... ... 4 ... ... 5
method fmtString(ary = ArrayList) private static returns Rexx

  fmt_str = Rexx ''
  itm = Rexx
  loop _i = 0 to ary.size - 1
    itm = Rexx ary.get(_i)
    if itm <> -1 then do
      fmt_str = fmt_str || itm.right(4)
    end
    else do
      itm = Rexx ''
      fmt_str = fmt_str || itm.right(4)
    end
  end _i

  return fmt_str.strip('t')

-- . ... 1 ... ... 2 ... ... 3 ... ... 4 ... ... 5
