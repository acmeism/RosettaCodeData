arraybase 1
limit = 500
dim Divisors(1)
c = 0

print "Special numbers under "; limit; ":"

for n = 1 to limit
	pro = 1
	for m = 2 to ceil(n / 2)
		if n mod m = 0 then
			pro *= m
			c += 1
			redim Divisors(c)
			Divisors[c] = m
		end if
	next m
	ub = Divisors[?]
	if n = pro and ub > 2 then
		print rjust(string(n), 3); " = "; rjust(string(Divisors[ub-1]), 2); " x "; rjust(string(Divisors[ub]), 3)
	end if
next n
