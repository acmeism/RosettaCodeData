LET limit = 50
DIM divisors(0)
LET c = 1

PRINT "Special numbers under"; limit; ":"

FOR n = 1 TO limit
    LET pro = 1
    FOR m = 2 TO ceil(n/2)
        IF remainder(n, m) = 0 THEN
           LET pro = pro*m
           MAT REDIM divisors(c)
           LET divisors(c) = m
           LET c = c+1
        END IF
    NEXT m
    LET ub = UBOUND(divisors)
    IF n = pro AND ub > 1 THEN PRINT  USING "### = ## x ###": n, divisors(ub-1), divisors(ub)
NEXT n
END
