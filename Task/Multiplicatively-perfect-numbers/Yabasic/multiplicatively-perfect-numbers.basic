limit = 500
dim Divisors(1)
c = 1

print "Special numbers under", limit, ":"

for n = 1 to limit
    pro = 1
    for m = 2 to ceil(n / 2)
        if mod(n, m) = 0 then
            pro = pro * m
            dim Divisors(c) : Divisors(c) = m
            c = c + 1
        fi
    next m
    ub = arraysize(Divisors(), 1)
    if n = pro and ub > 1 then
        print n using "###", " = ", Divisors(ub-1) using "##", " x ", Divisors(ub) using "###"
    fi
next n
