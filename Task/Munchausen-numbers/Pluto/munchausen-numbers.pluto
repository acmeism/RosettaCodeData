local powers = table.create(10)
for i = 0, 9 do powers[i + 1] = i ** i end  -- cache powers

local function munchausen(n)
    assert(n > 0 and n % 1 == 0, "Argument must be a positive integer.")
    local nn = n
    local sum = 0
    while n > 0 do
        local digit = n % 10
        sum += powers[digit + 1]
        n //= 10
    end
    return nn == sum
end

print("The Munchausen numbers <= 5000 are:")
for i = 1, 5000 do
    if munchausen(i) then print(i) end
end
