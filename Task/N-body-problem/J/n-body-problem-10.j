GENDT =: 3 : 0"0
  dt =: y
  GENDT0 3
)
GENDT0 =: 3 : 0"0
  N=:y
  VS =: (a N)^0.5
  IS=:>.2*pi%VS*dt
  IS ITER VS GEN N
  E =: >./>./({.out)-{:out
  dt;E
)
smoutput 'dt    ';'error     '
smoutput (GENDT"0) 10^_4+i.5
