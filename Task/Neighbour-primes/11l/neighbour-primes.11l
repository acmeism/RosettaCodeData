F isPrime(n)
   L(i) 2 .. Int(n ^ 0.5)
      I n % i == 0
         R 0B
   R 1B

print(‘p        q       pq+2’)
print(‘-----------------------’)
L(p) 2..498
   I !isPrime(p)
      L.continue
   V q = p + 1
   L !isPrime(q)
      q++
   I !isPrime(2 + p * q)
      L.continue
   print(p" \t "q" \t "(2 + p * q))
