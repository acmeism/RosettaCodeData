#include "isprime.bas"

dim as uinteger q

print "p             q             pq+2"
print "--------------------------------"
for p as uinteger = 2 to 499
     if not isprime(p) then continue for
     q = p + 1
     while not isprime(q)
         q+=1
     wend
     if not isprime( 2 + p*q ) then continue for
     print p,q,2+p*q
next p
