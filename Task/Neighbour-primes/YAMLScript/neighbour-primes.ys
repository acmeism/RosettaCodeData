!ys-0

defn main(n=1000):
  below =:
    loop k n.--:
      if prime?(k): k recur(k.--)
  above =:
    loop k n.++:
      if prime?(k): k recur(k.++)
  say: "$below < $n < $above"

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
