!ys-0

# Outer defines counter and separator; inner closes over both and
# bumps the counter through an atom for the side effect.

defn main():
  say: make-list('. ')

defn- make-list(sep):
  counter =: atom(0)
  make-item =:
    fn(item):
      n =: swap(counter inc)
      =>: "$n$sep$item\n"
  str:
    make-item('first')
    make-item('second')
    make-item('third')
