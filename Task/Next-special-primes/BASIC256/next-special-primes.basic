function isPrime(v)
	if v < 2 then return False
	if v mod 2 = 0 then return v = 2
	if v mod 3 = 0 then return v = 3
	d = 5
	while d * d <= v
		if v mod d = 0 then return False else d += 2
	end while
	return True
end function

p = 3
i = 2

print "2 3 ";    #special case
do
	if isPrime(p + i) then
		p += i
		print p; " ";
	end if
	i += 2
until p + i >= 1050
end
