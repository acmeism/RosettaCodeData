sub isPrime(v)
    if v < 2 then return False : fi
    if mod(v, 2) = 0 then return v = 2 : fi
    if mod(v, 3) = 0 then return v = 3 : fi
    d = 5
    while d * d <= v
        if mod(v, d) = 0 then return False else d = d + 2 : fi
    wend
    return True
end sub

p = 3
i = 2

print "2 3 ";    //special case
repeat
    if isPrime(p + i) = 1 then
        p = p + i
        print p;
    endif
    i = i + 2
until p + i >= 1050
end
