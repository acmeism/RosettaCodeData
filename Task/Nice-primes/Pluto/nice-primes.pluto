local int = require "int"
local fmt = require "fmt"

print("Nice primes in the interval (500, 900) are:")
local c = 0
for i = 501, 999, 2 do
    if int.isprime(i) then
        local s = i
        while s >= 10 do s = int.digstat(s)[2] end
        if int.isprime(s) then
            ++c
            fmt.print("%2d: %d -> Σ = %d", c, i, s)
        end
    end
end
