!ys-0

defn main(limit=1000):
  ps =:
    filter _ (2 .. limit):
      fn(n): prime?(n)
  ps =: V(ps)
  last =: ps.#.--.--
  each i (1 .. last):
    mid =: ps.$i * 2
    neighbors =: ps.nth(i.--) + ps.nth(i.++)
    when mid == neighbors:
      say: ps.$i

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
