sub infix:<‚äï> (Int $x, Int $y) { $x +^ $y }

sub infix:<‚äó> (Int $x, Int $y) {
    return $x √ó $y if so $x|$y < 2;
    my $h = exp $x.lsb, 2;
    return ($h ‚äó $y) ‚äï (($x ‚äï $h) ‚äó $y) if $x > $h;
    return ($y ‚äó $x) if $y.lsb < $y.msb;
    return $x √ó $y unless my $comp = $x.lsb +& $y.lsb;
    $h = exp $comp.lsb, 2;
    (($x +> $h) ‚äó ($y +> $h)) ‚äó (3 +< ($h - 1))
}

# TESTING

my $upto = 26;

for <‚äï>, &infix:<‚äï>,
    <‚äó>, &infix:<‚äó>
  -> $op, &f {

    put " $op ‚îÇ", ^$upto .fmt('%3s'), "\n‚îÄ‚îÄ‚îÄ‚îº", '‚îÄ‚îÄ‚îÄ‚îÄ' x $upto;
    -> $r { put $r.fmt('%2s'), ' ‚îÇ', ^$upto .map: { &f($r, $_).fmt('%3s')} } for ^$upto;
    put "\n";
}

