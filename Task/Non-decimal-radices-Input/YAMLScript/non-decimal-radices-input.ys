!ys-0

# Parse numeric strings in various radices.
# Long/parseLong takes an explicit radix; Long/decode guesses the
# base from a 0x / 0 prefix (decimal otherwise).

cases =::
- [10, '255']
- [16, 'ff']
- [8, '777']
- [2, '11111111']
- [19, 'd5']

defn main():
  each [base s] cases:
    say: "base $base: \"$s\" -> $(Long/parseLong(s base))"
  say:
  each s ['15' '0x0f' '017']:
    say: "decode \"$s\" -> $(Long/decode(s))"
