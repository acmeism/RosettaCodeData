!ys-0

# Print small ints in binary/octal/decimal/hex. Java printf treats
# %b as boolean, so use Integer/toBinaryString for the binary view.

defn main():
  say: format("%-6s  %-6s  %-6s  %-6s" 'bin' 'oct' 'dec' 'hex')
  each n (8 .. 16):
    say: format("%-6s  %-6o  %-6d  %-6x" bin(n) n n n)

defn- bin(n):
  Integer/toBinaryString(n)
