PROCEDURE nth
   DIM N : INTEGER; A, P : REAL
   DIM   TEMP0, TEMP1 : REAL
A = 144.0
P = 0.00001
PRINT "Base: "; A
PRINT "Number     Root"
FOR N = 1 TO 10
TEMP0 := A
TEMP1 := A/N
WHILE ( abs(TEMP0 - TEMP1) > P) DO
  TEMP0 := TEMP1
  TEMP1 := (( N - 1.0) * TEMP1 + A / TEMP1 ^ (N - 1.0)) / N
ENDWHILE
PRINT N, TEMP1
NEXT N
END
