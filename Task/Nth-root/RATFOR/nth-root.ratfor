program nth

integer n
real    number, precision
real    temp0, temp1

6 format('  number      root')
7 format(i6,f12.6)
precision=0.00001
root=1.0
number=144.0
n=10

write(6,6)

for (i=1;i<=n;i=i+1) {

temp0 = number
temp1 = number/i

while ( abs(temp1 - temp0) > precision )
   {
      temp0 = temp1
      temp1 = ((i - 1.0) * temp1 + number / temp1 ** (i - 1.0)) / i
   }

write (6,7)i,temp1
}
end
