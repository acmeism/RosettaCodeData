func nthroot(a, n)
    precision = .00001
    x1 = a
    x2 = a / n
    repeat
       x1 = x2
       x2 = ((n - 1) * x2 + a / x2 ^ (n - 1)) / n
    until (abs(x2 - x1) < precision)
    return x2
end

print "Finding the nth root of 144"
print "  x      n      nthroot"
print "------------------------"
for n = 2 to 8
   print using "###   ####    ###.000000"; 144; n; nthroot(144, n)
next
