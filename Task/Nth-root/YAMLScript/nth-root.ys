!ys-0

defn main(n=5, a=34):
  say: "$n root of $a = $(nth-root(n a))"

defn nth-root(n a):
  loop x (a / n), prev 0.0:
    if approx?(x prev):
      then: x
      else:
        next =: ((n.-- * x) + (a / pow(x n.--))) / n
        recur next: x

defn pow(x n):
  reduce mul: 1 n.repeat(x)

defn approx?(a b):
  abs(a - b) < 1.0e-15
