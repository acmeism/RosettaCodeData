!ys-0

defn main():
  show: 0 .. 25
  show: 250 .. 265
  show: 1000 .. 1025

defn show(coll):
  say: coll.map(nth-suffix):joins

defn nth-suffix(n):
  m100 =: n % 100
  m10 =: n % 10
  suffix =:
    cond:
      m100.in?([11 12 13]): 'th'
      m10 == 1: 'st'
      m10 == 2: 'nd'
      m10 == 3: 'rd'
      else: 'th'
  str: n "'" suffix
