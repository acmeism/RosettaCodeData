!ys-0

defn main():
  nums =: (1 .. 9):V:shuffle
  say: "Starting: $nums"
  play: nums 0

defn- play(v moves):
  if v == v:sort:V:
    say: "Sorted in $moves moves!"
    else:
      say: v
      print: 'How many digits to reverse? '
      n =: read-line():I
      if n:zero?:
        say: 'Goodbye'
        else:
          front =: v.take(n):reverse:V
          back =: v.drop(n):V
          play: (front + back) moves.++
