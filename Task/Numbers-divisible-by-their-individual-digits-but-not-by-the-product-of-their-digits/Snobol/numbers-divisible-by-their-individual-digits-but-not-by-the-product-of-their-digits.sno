        define('divis(n)i,d,p')             :(divis_end)
divis   p = 1
        i = n
digit   d = remdr(i,10)
        p = ne(d,0) eq(remdr(n,d),0) p * d  :f(freturn)
        i = gt(i,9) i / 10                  :s(digit)
        ne(remdr(n,p))                      :s(return)f(freturn)
divis_end

        n = 1
loop    output = divis(n) n
        n = lt(n,1000) n + 1                :s(loop)
end
