!ys-0

defn main(limit=1000):
  say: filter(wanted? (1 .. limit.--)):joins

defn wanted?(n):
  digits =:
    map _ n:S:seq:
      fn(c): c:S:I
  no-zero =: not-any?(zero? digits)
  if no-zero:
    then:
      by-each =:
        every? _ digits:
          fn(d):
            (n % d):zero?
      prod =: reduce(mul 1 digits)
      if by-each:
        then: (n % prod).!
        else: false
    else: false
