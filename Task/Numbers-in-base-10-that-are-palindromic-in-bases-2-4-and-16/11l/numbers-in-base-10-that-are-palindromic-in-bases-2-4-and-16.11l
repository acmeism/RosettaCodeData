F reverse(=n, base)
   V r = 0
   L n > 0
      r = r * base + n % base
      n I/= base
   R r

F palindrome(n, base)
   R n == reverse(n, base)

V cnt = 0
L(i) 0.<25000
   I all((2, 4, 16).map(base -> palindrome(@i, base)))
      cnt++
      print(‘#5’.format(i), end' " \n"[cnt % 12 == 0])

print()
