get "libhdr"
manifest $( MAXIMUM = 25000 $)

let reverse(n, base) = valof
$(  let r = 0
    while n > 0
    $(  r := r*base + n rem base
        n := n / base
    $)
    resultis r
$)

let palindrome(n, base) = n = reverse(n, base)

let start() be
    for i = 0 to MAXIMUM
        if palindrome(i,2) & palindrome(i,4) & palindrome(i,16)
            do writef("%N*N", i)
