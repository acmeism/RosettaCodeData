  [ temp put
    0
    [ over 0 > while
      temp share tuck *
      dip /mod +
      again ]
    temp release
    nip ]               is rev ( n n --> n )

  [ dip dup rev = ]     is pal ( n n --> b )

  []
  25000 times
    [ i^ 16 pal while
      i^  4 pal while
      i^  2 pal while
      i^ join ]
  echo
