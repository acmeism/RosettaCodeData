global fila
fila = 0
n = 0

print "Numbers in base-16 representation that cannot be written with decimal digits:"
call num(n)
for n = 10 to 15
	call num(n)
next n
print "Found "; fila; " numbers"
end

subroutine num(n)
	for i = 10 to 15
		print n * 16 + i; "  ";
		fila += 1
	next i
	print
end subroutine
