lownybble = proc (s: stream, hi: int)
    for lo: int in int$from_to(10, 15) do
        stream$putl(s, int$unparse(hi*16 + lo))
    end
end lownybble

start_up = proc ()
    po: stream := stream$primary_output()
    lownybble(po, 0)
    for hi: int in int$from_to(10, 15) do
        lownybble(po, hi)
    end
end start_up
