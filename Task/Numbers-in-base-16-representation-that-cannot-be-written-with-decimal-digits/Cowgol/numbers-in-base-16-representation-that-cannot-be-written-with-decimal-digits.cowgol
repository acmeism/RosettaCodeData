include "cowgol.coh";

sub lownybble(hi: uint8) is
    var lo: uint8 := 0xA;
    while lo <= 0xF loop
        print_i8(hi<<4 | lo);
        print_nl();
        lo := lo + 1;
    end loop;
end sub;

lownybble(0);
var hi: uint8 := 0xA;
while hi <= 0xF loop;
    lownybble(hi);
    hi := hi + 1;
end loop;
