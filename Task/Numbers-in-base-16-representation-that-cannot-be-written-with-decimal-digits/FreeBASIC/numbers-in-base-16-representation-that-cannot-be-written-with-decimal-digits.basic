Dim Shared As Integer fila = 0
Print "Numbers in base-16 representation that cannot be written with decimal digits:"

Sub num(n As Integer)
    For i As Integer = 10 To 15
        Print Using " #### "; n * 16 + i;
        fila += 1
    Next i
    Print
End Sub

Dim As Integer n = 0
num(n)
For n = 10 To 15
    num(n)
Next n

Print !"\nFound "; fila; " numbers"
Sleep
