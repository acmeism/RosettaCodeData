MODULE Base16NoDecimalNumbers;
FROM InOut IMPORT WriteCard, WriteLn;

VAR hi: CARDINAL;

PROCEDURE LowNybble(hi: CARDINAL);
    VAR lo: CARDINAL;
BEGIN
    FOR lo := 10 TO 15 DO
        WriteCard(hi*16 + lo, 3);
        WriteLn
    END
END LowNybble;

BEGIN
    LowNybble(0);
    FOR hi := 10 TO 15 DO
        LowNybble(hi)
    END
END Base16NoDecimalNumbers.
