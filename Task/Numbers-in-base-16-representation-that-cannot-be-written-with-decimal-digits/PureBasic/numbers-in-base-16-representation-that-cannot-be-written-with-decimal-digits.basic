Global fila.i = 0

Procedure num(n.i)
  For i = 10 To 15
    Print(" " + Str(n * 16 + i) + "  ")
    fila + 1
  Next i
  PrintN("")
EndProcedure


OpenConsole()
PrintN("Numbers in base-16 representation that cannot be written with decimal digits:")

n.i = 0
num(n)

For n = 10 To 15
  num(n)
Next n
PrintN(#CRLF$ + "Found " + Str(fila) + " numbers")

Input()
CloseConsole()
End
