SUB num(n)
    FOR i = 10 to 15
        PRINT n * 16 + i; "  ";
        LET  fila = fila + 1
    NEXT i
    PRINT
END SUB

PRINT "Numbers in base-16 representation that cannot be written with decimal digits:"

LET fila = 0
LET n = 0
CALL NUM(n)
FOR n = 10 to 15
    CALL NUM(n)
NEXT n
PRINT "Found "; fila; " numbers"
END
