print "Numbers in base-16 representation that cannot be written with decimal digits:"
fila = 0
n = 0
num(n)
for n = 10 to 15
    num(n)
next n
print "\nFound ", fila, " numbers"
end

sub num(n)
    for i = 10 to 15
        print n * 16 + i using "####",
        fila = fila + 1
    next i
    print
end sub
