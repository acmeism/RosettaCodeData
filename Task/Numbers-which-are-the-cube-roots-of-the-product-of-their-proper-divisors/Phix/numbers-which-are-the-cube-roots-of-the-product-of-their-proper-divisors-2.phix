function A111398(integer limit)
    -- we only need primes up to limit/6 since the
    --  worst case is part 3 needing 2*3*r<=limit.
    sequence primes = get_primes_le(floor(limit/6)),
             res = {1}

    -- 1) p^7
    for p in primes do
        atom n = power(p,7)
        if n > limit then exit end if
        res &= n
    end for

    -- 2) p^3 * q  (p != q)
    for p in primes do
        atom p3 = p*p*p
        if p3 > limit then exit end if
        for q in primes do
            if q!=p then
                atom n = p3 * q
                if n > limit then exit end if
                res &= n
            end if
        end for
    end for

    -- 3) p*q*r with p < q < r
    for i,p in primes do
        if p*p*p > limit then exit end if
        for j,q in primes from i+1 do
            if p*q*q > limit then exit end if
            for r in primes from j+1 do
                atom n = p*q*r
                if n > limit then exit end if
                res &= n
            end for
        end for
    end for

    res = sort(res)
    return res
end function

atom t0 = time()
--sequence res = A111398(2229229) -- 0.2s
--sequence res = A111398(22553794) -- 2.6s
sequence res = A111398(230063839) -- 32.5s
printf(1,"First 50 numbers which are the cube roots\n")
printf(1," of the products of their proper divisors:\n")
printf(1,"%s\n",join_by(res[1..50],1,10,"",fmt:="%4d"))
for n in {5e2,5e3,5e4,5e5,5e6,5e7} do
    printf(1,"%,10dth: %,d\n",{n,res[n]})
end for
?elapsed(time()-t0)
