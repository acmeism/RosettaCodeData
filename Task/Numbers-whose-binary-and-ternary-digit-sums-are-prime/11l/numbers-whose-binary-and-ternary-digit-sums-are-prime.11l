F is_prime(a)
   I a == 2
      R 1B
   I a < 2 | a % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(a))).step(2)
      I a % i == 0
         R 0B
   R 1B

F digit_sum(=n, b)
   V result = 0
   L n != 0
      result += n % b
      n I/= b
   R result

V count = 0
L(n) 2..199
   I is_prime(digit_sum(n, 2)) &
     is_prime(digit_sum(n, 3))
      count++
      print(‘#3’.format(n), end' I count % 16 == 0 {"\n"} E ‘ ’)
print()
print(‘Found ’count‘ numbers.’)
