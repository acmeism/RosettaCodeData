get "libhdr"

let digitsum(n, base) =
    n=0 -> 0, n rem base + digitsum(n/base, base)

let isprime(n) = valof
$(  if n<2 then resultis false
    for i=2 to n-1 do
        if n rem i = 0 then resultis false
    resultis true
$)

let accept(n) =
    isprime(digitsum(n,2)) & isprime(digitsum(n,3))

let start() be
$(  let c = 0
    for i=0 to 199 do
        if accept(i) do
        $(  writef("%I4",i)
            c := c + 1
            if c rem 10 = 0 then wrch('*N')
        $)
    wrch('*N')
$)
