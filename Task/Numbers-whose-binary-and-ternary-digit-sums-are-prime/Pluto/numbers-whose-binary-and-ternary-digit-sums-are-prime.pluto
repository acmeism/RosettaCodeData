local fmt = require "fmt"
local int = require "int"

local res = {}
for n = 1, 199 do
    if int.isprime(int.digstat(n, 2)[2]) and int.isprime(int.digstat(n, 3)[2]) then
        res:insert(n)
    end
end
print($"Found {#res} numbers < 200 whose binary and ternary digit sums are prime:")
fmt.tprint("%3d ", res, 14)
