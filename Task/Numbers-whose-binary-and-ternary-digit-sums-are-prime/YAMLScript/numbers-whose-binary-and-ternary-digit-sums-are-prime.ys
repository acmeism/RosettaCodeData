!ys-0

defn main(limit=100):
  each n (1 .. limit):
    b =: Long/toString(n 2):digits:sum
    t =: Long/toString(n 3):digits:sum
    when b:prime? && t:prime?:
      say: n

defn digit-sum(s):
  sum: s:digits

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
