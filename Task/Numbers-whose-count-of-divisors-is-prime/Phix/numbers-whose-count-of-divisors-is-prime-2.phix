atom t1 = time()
for n in {1e3,1e5,1e6,1e7,1e8,4e9} do
    sequence r = {}
    for a in get_primes_le(floor(sqrt(n))) do
        integer b = 2
        while true do
            atom c = power(a,get_prime(b)-1)
            if c>n then exit end if
            r &= c
            b += 1
        end while
    end for
    r = sort(deep_copy(r))
    printf(1,"%d < %,d found: %v\n",{length(r),n,shorten(r,"",5)})
end for
?elapsed(time()-t1)
