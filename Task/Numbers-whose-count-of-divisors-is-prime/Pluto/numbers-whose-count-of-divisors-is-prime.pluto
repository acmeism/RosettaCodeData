local int = require "int"
local fmt = require "fmt"

local res = {}
for i = 1, 99_999 do
    local c = int.divstat(i)[1]
    if c != 2 and int.isprime(c) then res:insert(i) end
end

print("Integers less than 100,000 whose count of divisors is prime:")
local res2 = res:filtered(|i| -> i < 1000)
fmt.tprint($"%,6s", res, 10)
fmt.print("\n%d such integers found of which %d are under 1,000.", #res, #res2)
