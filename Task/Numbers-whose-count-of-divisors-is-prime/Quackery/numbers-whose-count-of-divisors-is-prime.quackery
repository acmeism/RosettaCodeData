  [ dip number$
    over size -
    space swap of
    swap join echo$ ] is recho ( n n -->   )

  [ []
    100000 isqrt drop times
      [ i^ dup * factors size
        dup 2 = iff drop done
        factors size 2 = while
        i^ dup * join ] ]

  [ dup [] != while
    10 split swap
    witheach [ 6 recho ]
    cr again ]
   drop
