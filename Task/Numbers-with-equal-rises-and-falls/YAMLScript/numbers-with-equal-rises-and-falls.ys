!ys-0

defn main(limit=50):
  nums =: take(limit filter(equal-rises-falls? (10 .. 100000)))
  say: nums:joins

defn equal-rises-falls?(n):
  digits =:
    map _ n:S:seq:
      fn(c): c:S:I
  pairs =: partition(2 1 digits)
  rises =: count(filter(\(_.1 > _.0) pairs))
  falls =: count(filter(\(_.1 < _.0) pairs))
  rises ==: falls
