syms: [a, b, c, d, e, f]$
digits: [2, 3, 5, 7]$

form(n) := lreduce(lambda([x, y], 10*x+y), firstn(syms, n))$

alldigitsprime(n) := apply(create_list, cons(form(n), join(firstn(syms, n), makelist(digits, n))))$

poss_unluckies: flatten(makelist(alldigitsprime(i), i, 3, 6))$

digsum(n, nd) := sum(mod(floor(n/10^i), 10), i, 0, nd-1)$

sublist(poss_unluckies, lambda([n], digsum(n, 6) = 13));
