local fmt = require "fmt"

local function unlucky(set, needed, v = "", res = {})
    if needed == 0 then
        res:insert(string.format("%6s", v))
    elseif needed > 0 then
        for i = #set, 1, -1 do
            res = unlucky(set, needed - set[i], set[i] .. v, res)
        end
    end
    return res
end

local r = unlucky({2, 3, 5, 7}, 13):sort()
fmt.tprint("%s", r , 11)
