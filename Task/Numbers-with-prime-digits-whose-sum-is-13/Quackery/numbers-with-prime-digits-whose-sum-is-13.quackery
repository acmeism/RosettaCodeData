  [] ' [ [ ] ]
  [ behead
    ' [ 2 3 5 7 ] witheach
      [ dip dup join
        0 over witheach +
        dup 13 = iff
          [ drop nested
            dip rot join
            unrot conclude ]
          done
        11 > iff drop done
        nested swap dip join ]
    drop dup [] = until ]
  swap witheach
    [ 0 swap witheach
        [ swap 10 * + ]
      number$ nested join ]
  60 wrap$
