# using hash keys to create a pseudo-set
val makeset = fn(n) { fold split(n), by=fn(h, v) { h ~ {v: 0} }, init={:} }

var col = 1
for n in 0 .. 1000 { # 99999 {
    if makeset(n) == makeset(string(n, fmt=16)) {
        write "{{n:7}}"
        if col div 10: writeln()
        col += 1
    }
}
writeln()
