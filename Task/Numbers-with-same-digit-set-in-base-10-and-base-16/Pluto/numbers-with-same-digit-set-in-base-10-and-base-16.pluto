require "map"
local fmt = require "fmt"

$define LIMIT = 1e5

local count = 0
print("Numbers under 100,000 which use the same digits in decimal or hex:")
for i = 0, LIMIT - 1 do
    local h = fmt.itoa(i, 16):split("")
    local hs = set.of(h:unpack())
    local n = tostring(i):split("")
    local ns = set.of(n:unpack())
    if hs:same(ns) then
        ++count
        fmt.write("%6s ", fmt.int(i))
        if count % 10 == 0 then print() end
    end
end
print($"\n\n{count} such numbers found.")
