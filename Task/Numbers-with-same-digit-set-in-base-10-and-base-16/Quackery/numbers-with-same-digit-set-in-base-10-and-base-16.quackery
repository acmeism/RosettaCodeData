  [ 0 swap witheach [ bit | ] ] is ->set   ( [ --> s )

  [ 10 base put
    dup  number$ ->set
    16 base replace
    swap number$ ->set
    base release
    = ]                         is dec=hex ( n --> b )

  []
  100000 times
    [ i^ dec=hex if
        [ i^ number$
          nested join ] ]
  60 wrap$
