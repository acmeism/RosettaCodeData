program Numbers_with_same_digit_set_in_base_10_and_base_16;
    loop for i in [0..100000] | digitset(i,10) = digitset(i,16) do
        nprint(lpad(str i, 8));
        if (col +:= 1) mod 10 = 0 then print; end if;
    end loop;
    print;

    proc digitset(n, b);
        s := {};
        loop until n=0 do
            s with:= n mod b;
            n div:= b;
        end loop;
        return s;
    end proc;
end program;
