local function sinh(atom x) return (exp(x)-exp(-x))/2 end function
local function cosh(atom x) return (exp(x)+exp(-x))/2 end function
local function tanh(atom x) return sinh(x)/cosh(x)    end function

function tanh_sinh(integer func, lo, hi, steps, atom acc)
    atom h = 0.1, h0 = (hi-lo)/2, h1 = (lo+hi)/2, rr = 0
    for k=1 to steps do
        atom ro = rr, ss = 0
        integer n = power(2,k)-1
        for i=-n to n do
            atom t = i*h, sh = sinh(t)*PI/2
            ss += func(h1 + h0*tanh(sh))
                          * h *cosh(t)*PI/2
                       / power(cosh(sh),2)
        end for
        rr = h0*ss
        if abs(rr-ro)<acc then exit end if
    end for
    return rr
end function

printf(1,"%0.8f\n", tanh_sinh(sin, 0, 1, 5, 1e-8))
printf(1,"%0.8f\n", tanh_sinh(exp, -3, 3, 5, 1e-8))
