program ohalloran_numbers;
    print(ohalloran(1000));

    proc ohalloran(n);
        s := {3..n};
        loop for l in {1..n div 2} do
            loop for h in {1..n div 2} do
                loop for w in {1..n div 2} do
                    s less:= l*w + w*h + h*l;
                end loop;
            end loop;
        end loop;
        return {2*k : k in s};
    end proc;
end program;
