!ys-0

defn main(limit=1000):
  possible =: surface-areas(limit):set
  nums =: (8 .. limit.--)
    .filter(\((even?(_) && possible(_).!)))
  say: nums:joins

defn surface-areas(limit):
  max-dim =: I(limit / 4)
  for l (1 .. max-dim), w (1 .. l), h (1 .. w):
    area =: 2 * ((l * w) + (w * h) + (h * l))
    when area < limit: area
