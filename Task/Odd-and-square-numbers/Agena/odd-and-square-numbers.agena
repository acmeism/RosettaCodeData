local proc oddAndSquareNumbers( minNumber :: number, maxNumber :: number ) :: sequence
    local toNext, oddSquare, result := 8, 1, seq();
    while oddSquare < maxNumber do
        if minNumber < oddSquare then
            result[ size result + 1 ] := oddSquare
        fi;
        oddSquare +:= toNext;
        toNext    +:= 8
    od;
    return result
end
print( join( << v -> " " & v >> @ oddAndSquareNumbers( 100, 1000 ) ) )
