(fn oddAndSquareNumbers [minNumber maxNumber]
    (var (toNext oddSquare result) (values 8 1 {}))
    (while (< oddSquare maxNumber)
        (when (< minNumber oddSquare)
              (table.insert result oddSquare)
        )
        (set (oddSquare toNext) (values (+ oddSquare toNext) (+ toNext 8)))
    )
    result
)
(print (table.concat (oddAndSquareNumbers 100 1000) " "))
