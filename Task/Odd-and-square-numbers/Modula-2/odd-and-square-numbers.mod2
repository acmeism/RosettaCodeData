MODULE OddSquare;
FROM InOut IMPORT WriteCard, WriteLn;
VAR n, square: CARDINAL;
BEGIN
    n := 10;
    LOOP
        square := n * n;
        IF square > 1000 THEN EXIT END;
        IF square MOD 2 = 1 THEN
            WriteCard(square, 3);
            WriteLn
        END;
        n := n + 1
    END
END OddSquare.
