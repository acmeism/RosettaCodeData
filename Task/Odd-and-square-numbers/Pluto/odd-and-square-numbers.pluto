local function oddAndSquareNumbers( minNumber : number, maxNumber : number ) : table
    local toNext, oddSquare, result = 8, 1, {}
    while oddSquare < maxNumber do
        if minNumber < oddSquare then
            result[ # result + 1 ] = oddSquare
        end
        oddSquare += toNext
        toNext    += 8
    end
    return result
end
print( oddAndSquareNumbers( 100, 1000 ):concat( " " ) )
