F odd_square_free_semiprime(=n)
   I n % 2 == 0
      R 0B
   V count = 0
   V i = 3
   L i * i <= n
      L n % i == 0
         I ++count > 1
            R 0B
         n I/= i
      i += 2
   R count == 1

print(‘Odd square-free semiprimes < 1000:’)
V count = 0
L(i) (1.<1000).step(2)
   I odd_square_free_semiprime(i)
      print(‘#4’.format(i), end' ‘’)
      I ++count % 20 == 0
         print()

print("\nCount: "count)
