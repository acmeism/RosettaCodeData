    LET P = 1
 10 LET P = P + 2
    LET Q = P
    IF P >= 1000 THEN END
    LET A = P
    GOSUB 100
    IF Z = 0 THEN GOTO 10
 20 LET Q = Q + 2
    IF Q > 1000/P THEN GOTO 10
    LET A = Q
    GOSUB 100
    IF Z = 0 THEN GOTO 20
    PRINT P," ",Q," ",P*Q
    GOTO 20
100 REM PRIMALITY BY TRIAL DIVISION
    LET Z = 1
    LET I = 2
110 IF (A/I)*I = A THEN LET Z = 0
    IF Z = 0 THEN RETURN
    LET I = I + 1
    IF I*I <= A THEN GOTO 110
    RETURN
