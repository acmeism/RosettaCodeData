!ys-0

defn main():
  pairs =::
  - [[1, 2, 3], [1, 2, 3, 4]]
  - [[1, 2, 4], [1, 2, 3]]
  - [[1, 2], [1, 2]]
  - [[3, 2, 1], [1, 2, 3]]

  each [a b] pairs:
    result =: lex-before?(a b)
    say: "$a < $b => $result"

defn lex-before?(xs ys):
  loop xs xs, ys ys:
    cond:
      xs:empty? && ys:empty?: false
      xs:empty?: true
      ys:empty?: false
      xs:first < ys:first: true
      xs:first > ys:first: false
      else:
        recur: xs:rest ys:rest
