include "isPrime.kbs"
inicio = 2
final = 499
cnt = 0

for i = inicio to final
	hexi$ = tohex(i)

	if isPrime(i) = true and hexi$ = Reverse$(hexi$) then
		cnt += 1
		print hexi$; "  ";
	end if
next i

print chr(10)
print "Encontrados "; cnt; " primos palindrómicos entre "; inicio; " y "; final
end

function Reverse$ (txt$)
	txt2$ = ""
	lt = length(txt$)
	for x = lt to 1 step -1
		txt2$ += mid(txt$, x, 1)
	next x
	return txt2$
end function
