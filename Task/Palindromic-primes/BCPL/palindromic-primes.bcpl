get "libhdr"

let prime(n) =
    n<2 -> false,
    (n & 1) = 0 -> n = 2,
    valof
$(  let d = 3
    while d*d <= n
    $(  if n rem d=0 resultis false
        d := d+2
    $)
    resultis true
$)

let reverse(n) = valof
$(  let r = 0
    until n=0
    $(  r := r*10 + n rem 10
        n := n/10
    $)
    resultis r
$)

let start() be
$(  for i = 1 to 1000
        if reverse(i)=i & prime(i) do writef("%N ",i)
    wrch('*N')
$)
