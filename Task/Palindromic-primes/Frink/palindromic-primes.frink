// Iterative version
for n = 2 to 999
   if isPrime[n]
   {
      s = base[n,10]
      if s == reverse[s]
         print["$n "]
   }
println[]
println[]


// Single-line version with fancy formatting
println[formatTable[columnize[select[2 to 999, {|n| isPrime[n] and base[n,10]==reverse[base[n,10]]}],5], "right"]]
