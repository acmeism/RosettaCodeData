  [ [] swap
    [ base share /mod
      rot swap join swap
      dup 0 = until ]
    drop ]                      is digits       ( n --> [ )

  [ dup reverse = ]             is palindromic  ( [ --> b )

1000 eratosthenes

1000 times
  [ i^ isprime if
    [ i^ digits palindromic if
      [ i^ echo sp ] ] ]
