#include "isprime.kbs"

digits = 7654321
for z = 1 to 0 step -1
	print "The largest"; z; "..7 pandigital prime is ";
	start = msec
	for n = digits to 0 step -18
		cadena$ = string(n)
		flag = True
		for i = z to 7
			if instr(cadena$, string(i)) = 0 then
				flag = False
				exit for
			end if
		next i
		if flag and isPrime(n) then
			print rjust(string(n), 8);".  "; (msec - start); " ms"
			exit for
		end if
	next n
	digits = digits * 10 - 9
next z
