fs = function(f, s)
    res = []
    for e in s; res.push f(e); end for
    return res
end function

f1 = function(n); return 2 * n; end function

f2 = function(n); return n * n; end function

partial = function(f, g)
    fg = function(x); return f(@g, x); end function
    return @fg
end function

ss = [[0, 1, 2, 3], [2, 4, 6, 8]]
for s in ss
    fsf1 = partial(@fs, @f1)
    fsf2 = partial(@fs, @f2)
    print fsf1(s)
    print fsf2(s)
    print
end for
