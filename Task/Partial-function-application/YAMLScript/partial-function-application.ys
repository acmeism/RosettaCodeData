!ys-0

# Partial application: `fs + f1` is YS sugar for (partial fs f1),
# binding fs's first arg without naming the second.

defn main():
  fsf1 =: fs + f1
  fsf2 =: fs + f2
  evens =: (1 .. 4).mapv(\(_ * 2))
  seqs =: +[(0 .. 3):vec evens]
  each s seqs:
    say: "fsf1 $s: $(fsf1(s))"
    say: "fsf2 $s: $(fsf2(s))"

defn fs(f s):
  mapv: f s

defn f1(n):
  n * 2

defn f2(n):
  n:sqr
