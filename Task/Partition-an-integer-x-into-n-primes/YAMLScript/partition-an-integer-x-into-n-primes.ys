!ys-0

defn main(x=18, n=2):
  each part partitions(x n 2):
    say: part:joins

defn partitions(x n minp):
  if n == 0:
    if x == 0: +[[]] []
    apply concat:
      for p (minp .. x):
        when prime?(p):
          for rest partitions((x - p), n.--, p):
            rest + p

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
