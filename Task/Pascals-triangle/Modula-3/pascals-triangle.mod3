MODULE Main;

IMPORT SIO,Fmt;

PROCEDURE PrintLine(READONLY N:INTEGER) =
  VAR M:INTEGER;
  BEGIN
    IF N < 1 THEN RETURN END;
    M := 1;
    SIO.PutText("1 ");
    FOR I := 1 TO N-1 DO
      M := M * (N-I) DIV I;
      SIO.PutText(Fmt.F("%s ",Fmt.Int(M)))
    END;
    SIO.Nl()
  END PrintLine;

PROCEDURE Print(READONLY N:INTEGER) =
  BEGIN
    FOR I := 1 TO N DO PrintLine(I) END;
  END Print;

BEGIN
  Print(10)
END Main.
