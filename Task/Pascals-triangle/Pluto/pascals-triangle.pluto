local int = require "int"
local fmt = require "fmt"

local function pascal_triangle(n)
    if n <= 0 then return end
    for i = 0, n - 1 do
        io.write(string.rep("   ",  n - i - 1))
        for j = 0, i do
           fmt.write("%3d   ", int.binomial(i, j))
        end
        print()
    end
end

pascal_triangle(13)
