with javascript_semantics
constant words = unix_dict(), lw = length(words)
procedure print_passphrase(integer l)
    sequence res = repeat(0,l)
    for i=1 to l do
        res[i] = sprintf("%s%02d",{proper(words[rand(lw)]),rand(99)})
    end for
    printf(1,"%s\n",{join(res,'-')})
end procedure
for n=1 to 9 do print_passphrase(n) end for
