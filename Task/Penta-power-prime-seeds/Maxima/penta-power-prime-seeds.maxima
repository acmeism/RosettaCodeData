penta_power(n) := makelist(n^i+n+1, i, 0, 4)$

is_pprimeseed(n) := map(primep, penta_power(n))=makelist(true, 5)$

block(count: 0, n: 1,
    while count<30 do(
        if is_pprimeseed(n) then block(
            sprint(n),
            count: count+1,
            if mod(count, 6)=0 then newline()
        ),
        n: n+1))$
