!ys-0

defn main(word='ABC'):
  each p permutations(word:seq:V):
    say: p:join

defn permutations(xs):
  if xs.# != 1:
    mapcat _ (0 .. xs.#.--):
      fn(i):
        swapped =: swap(xs 0 i)
        first =: swapped.0
        rest =: swapped.subvec(1)
        permutations(rest): .map(\([first] + _))
    else: +[xs]

defn swap(xs i j):
  xs: .assoc(i xs.$j)
      .assoc(j xs.$i)
