arraybase 1
dim list1 = {{"a", "b", "c"}, {"a", "b", "c"}}
dim list2 = {{"1", "2", "3"}, {"1", "2", "3"}}

call permutation(list1)
print
call permutation(list2)
end

subroutine permutation(list1)
    for n = 1 to list1[][?]
        for m = 1 to list1[][?]
            print list1[1, n]; " "; list1[2, m]
        next m
    next n
    print
end subroutine
