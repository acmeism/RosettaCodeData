DIM list1$(1 TO 2, 1 TO 3) '= {{"a", "b", "c"}, {"a", "b", "c"}}
DIM list2$(1 TO 2, 1 TO 3) '= {{"1", "2", "3"}, {"1", "2", "3"}}

permutation$(list1$())
PRINT
permutation$(list2$())
END

SUB permutation$(list1$())

    FOR n = 1 TO UBOUND(list1$,1)
        FOR m = 1 TO UBOUND(list1$,2)
            PRINT list1$(1, n); " "; list1$(2, m)
        NEXT m
    NEXT n
    PRINT
END SUB
