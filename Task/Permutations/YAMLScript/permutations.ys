#!/usr/bin/env ys-0

defn main(n=3):
  each p permutations(1 .. n):
    say: p:joins

defn permutations(xs):
  if xs:empty?:
    list: +[]
    else:
      mapcat _ (range xs.#):
        fn(i):
          h =: xs.$i
          rest =: take(i xs) + drop(i.++ xs)
          map _ permutations(rest):
            fn(p): h.cons(p)
