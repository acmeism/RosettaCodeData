  [ [] swap
    [ 10 /mod
      rot join swap
      dup 0 = until ]
    drop ]                is digits  ( n --> [ )

  [ true swap
    dup digits sort
    swap
    5 times
      [ dup i 2 + *
        digits sort
        dip over != if
          [ rot not unrot
            conclude ] ]
    2drop ]               is permult ( n --> b )

  0
  [ 1+
    dup permult until ]
  6 times
    [ dup
      i^ 1+ dup echo
      say " * n = "
      * echo cr ]
  drop
