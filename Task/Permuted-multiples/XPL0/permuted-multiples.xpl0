func    Digits(N);              \Return counts of digits packed in 30 bits
int     N, Sums;
[Sums:= 0;
repeat  N:= N/10;
        Sums:= Sums + 1<<(rem(0)*3);
until   N = 0;
return Sums;
];

int N, Sums;
[N:= 1;
loop    [Sums:= Digits(N*2);
        if Digits(N*3) = Sums then
          if Digits(N*4) = Sums then
            if Digits(N*5) = Sums then
              if Digits(N*6) = Sums then
                quit;
        N:= N+1;
        ];
IntOut(0, N);
]
