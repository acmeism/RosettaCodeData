without javascript_semantics -- (far too slow)
requires(64,true) -- (twice as fast as 32-bit)
include mpfr.e
atom t0 = time()
-- a -ve precision means decimal rather than binary (phix-only)
mpfr pi = mpfr_init(0,-1e6); mpfr_const_pi(pi)
printf(1,"%s, %s\n",{shorten(mpfr_get_str(pi,10,1e6),""),elapsed(time()-t0)})
