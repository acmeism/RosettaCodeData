with javascript_semantics
constant sq = '&'+1 -- oops, pygments don't like '\''
function is_letter(integer c)
    c = lower(c); return (c>='a' and c<='z') or c=sq
end function

function is_vowel(integer c, bool first)
    c = lower(c); return (not first and c='y') or find(c,"aeiou")
end function

function to_pig_latin(string s)
    string result := ""
    integer p = 1, l = length(s)
    while p<=l do
        for c in s from p do
            if is_letter(c) then exit end if
            result &= c
            p += 1
        end for
        if p<=l then
            string front := "", word := ""
            bool uppercase = s[p]!=lower(s[p]), copyu = false, first=true;
            for c in s from p do
                if not is_letter(c) or (not copyu and is_vowel(c,first)) then exit end if
                if first then c = lower(c) end if
                front &= c
                copyu = p<l and lower(c)='q' and lower(s[p+1])='u'
                first = false
                p += 1
            end for
            integer wordstart = p
            for c in s from p do
                if not is_letter(c) then exit end if
                if uppercase then c = upper(c) end if
                word &= c
                uppercase = false
                p += 1
            end for
            if front="" then front="w" end if
            if uppercase then front[1] = upper(front[1]) end if
            word &= front & "ay"
            front = s[wordstart..p-1]
            if front=upper(front) then word = upper(word) end if
            result &= word
        end if
    end while
    return result
end function

-- comments indicate questionable or semi-disputed entries
constant tests = {"", "", " ", " ", "123456!", "123456!",
                  "Stop! In the name of Wuv!",
                  "Opstay! Inway ethay amenay ofway Uvway!",
