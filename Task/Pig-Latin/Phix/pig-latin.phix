for i,t in tests do
    if odd(i) then -- (aside: "for in" doesn't permit "by 2")
--for i,t in tests by 2 do -- permitted in 1.0.6+
        string e = tests[i+1], r = to_pig_latin(t)
        if e!=r then printf(1,"%s -> %s\n",{t,r}) end if
    end if
end for
