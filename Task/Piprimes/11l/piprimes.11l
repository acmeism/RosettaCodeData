F is_prime(n)
   I n == 2
      R 1B
   I n < 2 | n % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(n))).step(2)
      I n % i == 0
         R 0B
   R 1B

V pi = 0
V n = 1
L
   print(‘#2’.format(pi), end' I n % 10 == 0 {"\n"} E ‘ ’)
   n++
   I is_prime(n)
      pi++
      I pi == 22
         L.break
print()
