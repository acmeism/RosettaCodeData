!ys-0

defn main():
  ys =:
    for x (0 .. 4):
      sample(x)
  a b c =: fit-quadratic(ys)
  say: "y = $a*x^2 + $b*x + $c"

defn sample(x):
  (3 * x:sqr) + (2 * x) + 1

defn fit-quadratic(ys):
  c =: ys.0
  second-diff =: ys.2 - (2 * ys.1)
  second-diff +=: ys.0
  a =: second-diff / 2
  b =: ys.1 - ys.0
  b -=: a
  =>: +[a b c]
