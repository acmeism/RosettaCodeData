require "poly"
local fmt = require "fmt"

local ps = {
    { {1, -12, 0, -42}, {1, -3} },
    { {1, 0, 0, 0, -2}, {1, 1, 1, 1} }
}

for ps as p do
    local [p1, p2] = p
    p1 = poly.of(p1)
    p2 = poly.of(p2)
    local p3 = p1 / p2 -- uses synthetic division under the hood
    fmt.print("(%s) / (%s) = %s, remainder %s", p1, p2, p3[1], p3[2])
    print()
end
