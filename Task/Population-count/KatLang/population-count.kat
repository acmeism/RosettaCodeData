PopCount = {
    Step = Math.Floor(candidate / 2), bitCount + candidate mod 2, candidate > 0
    Step.while(n, 0):1
}
PowerPopCounts = range(0, 29).map{PopCount(3 ^ exponent)}
EvilNumbers = range(0, 59).filter{PopCount(n) mod 2 == 0}
OdiousNumbers = range(0, 59).filter{PopCount(n) mod 2 == 1}

('pow3:', PowerPopCounts)
('evil:' , EvilNumbers)
('odious:', OdiousNumbers)
