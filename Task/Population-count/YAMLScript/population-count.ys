!ys-0

defn main():
  pow3s =: (0 .. 29).map(\(pow(3 _):I))
  say: "Powers of 3: $(pow3s.map(popcount):joins)"
  naturals =: 0 .. 500
  evils =: naturals.filter(even-popcount?).take(30)
  odious =: naturals.remove(even-popcount?).take(30)
  say: "Evil: $(evils:joins)"
  say: "Odious: $(odious:joins)"

defn popcount(n):
  loop n n, acc 0:
    if n:zero?:
      then: acc
      else:
        recur: I(n / 2) (acc + (n % 2))

defn even-popcount?(n):
  rem(popcount(n) 2):zero?
