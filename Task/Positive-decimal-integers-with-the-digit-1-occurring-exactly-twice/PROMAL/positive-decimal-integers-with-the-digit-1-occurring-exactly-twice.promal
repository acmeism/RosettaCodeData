;;; find numbers below 1000 where 1 occurs twice in their decimal representation
PROGRAM oneTwice
INCLUDE LIBRARY

WORD i
WORD v
WORD count
WORD oneCount

BEGIN
count = 0
FOR i = 10 TO 999
  v = i
  oneCount = 0
  WHILE v > 0
    IF v % 10 = 1
      oneCount = oneCount + 1
    v = v / 10
  IF oneCount = 2
    OUTPUT " #3I", i
    count = count + 1
    IF count % 10 = 0
      OUTPUT "#C"
END
