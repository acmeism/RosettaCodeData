func Ones(N);           \Return count of 1's in N
int N, Count;
[Count:= 0;
repeat  N:= N/10;
        if rem(0) = 1 then Count:= Count+1;
until   N = 0;
return Count;
];

int  N, Count;
[for N:= 1 to 1000-1 do
    if Ones(N) = 2 then
        [IntOut(0, N);
        Count:= Count+1;
        if rem(Count/10) = 0 then CrLf(0) else ChOut(0, 9\tab\);
        ];
CrLf(0);
IntOut(0, Count);
Text(0, " such numbers found below 1000.
");
]
