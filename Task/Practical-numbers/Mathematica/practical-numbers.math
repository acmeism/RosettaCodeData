practicalQ[n_] := SubsetQ[Plus @@@ Subsets[Most[Divisors[n]]], Range[n - 1]];
result = Select[Range[333], practicalQ];
"Found " <> ToString[Length[result]] <> " practical numbers between 1 and 333:"
TableForm[Partition[result, UpTo[10]]]
"666 is " <> If[practicalQ[666], "", "not "] <> "a practical number"
