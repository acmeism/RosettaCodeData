!ys-0

# Wilson: p > 1 is prime iff p divides (p-1)! + 1. Use BigInt
# factorial to keep the arithmetic exact for larger p.

defn main():
  say: "Primes under 100 by Wilson's theorem:"
  say: filter(wilson-prime? (2 .. 99)):joins
  each n [2 3 4 17 25 31 100 1000]:
    say: "  $n -> $(wilson-prime?(n))"

defn- wilson-prime?(n):
  when n > 1:
    zero?: (factorial(n.--) + 1N) % n

defn- factorial(n):
  reduce mul 1N: (1 .. n)

defn- mul(a b):
  a * b
