isPrime = function(n)
	if n <= 3 then return n > 1
	if n % 2 == 0 or n % 3 == 0 then return false
	
	i = 5
	while i ^ 2 <= n
		if n % i == 0 or n % (i + 2) == 0 then return false
		i += 6
	end while
	return true
end function

primes = []
sum = 0
for n in range(2, 1000)
	if isPrime(n) then
		sum += n
		if isPrime(sum) then primes.push(n)
	end if
end for
print primes.len + " found: " + primes
