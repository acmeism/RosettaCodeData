local int = require "int"
local fmt = require "fmt"
require "table2"

local primes = int.primes(1000)
local max_sum = primes:sum()
local c = int.arecomps(max_sum)
local prime_sum = 0
local results = {}
for primes as p do
   prime_sum += p
   if !c[prime_sum] then results:insert(p) end
end
print("Primes 'p' under 1000 where the sum of all primes <= p is also prime:")
fmt.tprint("%4d", results, 7)
print($"\nFound {#results} such primes.")
