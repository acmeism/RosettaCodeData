next[primeList_] := Append[primeList, NextPrime[Ceiling[1 / (1 - Total[1 / primeList])]]];

format[n_] := With[{s = ToString[n]}, If[StringLength[s] <= 40, s,
    StringForm["``...`` (`` digits)", StringTake[s, 20], StringTake[s, -20], StringLength[s]]]];

Map[format, NestList[next, {2}, 14][[All, -1]]] // TableForm
