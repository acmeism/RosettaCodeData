F is_prime(n)
   I n == 2
      R 1B
   I n < 2 | n % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(n))).step(2)
      I n % i == 0
         R 0B
   R 1B

print(‘   p  p+2  p+6’)
V count = 0
L(n) (3.<5500).step(2)
   I is_prime(n) & is_prime(n + 2) & is_prime(n + 6)
      print(f:‘{n:4} {n + 2:4} {n + 6:4}’)
      count++

print("\nFound "count‘ primes triplets for p < 5500.’)
