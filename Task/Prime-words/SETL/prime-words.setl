program prime_words;
    loop for word in readlines("unixdict.txt") | is_prime_word word do
        print(word);
    end loop;

    op is_prime_word(word);
        return forall letter in word | prime ichar letter;
    end op;

    op prime(n);
        return n>=2 and not exists d in {2..floor sqrt n} | n mod d=0;
    end op;

    proc readlines(file);
        f := open(file, 'r');
        lines := [getline(f) : until eof(f)];
        close(f);
        return lines;
    end proc;
end program;
