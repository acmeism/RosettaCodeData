INCLUDE "H6:SIEVE.ACT"

BYTE FUNC OddDigitsCount(INT x)
  BYTE c,d

  c=0
  WHILE x#0
  DO
    d=x MOD 10
    IF (d&1)=1 THEN
      c==+1
    FI
    x==/10
  OD
RETURN (c)

PROC Main()
  DEFINE MAX="999"
  BYTE ARRAY primes(MAX+1)
  INT i,count=[0]

  Put(125) PutE() ;clear the screen
  Sieve(primes,MAX+1)
  FOR i=2 TO MAX
  DO
    IF primes(i)=1 AND OddDigitsCount(i)=1 THEN
      PrintI(i) Put(32)
      count==+1
    FI
  OD
  PrintF("%E%EThere are %I primes",count)
RETURN
