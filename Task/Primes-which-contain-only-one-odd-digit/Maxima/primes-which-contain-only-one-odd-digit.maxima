syms: [a, b, c, d, e, f]$
evens: [0, 2, 4, 6, 8]$
odds: [1, 3, 5, 7, 9]$

form(n) := lreduce(lambda([x, y], 10*x+y), firstn(syms, n))$

last_odd(n) := apply(create_list, cons(form(n), join(firstn(syms, n), endcons(odds, makelist(evens, n-1)))))$

apply(sprint, cons("Primes with only one odd digit below 1000 are:", sublist(last_odd(3), primep)))$
sprint("There are", length(sublist(last_odd(6), primep)), "primes with only one odd digit below one million.")$
