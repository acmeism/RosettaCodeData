np := 1;
!(3,'  ');
for d = 1 to 5 do
    for i = 3 to 10^d-1 by 10 do
        n:=3*10^d + i;
        if Isprime(n) = 1 then
            np:=np+1;
            if n<4000 then
                !(n,'  ');
                if Divides(10,np) then !! fi;
            fi;
        fi;
    od;
od;
!!;
!!;
!!('There were ',np,' primes of the form 3...3 below 1,000,000');
