F is_prime(a)
   I a == 2
      R 1B
   I a < 2 | a % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(a))).step(2)
      I a % i == 0
         R 0B
   R 1B

F digit_sum(=n)
   V result = 0
   L n != 0
      result += n % 10
      n I/= 10
   R result

V c = 0
L(n) 0.<5000
   I digit_sum(n) == 25 & is_prime(n)
      c++
      print(‘#4’.format(n), end' I c % 6 == 0 {"\n"} E ‘ ’)
print()
print(‘Found ’c‘ primes whose sum of digits is 25’)
