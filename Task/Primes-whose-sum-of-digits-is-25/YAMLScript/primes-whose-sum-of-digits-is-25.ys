!ys-0

defn main(limit=1000):
  each n (2 .. limit):
    when prime?(n):
      when sum-digits(n) == 25:
        say: n

defn sum-digits(n):
  sum:
    for c n:S:
      parse-long(c:S)

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
