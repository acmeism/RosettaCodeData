F is_prime(a)
   I a == 2
      R 1B
   I a < 2 | a % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(a))).step(2)
      I a % i == 0
         R 0B
   R 1B

F is_non_decreasing(=n)
   V prev = 10
   L n != 0
      V d = n % 10
      I d > prev {R 0B}
      prev = d
      n I/= 10
   R 1B

V c = 0
L(n) 0.<1000
   I is_non_decreasing(n) & is_prime(n)
      c++
      print(‘#3’.format(n), end' I c % 10 == 0 {"\n"} E ‘ ’)
print()
print(‘Found ’c‘ primes with digits in nondecreasing order’)
