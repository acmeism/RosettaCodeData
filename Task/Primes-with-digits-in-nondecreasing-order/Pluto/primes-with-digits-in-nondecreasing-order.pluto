local int = require "int"
local fmt = require "fmt"
require "table2"

local res = {}
print("Primes below 1,000 with digits in non-decreasing order:")
for n = 1, 999 do
    if int.isprime(n) then
        local digs = int.digits(n)
        if digs:isordered() then res:insert(n) end
    end
end
fmt.tprint("%3d ", res, 10)
print($"\n{#res} such primes found.")
