#include "isprime.bas"

Print !"  N     M    Prime\n------------------"
For n As Integer = 1 To 45
    Dim As Ulongint m = 0
    Do
        Dim As Ulongint p = n * (2 ^ m) + 1
        If isPrime(p) Then
            Print Using "###  ####   ####"; n; m; p
            Exit Do
        End If
        m += 1
    Loop
Next n
Sleep
