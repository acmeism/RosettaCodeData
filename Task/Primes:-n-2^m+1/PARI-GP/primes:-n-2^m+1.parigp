/* Check if there is an m such that n * 2^m + 1 is prime */
n2m1(n) = {
   for(m = 0, 10^300,
       if(isprime(n * 2^m + 1), return([1, m]));
   );
   return([0, 0]);
}


{
    print("  N      M  Prime\n------------------");
    for(n = 1, 400,
        result = n2m1(n);
        if(result[1],
            print(Str(n) " " Str(result[2]) "  " n * 2^result[2] + 1);
        );
    );
}
