require "bignum"
local fmt = require "fmt"

local one = bigint.new(1)
local two = bigint.new(2)
mpz.init()
print("  N     M    Prime")
print("------------------")
for n = 1, 400 do
    local m = 0
    local pow2 = one
    while true do
        local p = bigint.new(n) * pow2 + one
        if mpz.isprobableprime(p, 10) then
            fmt.print("%3d  %4d    %s", n, m, fmt.abridge(p:tostring(), 20))
            break
        end
        m += 1
        pow2 *= two
    end
end
