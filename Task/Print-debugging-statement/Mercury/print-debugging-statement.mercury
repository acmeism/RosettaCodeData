:- module add.
:- interface.
:- import_module io.
:- pred main(io::di, io::uo) is det.
:- implementation.
:- import_module int, io, string, list.

:- func add(int, int) = int.
A `add` B = C :-
    C = A + B,
    trace [io(!IO), compile_time(grade(debug))] (
        io.format("%s - %s(%d): %d `add` %d = %d\n",
            [s($grade), s($pred), i($line), i(A), i(B), i(C)], !IO)
    ).

main(!IO) :-
    2 `add` 7 = N,
    io.print_line(N, !IO).
