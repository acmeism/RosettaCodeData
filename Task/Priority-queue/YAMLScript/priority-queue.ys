!ys-0

# Priority queue using a sorted-set of [priority task] pairs.
# Lower priority value is dequeued first.

defn main():
  items =::
  - [3, Clear drains]
  - [4, Feed cat]
  - [5, Make tea]
  - [1, Solve RC tasks]
  - [2, Tax return]
  q =: reduce(push sorted-set() items)
  loop pq q:
    when pq.# > 0:
      item =: pq:top
      say: "$(item.0)  $(item.1)"
      recur: pq:pop

defn- push(q item):
  q.conj(item)

defn- top(q):
  first: q

defn- pop(q):
  q.disj(top(q))
