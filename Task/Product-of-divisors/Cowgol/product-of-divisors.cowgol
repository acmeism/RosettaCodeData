include "cowgol.coh";

sub divprod(n: uint32): (prod: uint32) is
    prod := 1;
    var d := n;
    while d > 1 loop
        if n % d == 0 then
            prod := prod * d;
        end if;
        d := d - 1;
    end loop;
end sub;

var n: uint32 := 1;
while n <= 50 loop
    var dp := divprod(n);
    print_i32(dp);
    print_char('\t');
    if dp < 10000000 then
        print_char('\t');
    end if;
    if n % 5 == 0 then
        print_nl();
    end if;
    n := n + 1;
end loop;
