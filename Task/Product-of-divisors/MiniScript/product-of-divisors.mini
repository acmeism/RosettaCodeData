divisorProduct = function(n)
	ans = 1
	i = 1
	while i * i <= n
		if n % i == 0 then
			ans *= i
			j = floor(n / i)
			if j != i then ans *= j
		end if
		i += 1
	end while
	return ans
end function

products = []
for n in range(1,50)
	products.push(divisorProduct(n))
end for

print products.join(", ")
