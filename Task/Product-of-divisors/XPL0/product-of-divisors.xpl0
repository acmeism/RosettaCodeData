func ProdDiv(N);        \Return product of divisors of N
int  N, Prod, Div;
[Prod:= 1;
for Div:= 2 to N do
    if rem(N/Div) = 0 then
        Prod:= Prod * Div;
return Prod;
];

int C, N;
[Format(10, 0);
C:= 0;
for N:= 1 to 50 do
    [RlOut(0, float(ProdDiv(N)));
    C:= C+1;
    if rem(C/5) = 0 then CrLf(0)];
]
