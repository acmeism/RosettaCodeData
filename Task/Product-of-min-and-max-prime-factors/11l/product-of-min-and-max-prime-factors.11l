V m = 100
V c = [0B] * (m + 1)

L(p) 2 .. Int(m ^ 0.5)
   L(ci) (p * p .. m).step(p)
      c[ci] = 1B

print(‘ #4’.format(1), end' ‘’)

L(i) 2 .. m
   L(l) 2 .. i
      I !(c[l] | i % l > 0)
         L(h) (i .. 2).step(-1)
            I !(c[h] | i % h > 0)
               print(‘ #4’.format(l * h), end' I i % 10 == 0 {"\n"} E ‘’)
               L(l).break
