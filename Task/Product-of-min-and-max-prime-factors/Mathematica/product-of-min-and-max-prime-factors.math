ClearAll[primeFactors, productOfMinAndMaxPrimeFactor];

primeFactors[n_Integer] := First@Transpose@FactorInteger[n];

productOfMinAndMaxPrimeFactor[n_Integer] := Times @@ MinMax @ primeFactors[n];

TableForm[Partition[productOfMinAndMaxPrimeFactor /@ Range[100], UpTo[10]], TableAlignments -> Right]
