local int = require "int"
local fmt = require "fmt"

local prods = table.create(100)
prods[1] = 1
for i = 2, 100 do
    local factors = int.factors(i)
    prods[i] = factors[1] * factors:back()
end
print("Product of smallest and greatest prime factors of n for 1 to 100:")
fmt.tprint("%4d", prods, 10)
