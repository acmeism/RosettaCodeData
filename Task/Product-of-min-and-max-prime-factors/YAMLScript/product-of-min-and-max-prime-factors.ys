!ys-0

defn main(limit=100):
  each n (2 .. limit):
    fs =: prime-factors(n)
    when fs:count > 1:
      say: "$n: $(fs.0 * fs.$)"

defn prime-factors(n):
  distinct:
    filter _ (2 .. n):
      fn(d):
        divides? =: (n % d).!
        divides? &&: prime?(d)

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
