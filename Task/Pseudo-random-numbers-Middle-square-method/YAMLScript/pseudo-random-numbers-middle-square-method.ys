!ys-0

defn main(seed=675248):
  each n middle-square(seed 5):
    say: n

defn middle-square(seed count):
  out =: +[]
  loop seed seed, count count, out out:
    if count:zero?:
      then: out
      else:
        padded =: format('%012d' seed:sqr)
        next =: subs(padded 3 9):I
        recur: next, count.--, out.conj(next)
