with javascript_semantics
constant rawtext = `
 &-0123456789ABCDEFGHIJKLMNOPQR/STUVWXYZ:#@'="[.<(+!]$*);^\,%_>??abcdefghijklmnopqrstuvwxyz{|}~
_x___________xxxxxxxxx________________________xxxxxx_____________xxxxxxxxxxxxxxxxxx________xx__
__x___________________xxxxxxxxx_____________________xxxxxx________________xxxxxxxxxxxxxxxxx_xxx
___x___________________________xxxxxxxxx__________________xxxxxx_xxxxxxxxx_________xxxxxxxxx_xx
____x________x________x________x________________________________xx________x___________________x
_____x________x________x________x_______x_____x_____x_____x_______x________x_______x___________
______x________x________x________x_______x_____x_____x_____x_______x________x_______x__________
_______x________x________x________x_______x_____x_____x_____x_______x________x_______x_________
________x________x________x________x_______x_____x_____x_____x_______x________x_______x________
_________x________x________x________x_______x_____x_____x_____x_______x________x_______x_______
__________x________x________x________x_______x_____x_____x_____x_______x________x_______x______
___________x________x________x________x_xxxxxxxxxxxxxxxxxxxxxxxxx_______x________x_______x_____
____________x________x________x________x_________________________________x________x_______x____
_______________________________________________________________________________________________`,
        rawdata = split(substitute_all(rawtext,{'_'," >","??"},{' ',"_>","?`"}),'\n'),
        idx = rawdata[1], tags = tagset(length(idx)), COLS = 80, hzln = repeat('_',COLS),
        punch_marks = reinstate({},idx,apply(true,vslice,{{rawdata[2..$]},tags}))

procedure Punch(sequence text)
    assert(length(text)<=COLS,"Too many columns")
    assert(min(text)>=#20 and max(text)<=#7E,"Bad char")
    sequence cols = extract(punch_marks,pad_tail(text,COLS))
    printf(1," %s.\n/%s|\n|%s|\n",{hzln,join(columnize(cols,defval:=' '),"|\n|"),hzln})
end procedure

Punch("&-0123456789ABCDEFGHIJKLMNOPQR/STUVWXYZ:#@'=\"[.<(+|]$*);^\\,%_>?")
puts(1,"Hello World!\n")
Punch(`puts(1,"Hello World!\n")`)
