quad_power(n) := makelist(n^i+n+1, i, 1, 4)$

is_qprimeseed(n) := map(primep, quad_power(n))=makelist(true, 4)$

block(count: 0, n: 0,
    while count<50 do(
        if is_qprimeseed(n) then block(
            sprint(n),
            count: count+1,
            if mod(count, 10)=0 then newline()
        ),
        n: n+1))$
