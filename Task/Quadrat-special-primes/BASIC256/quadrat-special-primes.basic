function isPrime(v)
	if v < 2 then return False
	if v mod 2 = 0 then return v = 2
	if v mod 3 = 0 then return v = 3
	d = 5
	while d * d <= v
		if v mod d = 0 then return False else d += 2
	end while
	return True
end function

p = 2
j = 1

print 2; " ";
while True
	while True
		if isPrime(p + j*j) then exit while
		j += 1
	end while
	p += j*j
	if p > 16000 then exit while
	print p; " ";
	j = 1
end while
end
