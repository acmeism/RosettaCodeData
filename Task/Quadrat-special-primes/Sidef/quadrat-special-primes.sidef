func quadrat_primes(callback) {

    var prev = 2
    callback(prev)

    loop {
        var curr = (1..Inf -> lazy.map { prev + _**2 }.first { .is_prime })
        callback(curr)
        prev = curr
    }
}

say gather {
    quadrat_primes({|k|
        break if (k >= 16000)
        take(k)
    })
}
