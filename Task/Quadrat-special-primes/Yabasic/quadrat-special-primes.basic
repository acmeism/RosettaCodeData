sub isPrime(v)
    if v < 2 then return False : fi
    if mod(v, 2) = 0 then return v = 2 : fi
    if mod(v, 3) = 0 then return v = 3 : fi
    d = 5
    while d * d <= v
        if mod(v, d) = 0 then return False else d = d + 2 : fi
    wend
    return True
end sub

p = 2
j = 1

print 2, " ";
do
    do
        if isPrime(p + j*j) then break : fi
        j = j + 1
    loop
    p = p + j*j
    if p > 16000 then break : fi
    print p, " ";
    j = 1
loop
end
