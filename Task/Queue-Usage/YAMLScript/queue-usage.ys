!ys-0

# FIFO queue backed by a vector: enqueue=conj, dequeue=first+subvec.

defn main():
  q =: reduce(enqueue [] qw(a b c))
  say: "queue:    $q"
  say: "front:    $(front(q))"
  say: "dequeue:  $(dequeue(q))"
  say: "empty?:   $(empty?(q))"
  emptied =: iterate(dequeue q).3
  say: "emptied?: $(empty?(emptied))"

defn- enqueue(q v):
  q.conj(v)

defn- front(q):
  first: q

defn- dequeue(q):
  subvec: q 1
