SCREEN 1,640,200,3,2
WINDOW 2,"Rainbow text",(0,10)-(320,50),15,1
LOCATE 3,18
s$="RAINBOW"
PALETTE 0,.8,.8,.8
FOR i=1 TO 7
  READ r,g,b
  PALETTE i,r,g,b
  COLOR i
  PRINT MID$(s$,i,1);
NEXT
WHILE INKEY$=""
WEND
SCREEN CLOSE 1

DATA .93,.11,.14
DATA 1,.5,.15
DATA 1,.95,0
DATA .13,.69,.3
DATA 0,.64,.91
DATA .25,.28,.8
DATA .64,.29,.65
