require "ansi"

local colors = {
    {255,   0,   0}, -- red
    {255, 128,   0}, -- orange
    {255, 255,   0}, -- yellow
    {  0, 255,   0}, -- green
    {  0,   0, 255}, -- blue
    { 75,   0, 130}, -- indigo
    {128,   0, 255}  -- violet
}

local rainbow = "RAINBOW":split("")
for i, c in rainbow do
    local col = screen.rgb(colors[i]:unpack())
    screen.write(c, col)
end
print()
