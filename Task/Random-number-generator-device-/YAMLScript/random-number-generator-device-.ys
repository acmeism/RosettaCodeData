!ys-0

# Obtain a random 32-bit number from the OS entropy device
# /dev/urandom. We read 4 raw bytes from the device and interpret
# them as a single unsigned 32-bit integer via od.
defn main(bits=32):
  bytes =: bits // 8
  cmd =: "head -c $bytes /dev/urandom | od -An -tu$bytes"
  say: cmd:bash-out:trim:N
