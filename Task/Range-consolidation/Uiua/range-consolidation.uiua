{ [[1 2.5] [3 4.2]]
  [[6.1 7.2] [7.2 8.3]]
  [[1 2] [4 8] [2 5]]
  [[1 3] [¯6 ¯1] [¯4 ¯5] [8 2] [¯6 ¯6]]}

Consolidate ← (
  ⊃↙↘1⍆≡⍆ # Sort each range, sort all by starts, split first.
  ⊙◌⍢(
    ⊓⊃↘₋₁⊣⊃⊢↘₁                 # compare next with last processed.
    ⊂⊙(⨬(⊟|[∘]⊂⊙↥⊓°⊟⊣)◡(≤⊓⊣⊢)) # If they overlap, take max end, else keep both
  | >0⧻◌)
)
≡◇(&pConsolidate)
