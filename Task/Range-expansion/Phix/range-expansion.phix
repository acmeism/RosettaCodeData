with javascript_semantics
function range_expansion(string range)
    sequence res = {}
    for s in split(range,',') do
        integer k = find('-',s,2)
        res &= iff(k=0?to_number(s)
               :tagset(to_number(s[k+1..$]),
                       to_number(s[1..k-1])))
    end for
    return res
end function

?range_expansion("-6,-3-1,3-5,7-11,14,15,17-20")
?range_expansion("-6,-3--1,3-5,7-11,14,15,17-20")
