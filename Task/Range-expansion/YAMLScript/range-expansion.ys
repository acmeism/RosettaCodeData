!ys-0

defn main(s='-6,-3--1,3-5,7-11,14,15,17-20'):
  say: expand(s):joins

defn expand(s):
  s.split(',').mapcat(expand-part)

defn expand-part(part):
  m =: part.re-find(/^(-?\d+)-(-?\d+)$/)
  if m:
    make-range: I(m.1) I(m.2)
    else: +[I(part)]

defn make-range(a b): a .. b

# Match "a-b" range, handling negatives like "-3--1"
