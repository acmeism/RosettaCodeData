!ys-0

defn main(total=300000 step=100000):
  start =: System/currentTimeMillis()
  loop i 1:
    if i > total:
      say: "done $total jobs"
      else:
        when (i % step):zero?:
          elapsed =: max(1 (System/currentTimeMillis() - start))
          rate =: (i * 1000.0) / elapsed
          say: "$i jobs in ${elapsed}ms: $(format('%.1f' rate))/s"
        recur: i.++
