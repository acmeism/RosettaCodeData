local e <const> = math.exp(1)

print($"e         = {e}")
print($"pi        = {math.pi}")
print($"sqrt(2)   = {math.sqrt(2)}")
print($"ln(3)     = {math.log(3)}")  -- log base e
print($"exp(2)    = {math.exp(2)}")
print($"abs(-e)   = {math.abs(-e)}")
print($"floor(e)  = {math.floor(e)}")
print($"ceil(e)   = {math.ceil(e)}")
print($"pow(e, 2) = {e ^ 2}")
