get "libhdr"

let vowel(c) = valof
$(  c := c | 32
    resultis c='a' | c='e' | c='i' | c='o' | c='u'
$)

let devowel(s) = valof
$(  let i = 1
    while i <= s%0
    $(  test vowel(s%i)
        $(  for j=i+1 to s%0 do s%(j-1) := s%j
            s%0 := s%0 - 1
        $)
        or i := i + 1
    $)
    resultis s
$)

let start() be
    writes(devowel("THE QUICK BROWN FOX jumps over the lazy dog.*N"))
