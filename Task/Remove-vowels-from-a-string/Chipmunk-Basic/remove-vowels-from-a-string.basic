100 mensaje$ = "If Peter Piper picked a pack of pickled peppers"+", how many pickled peppers did Peter Piper pick?"
110 textofinal$ = ""
120 for i = 1 to len(mensaje$)
130   c$ = mid$(mensaje$,i,1)
140   select case c$
150   case "a","e","i","o","u","A","E","I","O","U"
160     rem continue for
170   case else
180     textofinal$ = textofinal$+c$
190   end select
200 next i
210 print textofinal$
