dim as string message = "If Peter Piper picked a pack of pickled peppers"+_
                        ", how many pickled peppers did Peter Piper pick?"
dim as string outstr = "", c

for i as uinteger = 1 to len(message)
    c=mid(message,i,1)
    select case c
    case "a", "e", "i", "o", "u", "A", "E", "I", "O", "U":
        continue for
    case else:
        outstr += c
    end select
next i

print outstr
