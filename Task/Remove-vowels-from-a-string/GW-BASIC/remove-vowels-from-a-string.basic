10 MS$ = "If Peter Piper picked a pack of pickled peppers, how many pickled peppers did Peter Piper pick?"
20 TF$ = ""
30 FOR I = 1 TO LEN(MS$)
40   C$ = MID$(MS$,I,1)
50   IF C$ <> "a" AND C$ <> "e" AND C$ <> "i" AND C$ <> "o" AND C$ <> "u" AND C$ <> "A" AND C$ <> "E" AND C$ <> "I" AND C$ <> "O" AND C$ <> "U" THEN TF$ = TF$ + C$
60 NEXT I
70 PRINT TF$
