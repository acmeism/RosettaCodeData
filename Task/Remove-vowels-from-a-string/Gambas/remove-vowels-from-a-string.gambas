Public Sub Main()

  Dim mensaje As String = "If Peter Piper picked a pack of pickled peppers, how many pickled peppers did Peter Piper pick?"
  Dim textofinal As String = ""
  Dim c As String

  For i As Integer = 1 To Len(mensaje)
    c = Mid(mensaje, i, 1)
    Select Case c
      Case "a", "e", "i", "o", "u", "A", "E", "I", "O", "U"
        Continue
      Case Else
        textofinal &= c
    End Select
  Next

  Print textofinal

End
