OpenConsole()
mensaje.s = "If Peter Piper picked a pack of pickled peppers" + " or how many pickled peppers did Peter Piper pick?"
textofinal.s = ""

For i.i = 1 To Len(mensaje)
  c.s = Mid(mensaje,i,1)
  Select c
    Case "a", "e", "i", "o", "u", "A", "E", "I", "O", "U"
      Continue
    Default
      textofinal + c
  EndSelect
Next i

PrintN(textofinal)
Input()
CloseConsole()
