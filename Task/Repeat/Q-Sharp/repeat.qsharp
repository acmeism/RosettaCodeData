namespace RepeatExample {
    open Microsoft.Quantum.Diagnostics;

    operation Proc() : Unit {
        Message(" Inside loop");
    }

    operation Repeat(op : Unit => Unit, times : Int) : Unit {
        for i in 1..times {
            op();
        }
    }

    @EntryPoint()
    operation Main() : Unit {
        Repeat(Proc, 5);
        Message("Loop Ended");
    }
}
