require "bignum"
local int = require "int"
local fmt = require "fmt"

mpz.init()

local limit <const> = 2700
local primes = int.primes(limit)
for b = 2, 36 do
    local rprimes = {}
    for primes as p do
        local s = bigint.frombase(string.rep("1", p), b)
        if mpz.isprobableprime(s, 15) then rprimes:insert(p) end
    end
    fmt.print("Base %2d: %s", b, fmt.swrite(rprimes))
end
