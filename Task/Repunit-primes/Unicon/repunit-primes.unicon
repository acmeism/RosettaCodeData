link fastprime

procedure main(A)
   limit := \A[1] | 1000
   every writes("Base ",b := 2 to 16,":") do
      every writes(" ",repunits(b,limit) | "\n")
end

procedure repunits(b,n)
   every x := genprimes() do
      if x > n then break
      else suspend (is_prime(ru(b,x)), x)
end

procedure ru(b,n)
   every (r := 0) +:= b^(0 to n-1)
   return r
end
