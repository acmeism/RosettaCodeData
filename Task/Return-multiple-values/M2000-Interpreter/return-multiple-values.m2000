function give3(a) {
		flush ' empty stack of values
		for i=1 to 3
			data a ' add to the end of stack
			if i<3 then a*=a
		next
		' [] remove the stack and return a pointer
		' array( stack_object) consume stack to a new tuple
		=array([])
}
' multiple assign
(a,b,c)=give3(3)
? a=3, b=9, c=81
function swapvalues(a, b) {
	=b, a
}
(a,b)=swapvalues(a, b)
? a=9, b=3
