open "text.txt" for input as #1
dim as string textEnt, textSal()
dim as integer n, linea = 0

do while not eof(1)
    line input #1, textEnt
    linea += 1
    redim preserve textSal(linea)
    textSal(linea) = textEnt
loop

for n = ubound(textSal) to 1 step -1
    print textSal(n)
next n
close #1
sleep
