char    Array(1000, 1000);      \(tacky)
int     Line, Char, I;
def     LF=$0A, EOF=$1A;
[Line:= 0;
repeat  I:= 0;
        repeat  Char:= ChIn(1);
                Array(Line, I):= Char;  I:= I+1;
        until   Char = LF or Char = EOF;
        Line:= Line+1;
until   Char = EOF;
for Line:= Line-2 downto 0 do
        [I:= 0;
        repeat  Char:= Array(Line, I);  I:= I+1;
                ChOut(0, Char);
        until   Char = LF;
        ];
]
