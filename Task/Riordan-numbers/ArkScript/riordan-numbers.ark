(import std.Math)

(let riordan (fun (n) {
  (mut a [1 0 1])
  (mut i 3)
  (while (< i n) {
    (append! a (math:floordiv (* (- i 1) (+ (* 2 (@ a (- i 1))) (* 3 (@ a (- i 2))))) (+ i 1)))
    (set i (+ 1 i)) })
  a }))

(let nums (riordan 32))

(import std.List)
(list:forEach nums (fun (n) (print (format "{:18}" n))))
