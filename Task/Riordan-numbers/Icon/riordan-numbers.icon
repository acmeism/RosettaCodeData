procedure main(A)
   limit := \A[1] | 32
   every (cnt := 0, r := riordan(), cnt +:=1) do
      if cnt < limit then writes(" ",r)
      else if cnt = limit then write(" ",r)
      else if cnt = 1000 then write("The 1,000 Riordan has ",*r," digits")
      else if cnt = 10000 then break write("The 10,000 Riordan has ",*r," digits")
end

procedure riordan()
   a := [1,0]
   every suspend !a
   every n := seq(3) do {
      put(a, x := (n-2)*(2*a[n-1] + 3*a[n-2])/(n))
      suspend x
      }
end
