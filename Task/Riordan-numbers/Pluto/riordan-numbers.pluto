local bigint = require "bigint"
local fmt = require "fmt"

local limit <const> = 10000
local a = table.create(limit)
a[1] = bigint.new(1)
a[2] = bigint.new(0)
for n = 3, limit do
    a[n] = (a[n - 1] * 2 + a[n - 2] * 3) * (n - 2) / n
end
print("First 32 Riordan numbers:")
fmt.tprint("%13s", a:slice(1, 32), 4)
print()
for {1000, 10000} as i do
    local s = a[i]:tostring()
    fmt.print("%5dth: %20s (%s digits)", i, fmt.abridge(s, 20), #s)
end
