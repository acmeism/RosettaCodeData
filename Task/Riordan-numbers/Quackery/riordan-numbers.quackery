  [ dup -1 peek 2 *
    over -2 peek 3 * +
    over size tuck 1 - *
    swap 1+ /
    join ]               is nextterm ( [ --> [ )


  say "first 32 Riordan numbers: "
  ' [ 1 0 ]
  30 times nextterm
  witheach [ echo sp ]
  cr cr
  say "1000th Riordan number has "
  ' [ 1 0 ]
  1000 2 - times nextterm
  -1 peek number$ size echo
  say " digits"
  cr cr
  say "10000th Riordan number has "
  ' [ 1 0 ]
  10000 2 - times nextterm
  -1 peek number$ size echo
  say " digits"
