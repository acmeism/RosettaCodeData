!ys-0

defn main(n=1990):
  say: "$n = $(encode(n))"

values =:: [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1]
symbols =: qw(M CM D CD C XC L XL X IX V IV I)

defn encode(n):
  loop i 0, num n, acc '':
    cond:
      num:zero?: acc
      num >= values.$i:
        recur: i (num - values.$i) "$acc$(symbols.$i)"
      else:
        recur: i.++ num acc
