!ys-0

defn main():
  each n (2 .. 5):
    say: "$n roots of unity:"
    each k (0 .. dec(n)):
      say: "  $show(root(n k))"
    say:

defn show(r):
  re =: fmt(r.0)
  im =: fmt(r.1)
  format '%+.4f %+.4fi': re im

defn fmt(x):
  if abs(x) < 0.0000000001: 0.0 x

defn root(n k):
  theta =: (2 * Math/PI * k) / n
  re =: Math/cos(theta)
  im =: Math/sin(theta)
  vector: re im
