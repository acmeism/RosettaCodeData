!ys-0

defn main(text='WWWWWWWWWWWWBWWWWWWWWWWWWBBBWWWWWWWWWWWWWWWWWWWWWWWWBWWWWWWWWWWWWWW'):
  encoded =: encode(text)
  say: encoded
  say: decode(encoded)

defn encode(s):
  partition-by(identity s)
    .mapv(\("$(_.#)$(first _)"))
    .join()

defn decode(s):
  parts =:
    for m s.re-seq(/(\d+)(\w)/):
      n =: m.1:I
      ch =: m.2
      ch *: n
  str: parts*
