!ys-0

# YAMLScript evaluates source at runtime with eval(s): the string is
# compiled and run as full YS, and the value of its last expression is
# returned. There is no expression/statement distinction, so a fragment
# can be a single expression or a whole program.

defn main():
  # Evaluate an expression and use its return value.
  expr =: '(1 + 2) * 3'
  say: "$expr => $eval(expr)"

  # Pass a value in by interpolating it into the source string, get a
  # value out via the return value.
  x =: 20
  code =: "$x * 2"
  say: "double($x) => $eval(code)"

  # The colon-chain form runs source bound to a name.
  prog =: '(1 .. 10):sum'
  say: "sum 1..10 => $eval(prog)"
