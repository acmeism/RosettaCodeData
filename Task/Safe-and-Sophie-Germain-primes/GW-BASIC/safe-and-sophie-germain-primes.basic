10 PRINT "      2";
20 C = 1
30 N = 3
40 WHILE C < 50
50 P = N
60 GOSUB 170
70 IF Z = 0 THEN 140
80 P = 2 * N + 1
90 GOSUB 170
100 IF Z = 0 THEN 140
110 C = C + 1
120 PRINT USING "  #####"; N;
130 IF C MOD 10 = 0 THEN PRINT
140 N = N + 2
150 WEND
160 END
170 Z = 0
180 IF P < 2 THEN RETURN
190 IF P < 4 THEN Z = 1 : RETURN
200 IF P MOD 2 = 0 THEN RETURN
210 FOR I = 3 TO SQR(P) STEP 2
220 IF P MOD I = 0 THEN RETURN
230 NEXT I
240 Z = 1
250 RETURN
