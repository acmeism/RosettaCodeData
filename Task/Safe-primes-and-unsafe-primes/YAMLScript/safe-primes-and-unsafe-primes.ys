!ys-0

defn main(limit=100):
  safe =:
    filter safe-prime? (2 .. limit):
  unsafe =:
    filter _ (2 .. limit):
      fn(p): prime?(p) && not(safe-prime?(p))
  say: "safe: $(safe:joins)"
  say: "unsafe: $(unsafe:joins)"

defn safe-prime?(p):
  prime?(p) && prime?(p.-- // 2)

defn prime?(n):
  (n > 1) &&
  range(2 n:sqrt:I.++)
  .every?(\((n % _).?))
