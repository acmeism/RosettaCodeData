!ys-0

defn main(sailors=5):
  say: find-solution(sailors)

defn find-solution(sailors):
  loop n 1:
    if works?(n sailors):
      then: n
      else:
        recur: n.++

defn works?(n sailors):
  loop pile n, i 0:
    rem =: pile % sailors
    cond:
      i == sailors: rem.!
      rem != 1: false
      else:
        one-less =: pile.--
        share =: one-less // sailors
        next =: one-less
        next -=: share
        recur: next, i.++
