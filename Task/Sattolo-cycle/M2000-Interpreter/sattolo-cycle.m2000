module Sattolo_cycle {
	rem k=random(!123123)
	arr=lambda (i as long) ->{
		i--
		if i<0 then error "i>1"
		plusone=lambda k=10 ->{=k:k+=10}
		dim alfa(0 to i) as single <<plusone()
		while i>0
			j=random(0, i)
			swap alfa(i), alfa(j)
			i--
		end while
		=alfa()
	}
	Print arr(1)#str$(" ")
	Print arr(2)#str$(" ")
	Print arr(2)#str$(" ")
	Print arr(3)#str$(" ")
	Print arr(5)#str$(" ")
}
Sattolo_cycle
