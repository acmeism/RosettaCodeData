sattoloCycle[arr_] := Module[{res = arr, i, j},
    For[i = Length[arr], i >= 2, i--,
        j = RandomInteger[{1, i - 1}];
        res[[{i, j}]] = res[[{j, i}]]];
    res];

testCases = {{}, {10}, {10, 20}, {10, 20, 30}, Range[11, 22]};
Map[{#, "->", sattoloCycle[#]} &, testCases] // TableForm[#, TableDepth -> 2] &
