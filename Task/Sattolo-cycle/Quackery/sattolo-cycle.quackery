  [ temp put
    2dup swap
    temp share swap peek
    temp share rot peek
    dip
      [ swap
        temp take
        swap poke
        temp put ]
    swap
    temp take
    swap poke ]                 is [exch]  ( n n [ --> [ )

  [ dup size 1 - times
      [ i 1+ dup random
        rot [exch] ] ]         is sattolo (     [ --> [ )
