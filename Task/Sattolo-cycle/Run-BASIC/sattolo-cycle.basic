a$	= "123456789abcdefghijklmnopqrstuvwxyz"
n	= len(a$)
dim sit$(n)      '  hold area to string
global n

for i = 1 to n			' put string in array
    sit$(i) = mid$(a$,i,1)
next i

call shoSit			' show before change

for i		= n to 1 step -1
    j		= int(i * rnd(1)) + 1
    h$		= sit$(i)
    sit$(i)	= sit$(j)
    sit$(j)	= h$
next i

call shoSit			' show after change
end

sub shoSit
    for i = 1 to n
       print sit$(i);" ";
    next i
    print
end sub
