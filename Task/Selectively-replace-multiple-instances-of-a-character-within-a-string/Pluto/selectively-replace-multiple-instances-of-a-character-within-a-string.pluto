require "uchar"

local u = uchar.of("abracadabra")
local ixs  = {}
local start = 1
while ix := u:find("a", start) do
    ixs:insert(ix)
    start = ix + 1
end
local repl = "ABaCD"
for i = 1, #repl do u:set(ixs[i], repl[i]) end
local ix = u:find("b")
u:set(ix, "E")
ix = u:find("r", u:find("r") + 1)
u:set(ix, "F")
print(u)
