scope # find some self-contained numbers: odd numbers whose Collatz sequence
      #      contains a multiple of the number itself

    local scCount := 0;
    for n from 3 by 2 while scCount < 7 do
        local v := n;
        do
            v := ( 3 * v ) + 1;
            while not odd v do v \:= 2 od;
            if v mod n = 0 then
                scCount +:= 1;
                printf( " %d", n );
                v := 1
            fi
        until v = 1
    od
end
