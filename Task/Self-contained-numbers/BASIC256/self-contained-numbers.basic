i = 1
c = 0
dim res(6)

while c < 6
	j = i
	while j <> 1
		if j mod 2 = 0 then
			j = j \ 2
		else
			j = 3 * j + 1
		end if
		if j mod i = 0 then
			res[c] = i
			c += 1
			exit while
		end if
	end while
	i += 2
end while

print "The first 6 self-contained numbers are:"
for c = 0 to 5
	print res[c]; " ";
next c
