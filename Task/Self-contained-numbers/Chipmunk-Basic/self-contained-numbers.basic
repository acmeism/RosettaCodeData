100 cls
110 i = 1
120 c = 0
130 dim res(6)
140 while c < 7
150   j = i
160   while j <> 1
170     if j mod 2 = 0 then j = int(j/2) else j = 3*j+1
180     if j mod i = 0 then res(c) = i : c = c+1 : goto 200
190   wend
200   i = i+2
210 wend
220 print "The first 7 self-contained numbers are:"
230 for c = 0 to 6
240    print res(c);
250 next
260 print
270 end
