sequence res = {}
integer n = 3
do
    atom c = n
    do
        c = 3*c+1
        if rmdr(c,n)=0 then
            res &= n
            exit
        end if
        do
            c /= 2
        until odd(c)
    until c=1
    n += 2
until length(res)>=7
printf(1,"The first %s self-contained numbers are: %s\n",
 {ordinal(length(res),true),join(res,", ",", and ","%d")})
