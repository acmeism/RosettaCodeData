local res = {}
local i = 1
while #res < 7 do
    local j = i
    while j != 1 do
        if j % 2 == 0 then j //= 2 else j = 3 * j + 1 end
        if j % i == 0 then
            res:insert(i)
            break
        end
    end
    i += 2
end
print("The first 7 self-contained numbers are:")
for k = 1, 7 do io.write($"{res[k]} ") end
print()
