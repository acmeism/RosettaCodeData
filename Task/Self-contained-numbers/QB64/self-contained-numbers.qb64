Dim i As Integer, c As Integer
Dim res(5) As Integer
Dim j As _Unsigned _Integer64

i = 1
c = 0

While c < 6
    j = i
    While j <> 1
        If j Mod 2 = 0 Then j = j \ 2 Else j = 3 * j + 1
        If j Mod i = 0 Then
            res(c) = i
            c = c + 1
            Exit While
        End If
    Wend
    i = i + 2
Wend

Print "The first 6 self-contained numbers are:"
For c = 0 To 5
    Print res(c);
Next
