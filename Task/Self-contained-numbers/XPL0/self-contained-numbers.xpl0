int  I, C, Res(7), J;
[I:= 1;  C:= 0;
while C < 7 do
    [J:= I;
    while J # 1 do
        [if rem(J/2) = 0 then J:= J/2 else J:= 3*J + 1;
         if rem(J/I) = 0 then
             [Res(C):= I;  C:= C+1;
             J:= 1;     \break;
             ];
        ];
    I:= I+2;
    ];
for C:= 0 to 7-1 do
    [IntOut(0, Res(C));  ChOut(0, ^ )];
CrLf(0);
]
