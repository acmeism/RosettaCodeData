!ys-0

defn main(file='/tmp/unixdict.txt'):
  words =: read(file):lines
  word-map =: frequencies(words)
  matches =:
    keep _ words:
      fn(w):
        rev =: w:reverse
        when word-map.(rev) && (rev != w): w
  pairs =: sort(set(matches.map(make-pair)))
  say: "$(pairs.#) semordnilap pairs found"
  each pair pairs.take(5):
    say: pair:joins

defn make-pair(w):
  rev =: w:reverse
  pair =: +[w rev]
  V: sort(pair)
