!ys-0

defn main(limit=1000000):
  say: 'First 22 terms:'
  each n (1 .. 22):
    say: "n=$(format('%2d' n)) -> $(seq(n))"
  bad =:
    filter square?:
      map seq: 1 .. limit.--
  if bad:empty?:
    say: "No squares for n < $limit"
    say: "Found squares: $(take(5 bad))"

defn seq(n):
  n + floor(0.5 + sqrt(n))

defn square?(n):
  r =: I(sqrt(n))
  r:sqr ==: n
