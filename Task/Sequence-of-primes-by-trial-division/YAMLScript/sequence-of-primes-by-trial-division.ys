!ys-0

# Primes via trial division: test each odd candidate against odd
# divisors up to its square root.

defn main(limit=100):
  ps =: (2 .. limit).filter(prime?)
  say: "Primes below $limit:"
  say: ps:joins

defn- prime?(n):
  cond:
    n < 2: false
    n == 2: true
    n:even?: false
    else: n.trial(3)

defn- trial(n d):
  cond:
    d:sqr > n: true
    zero?(n % d): false
    else: recur(n (d + 2))
