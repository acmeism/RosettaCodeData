with javascript_semantics
include mpfr.e
constant limit = 9999,
        flimit = iff(platform()=JS?15:30)
mpz {p,p1} = mpz_inits(2,1)
atom t0 = time()
integer found = 0
for n=0 to limit do
    if n then mpz_mul_si(p, p, get_prime(n)) end if
    for i=-1 to +1 by 2 do
        mpz_add_si(p1, p, i)
        if mpz_prime(p1) then
            integer l = mpz_sizeinbase(p,10)
            string ps = iff(l>20?sprintf("%d digits",l)
                        :sprintf("%s%+d",{mpz_get_str(p),i}))
            found += 1
            printf(1,"%d: %d (%s) is a primorial prime\n",{found,n,ps})
        end if
    end for
    if found>=flimit then exit end if
end for
{p,p1} = mpz_free({p,p1})
?elapsed(time()-t0)
