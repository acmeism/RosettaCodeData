!ys-0

defn main(limit=10):
  loop k 1, prev 0:
    when k <= limit:
      next =: find-next(prev.++ k)
      say: next
      recur: k.++, next

defn find-next(start k):
  loop n start:
    if divisor-count(n) != k:
      recur: n.++
      else: n

defn divisor-count(n):
  count:
    for d (1 .. n):
      when (n % d).!:
        d
