local int = require "int"
require "table2"

local limit = 22
local numbers = table.rep(limit, 0)
local i = 1
while true do
    local nd = int.divstat(i)[1]
    if nd <= limit and numbers[nd] == 0 then
        numbers[nd] = i
        if numbers:checkall(|n| -> n > 0) then break end
    end
    i += 1
end
print($"The first {limit} terms are:")
print(numbers:concat(", "))
