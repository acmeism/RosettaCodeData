!ys-0

defn main(*):
  A =: \{1 2 3 4 5}
  B =: \{3 4 5 6 7}

  say: "A = $A"
  say: "B = $B"
  say: "3 in A? $(contains?(A 3))"
  say: "6 in A? $(contains?(A 6))"
  say: "A union B = $(set/union(A B))"
  say: "A intersect B = $(set/intersection(A B))"
  say: "A difference B = $(set/difference(A B))"
  say: "A subset of B? $(set/subset?(A B))"

  C =: \{3 4 5}
  say: "C = $C"
  say: "C subset of B? $(set/subset?(C B))"
  say: "A = B? $(A == B)"
  say: "A = A? $(A == A)"
