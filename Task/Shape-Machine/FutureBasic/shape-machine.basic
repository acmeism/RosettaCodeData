include "NSLog.incl"

begin globals
  double    nxt
  NSInteger cnt
end globals

local fn ShapeMachine( prv as double )
  while (YES)
    nxt = (prv + 3) * 0.86
    if prv == nxt
      NSLog( @"\n\tTook %d iterations.\n\n", cnt )
      exit fn
    end if
    NSLog( @"%3d. %.15f", cnt, nxt )
    prv = nxt
    cnt++
  wend
end fn

cnt = 1

fn ShapeMachine( 4 )

HandleEvents
