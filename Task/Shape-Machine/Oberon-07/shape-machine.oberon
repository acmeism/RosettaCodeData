MODULE ShapeMachine;
IMPORT In, Out;

VAR a, prevA : REAL;
    n, count : INTEGER;

BEGIN
    count := 0;
    In.Int( n );
    a     := FLT( n );
    prevA := 0.0;
    WHILE prevA # a
    DO
        INC(count);
        prevA := a;
        a     := ( a + 3.0 ) * 0.86;
        Out.Real( a, 9 );Out.Ln
    END;
    Out.Int( count, 0 );Out.String( " repetitions" )
END ShapeMachine.
