  [ stack ]                               is maxval ( --> s )

  [ $ "Starting value: " input
    $->v drop
    $ "Max denominator: " input
    $->n drop maxval put
    0 temp put
    [ 1 temp tally
      2dup
      3 1 v+ 86 100 v*
      proper maxval share round improper
      2swap 2over v- v0= until ]
    maxval release
    proper$ echo$
    say " after " temp take echo
    say " iterations." cr ]               is task   ( -->   )
