PROGRAM  "Shape-Machine"
VERSION "0.0000"

DECLARE FUNCTION  Entry ()

FUNCTION  Entry ()
    cnt& = 1

    kbd$ = INLINE$("")
    prev# = DOUBLE(kbd$)

    DO
        sgte# = (prev# + 3) * 0.86
        IF prev# = sgte# THEN EXIT DO
        PRINT sgte#
        prev# = sgte#
        INC cnt&
    LOOP

    PRINT "Took"; cnt&; " iterations."
END FUNCTION
END PROGRAM
