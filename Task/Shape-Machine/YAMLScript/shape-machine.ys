!ys-0

defn main():
  shapes =: +[circle(3) rectangle(4 5) square(6)]
  each s shapes:
    say: "$(s.name): area $(s.area)"

defn circle(r):
  +{:name 'circle' :area (Math/PI * r:sqr)}

defn rectangle(w h):
  +{:name 'rectangle' :area (w * h)}

defn square(s):
  rectangle(s s).assoc(:name 'square')
