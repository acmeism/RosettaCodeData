link lists  # for limage and lrotate
procedure main()
    l := [1,2,3,4,5,6,7,8,9]
    write("before:     ",limage(l))
    every |put(l,pop(l))\3 ;    # in-place rotate 3
    write("rotated 3:  ",limage(l))
    l := lrotate(l,-4)          # new list rotated -4
    write("rotated -4: ",limage(l))
end
