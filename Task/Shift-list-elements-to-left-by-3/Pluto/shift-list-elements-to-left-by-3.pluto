-- In place left shift of an array 'a' by 'by' places.
local function lshift(a, by)
    if #a == 0 then return end
    by %= #a
    if by == 0 then return end
    local t = {}
    table.move(a, 1, by, 1, t)
    table.move(a, by + 1, #a, 1, a)
    table.move(t, 1, #t, #a - by + 1, a)
end

local a = {1, 2, 3, 4, 5, 6, 7, 8, 9}
print($"Original list     : {a:concat(", ")}")
lshift(a, 3)
print($"Shifted left by 3 : {a:concat(", ")}")
