local fmt = require "fmt"

local function shoelace(pts)
    local area = 0
    for i = 1, #pts - 1 do
        area += pts[i][1] * pts[i + 1][2] - pts[i + 1][1] * pts[i][2]
    end
    return math.abs(area + pts:back()[1] * pts[1][2] - pts[1][1] * pts:back()[2]) / 2
end

local pts = { {3, 4}, {5, 11}, {12, 8}, {9, 5}, {5, 6} }
print($"The polygon with vertices at {fmt.swrite(pts)} has an area of {shoelace(pts)}.")
