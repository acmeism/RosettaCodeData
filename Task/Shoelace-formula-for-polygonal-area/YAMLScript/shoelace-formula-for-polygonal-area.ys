!ys-0

defn main(points='3,4 5,11 12,8 9,5 5,6'):
  say: area(parse(points))

defn parse(points):
  points:words.mapv(\(_.split(',').mapv(N)))

defn area(ps):
  # Pair each vertex with the next, wrapping around to the first.
  qs =: ps:rest:V.conj(ps.0)
  map(cross ps qs):sum:abs /: 2

defn cross([x1 y1] [x2 y2]):
  (x1 * y2) - (x2 * y1)
