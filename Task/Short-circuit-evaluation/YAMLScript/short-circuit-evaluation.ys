!ys-0

defn main():
  bools =: +[false true]
  each i bools, j bools:
    say: "--- i=$i, j=$j ---"
    say: 'AND:'
    x =: a(i) && b(j)
    say: "  result: $x"
    say: 'OR:'
    y =: a(i) || b(j)
    say: "  result: $y"

defn a(v):
  say: "  a($v) called"
  =>: v

defn b(v):
  say: "  b($v) called"
  =>: v
