local fmt = require "fmt"

for i = 0, 15 do
    local j = 32 + i
    while j < 128 do
        local k = string.char(j)
        if j == 32 then
            k = "Spc"
        elseif j == 127 then
            k = "Del"
        end
        fmt.write("%3d : %-3s   ", j, k)
        j += 16
    end
    print()
end
