\ publication syntax
main (p):+
    for i =: from 32 upto 32+15
        for j =: from 0 times 6 step 16
       k =: i + j
            c =: integer k code point as string
            if c = ' ': c =: 'sp'
            if k = 127: c =: 'del'
            print format '%4; : %3; ' k, c nonl
        print ''
