            NORMAL MODE IS INTEGER
            VECTOR VALUES FMT = $I8,7H **2 = ,I15*$
            THROUGH LOOP, FOR I=0, 1, I.G.7
            N = 0
            THROUGH ONES, FOR J=1, 1, J.G.I
ONES        N = N*10 + 1
            N = N*10 + 3
LOOP        PRINT FORMAT FMT,N,N*N
            END OF PROGRAM
