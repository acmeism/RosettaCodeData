!ys-0

# YS runs on the JVM; System/currentTimeMillis counts milliseconds
# from the Unix epoch (1970-01-01 00:00:00 UTC).

defn main():
  now-ms =: System/currentTimeMillis()
  say: "YS epoch: 1970-01-01 00:00:00 UTC (Unix/Java)"
  say: "Now (ms since epoch): $now-ms"
  say: "Now (s since epoch):  $(now-ms.quot(1000))"
