!ys-0

defn main(order=3):
  lines =: carpet(order)
  each line lines:
    say: line

defn carpet(n):
  if n:zero?:
    then: V+('#')
    else:
      prev =: carpet(n.--)
      size =: prev:count
      gap =: size * ' '
      concat:
        for row prev: row + row + row
        for row prev: row + gap + row
        for row prev: row + row + row
