	    ; Both input and output in A
signum: ora	a	; (4) Set flags
        rz		; (11 / 5) If zero, return (with zero) => 15 cycles in 0 case
        ral		; (4) Rotate sign bit into carry flag
        sbb	a	; (4) A = A - A - carry (extend carry across a)
        rnz		; (11 / 5) If not zero, return (with -1) => 28 cycles in - case
        inr	a	; (5) If it was positive, set A to 1
        ret		; (10) Return (with 1) => 37 cycles in + case
