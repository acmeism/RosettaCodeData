        org     100h
        jmp     test

signum: ora     a
        rz
        ral
        sbb     a
        rnz
        inr     a
        ret

test:   mvi b,0
loop:   push b! mov a,b! call hexout! lxi d,arrow! call outs! pop b
        push b! mov a,b! call signum! call hexout! lxi d,newlin! call outs! pop b
        inr b! jnz loop
        ret

hexout: push psw! rrc! rrc! rrc! rrc! call hexlo! pop psw
hexlo:  ani 15! cpi 10! jc outd! adi 7
outd:   adi 48! mov e,a! mvi c,2! jmp 5
outs:   mvi c,9! jmp 5
arrow:  db ' => $'
newlin: db 13,10,'$'
