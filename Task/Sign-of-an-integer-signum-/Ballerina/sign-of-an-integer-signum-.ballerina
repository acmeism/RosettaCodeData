import ballerina/io;

function signum(int|float n) returns int|float {
    if n is int {
        return n > 0 ? 1 : n < 0 ? -1 : 0;
    }
    if n === -0.0 {
        return n;
    }
    return signum(<int>n);
}

public function main() {
    var numbers = [5, -5, 0, -0.0];
    foreach var n in numbers {
        io:println(n, " -> ", signum(n));
    }
}
