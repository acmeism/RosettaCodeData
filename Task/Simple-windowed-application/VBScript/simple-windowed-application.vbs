CreateObject("Shell.Application").ShellExecute "mshta", """about:<HTA:APPLICATION BORDER=dialog MAXIMIZEBUTTON=no><html><head><title>Simple windowed application</title><style>body{text-align:center;font-size:1.5em;font-family:sans-serif}</style></head><body scroll=no><div id=div><p>There have been <span id=label>no</span> clicks</span></p><button onclick=updatelabel()>click me</button></div><script language=VBScript>window.resizeTo 500,200 : clicks=0 : Sub updatelabel() : clicks = clicks + 1 : label.innerText = CStr(clicks) : End Sub</script></body></html>"""
