!ys-0

# Singly-linked list as nested {value next} maps; traverse via loop.

defn main():
  list =: qw(alpha beta gamma delta):build
  traverse: list

defn- build(xs):
  reduce _ nil xs:reverse:
    fn(tail v):
      +{:value v :next tail}

defn- traverse(list):
  loop node list:
    when node:
      say: node.value
      recur: node.next
