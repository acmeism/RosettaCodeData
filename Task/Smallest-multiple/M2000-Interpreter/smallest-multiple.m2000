function smallest (n, k){
	integer m=1
	do
		if  n mod m>0 then n=n+1:m=0% else if m>=k then =n:break
		m++
	always
}
Print 10;": ";smallest(1%, 10)
Print 20;": ";smallest(1&, 20)
Print 200;": ";smallest(337293588832926264639465766794841407432394382785157234228847021917234018060677390066992000u-3, 200)
