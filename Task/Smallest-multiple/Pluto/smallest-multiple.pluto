local int = require "int"
local fmt = require "fmt"
local bigint = require "pluto:bigint"

local function lcm(n)
    local primes = int.primes(n)
    local res = bigint.new(1)
    for primes as p do
        local f = p
        while f * p <= n do f *= p end
        res *= f
    end
    return res
end

print("The LCMs of the numbers 1 to N inclusive is:")
for {10, 20, 200, 2000} as i do fmt.print("%,5s: %,s", i, lcm(i)) end
