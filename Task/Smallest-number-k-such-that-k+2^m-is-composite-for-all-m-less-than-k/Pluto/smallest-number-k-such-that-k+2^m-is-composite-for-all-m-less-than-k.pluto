require "bignum"

mpz.init() -- use GMP

-- Returns true if k is a sequence member, false otherwise.
local function a(k)
    if k == 1 then return false end
    for m = 1, k - 1 do
        local n = mpz.shl(1, m) + k
        if mpz.isprobableprime(n, 15) then return false end
    end
    return true
end

local count = 0
local k = 1
while count < 5 do
    if a(k) then
        io.write($"{k} ")
        count += 1
    end
    k += 2
end
print()
