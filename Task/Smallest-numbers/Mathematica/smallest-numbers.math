ClearAll[FindSmallestk]
FindSmallestk[n_Integer] := Module[{digs, id, out},
  id = IntegerDigits[n];
  Do[
   digs = IntegerDigits[k^k];
   If[Length[SequenceCases[digs, id, 1]] > 0, out = k; Break[]]
   ,
   {k, 1, \[Infinity]}
   ];
  out
  ]
Multicolumn[FindSmallestk /@ Range[0, 50], Appearance -> "Horizontal"]
