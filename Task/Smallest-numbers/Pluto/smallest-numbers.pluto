local bigint = require "pluto:bigint"
local fmt = require "fmt"

local res = {}
for n = 0, 50 do
    local k = 1
    local ns = tostring(n)
    while true do
        local s = (bigint.new(k) ^ k):tostring()
        if ns in s then
            res:insert(k)
            break
        end
        k += 1
    end
end

print("The smallest positive integers K where K ^ K contains N (0..50) are:")
fmt.tprint("%2d", res, 17)
