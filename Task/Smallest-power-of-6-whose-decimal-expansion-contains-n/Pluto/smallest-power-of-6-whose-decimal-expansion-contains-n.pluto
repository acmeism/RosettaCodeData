local bigint = require "pluto:bigint"
local fmt = require "fmt"

print(" n  smallest power of 6 which contains n")
local six = bigint.new(6)
for n = 0, 21 do
    local i = 0
    local ns = tostring(n)
    while true do
        local pow6 = (six ^ i):tostring()
        if ns in pow6 then
            fmt.print("%2d  6^%-2d = %,s", n, i, pow6)
            break
        end
        i += 1
    end
end
