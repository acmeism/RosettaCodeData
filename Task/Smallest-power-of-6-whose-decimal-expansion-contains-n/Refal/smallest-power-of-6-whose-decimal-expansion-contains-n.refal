$ENTRY Go {
    = <Each (ShowSmallest) <Iota 0 21>>;
};

ShowSmallest {
    s.N, <Symb <Smallest6 s.N>>: e.P =
        <Prout <Symb s.N> ': ' e.P>;
};

Smallest6 {
    s.N = <Smallest6 s.N 1>;
    s.N e.P, <Symb s.N>: e.SN,
             <Symb e.P>: e.X e.SN e.Y = e.P;
    s.N e.P = <Smallest6 s.N <Mul (e.P) 6>>;
};

Iota {
    s.E s.E = s.E;
    s.S s.E = s.S <Iota <Add 1 s.S> s.E>;
};

Each {
    (e.F) = ;
    (e.F) s.I e.X = <Mu e.F s.I> <Each (e.F) e.X>;
};
