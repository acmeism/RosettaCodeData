program smallest_power_of_six_whose_decimal_expansion_contains_n;
    loop for n in {0..21} do
        print(lpad(str n, 2) + ": " + lpad(str smallest6(n), 22));
    end loop;

    proc smallest6(n);
        p6 := 1;
        loop while not (str n in str p6) do
            p6 *:= 6;
        end loop;
        return p6;
    end proc;
end program;
