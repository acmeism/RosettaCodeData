// Rosetta Code problem: http://rosettacode.org/wiki/Smallest_power_of_6_whose_decimal_expansion_contains_n
// by Galileo, 05/2022

sub smallest_six(n)
    local p, n$

    n$ = str$(n)
    p = 1
    while not instr(str$(p, "%1.f"), n$) p = p * 6 : wend
    return p
end sub

for n = 0 to 21 : print n, ": ", str$(smallest_six(n), "%1.f") : next
