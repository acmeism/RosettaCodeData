main =>
  println([S : N in 1..49, S = smallest_square2(N)]).

smallest_square2(N) = Ret =>
  I = 1,
  Found = false,
  while (Found == false)
    Square = I*I,
    while (Square > N)
      Square := Square // 10
    end,
    if Square == N then
      Found := I*I
    end,
    I := I + 1
  end,
  Ret = Found.
