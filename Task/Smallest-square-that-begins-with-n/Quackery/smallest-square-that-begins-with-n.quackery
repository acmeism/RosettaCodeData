  [ dup * ]            is squared (   n --> n )

  [ 2dup = iff
      [ 2drop true ]
      done
    2dup < iff
      [ 2drop false ]
      done
    dip [ 10 / ]
    again ]            is starts  ( n n --> b )

  [ times
     [ 0
       [ 1+
         dup squared
         i^ 1+
         starts iff
           [ squared
             echo sp ]
           done
         again ] ] ]   is task    (   n -->   )

  49 task
