program smallest_square_that_begins_with_n;
    loop for n in [1..49] do
        nprint(lpad(str smallest_prefix_square n, 7));
        if n mod 10=0 then print; end if;
    end loop;
    print;

    op begins_with(n, s);
        loop while n>s do
            n div:= 10;
        end loop;
        return n=s;
    end op;

    op smallest_prefix_square(n);
        loop until s*s begins_with n do
            s +:= 1;
        end loop;
        return s*s;
    end op;
end program;
