(for ((cnt 49) (n 1) (sq 1) (st 3) (out (vector 50)))
     ((plusp cnt) (each ((x 1..50))
                    (put-line (pic "## ########" x [out x]))))
     ((inc sq st) (inc st 2) (inc n))
  (for ((xsq sq)) ((plusp xsq)) ((set xsq (trunc xsq 10)))
    (when (and (< xsq 50) (null [out xsq]))
      (set [out xsq] sq)
      (dec cnt))))
