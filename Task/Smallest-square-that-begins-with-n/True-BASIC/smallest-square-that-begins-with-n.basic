PRINT "Prefix           n^2             n"
PRINT "------------------------------------"

FOR i = 1 to 49
    LET N = 1
    DO
       LET j = N ^ 2
       DO WHILE j > i
          LET j = int(j / 10)
       LOOP
       IF j = i then
          PRINT i, N^2, sqr(N^2)
          EXIT DO
       END IF
       LET N = N + 1
    LOOP
NEXT i
END
