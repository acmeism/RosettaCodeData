int Count, N, M, Q;
[Count:= 0;
for N:= 1 to 49 do
   [M:= 1;
   loop [Q:= M*M;
        while Q > N do          \whittle off low digits
            Q:= Q/10;
        if Q = N then
            [IntOut(0, M*M);
            Count:= Count+1;
            if rem(Count/10) = 0 then CrLf(0) else ChOut(0, 9\tab\);
            quit;
            ];
        M:= M+1;
        ];
   ];
]
