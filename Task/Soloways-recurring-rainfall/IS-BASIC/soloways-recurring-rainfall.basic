100 PROGRAM "Rainfall.bas"
110 LET N,SUM=0
120 DO
130   INPUT PROMPT "Enter integer rainfall (99999 to quit): ":I
140   IF I=99999 THEN
150     EXIT DO
160   ELSE IF I<>INT(I) THEN
170     PRINT "Must be an integer. Try again."
180   ELSE
190     LET N=N+1
200     LET SUM=SUM+I
210     PRINT "The current average rainfall is";SUM/N
220   END IF
230 LOOP
