arraybase 1
n = 4
dim a(n)
for i = 1 to a[?]
    a[i] = i
    print "[ ";
    for j = 1 to i
        print a[j]; " ";
    next j
    print "] = "; getLantern(a)
next i
end

function getLantern(arr)
    res = 0
    for i = 1 to arr[?]
        if arr[i] <> 0 then
            arr[i] -= 1
            res += getLantern(arr)
            arr[i] += 1
        end if
    next i
    if res = 0 then res = 1
    return res
end function
