_elements = 5

local fn GetLantern( arr(_elements) as long ) as long
  long i, res = 0
  for i = 1 to _elements
    if arr(i) != 0
      arr(i) = arr(i) - 1
      res = res + fn GetLantern( arr(0) )
      arr(i) = arr(i) + 1
    end if
  next
  if res = 0 then res = 1
end fn = res

long i, j, a(_elements)
for i = 1 to _elements
  a(i) = i
  print "[";
  for j = 1 to i
    if j == i then print a(j); else print a(j); ",";
  next
  print "] = "; fn GetLantern( a(0) )
next

HandleEvents
