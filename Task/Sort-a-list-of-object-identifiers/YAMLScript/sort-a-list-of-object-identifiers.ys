!ys-0

defn main():
  each oid sort(oid-compare oids()):
    say: oid

defn oid-key(oid):
  oid.split(/\./).mapv(I)

defn oid-compare(a b):
  compare-keys(oid-key(a) oid-key(b))

defn compare-keys(a b):
  loop i 0:
    if i == min(a.# b.#):
      compare: a.# b.#
      else:
        c =: compare(a.$i b.$i)
        if c:zero?:
          recur: i.++
          else: c

