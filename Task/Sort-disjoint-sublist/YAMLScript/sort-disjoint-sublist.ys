!ys-0

defn main():
  values =:: [7, 6, 5, 4, 3, 2, 1, 0]
  indices =:: [6, 1, 7]
  say: sort-disjoint(values indices)

defn- sort-disjoint(values indices):
  sorted-idx =: indices:sort:V
  sorted-vals =: indices.map(\(values.nth(_))):sort:V
  loop result values, i 0:
    if i < sorted-idx.#:
      recur:
        result.assoc(sorted-idx.$i sorted-vals.$i)
        i.++
      else: result
