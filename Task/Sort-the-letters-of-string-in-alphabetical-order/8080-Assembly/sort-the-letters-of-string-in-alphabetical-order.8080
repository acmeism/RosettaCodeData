        org     100h
        jmp     demo

        ; Sort the $-terminated string at [DE] in place
sort:   lxi     h,300h
sinit:  mvi     m,1
        inr     l
        jnz     sinit
        push    d
scnt:   ldax    d
        cpi     '$'
        jz      smov
        mov     l,a
        inr     m
        inx     d
        jmp     scnt
smov:   pop     d
        mvi     l,32
schr:   dcr     m
        jnz     smchr
        inr     l
        rz
        jmp     schr
smchr:  mov     a,l
        stax    d
        inx     d
        jmp     schr

        ; Print string at [DE] using CP/M
puts:   mvi     c,9
        call    5
        lxi     d,nl
        mvi     c,9
        jmp     5

        ; Print and sort the demo string
demo:   lxi     d,str
        call    puts
        lxi     d,str
        call    sort
        lxi     d,str
        jmp     puts

str:    db      'Now is the time for all good men to come to the aid'
        db      ' of their country.$'
nl:     db      13,10,'$'
