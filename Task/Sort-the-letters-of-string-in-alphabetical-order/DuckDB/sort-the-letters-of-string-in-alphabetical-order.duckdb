create or replace function string_sort(s) as
  regexp_extract_all(s,'.').list_sort().array_to_string('');

## Examples:
.mode lines
select string_sort('azbyAZBY');

set variable dingbats =
  '✁✂✃✄✆✇✈✉✌✍✎✏✐✑✒✓✔✕✖✗✘✙✚✛✜✝✞✟✠✡✢✣✤✥✦✧✩✪✫✬✭✮✯✰✱✲✳✴✵✶✷✸✹✺✻✼✽✾✿❀❁❂❃❄❅❆❇❈❉❊❋❍❏❐❑❒❖❘❙❚❛❜❝❞❡❢❣❤❥❦❧❶❷❸❹❺❻❼❽❾❿➀➁➂➃➄➅➆➇➈➉➊➋➌➍➎➏➐➑➒➓➔➘➙➚➛➜➝';

select s = sort_by_codepoints(s) from (select getvariable('dingbats') as s) ;
