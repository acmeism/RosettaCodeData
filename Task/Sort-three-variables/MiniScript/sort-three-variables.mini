sort3 = function(x, y, z)
    a = [x, y, z]
    sort a
    x = a[0]
    y = a[1]
    z = a[2]
    print "  x = " + x
    print "  y = " + y
    print "  z = " + z
end function

print "After sorting strings:"
x = "lions, tigers, and"
y = "bears, oh my!"
z = "(from the ""Wizard of OZ"")"
sort3(x, y, z)
print

print "After sorting integers:"
x = 77444
y = -12
z = 0
sort3(x, y, z)
print

print "After sorting floats:"
x = -9.7
y = 11.17
z = 11.3
sort3(x, y, z)
