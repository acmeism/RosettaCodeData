!ys-0

# Sort three values using destructuring + sort. Works for any
# comparable type (numbers or strings).

defn main():
  show: +
    'lions, tigers, and' 'bears, oh my!'
    '(from the "Wizard of OZ")'
  show: 77444 -12 0

defn- show(x y z):
  say: "before: x=$x  y=$y  z=$z"
  sorted =: sort([x y z])
  a b c =: sorted
  say: "after:  x=$a  y=$b  z=$c\n"
