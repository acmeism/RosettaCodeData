local fmt = require "fmt"

local function comp(s, t)
    if #s == #t then return s:lower() < t:lower() end
    return #s > #t
end

local strings = {"Here", "are", "some", "sample", "strings", "to", "be", "sorted"}
fmt.print("Unsorted: %,s", strings)
strings:sort(comp)
fmt.print("Sorted  : %,s", strings)
