isSorted = function(a)
    if a.len < 2 then return true
    for i in range(1, a.len - 1)
        if a[i] < a[i - 1] then return false
    end for
    return true
end function

bogoSort = function(a)
    while not isSorted(a)
        a.shuffle
    end while
end function

a = [31, 41, 59, 26, 53, 58, 97, 93, 23, 84]
print "Before: " + a
bogoSort(a)
print "After : " + a
