!ys-0

defn main(nums='5 3 8 1 9 2 7 4 6'):
  nums .=: words().map(N):V
  say: nums:bubble-sort

defn swap-if-needed(v i):
  if v.get(i) > v.get(i.++):
    assoc v: i v.get(i.++), i.++ v.$i
    else: v

defn one-pass(v):
  reduce swap-if-needed v:
    range: 0 v.#.--

defn bubble-sort(xs):
  loop v xs:
    v2 =: v:one-pass
    if v == v2: v recur(v2)
