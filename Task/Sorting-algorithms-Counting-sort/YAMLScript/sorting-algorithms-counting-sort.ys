!ys-0

# Counting sort: a histogram of the input expanded back out.

defn main():
  xs =:: [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5, 8, 9, 7, 9, 3, 2, 3]
  say: "before: $xs"
  say: "after:  $(vec(counting-sort(xs)))"

defn- counting-sort(xs):
  freqs =: xs:frequencies
  lo =: min.apply(xs)
  hi =: max.apply(xs)
  mapcat _ (lo .. hi):
    fn(i): freqs(i 0).repeat(i)
