!ys-0

defn main():
  nums =:: [5, 3, 8, 4, 2, 7, 1, 6]
  say: nums
  say: gnome-sort(nums)

defn gnome-sort(coll):
  loop a coll, i 1, j 2:
    if i >= a:count:
      then: a
      else:
        prev =: i.--
        if a.$prev <= a.$i:
          recur: a j j.++
          else:
            b =: swap(a prev i)
            if i == 1:
              recur(b j j.++)
              recur(b prev j)

defn swap(v i k):
  v.assoc(i v.$k)
   .assoc(k v.$i)
