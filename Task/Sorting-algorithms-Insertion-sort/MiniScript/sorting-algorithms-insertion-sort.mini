insertionSort = function(a)
    for i in range(1, a.len - 1, 1)
        v = a[i]
        j = i - 1
        while j >= 0 and a[j] > v
            a[j + 1] = a[j]
            j -= 1
        end while
        a[j + 1] =v
    end for
end function

array = [ [4, 65, 2, -31, 0, 99, 2, 83, 782, 1], [7, 5, 2, 6, 1, 4, 2, 6, 3] ]
for a in array
    print "Before: " + a
    insertionSort(a)
    print "After : " + a
    print
end for
