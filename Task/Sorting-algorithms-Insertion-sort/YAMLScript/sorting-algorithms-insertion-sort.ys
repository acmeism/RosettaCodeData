!ys-0

defn main(nums='4 65 2 -31 0 99 2 83 782 1'):
  xs =: nums.split(/\s+/).map(N _)
  sorted =: xs:insertion-sort
  say: sorted:joins

defn insertion-sort(xs):
  empty =:: []
  reduce insert: empty xs

defn insert(sorted x):
  head =: sorted.take-while(le(x))
  tail =: sorted.drop-while(le(x))
  concat: head [x] tail
