#!/usr/bin/env ys-0

defn main():
  xs =:: [5, 3, 8, 1, 9, 2, 7, 4, 6, 0]
  say: "Input:  $(xs:joins)"
  say: "Sorted: $(merge-sort(xs):joins)"

defn merge-sort(xs):
  if xs.# <= 1:
    then: xs
    else:
      mid =: quot(xs.# 2)
      left =: merge-sort(xs.take(mid))
      right =: merge-sort(xs.drop(mid))
      merge: left right

defn merge(a b):
  cond:
    a:empty?: b
    b:empty?: a
    a.0 <= b.0:
      cons(a.0 merge(rest(a) b))
    else:
      cons(b.0 merge(a rest(b)))
