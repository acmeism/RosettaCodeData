local function flip(a, r)
    local l = 1
    while l <= r do
        a[r], a[l] = a[l], a[r]
        l += 1
        r -= 1
    end
end

local function pancake_sort(a)
    for uns = #a, 2, -1 do
        local lg = a:slice(1, uns):max()
        local lx = a:findindex(|e| -> e == lg)
        flip(a, lx)
        flip(a, uns)
    end
end

local a = {31, 41, 59, 26, 53, 58, 97, 93, 23, 84}
print($"Before: \{{a:concat(", ")}}")
pancake_sort(a)
print($"After : \{{a:concat(", ")}}")
