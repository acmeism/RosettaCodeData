local array = {
    {4, 65, 2, -31, 0, 99, 2, 83, 782, 1},
    {7, 5, 2, 6, 1, 4, 2, 6, 3},
    {"echo", "lima", "charlie", "whiskey", "golf", "papa", "alfa", "india", "foxtrot", "kilo"}
}

for array as a do
    print($"Before: \{{a:concat(", ")}}")
    a:sort()
    print($"After : \{{a:concat(", ")}}")
    print()
end
