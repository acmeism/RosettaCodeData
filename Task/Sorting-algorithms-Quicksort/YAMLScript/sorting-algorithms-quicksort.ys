!ys-0

defn main(nums='3 1 4 1 5 9 2 6 5 3 5'):
  nums .=: words().map(N)
  say: quicksort(nums)

defn quicksort(xs):
  if xs:empty?:
    then: xs
    else:
      p =: xs:first
      rest =: xs:rest
      less =: rest.filter(lt(p))
      more =: rest.filter(ge(p))
      concat:
        quicksort(less)
        vector(p)
        quicksort(more)
