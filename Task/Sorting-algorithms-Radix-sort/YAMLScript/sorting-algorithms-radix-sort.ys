!ys-0

defn main(nums='170 45 75 90 802 24 2 66'):
  data =: nums:words.mapv(I)
  say: radix-sort(data):joins

defn radix-sort(xs):
  maxv =: apply(max xs)
  loop arr xs, exp 1:
    if exp > maxv:
      then: arr
      else:
        next =: (0 .. 9).mapcat(\(digit-bucket(arr exp _))):V
        recur: next, (exp * 10)

defn digit-bucket(xs exp digit):
  xs.filter(\(((_ // exp) % 10) == digit))
