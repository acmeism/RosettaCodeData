!ys-0

defn main(v=nil):
  v ||=: +[64 25 12 22 11]
  say: selection-sort(v):joins

defn selection-sort(v):
  loop i 0, a v:
    if i >= a.#:
      then: a
      else:
        j =: min-idx(a i)
        a2 =: a.assoc(i a.$j).assoc(j a.$i)
        recur: i.++ a2

defn min-idx(v start):
  loop best start, i start.++:
    if i >= v.#:
      then: best
      else:
        nb =: (v.$i < v.$best).if(i best)
        recur: nb i.++
