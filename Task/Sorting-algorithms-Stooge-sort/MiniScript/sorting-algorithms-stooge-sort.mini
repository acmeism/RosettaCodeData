stoogeSort = function(a, i, j)
    if a[j] < a[i] then
        t = a[i]
        a[i] = a[j]
        a[j] = t
    end if
    if j - i > 1 then
        t = floor((j - i + 1) / 3)
        stoogeSort(a, i, j - t)
        stoogeSort(a, i + t, j)
        stoogeSort(a, i, j - t)
    end if
end function

array = [ [4, 65, 2, -31, 0, 99, 2, 83, 782, 1], [7, 5, 2, 6, 1, 4, 2, 6, 3] ]
for a in array
    print "Before: " + a
    stoogeSort(a, 0, a.len - 1)
    print "After : " + a
    print
end for
