with javascript_semantics

enum KEY,LEFT,RIGHT
function tree_insert(object node, item)
    if node=NULL then
        node = {item,NULL,NULL}
    else
        object {d,l,r} = node
        node = NULL
        if item<d then
            l = tree_insert(l,item)
        else
            r = tree_insert(r,item)
        end if
        node = {d,l,r}
    end if
    return node
end function

function inOrder(object node)
    return iff(node=NULL?"":inOrder(node[LEFT]) &
                            node[KEY] &
                            inOrder(node[RIGHT]))
end function

procedure treeSort(sequence s)
    object tree = NULL
    for e in s do tree = tree_insert(tree,e) end for
    printf(1,"%v => %v\n",{s,inOrder(tree)})
end procedure

treeSort({5, 3, 7, 9, 1})
treeSort("dceba")
