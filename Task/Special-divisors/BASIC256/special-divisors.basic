c = 0
for n = 1 to 200
    u = reverse(n)
    s = true
    for d = 1 to n
        if n mod d = 0 then
            b = reverse(d)
            if u mod b <> 0 then s = false
        end if
    next d
    if s then c += 1 : print n; chr(9);
next n

print
print "Found "; c; " special divisors."
end

function reverse(n)
    u = 0
    while n
        u = u * 10 + n mod 10
        n = n \ 10
    end while
    return u
end function
