Procedure reverse(n.i)
  u.i = 0
  While n
    u = u * 10 + (n % 10)
    n = Int(n / 10)
  Wend
  ProcedureReturn u
EndProcedure

OpenConsole()
c.i = 0
For n.i = 1 To 200
  u.i = reverse(n)
  s.b = #True
  For d.i = 1 To n
    If n % d = 0
      b = reverse(d)
      If u % b <> 0
        s = #False
      EndIf
    EndIf
  Next d
  If s
    Print(Str(n) + #TAB$)
    c + 1
  EndIf
Next n

PrintN(#CRLF$ + "Found " + Str(c) + " special divisors.")
Input()
CloseConsole()
