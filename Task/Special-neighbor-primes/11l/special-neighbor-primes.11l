F is_prime(n)
   I n == 2
      R 1B
   I n < 2 | n % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(n))).step(2)
      I n % i == 0
         R 0B
   R 1B

V primes = (0.<100).filter(n -> is_prime(n))

L(i) 0 .< primes.len - 1
   V p1 = primes[i]
   V p2 = primes[i + 1]
   I is_prime(p1 + p2 - 1)
      print((p1, p2))
