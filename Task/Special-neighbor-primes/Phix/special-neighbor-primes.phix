with javascript_semantics
function np(integer n) return is_prime(get_prime(n)+get_prime(n+1)-1) end function
function npt(integer p) return filter(tagset(length(get_primes_le(p))-1),np) end function
sequence s = npt(100)
for i,si in s do
    integer pi = get_prime(si), pj = get_prime(si+1)
    s[i] = sprintf(" (%2d,%2d) => %d",{pi,pj,pi+pj-1})
end for
printf(1,"Found %d special neighbour primes < 100:\n%s\n\n",{length(s),join(s,'\n')})
for p in sq_power(10,tagset(7)) do
    printf(1,"Found %,d special neighbour primes < %,d\n",{length(npt(p)),p})
end for
