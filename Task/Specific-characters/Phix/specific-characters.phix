with javascript_semantics
function specific(sequence s)
    s = apply(s,utf8_to_utf32)
    sequence all = join(s,"")
    for i,l in s do
        integer n = 0
        sequence u = unique(l)
        for c in u do
            n += sum(sq_eq(c,l))==2 and
                 sum(sq_eq(c,all))==2
        end for
        s[i] = {n,length(u)-n}
    end for
    return columnize(s)
end function

?specific({"ahwiueshaiu","ajxxfioaaf","ajrdsfroiwr"})
