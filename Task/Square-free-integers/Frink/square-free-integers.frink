sf = {|x| last[last[sort[factor[x], byColumn[1]]]] <2 }

println["From 1 to 145:"]
println[select[1 to 145, sf]]

println["\nFrom 1 trillion to 1 trillion + 145:"]
println[select[1 trillion to 1 trillion + 145, sf]]

res = new array
for n = [one hundred, one thousand, ten thousand, one hundred thousand, one million]
   res.push[["From 1 to" , n, length[select[1 to n, sf]]]]

println["\nNumber of square-free integers:"]
println[formatTable[res,"right"]]
