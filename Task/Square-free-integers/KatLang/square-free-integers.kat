IsSquareFree(num) = {
    Step = {
        Square = k * k
        k + 1, s + if(num mod Square == 0, 1, 0), Square <= num and s <= 0
    }
    Step.while(2, 0):1 == 0
}
ListSquareFree = range(start, end).filter(IsSquareFree)
SquareFreeCount = range(1, n).filter(IsSquareFree).count

ListSquareFree(1, 145)
(100, 1000, 10000).map(SquareFreeCount)
