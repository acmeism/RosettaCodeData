!ys-0

defn main():
  say: "1..145:"
  say: square-free-between(1 145):joins
  say: "1000000000000..1000000000145:"
  say: square-free-between(1000000000000 1000000000145):joins
  each n [100 1000 10000]:
    say: "count 1..$n: $(square-free-between(1 n).#)"

defn square-free-between(lo hi):
  filter square-free?: lo .. hi

defn square-free?(n):
  (n < 4) ||:
    not-any? _ (2 .. I(sqrt(n))):
      fn(k):
        (n % k:sqr):zero?
