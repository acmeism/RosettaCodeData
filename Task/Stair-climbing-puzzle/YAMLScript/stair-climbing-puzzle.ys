!ys-0

# Climb one stair. step() succeeds 50% of the time and falls
# otherwise; on failure climb back twice. Track position in an atom.

pos =: atom(0)

defn main():
  start =: pos.@
  step-up:
  finish =: pos.@
  say: "started at $start, now at $finish"

defn- step-up():
  when-not step():
    step-up()
    step-up()

defn- step():
  if rand() < 0.5:
    then:
      swap! pos: inc
      =>: true
    else:
      swap! pos: dec
      =>: false
