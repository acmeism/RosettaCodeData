REM Steady squares
FOR I = 1 TO 9999
  N = I
  GOSUB CheckIfSteady:
  IF Steady <> 0 THEN
    PRINT I;
    PRINT " ^ 2 = ";
    II& = I * I
    PRINT II&
  ENDIF
NEXT I
END

CheckIfSteady:
REM Result: Steady = 1 if N * N is steady; Steady = 0 otherwise.
Mask = 1
D = N
WHILE D <> 0
  Mask = Mask * 10
  D = D / 10
WEND
NNModMask& = N * N
NNModMask& = NNModMask& MOD Mask
IF NNModMask& = N THEN
  Steady = 1
ELSE
  Steady = 0
ENDIF
RETURN
