proc nonrec steady(ulong n) bool:
    ulong mask;
    mask := 1;
    while mask <= n do mask := mask * 10 od;
    n*n % mask = n
corp

proc nonrec main() void:
    word i;
    for i from 1 upto 10000 do
        if steady(i) then
            writeln(i:4, "^2 = ", make(i,ulong)*i:8)
        fi
    od
corp
