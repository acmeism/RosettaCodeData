;;; find some steady squares - numbers whose squares end in the number, e.g.: 376^2 = 141 376

make "maxNumber 10000
make "powerOfTen 10
make "lastDigit listtoarray [1 5 6]

for [n 0 maxNumber 10] [
    if :n = :powerOfTen [make "powerOfTen :powerOfTen * 10]
    for [d 1 [count :lastDigit]] [
        localmake "nd :n + item :d :lastDigit
        localmake "n2 :nd * :nd
        if :nd = modulo :n2 :powerOfTen [print (word (form :nd 5 0) "|^2 = | :n2)]
    ]
]
