const maxnumber = 10000;
var   p10, n, d, nd, n2;
begin
    p10 := 10;
    n   :=  0;
    while n <= maxnumber do begin
        if n = p10 then p10 := p10 * 10;
        d := 0;
        while d < 6 do begin
            if d = 5 then d := 6;
            if d = 1 then d := 5;
            if d = 0 then d := 1;
            nd := n + d;
            n2 := nd * nd;
            n2 := n2 - ( ( n2 / p10 ) * p10 );
            if n2 = nd then ! nd
        end;
        n := n + 10
    end
end.
