$ENTRY Go {
    = <FindSteady 1 9999>;
};

FindSteady {
    s.N s.Max, <Compare s.N s.Max>: '+' = ;
    s.N s.Max, <Steady <Symb s.N>>: F = <FindSteady <+ s.N 1> s.Max>;
    s.N s.Max = <ShowSteady s.N> <FindSteady <+ s.N 1> s.Max>;
};

ShowSteady {
    s.N = <Prout <Symb s.N> '^2 = ' <* s.N s.N>>;
};

Steady {
    e.N, <Symb <* <Numb e.N> <Numb e.N>>>: e.X e.N = T;
    e.N = F;
};
