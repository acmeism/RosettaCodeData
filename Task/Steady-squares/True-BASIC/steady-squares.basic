FUNCTION issteady(n)
    LET mask = 1
    LET d = n
    DO WHILE d <> 0
       LET mask = mask*10
       LET d = INT(d/10)
    LOOP
    LET res = MOD((n * n), mask)
    IF res = n THEN
       LET issteady = res
    ELSE
       LET issteady = 0
    END IF
END FUNCTION

FOR i = 1 TO 9999
    IF issteady(i) <> 0 THEN
       PRINT USING("####"):i;
       PRINT "^2 = ";
       PRINT USING("########"): i*i
    END IF
NEXT i
END
