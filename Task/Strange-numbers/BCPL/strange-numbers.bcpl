get "libhdr"

let dgtprime(x) = x=2 | x=3 | x=5 | x=7
let strange(x)  =
    x<10 -> true,
    dgtprime(abs(x rem 10 - (x/10) rem 10)) & strange(x/10)

let start() be
$(  let col = 0
    for i=100 to 500 do
        if strange(i) then
        $(  writed(i, 4)
            col := col + 1
            if col rem 10 = 0 then wrch('*N')
        $)
    wrch('*N')
$)
