get "libhdr"

let smallprime(n) = n=2 | n=3 | n=5 | n=7 | n=11 | n=13 | n=17

let strangeplus(n) =
    n<10 -> true,
    ~smallprime(n rem 10 + (n/10) rem 10) -> false,
    strangeplus(n / 10)

let start() be
$(  let col = 0
    for i = 100 to 500 if strangeplus(i)
    $(  writef("%I3 ",i)
        col := col + 1
        if col rem 10 = 0 then wrch('*N')
    $)
    wrch('*N')
$)
