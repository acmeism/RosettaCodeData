  [ ' [ 2 3 5 7 11 13 17 ]
    find 7 < ]             is prime    ( n --> b )

  [ 10 /mod
    swap 10 /mod
    tuck + prime not iff
      [ 2drop false ] done
    + prime ]              is strange+ ( n --> b )

  [] 399 times
    [ i^ 101 +
      dup strange+ iff
        join else drop ]
  dup size echo
  say " strange plus numbers:"
  cr cr
  witheach
    [ echo
      i^ 10 mod 9 = iff cr else sp ]
