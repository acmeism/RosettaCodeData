func StrangePlus(N);
int  N, A, B, S;
[N:= N/10;
A:= rem(0);
loop    [N:= N/10;
        B:= rem(0);
        S:= A+B;
        if S#2 & S#3 & S#5 & S#7 & S#11 & S#13 & S#17 then return false;
        if N = 0 then return true;
        A:= B];
];

int Cnt, N;
[Cnt:= 0;
for N:= 100 to 500-1 do
    if StrangePlus(N) then
        [Cnt:= Cnt+1;
        IntOut(0, N);
        if rem(Cnt/20) = 0 then CrLf(0) else ChOut(0, ^ )];
]
