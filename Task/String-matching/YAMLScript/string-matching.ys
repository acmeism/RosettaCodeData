!ys-0

defn main(s1='abracadabra', s2='abra'):
  say: "s1 = '$s1'"
  say: "s2 = '$s2'"
  say: "starts with: $(s1.starts?(s2))"
  say: "contains:    $(s2.in?(s1))"
  say: "ends with:   $(s1.ends?(s2))"
  positions =: s1.find-all(s2)
  say: "all positions: $positions"

defn find-all(s sub):
  loop i 0, found []:
    rest =: s.subs(i)
    j =: index(rest sub)
    if j:nil?:
      then: found
      else:
        pos =: i + j
        recur: pos.++ found.conj(pos)
