local a = " \t\r\nString with leading whitespace removed"
local b = "String with trailing whitespace removed \t\r\n"
local c = " \t\r\nString with both leading and trailing whitespace removed \t\r\n"
local d = " \t\r\n\v\fString with leading whitespace and form feed removed"
print($"'{a:lstrip()}'")
print($"'{b:rstrip()}'")
print($"'{c:strip()}'")
print($"'{d:lstrip(" \t\r\n\v\f")}'") -- similar overloads of rstrip and strip exist
