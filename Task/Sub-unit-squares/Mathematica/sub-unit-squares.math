subUnitSquare[1] = True;
subUnitSquare[n_] := With[{dig = IntegerDigits[n]},
    IntegerQ[Sqrt[n]] &&
    Min[dig] > 0 &&
    First[dig] != 1 &&
    IntegerQ[Sqrt[FromDigits[dig - 1]]]];

res = {};
n = 1;
While[Length[res] < 5,
    If[subUnitSquare[n^2], AppendTo[res, n^2]];
    n++;
];
res // TableForm
