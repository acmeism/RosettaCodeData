!ys-0

defn main(s='knights'):
  say: "input:      '$s'"
  say: "drop first: '$(drop-first(s))'"
  say: "drop last:  '$(drop-last(s))'"
  say: "drop both:  '$(drop-both(s))'"

defn drop-first(s):
  if s:empty?: s s.subs(1)

defn drop-last(s):
  if s:empty?: s s.subs(0 s.#.--)

defn drop-both(s):
  if s.# >= 2:
    subs s: 1 s.#.--
    else: ''
