fastfunc isprim n .
   i = 2
   while i <= sqrt n
      if n mod i = 0 : return 0
      i += 1
   .
   return 1
.
digs[] = [ 2 3 5 7 ]
#
for p in digs[] : write p & " "
for d1 in digs[] : for d2 in digs[]
   h = d1 * 10 + d2
   if isprim h = 1 : write h & " "
.
for d1 in digs[] : for d2 in digs[] : for d3 in digs[]
   h = d1 * 100 + d2 * 10 + d3
   if h >= 500 : break 1
   if isprim h = 1 and isprim (h div 10) = 1 and isprim (h mod 100) = 1
      write h & " "
   .
.
print ""
