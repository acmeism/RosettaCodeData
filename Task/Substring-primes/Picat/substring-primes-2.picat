t(N,false) :-
  not prime(N),!.
t(N,true) :-
  N < 10,!.
t(N,false) :-
  not prime(N mod 100), !.
t(N,false) :-
  not prime(N mod 10),!.
t(N,false) :-
  not prime(N // 10),!.
t(N,true) :-
  N < 100,!.
t(N,false) :-
  not prime(N // 100),!.
t(N,false) :-
  not prime((N mod 100) // 10),!.
t(_N,true).

go2 =>
  println(findall(N,(member(N,1..500),t(N,Status),Status==true))).
