!ys-0

defn main(s='Hello, world!', n=7, m=5):
  say: "string: $s"
  say: "from $n length $m: $(s.subs(n (n + m)))"
  say: "from $n to end:    $(s.subs(n))"
  say: "all but last:      $(s.subs(0 s.#.--))"
  ci =: s.index('o')
  say: "from 'o' length $m: $(s.subs(ci (ci + m)))"
  si =: s.index('orl')
  say: "from 'orl' length $m: $(s.subs(si (si + m)))"
