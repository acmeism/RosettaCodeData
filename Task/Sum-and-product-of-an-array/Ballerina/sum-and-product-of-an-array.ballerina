import ballerina/io;

function prod(int[] a) returns int {
    var comb = function(int L, int R) returns int {
        return L * R;
    };
    return a.reduce(comb, 1);
}

public function main() {
    int[] a = from int i in 1...10 select i;
    io:println(int:sum(...a));
    io:println(prod(a));
}
