class variant
    public v, kind

    function __construct(v)
        -- Restrict 'v' to numbers or strings.
        local tv = type(v)
        assert(tv == "string" or tv == "number", "argument must be a number or a string.")
        self.v = v
        self.kind = tv
    end
end

local v1 = new variant(6)
print(v1.v, v1.kind)
local v2 = new variant("six")
print(v2.v, v2.kind)
local v3 = new variant({6}) -- will give an error as argument is a table
print(v3.v, v3.kind)
