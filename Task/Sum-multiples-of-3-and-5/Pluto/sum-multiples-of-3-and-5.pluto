local bigint = require "pluto:bigint"
local fmt = require "fmt"

local function sum_multiples(limit, f)
    local m = (limit - 1) / f
    return (m + 1) * m * f / 2
end

local limit = bigint.new(1)
local sum35
local max = 25
fmt.print($"%{max + 1}s  %s", "limit", "sum")
for i = 0, max do
    fmt.write($"%{max + 1}s  ", limit)
    sum35 = sum_multiples(limit, 3) + sum_multiples(limit, 5) - sum_multiples(limit, 15)
    print(sum35)
    limit *= 10
end
