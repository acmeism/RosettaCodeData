func SumDiv(N);         \Return sum of divisors of N
int  N, Sum, Div;
[Sum:= 0;
for Div:= 1 to N do
    if rem(N/Div) = 0 then
        Sum:= Sum + Div;
return Sum;
];

int C, N;
[C:= 0;
for N:= 1 to 100 do
    [IntOut(0, SumDiv(N));
    C:= C+1;
    if rem(C/10) then ChOut(0, 9\tab\) else CrLf(0)];
]
