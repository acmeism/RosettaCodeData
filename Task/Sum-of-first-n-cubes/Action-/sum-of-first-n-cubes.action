INCLUDE "D2:REAL.ACT" ;from the Action! Tool Kit

PROC Main()
  BYTE i
  REAL sum,r3,tmp1,tmp2

  Put(125) PutE() ;clear the screen
  IntToReal(0,sum)
  IntToReal(3,r3)
  FOR i=0 TO 49
  DO
    IntToReal(i,tmp1)
    RealMult(tmp1,tmp1,tmp2)
    RealMult(tmp1,tmp2,tmp2)
    RealAdd(sum,tmp2,sum)
    PrintR(sum) Put(32)
    IF i MOD 4=3 THEN
      PutE()
    FI
  OD
RETURN
