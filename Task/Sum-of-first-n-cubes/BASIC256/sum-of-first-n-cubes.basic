fila = 0
lenCubos = 49

cls
print "Suma de N cubos para n = [0..49]" + chr(10)

for n = 0 to lenCubos
	sumCubos = 0
	for m = 1 to n
		sumCubos += int(m ^ 3)
	next m
	fila += 1
	print "" + sumCubos + " ";
	#Print Using " ####### "; sumCubos;
	if (fila % 5) = 0 then print
next n

print chr(13) + "Encontrados " & fila & " cubos."
end
