include "cowgol.coh";

sub cube(n: uint32): (r: uint32) is
    r := n * n * n;
end sub;

var i: uint8 := 0;
var sum: uint32 := 0;
while i < 50 loop
    sum := sum + cube(i as uint32);
    print_i32(sum);
    i := i + 1;
    if i % 10 == 0 then
        print_nl();
    else
        print_char(' ');
    end if;
end loop;
