program sum_of_first_cubes;
    cubes := [n**3 : n in [0..49]];

    loop for i in [2..#cubes] do
        cubes(i) +:= cubes(i-1);
    end loop;

    printtab(cubes, 5, 10);

    proc printtab(list, cols, width);
        lines := [list(k..cols+k-1) : k in [1, cols+1..#list]];
        loop for line in lines do
            print(+/[lpad(str item, width+1) : item in line]);
        end loop;
    end proc;
end program;
