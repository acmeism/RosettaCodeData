fila = 0
lenCubos = 49

clear screen
print "Suma de N cubos para n = [0..49]\n"

for n = 0 to lenCubos
    sumCubos = 0
    for m = 1 to n
        sumCubos = sumCubos + (m ^3)
    next m
    fila = fila + 1
    print "", sumCubos, " ";
    if mod(fila, 5) = 0 then print : fi
next n

print "\nEncontrados ", fila, " cubos.\n"
end
