F is_prime(n)
   I n == 2
      R 1B
   I n < 2 | n % 2 == 0
      R 0B
   L(i) (3 .. Int(sqrt(n))).step(2)
      I n % i == 0
         R 0B
   R 1B

print(‘  i  p(i)   sum’)
V idx = 0
V s = 0
V p = 1
L p < 1000
   p++
   I is_prime(p)
      idx++
      I idx % 2 != 0
         s += p
         I is_prime(s)
            print(f:‘{idx:3}  {p:3}  {s:5}’)
