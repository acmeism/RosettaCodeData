program sum_of_digits_of_square_and_cube_are_prime;
    print({n in {1..99} | prime(digitsum(n**2)) and prime(digitsum(n**3))});

    op prime(n);
        return n>=2 and not exists d in {2..floor sqrt n} | n mod d=0;
    end op;

    op digitsum(n);
        return +/[[n mod 10, n div:= 10](1) : until n=0];
    end op;
end program;
