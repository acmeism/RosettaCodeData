!ys-0

defn main(limit=100):
  say: (1 .. limit.--)
    .filter(good?):joins

defn good?(n):
  prime?(digit-sum(sqr(n))) &&
  prime?(digit-sum(n:cube))

defn digit-sum(n):
  n:S:seq.map(\(_:S:I)):sum

defn prime?(n):
  when n >= 2:
    if n >= 4:
      not: (2 .. sqrt(n):I)
        .some(\((n % _).!))
      else: true
