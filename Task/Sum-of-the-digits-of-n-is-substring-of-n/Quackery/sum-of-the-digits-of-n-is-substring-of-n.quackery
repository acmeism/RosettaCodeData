  [ over findseq swap found ] is hasseq ( [ [ --> b )

  [ [] swap
    [ 10 /mod
      rot join swap
      dup 0 = until ]
    drop ]                    is digits (   n --> [ )

 [ digits
   0 over witheach +
   digits hasseq ]            is subsum (   n --> b )

 [] 1000 times
    [ i^ subsum if
        [ i^ join ] ]
 dup echo
 cr cr
 say "There are " size echo say " numbers."
