program sum_of_digits_of_n_is_substring_of_n;
    loop for n in [0..999] | str digitsum n in str n do
        nprint(lpad(str n, 5));
        if (col +:= 1) mod 8 = 0 then print; end if;
    end loop;

    op digitsum(n);
        s := 0;
        loop while n>0 do
            s +:= n mod 10;
            n div:= 10;
        end loop;
        return s;
    end op;
end program;
