        define('digsum(n)')             :(digsum_end)
digsum  digsum = 0
dsloop  digsum = digsum + remdr(n,10)
        n = ne(n,0) n / 10              :s(dsloop)f(return)
digsum_end

        define('sumsub(n)')             :(sumsub_end)
sumsub  n digsum(n)                     :s(return)f(freturn)
sumsub_end

        i = 0
loop    output = sumsub(i) i
        i = lt(i,999) i + 1             :s(loop)
end
