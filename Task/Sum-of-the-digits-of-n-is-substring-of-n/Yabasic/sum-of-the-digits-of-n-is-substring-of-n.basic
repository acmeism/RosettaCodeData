// Rosetta Code problem: http://rosettacode.org/wiki/Sum_of_the_digits_of_n_is_substring_of_n
// by Galileo, 04/2022

for n = 0 to 999
    if isSubstring(n) print n using "####";
next
print

sub isSubstring(n)
    local n$, lon, i, p

    n$ = str$(n)
    lon = len(n$)
    for i = 1 to lon
        p = p + val(mid$(n$,i,1))
    next

    return instr(n$, str$(p))
end sub
