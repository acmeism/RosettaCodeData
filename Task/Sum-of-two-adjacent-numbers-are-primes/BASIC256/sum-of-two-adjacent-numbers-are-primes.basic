function isPrime(v)
	if v < 2 then return False
	if v mod 2 = 0 then return v = 2
	if v mod 3 = 0 then return v = 3
	d = 5
	while d * d <= v
		if v mod d = 0 then return False else d += 2
	end while
	return True
end function

n = 0
num = 0

print "The first 20 pairs of numbers whose sum is prime:"
while True
	n += 1
	suma = 2*n+1
	if isPrime(suma) then
		num += 1
		if num < 21 then
			print n; " + "; (n+1); " = "; suma
		else
			exit while
		end if
	end if
end while
end
