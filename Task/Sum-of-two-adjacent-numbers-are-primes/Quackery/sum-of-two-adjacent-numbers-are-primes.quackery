  [ 1 [] rot
    [ over size
      over != while
      dip
        [ over isprime if
            [ over join ]
          dip [ 2 + ] ]
      again ]
     drop nip ]           is oddprimes ( n --> [ )

  [ oddprimes
    witheach
      [ dup 2 /
        dup echo
        say " + "
        1+ echo
        say " = "
        echo cr ] ]       is task       ( n -->   )

20 task
