include xpllib;
int N, Num, Sum;
[Text(0, "Working...^M^J");
N:= 0;
Num:= 0;
loop
    [N:= N+1;
    Sum:= 2*N + 1;
    if IsPrime(Sum) then
        [Num:= Num+1;
        if Num < 21 then
          [Text(0,"N = "); IntOut(0,N); Text(0,"  Sum = "); IntOut(0,Sum); CrLf(0)]
        else
          quit
        ]
    ];
Text(0, "Done...^M^J");
]
