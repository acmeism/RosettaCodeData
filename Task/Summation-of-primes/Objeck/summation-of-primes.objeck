class SumPrimes {
  function : native : IsPrime(p : Int ) ~ Int {
    if(p=2) {
      return 1;
    };

    if(p%2 = 0) {
      return 0;
    };

    for(i:=3; i*i<=p; i+=2;) {
      if(p%i = 0) {
        return 0;
      };
    };

    return 1;
  }

  function : Main(args : String[]) ~ Nil {
    s := 2;

    for(p:=3;p<2000000;p+=2) {
      if(IsPrime(p) <> 0) {
        s+=p;
      };
    };

    s->PrintLine();
  }
}
