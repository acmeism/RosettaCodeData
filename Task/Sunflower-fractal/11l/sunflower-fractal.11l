-V
   phi = (1 + sqrt(5)) / 2
   size = 600
   seeds = 5 * size

print(‘<svg xmlns="http://www.w3.org/2000/svg" width="’size‘" height="’size‘" style="stroke:gold">’)
print(‘<rect width="100%" height="100%" fill="black" />’)

L(i) 1..seeds
   V r = 2 * (i ^ phi) / seeds
   V t = 2 * math:pi * phi * i
   print(‘<circle cx="#.2" cy="#.2" r="#.1" />’.format(r * sin(t) + size / 2,
                                                       r * cos(t) + size / 2, sqrt(i) / 13))

print(‘</svg>’)
