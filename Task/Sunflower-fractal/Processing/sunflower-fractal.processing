size(1024, 1024);

float tau = PI * 2.0;
float phi = 0.5 * (1.0 + sqrt(5.0));

int scale = 1024;
int seeds = scale / 2;

background(#000000);
noFill();
stroke(#ffd700);

for (int i=0; i<seeds; i++) {
  float r = 0.02 * pow(i, phi);
  float t = tau * phi * i;
  float x = r * sin(t) + 0.5 * scale;
  float y = r * cos(t) + 0.5 * scale;
  float c = pow(i, phi) * 0.005;
  ellipse(x, y, c, c);
}
