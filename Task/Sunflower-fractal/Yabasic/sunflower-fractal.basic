// Rosetta Code problem: http://rosettacode.org/wiki/Sunflower_fractal
// Adapted from Wren to Yabasic by Galileo, 01/2022

width = 400
height = 400

open window width, height
backcolor 0,0,0
clear window

color 0,255,0
seeds = 3000

c = (sqrt(5) + 1) / 2
for i = 0 to seeds
    r = (i ** c) / seeds
    angle = 2 * pi * c * i
    x = r * sin(angle) + 200
    y = r * cos(angle) + 200
    circle x, y, i / seeds * 5
next
