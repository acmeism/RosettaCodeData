fcn sunflower(seeds=3000){
   img,color := PPM(400,400), 0x00ff00;		// green
   c:=((5.0).sqrt() + 1)/2;
   foreach n in ([0.0 .. seeds]){  // floats
      r:=n.pow(c)/seeds;
      x,y := r.toRectangular(r.pi*c*n*2);
      r=(n/seeds*5).toInt();
      img.circle(200 + x, 200 + y, r,color);
   }
   img.writeJPGFile("sunflower.zkl.jpg");
}();
