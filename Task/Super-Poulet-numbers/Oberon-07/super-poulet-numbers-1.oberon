// java class for the Oberon-07 I64Ops module

public class I64Ops
{

    private I64Ops(){}    // this class can't be instantiated

    /** multiplies a by b to get a 64 bit result and returns that MOD c as an int.
      */
    public static int mulMod( int a, int b, int c )
    {
    return (int) ( ( (long) a * (long) b ) % c );
    } // mulMod


} // I64Ops
