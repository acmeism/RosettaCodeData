!ys-0

# Using built-in set operations from clojure.set.

defn main():
  a =: \{'John' 'Bob' 'Mary' 'Serena'}
  b =: \{'Jim' 'Mary' 'John' 'Bob'}
  say: "A         = $a"
  say: "B         = $b"
  say: "A \\ B     = $(set/difference(a b))"
  say: "B \\ A     = $(set/difference(b a))"
  say: "A sym B   = $(sym-diff(a b))"

defn sym-diff(a b):
  set/union:
    set/difference(a b)
    set/difference(b a)
