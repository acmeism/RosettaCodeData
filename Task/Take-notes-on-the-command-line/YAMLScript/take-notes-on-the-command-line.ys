!ys-0

# NOTES: with no arguments, print the current NOTES.TXT (if any).
# With arguments, append a timestamp line followed by a tab-indented
# line of the arguments joined with spaces. Creates the file if it
# does not exist.

defn main(*args):
  file =: FILE
  if args:empty?:
    then:
      when file:fs-e:
        print: file:read
    else:
      stamp =: bash-out('date'):trim
      entry =: "$stamp\n\t$(args:joins)\n"
      old =: file:fs-e.if(file:read '')
      write file: old + entry
