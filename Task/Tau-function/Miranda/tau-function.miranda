main :: [sys_message]
main = [Stdout (table 10 5 (map tau [1..100]))]

tau :: num->num
tau = t 0 1
      where t acc d n = acc, if d*d > n
                      = t acc (d+1) n, if n mod d ~= 0
                      = t (acc+1) (d+1) n, if n div d = d
                      = t (acc+2) (d+1) n, otherwise

table :: num->num->[num]->[char]
table w cw = lay . map concat . group w . map (rjustify cw . show)

group :: num->[*]->[[*]]
group n [] = []
group n xs = take n xs : group n (drop n xs)
