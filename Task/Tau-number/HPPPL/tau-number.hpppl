EXPORT Tau_number()
BEGIN
PRINT();
PRINT("Primeros 100 números Tau:");
LOCAL N:=0;
LOCAL M:=0;
LOCAL L:=100;
LOCAL I:=0;
LOCAL S:="";
WHILE M<L DO
  N:=N + 1;
  T:=0;
  FOR I FROM 1 TO N DO
    IF N MOD I == 0 THEN T:=T + 1;
    END;
  END;
  IF N MOD T == 0 THEN
    M:=M + 1;
    IF M>=L
      THEN S:=S + N;
      ELSE S:=S + N + ", ";
    END;
  END;
END;
PRINT(S);
PRINT("<fin>")
END;
