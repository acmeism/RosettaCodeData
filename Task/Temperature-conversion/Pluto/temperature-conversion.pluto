local fmt = require "fmt"

local function temp_conv(k)
    local c = k - 273.15
    local f = c * 1.8 + 32
    local r = f + 459.67
    fmt.print("%7.2f˚ Kelvin" , k)
    fmt.print("%7.2f˚ Celsius", c)
    fmt.print("%7.2f˚ Fahrenheit", f)
    fmt.print("%7.2f˚ Rankine", r)
    print()
end

local ks = {0, 21, 100}
for ks as k do temp_conv(k) end
