!ys-0

# Tests the palindrome check from the YAMLScript Palindrome entry,
# using ys::taptest, the TAP testing library bundled with YAMLScript.

use ys::taptest: :all

defn main():
  test::
  - name: Palindromic number
    code: palindrome?(12321)
    want: true

  - name: Non-palindromic number
    code: palindrome?(31337)
    want: false

  - name: Palindromic word
    code: palindrome?('racecar')
    want: true

  - name: Non-palindrome
    code: palindrome?('YAMLScript')
    want: false

  - name: Empty string is a palindrome
    code: palindrome?('')
    want: true

  done: 5

defn palindrome?(x):
  s =: x:S
  s ==: s:reverse
