nth_rsimplex(n,r) := binomial(n+r-1, r)$
simplexnums(r) := makelist(nth_rsimplex(i,r), i, 1, 30)$
map(simplexnums, [2,3,4,12]);

rootnums: [7140, 21408696, 26728085384, 14545501785001]$
tri_root(x) := 0.5*(sqrt(8*x+1)-1)$
tet_root(x) := (3*x+sqrt(9*x^2-1/27))^(1/3)+(3*x-sqrt(9*x^2-1/27))^(1/3)-1$
pent_root(x) := 0.5*(sqrt(5+4*sqrt(24*x+1))-3)$

roots: float(map(lambda([f], map(f, rootnums)), ["+", tri_root, tet_root, pent_root]))$
args(transpose(apply(matrix, roots)));
