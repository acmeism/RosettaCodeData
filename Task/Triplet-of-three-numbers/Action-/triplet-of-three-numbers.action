INCLUDE "H6:SIEVE.ACT"

PROC Main()
  DEFINE MAX="5999"
  BYTE ARRAY primes(MAX+1)
  INT i,count=[0]

  Put(125) PutE() ;clear the screen
  Sieve(primes,MAX+1)
  FOR i=3 TO MAX-5
  DO
    IF primes(i-1)=1 AND primes(i+3)=1 AND primes(i+5)=1 THEN
      PrintF("(%I,%I,%I) ",i-1,i+3,i+5)
      count==+1
    FI
  OD
  PrintF("%E%EThere are %I triplets",count)
RETURN
