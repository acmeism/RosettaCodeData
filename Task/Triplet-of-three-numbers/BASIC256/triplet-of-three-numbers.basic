N = 6000
dim p(N+6)

for i = 2 to sqr(N)
  if not p[i] then
    for j = i*2 to N step i
      p[j] = 1
    next j
  end if
next i

for i = 3 to N
  if (p[i-1] or p[i+3] or p[i+5]) then
    # en BASIC256 no exite un comando CONTINUE
  else
    print i; ": "; i-1; "  "; i+3; "  "; i+5
  end if
next i
end
