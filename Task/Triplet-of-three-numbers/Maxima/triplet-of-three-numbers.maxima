/* Function that find the number and the triple with the property */
triplets(n):=block(
    L:makelist([i-1,i+3,i+5],i,1,n),
    caching:length(L),
    L1:[],
    for i from 1 thru caching do if map(primep,L[i])=[true,true,true] then L1:endcons(append([[i]],L[i]),L1),
    L1)$

/* Test case */
triplets(6000);
