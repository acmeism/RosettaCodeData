local int = require "int"
local fmt = require "fmt"

local c = int.arecomps(6003)
local numbers = {}
print("Numbers n < 6000 where: n - 1, n + 3, n + 5 are all primes:")
for n = 4, 5998, 2 do
    if !c[n - 1] and !c[n + 3] and !c[n + 5] then numbers:insert(n) end
end
for numbers as n do
    fmt.write("%6s  => ", fmt.int(n))
    fmt.tprint("%6s", {n - 1, n + 3, n + 5}:mapped(|e| -> fmt.int(e)), 3)
end
print($"\nFound {#numbers} such numbers.")
