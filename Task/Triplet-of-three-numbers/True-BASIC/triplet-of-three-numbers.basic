LET n = 6000

DIM p(0)
MAT REDIM p(n)

FOR i = 2 TO SQR(n)
    IF (NOT p(i) <> 0) THEN
       FOR j = i*2 TO n STEP i
           LET p(j) = 1
       NEXT j
    END IF
NEXT i

FOR i = 3 TO n
    IF (p(i-1) <> 0 OR p(i+3) <> 0 OR p(i+5) <> 0) THEN
       ! en TB no exite un comando CONTINUE
    ELSE
       PRINT USING "####: ####  ####  ####": i, i-1, i+3, i+5
    END IF
NEXT i
END
