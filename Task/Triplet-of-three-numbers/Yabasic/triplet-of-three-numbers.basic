// Rosetta Code problem: http://rosettacode.org/wiki/Triplet_of_three_numbers
// by Galileo, 04/2022

N = 6000
dim p(N)

for i = 2 to int(N ^ 0.5)
    if not p(i) then
        for j = i*2 to N step i
            p(j) = 1
        next
    endif
next

for i = 3 to N
    if not (p(i-1) or p(i+3) or p(i+5)) print i, ": ", i-1,  " ", i+3,  " ", i+5
next
