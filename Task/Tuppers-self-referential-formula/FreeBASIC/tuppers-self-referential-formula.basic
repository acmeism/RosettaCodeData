#include "big_int/big_integer.bi"

Sub DrawTupperFormula()
    ' Tupper's constant k (string format for precise initialization)
    Dim As String k_str = _
    "9609393799189588849716729621278527547150043396601293066515055192717028" & _
    "0239526642468964284217435071812126715378277062335599323728087414430789" & _
    "1325963941337723487857735749823926629715517173716995165232890538221612" & _
    "4032388558661840132355851360488286933379024914542292886670810961844960" & _
    "9170518345406782773155170540538162738096760256562501698148208341878316" & _
    "3849115590225610003652351370343874461848378737238198224849863465033159" & _
    "4100549747005931383392264972494617515457283667023697454610146559979337" & _
    "98537483143786841806593422227898388722980000748404719"

    Dim As BigInt k = BigInt(k_str)
    Dim As BigInt seventeen = BigInt(17)
    Dim As Integer x, y, row, column

    Dim As String matrix(0 To 16)
    For y = 0 To 16
        matrix(y) = Space(106)
    Next

    For column = 0 To 105
        For row = 0 To 16
            Dim As BigInt y_val = k + BigInt(row)
            Dim As BigInt a = y_val \ seventeen
            Dim As Integer bb = (y_val Mod seventeen) + column * 17
            Dim As BigInt b = BigInt(2) ^ bb
            a \= b
            Dim As Integer aa = (a Mod BigInt(2))

            If aa = 1 Then Mid(matrix(row), 106 - column, 1) = Chr(219)
        Next
    Next

    Color 15, 5 ' Magenta background, White text
    For y = 0 To 16
        Print matrix(y)
    Next
    Color 7, 0 ' Resets to the default console background and foreground colors
End Sub

DrawTupperFormula()

Sleep
