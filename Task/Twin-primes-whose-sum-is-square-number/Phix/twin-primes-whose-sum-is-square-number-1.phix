atom p=2, np, pn = 2, s = 1, sq = 1, count = 0
while true do
    np = get_prime(pn)
    if np>1e7 then exit end if
    if np=p+2 then
        atom npnp = p+np
        while sq<npnp do
            s += 1
            sq = s*s
        end while
        if npnp=sq then
            count += 1
            if count<8 or count>=65 then
                printf(1,"%d: %d^2 = %d = %d + %d\n",{count,s,sq,p,np})
            end if
        end if
    end if
    p = np
    pn += 1
end while
