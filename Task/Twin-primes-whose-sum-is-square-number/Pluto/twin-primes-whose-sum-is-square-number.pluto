local int = require "int"
local fmt = require "fmt"

local count = 0
local p = int.primes(9_999_999)
for i = 2, #p - 1 do
    if p[i + 1] == p[i] + 2 and int.issquare(p[i] + p[i + 1]) then
        local s = p[i] + p[i + 1]
        local sq = int.sqrt(s)
        fmt.print("%9s + %9s = %10s = %5s²", fmt.int(p[i]), fmt.int(p[i + 1]), fmt.int(s), fmt.int(sq))
        count += 1
    end
end
print($"\nFound {count} twin primes whose sum is a square number.")
