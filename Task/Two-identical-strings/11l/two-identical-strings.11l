F bits(=n)
   ‘Count the amount of bits required to represent n’
   V r = 0
   L n != 0
      n >>= 1
      r++
   R r

F concat(n)
   ‘Concatenate the binary representation of n to itself’
   R n << bits(n) [|] n

V n = 1
L concat(n) <= 1000
   print(‘#.: #.’.format(concat(n), bin(concat(n))))
   n++
