HOW TO RETURN bit.size.of n:
    SELECT:
        n = 0: RETURN 0
        ELSE: RETURN 1 + bit.size.of (floor (n/2))

HOW TO RETURN bit.string.of n:
    PUT "" IN bit.string
    SELECT:
        n = 0: RETURN ""
        ELSE: RETURN (bit.string.of (floor (n/2)))^"`n mod 2`"

HOW TO RETURN identical n:
    RETURN n + n * (2 ** bit.size.of n)

PUT 1 IN n
WHILE identical n < 1000:
    WRITE "`identical n`: `bit.string.of (identical n)`"/
    PUT n+1 IN n
