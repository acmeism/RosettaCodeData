0010 FUNC ident#(n#) CLOSED
0020   l#:=n#;r#:=n#
0030   WHILE r#>0 DO l#:=l#*2;r#:=r# DIV 2
0040   RETURN l#+n#
0050 ENDFUNC ident#
0060 //
0070 FUNC bit'string$(n#) CLOSED
0080   b$:=""
0090   WHILE n#>0 DO b$:=STR$(n# MOD 2)+b$;n#:=n# DIV 2
0100   RETURN b$
0110 ENDFUNC bit'string$
0120 //
0130 n#:=1
0140 WHILE ident#(n#)<1000 DO
0150   i#:=ident#(n#)
0160   PRINT STR$(i#)+": "+bit'string$(i#)
0170   n#:+1
0180 ENDWHILE
0190 END
