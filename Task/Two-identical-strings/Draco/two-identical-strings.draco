proc nonrec concat_self(word n) word:
    word rslt, k;
    k := n;
    rslt := n;
    while k ~= 0 do
        k := k >> 1;
        rslt := rslt << 1
    od;
    rslt | n
corp

proc nonrec main() void:
    word n, conc;
    n := 1;
    while
        conc := concat_self(n);
        conc < 1000
    do
        writeln(conc:3, ": ", conc:b:10);
        n := n + 1
    od
corp
