$ENTRY Go {
    = <IdentUpTo 1000>;
};

IdentUpTo {
    s.M = <IdentUpTo s.M 1>;
    s.M s.I, <Ident s.I>: s.Id, <Compare s.Id s.M>: {
        '-' = <Prout <Symb s.Id> ': ' <Bin s.Id>>
              <IdentUpTo s.M <+ s.I 1>>;
        s.X = ;
    };
};

Ident {
    s.N = <Ident s.N s.N s.N>;
    s.N s.R 0 = <+ s.N s.R>;
    s.N s.R s.K = <Ident s.N <* s.R 2> <Div s.K 2>>;
};

Bin {
    0 = ;
    s.N, <Divmod s.N 2>: (s.X) s.Y = <Bin s.X> <Symb s.Y>;
};
