program identical_strings;
    loop init i := 0; doing n := ident(i +:= 1); while n<1000 do
        print(lpad(str n, 4) + lpad(binary(n), 15));
    end loop;

    proc ident(n);
        ns := n;
        loop init t := n; doing t div:= 2; until t = 0 do
            ns *:= 2;
        end loop;
        return ns + n;
    end proc;

    proc binary(n);
        return {[0,""]}(n) ? binary(n div 2) + str (n mod 2);
    end proc;
end program;
