FUNCTION tobin$(d)
    LET s$ = ""
    DO WHILE d <> 0
       LET r = REMAINDER(ROUND(d),2)
       LET s$ = STR$(r) & s$
       LET d = IP(ROUND(d)/2)
    LOOP
    LET tobin$ = s$
END FUNCTION

LET n = 1
LET k = 0
LET p = 2
DO
   IF n >= p THEN LET p = p+p
   LET k = n+n*p
   IF k < 1000 THEN
      PRINT k; " = "; tobin$(k)
   ELSE
      EXIT DO
   END IF
   LET n = n+1
LOOP
END
