proc BinOut(N);         \Output N in binary
int  N, Rem;
[Rem:= N&1;
N:= N>>1;
if N then BinOut(N);
ChOut(0, Rem+^0);
];

int H, N, M;
[for H:= 1 to 31 do
    [N:= H;  M:= H;
    while M do
        [N:= N<<1;  M:= M>>1];
    N:= N+H;
    if N < 1000 then
        [IntOut(0, N);
        Text(0, ": ");
        BinOut(N);
        CrLf(0);
        ];
    ];
]
