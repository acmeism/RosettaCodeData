!ys-0

defn main(limit=1000):
  each n filter(double-binary? (1 .. limit.--)):
    say: "$n $(binary(n))"

defn double-binary?(n):
  s =: binary(n)
  rem =: s.# % 2
  even =: rem:zero?
  when even:
    half =: s.# // 2
    subs(s 0 half) ==: subs(s half)

defn binary(n):
  loop n n, out '':
    if n:zero?:
      if out.!: +
        '0'
        out
      else:
        q =: n // 2
        bit =: n % 2
        out =: bit:S + out
        recur: q, out
