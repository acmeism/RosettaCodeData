include ..\Utilitys.pmt

def two_sum /# arr num -- n #/
    var num
    1 var i
    len var j
    true
    while
        i get swap j get rot + >ps
        tps num == if
            ps> drop j get swap i get rot 2 tolist false
        else
            ps> num < if i 1 + var i else j 1 - var j endif true
        endif
        i j < and
    endwhile
    len 2 > if drop ( ) endif
enddef

( 0 2 11 19 90 )
