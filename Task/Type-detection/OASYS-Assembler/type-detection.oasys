; The following method checks if a global variable or property is an
; object type. Does not work with locals and arguments.

[&OBJ#,^]
  ,^<,^<<    ; Remember old value
  ,^<*>      ; Create new object
  ,^<<DES    ; Destroy the object
  ,^<<EX     ; Check if variable has been cleared
  />1RF      ; It is clear
  :>0RF      ; It is not clear
