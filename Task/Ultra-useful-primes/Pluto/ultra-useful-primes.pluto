require "bignum"
local fmt = require "fmt"

mpz.init()

local function a(n)
    local p = mpz.shl(bigint.one, 1 << n) - 1
    local k = 1
    while true do
        if mpz.isprobableprime(p, 15) then return k end
        p -= bigint.two
        k += 2
    end
end

print(" n   k")
print("----------")
for n = 1, 13 do fmt.print("%2d   %d", n, a(n)) end
