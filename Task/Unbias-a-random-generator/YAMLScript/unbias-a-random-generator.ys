!ys-0

defn main():
  bits =: unbiased(biased-bits()).take(40)
  say: bits:join

defn biased-bits():
  repeatedly:
    fn(): I(rand() < 0.7)

defn unbiased(bits):
  lazy-seq:
    a =: bits:first
    b =: bits:rest:first
    rest =: bits:rest:rest
    cond:
      a == b: unbiased(rest)
      a == 0: 0.cons(unbiased(rest))
      else: 1.cons(unbiased(rest))
