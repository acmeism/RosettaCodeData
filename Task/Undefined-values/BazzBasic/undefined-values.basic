' https://rosettacode.org/wiki/Undefined_values
' BazzBasic: https://github.com/EkBass/BazzBasic
' ============================================
[inits]
    LET ok$
    LET okToo$ = "Ok too"

[main]
    PRINT "ok$: "; ok$
    PRINT "okToo$: "; okToo$
    PRINT "error$: "; error$
END

' Output:
' ok$:
' okToo$: Ok too
' Error at line 11: Undefined variable: ERROR$
' error$: 0
