!ys-0

# YS's reader only accepts ASCII identifiers, so you cannot write a bare
# variable named Δ in source the way Clojure (its host) allows. You can
# still create and use one through the runtime symbol table: intern a var
# named "Δ" in the current namespace, then read it back with resolve.

defn main():
  ns =: find-ns(symbol('main'))
  intern: ns symbol('Δ') 1
  intern: ns symbol('Δ') delta(ns).++
  say: delta(ns)

defn delta(ns):
  var-get(ns-resolve(ns symbol('Δ')))
