local strings = {"1a3c52debeffd", "2b6178c97a938stf", "3ycxdb1fgxa2yz"}
local u = {}
for strings as s do
    local k = s:split(""):countvalues():filter(|v| -> v == 1):keys()
    table.move(k, 1, #k, #u + 1, u)
end
local n = #strings
local unique = u:countvalues():filter(|v| -> v == n):keys():sort():concat(" ")
print(unique)
