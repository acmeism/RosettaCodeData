#lang transd

MainModule: {
_start: (lambda locals: pos Position<String>() b Bool()
    (for c in (sort "1a3c52debeffd") do (= b true)
        (for str in ["1a3c52debeffd", "2b6178c97a938stf", "3ycxdb1fgxa2yz"] do
            (= pos (find str c))
            (if (or (is-end pos) (find Range(in: str (+ (get-idx pos) 1) -0) c))
                (= b false)))
        (if b (textout c " "))
)  )
}
