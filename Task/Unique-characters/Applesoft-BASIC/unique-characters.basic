 10  DIM C(255)
 20  LET S$ = ""
 30  FOR Q = 0 TO 1 STEP 0
 40      READ A$:L =  LEN (A$): IF L THEN  FOR I = 1 TO L:A =  ASC ( MID$ (A$,I,1)):C(A) = C(A) + 1: NEXT I,Q
 50  FOR I = 0 TO 255
 60      IF C(I) = 1 THEN  PRINT  CHR$ (I);
 70  NEXT I
 80  DATA "133252abcdeeffd","a6789798st","yxcdfgxcyz",
