int     List, I, N, C;
char    Tbl(128), Str;
string  0;
[List:= ["133252abcdeeffd", "a6789798st","yxcdfgxcyz"];
for I:= 0 to 127 do Tbl(I):= 0;
for N:= 0 to 2 do
        [Str:= List(N);
        I:= 0;
        loop    [C:= Str(I);
                if C = 0 then quit;
                I:= I+1;
                Tbl(C):= Tbl(C)+1;
                ];
        ];
for I:= 0 to 127 do
        if Tbl(I) = 1 then ChOut(0, I);
]
