!ys-0

defn main(samples=1000 buckets=10):
  counts =:
    frequencies:
      for [_ (1 .. samples)]:
        rand-int(buckets)
  expected =: samples / buckets
  each bucket (0 .. buckets.--):
    count =: counts.$bucket || 0
    diff =: abs(count - expected)
    threshold =: expected * 0.25
    ok =: diff < threshold
    say: "$bucket: $count $ok"
