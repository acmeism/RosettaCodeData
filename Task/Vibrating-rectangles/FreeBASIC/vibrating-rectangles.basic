REM set mode with 256 colours
SCREENRES 640, 480, 8
WINDOWTITLE "Vibrating Rectangles"

DIM Z AS INTEGER ' loop counter
DIM O AS INTEGER ' palette offset
DIM C AS INTEGER ' colour variable

O=0
DO
  SCREENLOCK
  FOR Z=1 TO 60
    C = Z + O
    IF C > 63 THEN C = C - 63
    LINE (5*Z, 4*Z) - (640-5*Z, 480-4*Z),C,B
  NEXT Z
  SCREENUNLOCK
  O = O + 1
  IF O > 63 THEN O = 0
  SLEEP 40
LOOP UNTIL INKEY = CHR(255)&"k" ' loop until window is closed
