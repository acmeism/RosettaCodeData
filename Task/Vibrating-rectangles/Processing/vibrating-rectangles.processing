int h = 0;

void
setup ()
{
  size(640, 512);
  noFill();
  strokeWeight(4);
  background(#ffffff);
  colorMode(HSB, 360, 100, 100);
  rectMode(CORNERS);
}

void
draw()
{
  for (int i=0; i<32; i++) {
    double hue = h + 360*i / 32.0;
    if (hue > 360.0)
      hue -= 360.0;
    stroke(color((int)hue, 50, 100));
    rect(10*i, 8*i, 640-10*i, 512-8*i);
  }

  if (++h > 360)
    h = 0;

  delay(10);
}
