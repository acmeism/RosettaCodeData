int Sz, Color;

proc OnTimer;
[Sz:= Sz - 2;
if Sz < 0 then
    [Sz:= 49;
    Color:= Ran(256);
    ];
Move(50-Sz, 50-Sz);
Line(50+Sz, 50-Sz, Color);
Line(50+Sz, 50+Sz, Color);
Line(50-Sz, 50+Sz, Color);
Line(50-Sz, 50-Sz, Color);
];

[SetVid($13);   \set video to VGA 320x200 in 256 colors
Sz:= 0;
repeat  DelayUS(200_000);
        OnTimer;
until   KeyHit;
]
