with javascript_semantics
atom t0 = time()
include mpfr.e

function isWagstaff(integer p)
    mpz w = mpz_init()
    mpz_ui_pow_ui(w,2,p)
    mpz_add_si(w,w,1)
    assert(mpz_fdiv_q_ui(w,w,3)=0)
    return iff(mpz_prime(w)?w:NULL)
end function

integer p, pdx = 2, extra = 0
sequence wagstaff = {}
while length(wagstaff)<10 do
    p = get_prime(pdx)
    atom res = isWagstaff(p)
    if res then
        string s = mpz_get_str(res,comma_fill:=true)
        wagstaff &= {{p,s}}
    end if
    pdx += 1
end while
printf(1,"First 10 Wagstaff primes for the values of 'p' shown:\n")
papply(true,printf,{1,{"%2d: %s\n"},wagstaff})
printf(1,"\nTook %s\n\n",elapsed(time()-t0))

printf(1,"Wagstaff primes that we can find in 6 seconds:\n")
while time()<t0+6 do
    p = get_prime(pdx)
    atom res = isWagstaff(p)
    if res then
        integer l = mpz_sizeinbase(res,10)
        string e = elapsed(time()-t0,0.1,", %s")
        printf(1,"%5d (%,d digits%s)\n", {p,l,e})
        extra += 1
    end if
    pdx += 1
end while
printf(1,"%d extra Wagstaff primes found.\n\n",extra)

printf(1,"Somewhat cheating, if it takes this long just to verify...:\n")
for p in {5807,10501,10691,11279,12391,14479,42737} do
    while p!=get_prime(pdx) do pdx += 1 end while
    mpz w = isWagstaff(p)
    integer l = mpz_sizeinbase(w,10)
    string e = elapsed(time()-t0), th = ord(pdx)
    printf(1,"%5d, the %,d%s prime: %,d digits, %s\n", {p,pdx,th,l,e})
end for
