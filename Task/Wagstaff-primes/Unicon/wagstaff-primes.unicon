link fastprime

procedure main(A)
   limit := \A[1] | 24
   write("The first ",limit," Wagstaff primes:")
   every (cnt := 0, n := is_wagstaff(p := genprimes(3))\limit, cnt +:= 1) do
      write(" (2^",p,"+1)/3",if cnt <= 10 then " = "||n else "")
end

procedure is_wagstaff(p)
    return is_prime((2^p+1)/3)
end
