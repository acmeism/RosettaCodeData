import util

procedure main(A)
   n := \A[1] | 1
   writem(walsh(n))
end

procedure walsh(n)
   static w1
   initial w1 := [[1,1],[1,-1]]
   if n > 1 then return combine(wa := walsh(n-1),m_negate(wa))
   return w1
end

procedure combine(wa,wb)
   m := list(*wa*2)
   every r := 1 to *wa do {
      m[r] := [: !((wa|wa)[r]) :]
      m[r+*wa] := [: !((wa|wb)[r]) :]
      }
   return m
end
