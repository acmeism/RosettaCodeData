     {{{210,120}, {355,115}, {425,290}, {380,315}, {180,275}},
      {{110,180}, {210,55}, {420,80}, {470,305}, {315,355}, {130,305}}},
     {{{195,85}, {515,80}, {410,360}, {80,280}},
      {{230,130}, {425,120}, {450,200}, {330,290}, {190,245}}},
     {{{84,140}, {200,135}, {290,190}, {245,340}, {60,340}},
      {{360,80}, {540,140}, {550,230}, {330,250}}},
     {{{247,183},{536,181},{536,374},{129,374}},
      {{128,71},{295,70},{455,374},{263,374}}},
     {{{50,80}, {170,250}, {210,165}, {310,340}, {470,225}, {515,365}, {90,365}},
      {{95,190}, {515,180}, {530,320}, {30,280}}},
     {{{95,90}, {250,300}, {425,145}, {475,330}, {125,325}},
      {{130,175}, {465,100}, {500,275}, {70,250}}},
     {{{130,80}, {250,275}, {500,175}, {500,350}, {100,330}},
      {{60,140}, {550,130}, {530,285}, {45,220}}},
     {{{270,175}, {447,175}, {468,353}, {270,353}},
      {{213,175}, {394,175}, {394,292}, {134,292}}},
     {{{232,178}, {470,177}, {470,389}, {232,389}},
      {{152,210}, {378,119}, {376,203}, {152,347}}},
     {{{56,440}, {230,487}, {260,340}, {90,300}},
      {{188,132}, {188,388}, {444,388}, {444,132}}},
     {{{245,70},{185,110},{360,290},{245,430},{435,300}},
      {{470,380},{245,380},{420,110},{360,70},{110,445},{470,445}}},
     {{{200,100},{300,100},{300,400},{200,400}},
      {{250,150},{350,150},{350,450},{250,450}}},
     {{{200,325},{550,325},{550,400},{200,400}},
      {{250,150},{350,150},{350,450},{250,450}}},
     {{{200,100},{300,100},{500,380},{300,400},{200,400},{150,305}},
      {{250,150},{350,150},{350,450},{250,450}}},
     {{{230,160},{330,160},{530,440},{330,460},{230,460},{180,365}},
      {{205,80},{350,80},{305,435},{265,530},{205,380},{180,180}}},
     {{{230,30},{330,30},{530,310},{330,330},{230,330},{180,235}},
      {{205,80},{350,80},{305,435},{265,530},{205,380},{180,180}}}}

integer tdx = 1, ndx = 0
sequence P, C, CP
procedure set_tests()
    {P,C} = tests[tdx]
    CP = weiler_atherton_poly_clip(P,C)
    ndx = min(ndx,length(CP))
    printf(1,"Found %d polygons\n",length(CP))
    pp(CP,{pp_FltFmt,"%.0f",pp_Maxlen,120,pp_Nest,1})
end procedure
set_tests()

include theGUI.e -- (delete to end if you don't have 1.0.6+)
--gUseGTK()

procedure redraw(gdx canvas, integer w, h)
    gDrawPolygon(canvas,C,colour:=TG_CYAN)
    gDrawPolygon(canvas,P,colour:=TG_MAGENTA)
    for p in CP do
        gDrawPolygon(canvas,p,colour:=TG_ORANGE)
    end for
    if ndx then
        for i,pt in iff(ndx<0?{C,P}:CP)[ndx] do
            atom {x,y} = pt
            gDrawText(canvas,x,y,"%d",{i},TG_C)
        end for
    end if
end procedure

function key_handler(gdx dlg, integer c)
    if c=' ' or c='+' then
        tdx = iff(tdx=length(tests)?1:tdx+1)
        set_tests()
    elsif c='-' then
        tdx = iff(tdx=1?length(tests):tdx-1)
        set_tests()
    elsif lower(c)='n' then
        ndx = iff(ndx=length(CP)?-2:ndx+1)
    elsif lower(c)='p' then
        ndx = iff(ndx=-2?length(CP):ndx-1)
    end if
    gRedraw(dlg)
    return TG_DEFAULT
end function

gdx canvas = gCanvas(redraw,"BGCLR = PARCHMENT, WU_BLEND = true"),
    dlg = gDialog(canvas,"Weiler-Atherton polygon clipping","SIZE=600x600")
gSetHandler(dlg,"KEY",key_handler)
gShow(dlg)
gMainLoop()
