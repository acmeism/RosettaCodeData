WelschTTest[x_List, y_List] := Module[
  {n1 = Length[x], n2 = Length[y],
   m1 = Mean[x], m2 = Mean[y],
   v1 = Variance[x], v2 = Variance[y],
   t, nu, p},
  t = (m1 - m2)/Sqrt[v1/n1 + v2/n2];
  nu = (v1/n1 + v2/n2)^2/(v1^2/(n1^2*(n1 - 1)) + v2^2/(n2^2*(n2 - 1)));
  p = 2*CDF[StudentTDistribution[nu], -Abs[t]];
  {t, nu, p}
  ]

x = {3, 4, 1, 2.1};
y = {490.2, 340, 433.9};
WelschTTest[x, y] //Print

(* Out: {-9.559497721932655, 2.000852348856281, 0.010751561149784536} *)
