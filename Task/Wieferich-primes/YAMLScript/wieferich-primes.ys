!ys-0

defn main(limit=5000):
  each p (2 .. limit):
    when prime?(p):
      e =: p.--
      when mod-pow(2 e (p * p)) == 1:
        say: p

defn mod-pow(a e m):
  loop a (mod a m), e e, r 1:
    if e.!:
      then: r
      else:
        r :if e:odd? =: mod((r * a) m)
        recur: mod((a * a) m), (e // 2), r

defn prime?(n):
  condp gt n:
    2: false
    4: true
    else:
      every? _ (2 .. n:sqrt):
        fn(d): (n % d).?
