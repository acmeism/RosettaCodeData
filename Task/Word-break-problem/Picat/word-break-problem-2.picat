s2(Dict,String) = S =>
  String2 = copy_term(String),
  S = [],
  while(S.flatten != String, S.flatten.len < String.len)
    % Pick an element from Dict
    member(D,Dict),

    % Check that it fits and remove it from the string.
    % If not: backtrack
    append(D,String3,String2),

    % ok!
    String2 := String3,
    S := S ++ [D]
  end,
  S.flatten==String.
