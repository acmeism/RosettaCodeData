!ys-0

# Top-N word frequency. Letters-only word, case-insensitive.
# Default to Les Mis at /tmp/les-mis.txt; -n picks how many.

url =:: https://www.gutenberg.org/files/135/135-0.txt

defn main(n=10):
  top =:
    curl(url)
      .lc()
      .re-seq(/[a-z]+/)
      .frequencies()
      .seq()
      .sort-by(\(- _.$))
      .take(n)
  each p top: show(p)

defn- show(pair):
  say:
    format "%-8s %d": pair.0 pair.$
