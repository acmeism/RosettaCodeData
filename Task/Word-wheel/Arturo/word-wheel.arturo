solveWordWheel: function [word dictionary sizeFloor][
    wordTally: tally word
    centerLetter: word\[(size word) / 2]
    select dictionary 'word ->
        every? [[(size word) >= sizeFloor]
                [centerLetter ∈ word]
                [every? word 'ch -> key? wordTally ch]
                [every? tally word [k v] -> v =< wordTally\[k]]] => do
]

words: read.lines ./"unixdict.txt"
solveWordWheel "ndeokgelw" words 3
| loop => print
