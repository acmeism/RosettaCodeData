short x = 80, y = 20

clear local fn colorString( w1 as str15, w2 as str15 ) as str15
  str255 n : str15 c : c[0] = w2[0] : short r
  for r = 1 to w1[0]
    if w2[r] = w1[r] then c[r] = 2 else n[w1[r]]++
  next
  for r = 1 to w2[0]
    if c[r] == 0 then if n[w2[r]] then n[w2[r]]-- : c[r] = 1
  next
end fn = c
