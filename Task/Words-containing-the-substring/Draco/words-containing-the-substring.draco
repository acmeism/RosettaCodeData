\util.g

proc theword(*char line) bool:
    CharsLen(line) > 11
    and CharsIndex(line, "the") ~= -1
corp

proc nonrec main() void:
    file(1024) dictfile;
    [32] char buf;
    *char line;
    channel input text dict;

    open(dict, dictfile, "unixdict.txt");
    line := &buf[0];

    while readln(dict; line) do
        if theword(line) then writeln(line) fi
    od;

    close(dict)
corp
