local fmt = require "fmt"

local word_list = "unixdict.txt"  -- local copy
local words = io.contents(word_list):rstrip():split("\n"):filter(|w| -> #w > 11):reorder()
local count = 0
print($"Words containing 'the' having a length > 11 in {word_list}:")
for words as word do
    if "the" in word then
        count += 1
        fmt.print("%2d: %s", count, word)
    end
end
