local fmt = require "fmt"

local word_list = "unixdict.txt"  -- local copy
local words = io.contents(word_list):rstrip():split("\n"):filter(|w| -> #w >= 9):reorder()
local count = 0
local already_found = {}
for i = 1, #words - 9 do
    local word = ""
    for j = i, i + 8 do word ..= words[j][j - i + 1] end
    if word in words and not(word in already_found) then
        count += 1
        fmt.print("%2d: %s", count, word)
        already_found:insert(word)
    end
end
