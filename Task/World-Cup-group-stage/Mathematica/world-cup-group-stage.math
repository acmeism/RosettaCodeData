scoring[1] = 3; scoring[0] = 1; scoring[-1] = 0;
scoreTable[results_] := Module[{s = {0, 0, 0, 0}, pairs = Subsets[Range[4], {2}]},
   MapThread[(
      s[[First@#2]] += scoring[#1];
      s[[Last@#2]] += scoring[-#1]) &,
    {results, pairs}];
   ReverseSort[s]];

allScoreTables = Map[scoreTable, Tuples[{-1, 0, 1}, 6]];
Table[BinCounts[allScoreTables[[All, i]], {0, 10}], {i, 4}] // TableForm
