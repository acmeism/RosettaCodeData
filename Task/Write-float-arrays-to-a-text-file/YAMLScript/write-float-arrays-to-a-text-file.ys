!ys-0

# Write two columns x, y to a text file, each with its own precision
# (%.Ng). Read it back to show what landed on disk.

defn main():
  xs =:: [1.0, 2.0, 3.0, 1.0e11]
  ys =: xs.map(sqrt)
  path =: '/tmp/floats.txt'
  write-floats path: xs 3 ys 5
  say: "wrote $path:"
  say: path:read

defn- write-floats(path xs xp ys yp):
  xfmt =: "%.${xp}g"
  yfmt =: "%.${yp}g"
  lines =:
    for pair map(vector xs ys):
      format "$xfmt  $yfmt": pair.0 pair.$
  write path: lines:text
