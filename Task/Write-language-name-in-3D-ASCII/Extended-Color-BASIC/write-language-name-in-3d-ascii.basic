5 CLS 8
10 D=0: C$=CHR$(159): GOSUB 40
20 D=1: C$=CHR$(175): GOSUB 40
30 GOTO 30
40 RESTORE
50 FOR N=1 TO 5
60 READ A$
70 FOR J=1 TO LEN(A$)
90 IF MID$(A$,J,1)="X" THEN ?@((N+4)*32) + (J+2+D),C$;
100 NEXT J
110 NEXT N
120 RETURN
130 DATA "XXX   XXXX  XXX  X  XXX"
140 DATA "X  X  X  X  X    X  X  "
150 DATA "XXX   XXXX  XXX  X  X  "
160 DATA "X  X  X  X    X  X  X  "
170 DATA "XXX   X  X  XXX  X  XXX"
