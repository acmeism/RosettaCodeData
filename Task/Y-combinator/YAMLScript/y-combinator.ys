!ys-0

defn main(*):
  fact =:
    Y:
      fn(self n):
        if n:zero?: 1 (n * self(self n.--))

  fib =:
    Y:
      fn(self n):
        if n < 2: n (self(self n.--) + self(self (n - 2)))

  say: 'Factorials:'
  each i (0 .. 10):
    say: "$i! = $fact(i)"

  say: 'Fibonacci:'
  each i (0 .. 10):
    say: "fib($i) = $fib(i)"

defn Y(f):
  fn(*args):
    apply f: +[f] + args
