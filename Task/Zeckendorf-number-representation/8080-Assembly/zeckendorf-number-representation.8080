bdos    equ     5
puts    equ     9
        org     100h
        jmp     demo

        ; Write Zeckendorf representation of A starting at HL
zeck:   ana     a
        jnz     zecknz
        mvi     m,'0'           ; If 0, write a zero
        inx     h
        mvi     m,'$'
        ret
zecknz: xchg
        lxi     h,zfib-1
        mvi     b,14
zfind:  inx     h               ; Find the first Fibonacci number to use
        dcr     b
        cmp     m
        jc      zfind
        dcx     h
zstep:  inx     h               ; Next Fibonacci number
        dcr     b
        jz      zdone           ; Stop when none are left
        mvi     c,'0'           ; Digit to write
        sub     m               ; Subtract the current Fibonacci number
        jc      z0              ; Did that make it go negative?
        inr     c               ; If not, write a 1 instead of a 0
        jmp     zwr
z0:     add     m               ; If so, undo the subtraction
zwr:    xchg
        mov     m,c             ; Write the digit
        inx     h
        xchg
        jmp     zstep
zdone:  xchg
        mvi     m,'$'
        ret
zfib:   db      233,144,89,55,34,21,13,8,5,3,2,1

        ; Write the Zeckendorf representations of 0..20
demo:   xra     a               ; Start at 0
loop:   push    psw
        lxi     h,zbuf          ; Find the Zeckendorf representation
        call    zeck
        lxi     d,zbuf          ; Write it
        mvi     c,puts
        call    bdos
        lxi     d,nl            ; Write a newline
        mvi     c,puts
        call    bdos
        pop     psw
        inr     a               ; Next number
        cpi     21              ; Stop at 21
        jc      loop
        ret
nl:     db      13,10,'$'
zbuf    equ     $
