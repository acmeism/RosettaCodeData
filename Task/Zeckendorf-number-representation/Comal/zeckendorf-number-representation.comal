0010 FUNC zeck$(n#) CLOSED
0020   IF n#=0 THEN RETURN "0"
0030   DIM fib#(30)
0040   fib#(1):=1
0050   fib#(2):=2
0060   f#:=1
0070   WHILE fib#(f#)<=n# DO fib#(f#+2):=fib#(f#+1)+fib#(f#);f#:+1
0080   z$:=""
0090   WHILE f#>1 DO
0100     f#:-1
0110     IF fib#(f#)<=n# THEN
0120       z$:+"1"
0130       n#:-fib#(f#)
0140     ELSE
0150       z$:+"0"
0160     ENDIF
0170   ENDWHILE
0180   RETURN z$
0190 ENDFUNC zeck$
0200 FOR n#:=0 TO 20 DO PRINT STR$(n#)+": "+zeck$(n#)
0210 END
