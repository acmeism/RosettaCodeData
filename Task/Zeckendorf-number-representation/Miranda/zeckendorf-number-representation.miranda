main :: [sys_message]
main = [Stdout (lay (map zline [0..20]))]
       where zline n = rjustify 2 (show n) ++ ": " ++ rjustify 8 (zeck n)

zeck :: num->[char]
zeck 0 = "0"
zeck n = reverse (snd (foldl step (n,"") fibs))
         where fibs = reverse (takewhile (<=n) fib)
               step (i,z) f = (i, '0':z), if i<f
                            = (i-f, '1':z), otherwise

fib :: [num]
fib = 1 : 2 : map f (zip2 fib (tl fib)) where f (a,b) = a+b
