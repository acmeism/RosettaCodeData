#!/usr/bin/env ys-0
!ys-0

API-URL =: 'https://rosettacode.org/w/api.php'

defn main():
  each name fetch-category('Category:Programming_Tasks' 'page'):
    say: name

defn- fetch-category(category cmtype):
  loop names [], cont nil:
    base =: "$API-URL?action=query&list=categorymembers\
             &cmtitle=$(url-encode(category))&cmlimit=max\
             &cmtype=$cmtype&format=json&formatversion=2"
    url =:
      if cont:
        then: "$base&cmcontinue=$(url-encode(cont))"
        else: base
    body =: http/get(url).body:json/load
    page-names =:
      map \(_.title):
        body.query.categorymembers
    new =: into(names page-names)
    next-cont =:
      when body.continue:
        body.continue.cmcontinue
    if next-cont:
      then: recur(new next-cont)
      else: new

defn- url-encode(s):
  s.replace(qr(" ") "_")
   .replace(qr("[+]") "%2B")
   .replace(qr("[#]") "%23")
   .replace(qr("'") "%27")
   .replace(qr("[\"]") "%22")
   .replace(qr("[?]") "%3F")
   .replace(qr("&") "%26")
   .replace(qr("[|]") "%7C")
