#!/usr/bin/env ys-0
!ys-0

EXCLUDE =:
  qr("[éæ:]|Languages by Feature|Programming Language|Oberon-2|Free Pascal")

defn main():
  when-not fs/e('Conf/lang.yaml'):
    die: 'Not at RosettaCodeData root (Conf/lang.yaml missing)'
  known =: set(keys(read('Conf/lang.yaml'):yaml/load))
  raw =: bash-out('bin/rcd-api-list-all-langs')
  each name raw:lines:
    when-not (known.has?(name) || (name =~ EXCLUDE)):
      say: name
