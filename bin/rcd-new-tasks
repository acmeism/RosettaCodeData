#!/usr/bin/env ys-0
!ys-0

defn main():
  when-not fs/e('Conf/task.yaml'):
    die: 'Not at RosettaCodeData root (Conf/task.yaml missing)'
  known =: set(keys(read('Conf/task.yaml'):yaml/load))
  raw =: bash-out('bin/rcd-api-list-all-tasks')
  each name raw:lines:
    when-not known.has?(name):
      say: name
