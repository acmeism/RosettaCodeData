#!/usr/bin/env ys-0
!ys-0

defn main():
  when-not fs/d('Lang'):
    die: 'No Lang/ directory (run from RosettaCodeData root)'
  fmt =: '%06d %s'
  total =: atom(0)
  each lang sort-by(lc fs/ls('Lang')):
    n =: count-samples(lang)
    swap total \(_ + n):
    say: fmt.format(n fs/basename(lang))
  say: fmt.format(total.@ 'Total')

defn- count-samples(lang-dir):
  fs/ls(lang-dir).filter(fs/d).map(count-task).reduce(+ 0)

defn- count-task(task-dir):
  fs/ls(task-dir)
    .filter(fs/f)
    .filter(\(fs/basename(_).starts?('00-').!))
    .count()
