#!/usr/bin/env ys-0
!ys-0

defn main():
  when-not fs/d('Task'):
    die: 'No Task/ directory (run from RosettaCodeData root)'
  fmt =: '%06d %s'
  total =: atom(0)
  each task sort-by(lc fs/ls('Task')):
    n =: count-samples(task)
    swap total \(_ + n):
    say: fmt.format(n fs/basename(task))
  say: fmt.format(total.@ 'Total')

defn- count-samples(task-dir):
  fs/ls(task-dir).filter(fs/d).map(count-lang).reduce(+ 0)

defn- count-lang(lang-dir):
  fs/ls(lang-dir)
    .filter(fs/f)
    .filter(\(fs/basename(_).starts?('00-').!))
    .count()
